  _weekRules: []
  _onWeekStartInteractions: []
  _onWeekEndInteractions: []
  _fixedEvent:
    _title: "\uC9C1\uC811 \uBB3B\uB294 \uC2DC\uC120"
    _situationText: "\uB354\uB294 \uD53C\uD560 \uC218 \uC5C6\uB2E4\uB294 \uB4EF,
      \uB124\uBAA8\uB294 \uC800\uB141 \uC2DD\uD0C1 \uB9DE\uC740\uD3B8\uC5D0\uC11C
      \uC624\uB798 \uC2DC\uC120\uC744 \uB450\uACE0 \uB2F9\uC2E0\uC758 \uB300\uB2F5\uC744
      \uAE30\uB2E4\uB9B0\uB2E4."
    _reactions:
    - _dominantStat: 0
      _reactionText: "\uB124\uBAA8\uB294 \uC544\uC9C1 \uB2F9\uC2E0\uC774 \uB9D0\uD574\uC904
        \uAC70\uB77C\uB294 \uAE30\uB300\uB97C \uBC84\uB9AC\uC9C0 \uC54A\uC558\uACE0,
        \uADF8 \uAE30\uB300\uB97C \uC9C0\uD0A4\uAE30 \uC704\uD574 \uC870\uC2EC\uC2A4\uB7FD\uAC8C
        \uC9C8\uBB38\uC744 \uACE0\uB974\uACE0 \uC788\uB2E4."
      _statDeltas:
      - _statType: 0
        _amount: 1
    - _dominantStat: 1
      _reactionText: "\uB124\uBAA8\uB294 \uC774\uBBF8 \uBA87 \uAC00\uC9C0 \uB2F5\uC744
        \uC2A4\uC2A4\uB85C \uC870\uD569\uD574 \uB450\uC5C8\uACE0, \uC774\uC81C\uB294
        \uB9C8\uC9C0\uB9C9 \uD37C\uC990\uB9CC \uD655\uC778\uD558\uACE0 \uC2F6\uC5B4
        \uD55C\uB2E4."
      _statDeltas:
      - _statType: 1
        _amount: 1
      - _statType: 3
        _amount: -1
    - _dominantStat: 2
      _reactionText: "\uB124\uBAA8\uB294 \uC9C4\uC2E4\uBCF4\uB2E4\uB3C4 \uB2F9\uC2E0\uC758
        \uD45C\uC815\uACFC \uCE68\uBB35\uC5D0\uC11C \uBA3C\uC800 \uC0C1\uCC98\uB97C
        \uC77D\uACE0 \uC788\uC5C8\uB2E4."
      _statDeltas:
      - _statType: 2
        _amount: 1
      - _statType: 0
        _amount: -1
    - _dominantStat: 3
      _reactionText: "\uB124\uBAA8\uB294 \uC608\uC758 \uBC14\uB974\uAC8C \uC549\uC544
        \uC788\uC5C8\uC9C0\uB9CC, \uC774\uBC88\uB9CC\uD07C\uC740 \uBB3C\uB7EC\uC11C\uC9C0
        \uC54A\uACA0\uB2E4\uB294 \uC758\uC9C0\uAC00 \uBD84\uBA85\uD588\uB2E4."
      _statDeltas:
      - _statType: 3
        _amount: -1
      - _statType: 1
        _amount: 1
  _privateDialogue:
    _title: "\uB9C8\uC9C0\uB9C9 \uC9C8\uBB38"
    _openingLine: "\uC774\uC81C\uB294 \uB098\uB3C4 \uC54C\uC544\uC57C \uD560 \uAC83
      \uAC19\uC544. \uB2F9\uC2E0\uC740 \uB098\uB97C \uC9C0\uD0A4\uACE0 \uC788\uC5C8\uB358
      \uAC70\uC57C, \uC544\uB2C8\uBA74 \uC228\uAE30\uACE0 \uC788\uC5C8\uB358 \uAC70\uC57C?"
    _choices:
    - _label: "\uB05D\uAE4C\uC9C0 \uBCF4\uD638\uC600\uB2E4\uACE0 \uB9D0\uD55C\uB2E4"
      _responseLine: "\uB124\uBAA8\uB294 \uBC14\uB85C \uB300\uB2F5\uD558\uC9C0 \uC54A\uC558\uB2E4.
        \uD558\uC9C0\uB9CC \uADF8 \uB9D0\uC774 \uC9C4\uC2EC\uC778\uC9C0 \uC544\uB2CC\uC9C0\uB97C
        \uC624\uB798 \uB4E4\uC5EC\uB2E4\uBCF4\uB294 \uB208\uC774\uC5C8\uB2E4."
      _statDeltas:
      - _statType: 0
        _amount: 1
      - _statType: 3
        _amount: 1
    - _label: "\uC228\uAE34 \uAC83\uB3C4 \uC788\uC5C8\uB2E4\uACE0 \uC778\uC815\uD55C\uB2E4"
      _responseLine: "\uB124\uBAA8\uB294 \uC0C1\uCC98\uBC1B\uC558\uC9C0\uB9CC, \uCC98\uC74C\uC73C\uB85C
        \uAC19\uC740 \uC790\uB9AC\uC5D0 \uC11C\uC11C \uC774\uC57C\uAE30\uD558\uACE0
        \uC788\uB2E4\uB294 \uAC10\uAC01\uC744 \uB290\uAF08\uB2E4."
      _statDeltas:
      - _statType: 1
        _amount: 1
      - _statType: 0
        _amount: -1
    - _label: "\uB2F5\uD558\uC9C0 \uC54A\uACE0 \uB418\uBB3B\uB294\uB2E4"
      _responseLine: "\uB124\uBAA8\uB294 \uB354 \uC774\uC0C1 \uAE30\uB300\uC9C0 \uC54A\uACE0
        \uC2A4\uC2A4\uB85C \uB2F5\uC744 \uCC3E\uC73C\uB824\uB294 \uD45C\uC815\uC73C\uB85C
        \uC2DC\uC120\uC744 \uAC70\uB450\uC5C8\uB2E4."
      _statDeltas:
      - _statType: 2
        _amount: 1
      - _statType: 1
        _amount: 1
