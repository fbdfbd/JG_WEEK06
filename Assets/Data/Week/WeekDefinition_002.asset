  _weekRules: []
  _onWeekStartInteractions: []
  _onWeekEndInteractions: []
  _fixedEvent:
    _title: "\uBCF5\uB3C4 \uB05D\uC758 \uD3B8\uC9C0"
    _situationText: "\uC800\uB141 \uBB34\uB835, \uB124\uBAA8\uB294 \uC790\uC2E0\uC774
      \uBC1B\uC9C0 \uBABB\uD55C \uAC83 \uAC19\uC740 \uD3B8\uC9C0\uB97C \uD558\uC778\uC758
      \uC190\uC5D0\uC11C \uC5BC\uD54F \uBCF4\uC558\uB2E4\uAC00 \uAE08\uC138 \uC0AC\uB77C\uC9C0\uB294
      \uC7A5\uBA74\uC744 \uBCF4\uAC8C \uB41C\uB2E4."
    _reactions:
    - _dominantStat: 0
      _reactionText: "\uB124\uBAA8\uB294 \uC7A0\uC2DC \uC2E0\uACBD\uC774 \uC4F0\uC600\uC9C0\uB9CC,
        \uACE7 \uC5B4\uB978\uB4E4\uC774 \uC54C\uC544\uC11C \uCC98\uB9AC\uD55C \uC77C\uC77C
        \uAC70\uB77C \uC5EC\uAE30\uBA70 \uB118\uC5B4\uAC14\uB2E4."
      _statDeltas:
      - _statType: 0
        _amount: 1
    - _dominantStat: 1
      _reactionText: "\uB124\uBAA8\uB294 \uADF8 \uD3B8\uC9C0\uC758 \uBD09\uC778\uACFC
        \uC190\uAE00\uC528\uB97C \uB5A0\uC62C\uB9AC\uBA70 \uC790\uC2E0\uC5D0\uAC8C
        \uC624\uB358 \uAC83\uC774\uC5C8\uB294\uC9C0 \uBA38\uB9BF\uC18D\uC73C\uB85C
        \uB418\uC9DA\uC5C8\uB2E4."
      _statDeltas:
      - _statType: 1
        _amount: 1
      - _statType: 0
        _amount: -1
    - _dominantStat: 2
      _reactionText: "\uB124\uBAA8\uB294 \uC790\uC2E0\uB9CC \uBAA8\uB974\uB294 \uBB34\uC5B8\uAC00\uAC00
        \uB610 \uC9C0\uB098\uAC14\uB2E4\uB294 \uC0DD\uAC01\uC5D0 \uB9C8\uC74C\uC774
        \uC11C\uB298\uD574\uC84C\uB2E4."
      _statDeltas:
      - _statType: 2
        _amount: 1
      - _statType: 0
        _amount: -1
    - _dominantStat: 3
      _reactionText: "\uB124\uBAA8\uB294 \uAD1C\uD788 \uBB3C\uC5B4\uBCF4\uC9C0 \uB9D0\uC544\uC57C\uACA0\uB2E4\uACE0
        \uACB0\uC2EC\uD588\uC9C0\uB9CC, \uADF8 \uACB0\uC2EC \uC790\uCCB4\uAC00 \uC624\uB798
        \uB0A8\uC558\uB2E4."
      _statDeltas:
      - _statType: 3
        _amount: 1
      - _statType: 2
        _amount: 1
  _privateDialogue:
    _title: "\uCC3D\uAC00\uC5D0\uC11C\uC758 \uC9C8\uBB38"
    _openingLine: "\uC624\uB298 \uD3B8\uC9C0\uC600\uC5B4? \uC544\uB2C8\uBA74 \uB0B4
      \uCC29\uAC01\uC774\uC57C?"
    _choices:
    - _label: "\uBCC4\uC77C \uC544\uB2C8\uB77C\uACE0 \uC548\uC2EC\uC2DC\uD0A8\uB2E4"
      _responseLine: "\uB124\uBAA8\uB294 \uC58C\uC804\uD788 \uACE0\uAC1C\uB97C \uB044\uB355\uC600\uC9C0\uB9CC,
        \uCC3D\uBB38 \uCABD\uC73C\uB85C \uC2DC\uC120\uC744 \uD55C \uBC88 \uB354 \uBCF4\uB0C8\uB2E4."
      _statDeltas:
      - _statType: 0
        _amount: 1
      - _statType: 1
        _amount: 1
    - _label: "\uB124\uBAA8\uB294 \uBAB0\uB77C\uB3C4 \uB41C\uB2E4\uACE0 \uC120\uC744
        \uAE0B\uB294\uB2E4"
      _responseLine: "\uB124\uBAA8\uB294 \uC785\uC744 \uB2E4\uBB3C\uC5C8\uC9C0\uB9CC,
        \uB354 \uC774\uC0C1 \uD3B8\uD558\uAC8C \uAE30\uB300\uC9C0\uB294 \uBABB\uD588\uB2E4."
      _statDeltas:
      - _statType: 3
        _amount: 1
      - _statType: 2
        _amount: 1
    - _label: "\uB204\uAD70\uAC00 \uB124\uBAA8\uB97C \uAC71\uC815\uD574 \uBCF4\uB0B8
        \uAC83 \uAC19\uB2E4\uACE0 \uB9D0\uD55C\uB2E4"
      _responseLine: "\uB124\uBAA8\uB294 \uD3B8\uC9C0\uC758 \uB0B4\uC6A9\uC744 \uB354
        \uC54C\uACE0 \uC2F6\uC5B4\uC84C\uC9C0\uB9CC, \uC801\uC5B4\uB3C4 \uC790\uC2E0\uC774
        \uC644\uC804\uD788 \uBC30\uC81C\uB41C \uAC74 \uC544\uB2C8\uB77C\uB294 \uB290\uB08C\uC744
        \uBC1B\uC558\uB2E4."
      _statDeltas:
      - _statType: 1
        _amount: 1
      - _statType: 0
        _amount: 1
