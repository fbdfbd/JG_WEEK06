  _weekRules: []
  _onWeekStartInteractions: []
  _onWeekEndInteractions: []
  _fixedEvent:
    _title: "\uCCAB \uD655\uC778"
    _situationText: "\uC218\uC5C5\uC774 \uB05D\uB09C \uB4A4, \uB124\uBAA8\uB294 \uBE44\uC5B4
      \uC788\uB294 \uBCF5\uB3C4\uB97C \uCC9C\uCC9C\uD788 \uAC77\uB2E4\uAC00 \uD558\uC778\uB4E4\uC774
      \uAE09\uD788 \uB9D0\uC744 \uBA48\uCD94\uB294 \uC7A5\uBA74\uC744 \uB9C8\uC8FC\uD588\uB2E4."
    _reactions:
    - _dominantStat: 0
      _reactionText: "\uB124\uBAA8\uB294 \uC7A0\uC2DC \uBA48\uCDC4\uB2E4\uAC00 '\uB9D0\uD560
        \uC218 \uC5C6\uB294 \uC774\uC720\uAC00 \uC788\uACA0\uC9C0' \uD558\uACE0 \uC2A4\uC2A4\uB85C\uB97C
        \uB2EC\uB7AC\uB2E4."
      _statDeltas:
      - _statType: 0
        _amount: 1
      - _statType: 3
        _amount: 1
    - _dominantStat: 1
      _reactionText: "\uB124\uBAA8\uB294 \uB300\uD654\uAC00 \uB04A\uAE34 \uC790\uB9AC\uB97C
        \uC624\uB798 \uB3CC\uC544\uBCF4\uBA70 \uBB34\uC5C7\uC774 \uBE60\uC84C\uB294\uC9C0
        \uC2A4\uC2A4\uB85C \uC5F0\uACB0\uD574 \uBCF4\uB824 \uD588\uB2E4."
      _statDeltas:
      - _statType: 1
        _amount: 1
      - _statType: 0
        _amount: -1
    - _dominantStat: 2
      _reactionText: "\uB124\uBAA8\uB294 \uC544\uBB34 \uB9D0\uB3C4 \uBB3B\uC9C0 \uBABB\uD55C
        \uCC44 \uC870\uC6A9\uD788 \uBC1C\uAC78\uC74C\uC744 \uC7AC\uCD09\uD588\uB2E4.
        \uC774\uC0C1\uD55C \uC815\uC801\uC774 \uC624\uB798 \uB0A8\uC558\uB2E4."
      _statDeltas:
      - _statType: 2
        _amount: 1
      - _statType: 0
        _amount: -1
    - _dominantStat: 3
      _reactionText: "\uB124\uBAA8\uB294 \uACE0\uAC1C\uB97C \uC219\uC778 \uCC44 \uADF8
        \uC7A5\uBA74\uC744 \uC9C0\uB098\uCCE4\uC9C0\uB9CC, \uC65C \uD53C\uD574\uC57C
        \uD558\uB294\uC9C0 \uB9C8\uC74C \uD55C\uD3B8\uC5D0 \uB0A8\uACA8\uB450\uC5C8\uB2E4."
      _statDeltas:
      - _statType: 3
        _amount: 1
      - _statType: 2
        _amount: 1
  _privateDialogue:
    _title: "\uC7A0\uB4E4\uAE30 \uC804 \uC9E7\uC740 \uB300\uD654"
    _openingLine: "\uC624\uB298 \uB2E4\uB4E4 \uB0B4\uAC00 \uC624\uB2C8\uAE4C \uB9D0\uC744
      \uBA48\uCDC4\uC5B4. \uC6D0\uB798 \uADF8\uB7F0 \uAC70\uC57C?"
    _choices:
    - _label: "\uBD80\uB4DC\uB7FD\uAC8C \uC5BC\uBC84\uBB34\uB9B0\uB2E4"
      _responseLine: "\uB124\uBAA8\uB294 \uACE0\uAC1C\uB97C \uB044\uB355\uC600\uC9C0\uB9CC,
        \uB208\uBE5B\uC740 \uC7A0\uAE50 \uB354 \uBA38\uBB34\uB974\uB2E4\uAC00 \uC774\uBD88\uC744
        \uB04C\uC5B4\uC548\uC558\uB2E4."
      _statDeltas:
      - _statType: 0
        _amount: 1
      - _statType: 1
        _amount: 1
    - _label: "\uADDC\uCE59\uC774\uB77C\uACE0\uB9CC \uB9D0\uD55C\uB2E4"
      _responseLine: "\uB124\uBAA8\uB294 \uC774\uC720\uB97C \uB354 \uBB3B\uC9C0 \uC54A\uC558\uC9C0\uB9CC,
        \uD45C\uC815\uC774 \uC870\uAE08 \uAD73\uC5B4\uC84C\uB2E4."
      _statDeltas:
      - _statType: 3
        _amount: 1
      - _statType: 2
        _amount: 1
    - _label: "\uC194\uC9C1\uD558\uAC8C \uBD88\uD3B8\uD55C \uC9C4\uC2E4\uC744 \uC77C\uBD80
        \uB9D0\uD55C\uB2E4"
      _responseLine: "\uB124\uBAA8\uB294 \uB180\uB790\uC9C0\uB9CC, \uC801\uC5B4\uB3C4
        \uC790\uC2E0\uC774 \uBAA8\uB974\uB294 \uCC44 \uB450\uC9C0\uB294 \uC54A\uC558\uB2E4\uB294
        \uC548\uB3C4\uB3C4 \uD568\uAED8 \uB290\uAF08\uB2E4."
      _statDeltas:
      - _statType: 1
        _amount: 1
      - _statType: 0
        _amount: -1
