  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: Step_TEST_W1_Night
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: '[W1 밤 대화] 선택 결과와 다음 스텝 분기 테스트'
  _bodyText: "\uD655\uC778 \uD3EC\uC778\uD2B8: \uBC24 \uB300\uD654, \uC120\uD0DD\uC9C0 \uACB0\uACFC \uD654\uBA74, \uB2E4\uC74C \uC2A4\uD15D \uC774\uB3D9\uC744 \uD55C \uBC88\uC5D0 \uD655\uC778."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: '[대화 내용 1] 외부 관심 플래그가 생겨서 1주차 밤 대화가 열렸습니다.'
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: '[대화 내용 2] 선택지 A는 다음 스텝으로, 선택지 B는 여기서 종료됩니다.'
  _nemoLine: '[대화 내용 1] 외부 관심 플래그가 생겨서 1주차 밤 대화가 열렸습니다.'
  _useCustomVisualState: 0
  _visualState: 1
  _onEnterInteractions: []
  _choices:
  - _label: '[선택지 A] 결과 화면 확인 후 다음 스텝으로 이동'
    _responseDialogueLines:
    - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
      _text: '[결과 내용 1] 선택지 A를 골라 결과 화면이 열렸습니다.'
    - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
      _text: '[결과 내용 2] 계속 진행하면 다음 스텝으로 넘어갑니다.'
    _responseLine: '테스트 결과: 선택지 A를 선택했습니다.'
    _interactions:
    - {fileID: 11400000, guid: eae4044633908994ca5dd9b07b5c955c, type: 2}
    - {fileID: 11400000, guid: f5258a52bdc299643973dc266095c337, type: 2}
    - {fileID: 11400000, guid: dd3a99a24b3e0a643a847c1b8b0de022, type: 2}
    _nextStep: {fileID: 11400000, guid: 6cdb109c43f811d41b4b2aaf03baa07c, type: 2}
    _resultCinematicCues:
      _enterCue: {fileID: 0}
      _exitCue: {fileID: 0}
  - _label: '[선택지 B] 결과 화면만 보고 이벤트 종료'
    _responseDialogueLines:
    - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
      _text: '[결과 내용 1] 선택지 B를 골라 결과 화면이 열렸고, 이어서 이벤트가 종료됩니다.'
    _responseLine: '테스트 결과: 선택지 B를 선택했습니다.'
    _interactions:
    - {fileID: 11400000, guid: 45df65fdfdb6c9048a688b82fd984b28, type: 2}
    - {fileID: 11400000, guid: a37c028c943886645819e3b8ab03f497, type: 2}
    _nextStep: {fileID: 0}
    _resultCinematicCues:
      _enterCue: {fileID: 0}
      _exitCue: {fileID: 0}
  _nextStep: {fileID: 0}
