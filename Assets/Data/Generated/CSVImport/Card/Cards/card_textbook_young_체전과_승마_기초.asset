  _id: "card_textbook_young_\uCCB4\uC804\uACFC_\uC2B9\uB9C8_\uAE30\uCD08"
  _cardType: {fileID: 11400000, guid: e8644e571406f564b9ea2d52094a16a5, type: 2}
  _title: "\uCCB4\uC804\uACFC \uC2B9\uB9C8 \uAE30\uCD08"
  _originalText: "\uC720\uB144\uAE30\uC758 \u2018\uBAB8\uAC00\uC9D0\uACFC \uBC1C\uB180\uB9BC\u2019\uC774
    \uC2EC\uD654\uB418\uC5B4, \uC774\uC81C\uB294 \uB3D9\uBB3C\uC744 \uB2E4\uB8E8\uACE0
    \uD65C\uB3D9\uC801\uC73C\uB85C \uBAB8\uC744 \uC6C0\uC9C1\uC774\uB294 \uD65C\uAE30\uCC2C
    \uC218\uC5C5\uC774\uC57C. - a. \uAC70\uBD80 (\uD1B5\uC81C)"
  _options:
  - _semantic: 2
    _label: "\uAC00\uBCCD\uAC8C \uB118\uAE34\uB2E4"
    _presentedText: "\uCCB4\uC804\uACFC \uC2B9\uB9C8 \uAE30\uCD08 \uAD50\uC7AC\uB294
      \uC624\uB298 \uAC00\uBCCD\uAC8C\uB9CC \uD6D1\uACE0 \uB118\uC5B4\uAC04\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: 7e9e7c466b743084c8fdfed064fa2fb3, type: 2}
  - _semantic: 1
    _label: "\uC27D\uAC8C \uD480\uC5B4\uC900\uB2E4"
    _presentedText: "\uCCB4\uC804\uACFC \uC2B9\uB9C8 \uAE30\uCD08 \uB0B4\uC6A9\uC744
      \uC774\uD574\uD558\uAE30 \uC27D\uAC8C \uD480\uC5B4\uC11C \uC804\uB2EC\uD55C\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: 3767dfb8845aead42b17c728fe339544, type: 2}
  - _semantic: 0
    _label: "\uCC28\uBD84\uD788 \uC77D\uD78C\uB2E4"
    _presentedText: "\uCCB4\uC804\uACFC \uC2B9\uB9C8 \uAE30\uCD08 \uAD50\uC7AC \uB0B4\uC6A9\uC744
      \uCC28\uBD84\uD788 \uC77D\uACE0 \uADF8\uB300\uB85C \uC775\uD788\uAC8C \uD55C\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: f4ea349d76ad73e488dcc5448ce0e451, type: 2}
