    - {fileID: 11400000, guid: 23289d77d918bd54da5726f91ea72ea8, type: 2}
  - _semantic: 1
    _label: "\uC870\uAE08 \uB204\uADF8\uB7EC\uB728\uB9B0\uB2E4"
    _presentedText: "\uC790\uADF9\uC801\uC778 \uBD80\uBD84\uC744 \uB35C\uC5B4\uB0B4\uACE0
      \uD575\uC2EC\uB9CC \uC804\uD55C\uB2E4."
