  _cardType: {fileID: 11400000, guid: e8644e571406f564b9ea2d52094a16a5, type: 2}
  _title: "\uAD70\uC0AC \uC804\uB7B5\uACFC \uBC29\uC5B4 \uC9C4\uD615"
  _originalText: "\uC601\uC9C0\uB97C \uCE68\uB7B5\uC73C\uB85C\uBD80\uD130 \uC9C0\uD0A4\uAE30
    \uC704\uD55C \uBCD1\uBC95\uC774\uC57C. \uC9C1\uC811 \uCE7C\uC744 \uD718\uB450\uB974\uB294
    \uAC83\uBCF4\uB2E4, \uAD70\uB300\uB97C \uC5B4\uB5BB\uAC8C \uBC30\uCE58\uD558\uACE0
    \uC9C0\uD615\uC744 \uD65C\uC6A9\uD560\uC9C0 \uBA38\uB9AC \uC4F0\uB294 \uBC95\uC744
    \uBC30\uC6CC. - a. \uAC70\uBD80 (\uD1B5\uC81C)"
  _options:
  - _semantic: 2
    _label: "\uAC00\uBCCD\uAC8C \uB118\uAE34\uB2E4"
    _presentedText: "\uAD70\uC0AC \uC804\uB7B5\uACFC \uBC29\uC5B4 \uC9C4\uD615 \uAD50\uC7AC\uB294
      \uC624\uB298 \uAC00\uBCCD\uAC8C\uB9CC \uD6D1\uACE0 \uB118\uC5B4\uAC04\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: 7e9e7c466b743084c8fdfed064fa2fb3, type: 2}
  - _semantic: 1
    _label: "\uC27D\uAC8C \uD480\uC5B4\uC900\uB2E4"
    _presentedText: "\uAD70\uC0AC \uC804\uB7B5\uACFC \uBC29\uC5B4 \uC9C4\uD615 \uB0B4\uC6A9\uC744
      \uC774\uD574\uD558\uAE30 \uC27D\uAC8C \uD480\uC5B4\uC11C \uC804\uB2EC\uD55C\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: 3767dfb8845aead42b17c728fe339544, type: 2}
  - _semantic: 0
    _label: "\uCC28\uBD84\uD788 \uC77D\uD78C\uB2E4"
    _presentedText: "\uAD70\uC0AC \uC804\uB7B5\uACFC \uBC29\uC5B4 \uC9C4\uD615 \uAD50\uC7AC
      \uB0B4\uC6A9\uC744 \uCC28\uBD84\uD788 \uC77D\uACE0 \uADF8\uB300\uB85C \uC775\uD788\uAC8C
