  _cardType: {fileID: 11400000, guid: ce3bff0c6c6a2844998d0c18806d6b74, type: 2}
  _title: "\uBE44\uADF9\uC758 \uC232 \uB178\uB7AB\uC18C\uB9AC \uC18C\uBB38"
  _originalText: "\uBE44\uADF9\uC758 \uC232\uC5D0\uC11C \uB4E4\uB824\uC628\uB2E4\uB294
    \uB178\uB7AB\uC18C\uBB38\uC774 \uB3C8\uB2E4. \uBD88\uAE38\uD55C \uC774\uC57C\uAE30\uB85C
    \uB0A8\uAE38\uC9C0 \uBC31\uC791\uC774 \uC900\uBE44\uD55C \uC704\uB85C\uB85C \uBC14\uAFD4
    \uB4E4\uB824\uC904\uC9C0 \uC815\uD55C\uB2E4."
  _options:
  - _semantic: 2
    _label: "\uC18C\uBB38\uC744 \uC228\uAE34\uB2E4"
    _presentedText: "\uC800\uD0DD \uB0B4 \uC18C\uBB38\uC744 \uB124\uBAA8\uC5D0\uAC8C
      \uB4E4\uB824\uC8FC\uC9C0 \uC54A\uB294\uB2E4."
    _interactions: []
  - _semantic: 0
    _label: "\uC18C\uBB38\uC744 \uB4E4\uB824\uC900\uB2E4"
    _presentedText: "\uC800\uD0DD \uB0B4 \uC18C\uBB38\uC744 \uC788\uB294 \uADF8\uB300\uB85C
      \uC804\uD574 \uC900\uB2E4."
    _interactions: []
  - _semantic: 1
    _label: "\uB3CC\uB824\uC11C \uB9D0\uD55C\uB2E4"
    _presentedText: "\uC18C\uBB38\uC758 \uB0A0\uCE74\uB85C\uC6B4 \uBD80\uBD84\uC744
      \uB35C\uC5B4\uB0B4\uACE0 \uBD80\uB4DC\uB7FD\uAC8C \uC804\uB2EC\uD55C\uB2E4."
    _interactions: []
