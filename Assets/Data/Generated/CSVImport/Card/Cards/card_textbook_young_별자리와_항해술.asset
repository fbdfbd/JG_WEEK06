  m_EditorClassIdentifier: Assembly-CSharp::SO_CardInfoDefinition
  _id: "card_textbook_young_\uBCC4\uC790\uB9AC\uC640_\uD56D\uD574\uC220"
  _cardType: {fileID: 11400000, guid: e8644e571406f564b9ea2d52094a16a5, type: 2}
  _title: "\uBCC4\uC790\uB9AC\uC640 \uD56D\uD574\uC220"
  _originalText: "\uC720\uB144\uAE30\uC758 \u2018\uAF43\uACFC \uBC8C\uB808 \uAD00\uCC30\u2019\uC774
    \uB545 \uC704\uB97C \uBD24\uB2E4\uBA74, \uC774\uC81C\uB294 \uBC24\uD558\uB298\uC744
    \uBCF4\uBA70 \uB113\uC740 \uC138\uC0C1\uC744 \uAFC8\uAFB8\uB294 \uACFC\uBAA9\uC774\uC57C.
    \uB098\uC911\uC5D0 \uC5EC\uD589\uC744 \uAC00\uAC70\uB098 \uAE38\uC744 \uC783\uC9C0
    \uC54A\uB294 \uBC95\uC744 \uBC30\uC6CC. - a. \uAC70\uBD80 (\uD1B5\uC81C)"
  _options:
  - _semantic: 2
    _label: "\uAC00\uBCCD\uAC8C \uB118\uAE34\uB2E4"
    _presentedText: "\uBCC4\uC790\uB9AC\uC640 \uD56D\uD574\uC220 \uAD50\uC7AC\uB294
      \uC624\uB298 \uAC00\uBCCD\uAC8C\uB9CC \uD6D1\uACE0 \uB118\uC5B4\uAC04\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: 7e9e7c466b743084c8fdfed064fa2fb3, type: 2}
  - _semantic: 1
    _label: "\uC27D\uAC8C \uD480\uC5B4\uC900\uB2E4"
    _presentedText: "\uBCC4\uC790\uB9AC\uC640 \uD56D\uD574\uC220 \uB0B4\uC6A9\uC744
      \uC774\uD574\uD558\uAE30 \uC27D\uAC8C \uD480\uC5B4\uC11C \uC804\uB2EC\uD55C\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: 3767dfb8845aead42b17c728fe339544, type: 2}
  - _semantic: 0
    _label: "\uCC28\uBD84\uD788 \uC77D\uD78C\uB2E4"
    _presentedText: "\uBCC4\uC790\uB9AC\uC640 \uD56D\uD574\uC220 \uAD50\uC7AC \uB0B4\uC6A9\uC744
      \uCC28\uBD84\uD788 \uC77D\uACE0 \uADF8\uB300\uB85C \uC775\uD788\uAC8C \uD55C\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: f4ea349d76ad73e488dcc5448ce0e451, type: 2}
