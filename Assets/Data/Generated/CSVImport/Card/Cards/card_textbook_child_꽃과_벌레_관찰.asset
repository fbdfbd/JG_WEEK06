  _cardType: {fileID: 11400000, guid: e8644e571406f564b9ea2d52094a16a5, type: 2}
  _title: "\uAF43\uACFC \uBC8C\uB808 \uAD00\uCC30"
  _originalText: "\uC815\uC6D0\uACFC \uC800\uD0DD \uC8FC\uBCC0\uC5D0\uC11C \uBCFC
    \uC218 \uC788\uB294 \uAF43, \uBC8C\uB808, \uC0C8 \uAC19\uC740 \uAC83\uB4E4\uC744
    \uBC30\uC6B0\uB294 \uAD50\uC7AC. \uB124\uBAA8\uC758 \uD638\uAE30\uC2EC\uACFC
    \uC544\uC774\uB2E4\uC6B4 \uAC10\uC131\uC744 \uC0B4\uB9AC\uAE30 \uC88B\uC740 \uACFC\uBAA9\uC774\uB2E4."
  _options:
  - _semantic: 2
    _label: "\uAC00\uBCCD\uAC8C \uB118\uAE34\uB2E4"
    _presentedText: "\uAF43\uACFC \uBC8C\uB808 \uAD00\uCC30 \uAD50\uC7AC\uB294 \uC624\uB298
      \uAC00\uBCCD\uAC8C\uB9CC \uD6D1\uACE0 \uB118\uC5B4\uAC04\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: 7e9e7c466b743084c8fdfed064fa2fb3, type: 2}
  - _semantic: 1
    _label: "\uC27D\uAC8C \uD480\uC5B4\uC900\uB2E4"
    _presentedText: "\uAF43\uACFC \uBC8C\uB808 \uAD00\uCC30 \uB0B4\uC6A9\uC744 \uC774\uD574\uD558\uAE30
      \uC27D\uAC8C \uD480\uC5B4\uC11C \uC804\uB2EC\uD55C\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: 3767dfb8845aead42b17c728fe339544, type: 2}
  - _semantic: 0
    _label: "\uCC28\uBD84\uD788 \uC77D\uD78C\uB2E4"
    _presentedText: "\uAF43\uACFC \uBC8C\uB808 \uAD00\uCC30 \uAD50\uC7AC \uB0B4\uC6A9\uC744
      \uCC28\uBD84\uD788 \uC77D\uACE0 \uADF8\uB300\uB85C \uC775\uD788\uAC8C \uD55C\uB2E4."
    _interactions:
