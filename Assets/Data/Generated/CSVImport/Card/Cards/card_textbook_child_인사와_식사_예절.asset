  _cardType: {fileID: 11400000, guid: e8644e571406f564b9ea2d52094a16a5, type: 2}
  _title: "\uC778\uC0AC\uC640 \uC2DD\uC0AC \uC608\uC808"
  _originalText: "\uADC0\uC871\uAC00 \uC544\uC774\uB85C\uC11C \uAC00\uC7A5 \uBA3C\uC800
    \uBC30\uC6B0\uB294 \uAE30\uBCF8 \uC608\uC808. \uC778\uC0AC\uD558\uB294 \uBC95,
    \uBC14\uB974\uAC8C \uC549\uB294 \uBC95, \uC2DD\uC0AC \uC790\uB9AC\uC5D0\uC11C
    \uC870\uC6A9\uD788 \uD589\uB3D9\uD558\uB294 \uBC95\uC744 \uC775\uD78C\uB2E4."
  _options:
  - _semantic: 2
    _label: "\uAC00\uBCCD\uAC8C \uB118\uAE34\uB2E4"
    _presentedText: "\uC778\uC0AC\uC640 \uC2DD\uC0AC \uC608\uC808 \uAD50\uC7AC\uB294
      \uC624\uB298 \uAC00\uBCCD\uAC8C\uB9CC \uD6D1\uACE0 \uB118\uC5B4\uAC04\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: 7e9e7c466b743084c8fdfed064fa2fb3, type: 2}
  - _semantic: 1
    _label: "\uC27D\uAC8C \uD480\uC5B4\uC900\uB2E4"
    _presentedText: "\uC778\uC0AC\uC640 \uC2DD\uC0AC \uC608\uC808 \uB0B4\uC6A9\uC744
      \uC774\uD574\uD558\uAE30 \uC27D\uAC8C \uD480\uC5B4\uC11C \uC804\uB2EC\uD55C\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: 3767dfb8845aead42b17c728fe339544, type: 2}
  - _semantic: 0
    _label: "\uCC28\uBD84\uD788 \uC77D\uD78C\uB2E4"
    _presentedText: "\uC778\uC0AC\uC640 \uC2DD\uC0AC \uC608\uC808 \uAD50\uC7AC \uB0B4\uC6A9\uC744
      \uCC28\uBD84\uD788 \uC77D\uACE0 \uADF8\uB300\uB85C \uC775\uD788\uAC8C \uD55C\uB2E4."
