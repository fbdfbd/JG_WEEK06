  _title: "\uAC00\uBB38\uC758 \uAC00\uBCF4 \uC120\uD0DD \uC18C\uBB38"
  _originalText: "\uC131\uC778\uC2DD \uAC00\uBCF4\uAC00 \uC8FC\uC778\uC744 \uACE0\uB978\uB2E4\uB294
    \uB9D0\uC774 \uD558\uC778\uB4E4 \uC0AC\uC774\uC5D0 \uB3C8\uB2E4. \uBD88\uC548\uD55C
    \uC2DC\uD5D8\uCC98\uB7FC \uB4E4\uB824\uC904\uC9C0 \uB2F9\uB2F9\uD55C \uC758\uC2DD\uCC98\uB7FC
    \uB290\uB07C\uAC8C \uD560\uC9C0 \uC815\uD55C\uB2E4."
  _options:
  - _semantic: 2
    _label: "\uC18C\uBB38\uC744 \uC228\uAE34\uB2E4"
    _presentedText: "\uC800\uD0DD \uB0B4 \uC18C\uBB38\uC744 \uB124\uBAA8\uC5D0\uAC8C
      \uB4E4\uB824\uC8FC\uC9C0 \uC54A\uB294\uB2E4."
    _interactions: []
  - _semantic: 0
    _label: "\uC18C\uBB38\uC744 \uB4E4\uB824\uC900\uB2E4"
    _presentedText: "\uC800\uD0DD \uB0B4 \uC18C\uBB38\uC744 \uC788\uB294 \uADF8\uB300\uB85C
      \uC804\uD574 \uC900\uB2E4."
    _interactions: []
  - _semantic: 1
    _label: "\uB3CC\uB824\uC11C \uB9D0\uD55C\uB2E4"
    _presentedText: "\uC18C\uBB38\uC758 \uB0A0\uCE74\uB85C\uC6B4 \uBD80\uBD84\uC744
      \uB35C\uC5B4\uB0B4\uACE0 \uBD80\uB4DC\uB7FD\uAC8C \uC804\uB2EC\uD55C\uB2E4."
