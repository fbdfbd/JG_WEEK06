  _cardType: {fileID: 11400000, guid: e8644e571406f564b9ea2d52094a16a5, type: 2}
  _title: "\uC81C\uAD6D\uBC95\uACFC \uC601\uC9C0 \uD589\uC815"
  _originalText: "\uB2E8\uC21C\uD788 \uC608\uC808\uC744 \uBC30\uC6B0\uB294 \uB2E8\uACC4\uB97C
    \uB118\uC5B4, \uC601\uBBFC\uB4E4 \uC0AC\uC774\uC758 \uAC08\uB4F1\uC744 \uD574\uACB0\uD558\uACE0
    \uBC95\uC744 \uC9D1\uD589\uD558\uB294 \uBC95\uC744 \uBC30\uC6CC. \uBC31\uC791\uB2D8\uC758
    \uB4A4\uB97C \uC774\uC744 \uD6C4\uACC4\uC790\uC5D0\uAC8C \uAC00\uC7A5 \uC911\uC694\uD55C
    \uACFC\uBAA9\uC774\uC57C. - a. \uAC70\uBD80 (\uD1B5\uC81C)"
  _options:
  - _semantic: 2
    _label: "\uAC00\uBCCD\uAC8C \uB118\uAE34\uB2E4"
    _presentedText: "\uC81C\uAD6D\uBC95\uACFC \uC601\uC9C0 \uD589\uC815 \uAD50\uC7AC\uB294
      \uC624\uB298 \uAC00\uBCCD\uAC8C\uB9CC \uD6D1\uACE0 \uB118\uC5B4\uAC04\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: 7e9e7c466b743084c8fdfed064fa2fb3, type: 2}
  - _semantic: 1
    _label: "\uC27D\uAC8C \uD480\uC5B4\uC900\uB2E4"
    _presentedText: "\uC81C\uAD6D\uBC95\uACFC \uC601\uC9C0 \uD589\uC815 \uB0B4\uC6A9\uC744
      \uC774\uD574\uD558\uAE30 \uC27D\uAC8C \uD480\uC5B4\uC11C \uC804\uB2EC\uD55C\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: 3767dfb8845aead42b17c728fe339544, type: 2}
  - _semantic: 0
    _label: "\uCC28\uBD84\uD788 \uC77D\uD78C\uB2E4"
    _presentedText: "\uC81C\uAD6D\uBC95\uACFC \uC601\uC9C0 \uD589\uC815 \uAD50\uC7AC
