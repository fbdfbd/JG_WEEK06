  _id: "card_textbook_child_\uB3D9\uD654\uC640_\uAE00\uC790"
  _cardType: {fileID: 11400000, guid: e8644e571406f564b9ea2d52094a16a5, type: 2}
  _title: "\uB3D9\uD654\uC640 \uAE00\uC790"
  _originalText: "\uC9E7\uC740 \uB3D9\uD654\uC640 \uC26C\uC6B4 \uAE00\uC790\uB97C
    \uD1B5\uD574 \uC77D\uAE30\uC640 \uC4F0\uAE30\uC758 \uAE30\uCD08\uB97C \uBC30\uC6B0\uB294
    \uAD50\uC7AC. \uB3C4\uC11C\uAD00, \uD3B8\uC9C0, \uAE30\uB85D\uACFC \uC790\uC5F0\uC2A4\uB7FD\uAC8C
    \uC5F0\uACB0\uB418\uB294 \uAE30\uBCF8 \uACFC\uBAA9\uC774\uB2E4."
  _options:
  - _semantic: 2
    _label: "\uAC00\uBCCD\uAC8C \uB118\uAE34\uB2E4"
    _presentedText: "\uB3D9\uD654\uC640 \uAE00\uC790 \uAD50\uC7AC\uB294 \uC624\uB298
      \uAC00\uBCCD\uAC8C\uB9CC \uD6D1\uACE0 \uB118\uC5B4\uAC04\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: 7e9e7c466b743084c8fdfed064fa2fb3, type: 2}
  - _semantic: 1
    _label: "\uC27D\uAC8C \uD480\uC5B4\uC900\uB2E4"
    _presentedText: "\uB3D9\uD654\uC640 \uAE00\uC790 \uB0B4\uC6A9\uC744 \uC774\uD574\uD558\uAE30
      \uC27D\uAC8C \uD480\uC5B4\uC11C \uC804\uB2EC\uD55C\uB2E4."
    _interactions:
    - {fileID: 11400000, guid: 3767dfb8845aead42b17c728fe339544, type: 2}
  - _semantic: 0
    _label: "\uCC28\uBD84\uD788 \uC77D\uD78C\uB2E4"
    _presentedText: "\uB3D9\uD654\uC640 \uAE00\uC790 \uAD50\uC7AC \uB0B4\uC6A9\uC744
      \uCC28\uBD84\uD788 \uC77D\uACE0 \uADF8\uB300\uB85C \uC775\uD788\uAC8C \uD55C\uB2E4."
    _interactions:
