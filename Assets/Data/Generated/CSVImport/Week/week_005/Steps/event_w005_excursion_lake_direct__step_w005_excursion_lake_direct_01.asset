  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w005_excursion_lake_direct__step_w005_excursion_lake_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 5\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uB9D1\uC740 \uC624\uC804. \uD638\uC22B\uAC00 \uAC08\uB300 \uB05D\uC5D0
    \uC587\uC740 \uC0C9\uC885\uC774 \uC870\uAC01 \uBA87 \uC7A5\uC774 \uAC78\uB824
    \uC788\uB2E4. \uBB3C\uAC00\uC5D4 \uD0C0\uB2E4 \uB0A8\uC740 \uAC00\uB294 \uB9C9\uB300\uC640,
    \uAE08\uAC00\uB8E8\uAC00 \uB0A8\uC740 \uC885\uC774\uAECD\uC9C8\uC774 \uC816\uC740
    \uCC44 \uB4E4\uB7EC\uBD99\uC5B4 \uC788\uB2E4.)\n        \n        \uB124\uBAA8
    : \uC5B4?\n        \n        \uB124\uBAA8 : \uC774\uAC70 \uB0B4 \uC0DD\uC77C\uB0A0
    \uADF8\uAC70\uB124.\n        \n        (\uB124\uBAA8\uAC00 \uB09C\uAC04 \uAC00\uAE4C\uC774
    \uAC00\uC11C \uC0C9\uC774 \uBC14\uB79C \uC885\uC774 \uC870\uAC01\uC744 \uB0B4\uB824\uB2E4\uBCF8\uB2E4.
    \uC190\uB05D\uB9CC \uD55C \uC870\uAC01\uC778\uB370\uB3C4 \uD587\uBE5B\uC744 \uBC1B\uC73C\uB2C8
    \uC544\uC9C1 \uC870\uAE08 \uBC18\uC9DD\uC778\uB2E4.)\n        \n        \uB124\uBAA8
    : \uBC24\uC5D4 \uB354 \uC608\uBEE4\uB294\uB370.\n        \n        \uB124\uBAA8
    : \uB0AE\uC5D0 \uBCF4\uB2C8\uAE4C \uB418\uAC8C \uC870\uC6A9\uD558\uB2E4.\n       
    \n\n(\uD558\uB140\uAC00 \uB9C8\uB978 \uC870\uAC01 \uD558\uB098\uB97C \uACE8\uB77C
    \uC190\uBC14\uB2E5 \uC704\uC5D0 \uC62C\uB824 \uBCF4\uC5EC \uC900\uB2E4.)\n       
    \n        \uD558\uB140 : \uC774\uAC74 \uAD1C\uCC2E\uC2B5\uB2C8\uB2E4. \uB2E4
    \uC2DD\uACE0 \uB9C8\uB978 \uAC70\uC608\uC694.\n        \n        \uB124\uBAA8
    : ...\uC9C4\uC9DC \uADF8\uB0A0 \uAC70\uAD6C\uB098.\n        \n        \uD558\uB140
    : \uC608. \uD638\uC218 \uC704\uC5D0\uC11C \uD130\uC9C0\uB358 \uC791\uC740 \uBD88\uAF43
    \uC911 \uD558\uB098\uC9C0\uC694.\n        \n        \uB124\uBAA8 : \uBC24\uC5D4
    \uC5C4\uCCAD \uCEE4 \uBCF4\uC600\uB294\uB370.\n        \n        \uD558\uB140
    : \uC5B4\uB461\uACE0 \uBB3C \uC704\uC600\uC73C\uB2C8\uAE4C\uC694.\n        \n       
    \uB124\uBAA8 : \uB9DE\uC544.\n        \n        \uB124\uBAA8 : \uBB3C\uC5D0 \uBE44\uCE5C
    \uAC8C \uB354 \uC608\uBEE4\uC5B4. \uD558\uB298\uBCF4\uB2E4 \uC544\uB798\uCABD\uC774
    \uB354 \uBC18\uC9DD\uC600\uAC70\uB4E0.\n        \n        \uB124\uBAA8 : \uC7A0\uAE50\uC774\uC5C8\uB294\uB370\uB3C4
    \uAE30\uC5B5\uB098.\n        \n        (\uB124\uBAA8\uAC00 \uAE08\uAC00\uB8E8
    \uBB3B\uC740 \uC870\uAC01\uC744 \uAC00\uB9CC\uD788 \uBCF8\uB2E4.)\n        \n       
    \uB124\uBAA8 : \uADFC\uB370 \uC774\uB7F0 \uAC78 \uCE58\uC6B0\uACE0 \uB098\uBA74,
    \uC9C4\uC9DC \uC788\uC5C8\uB358 \uAC74\uC9C0 \uC880 \uC774\uC0C1\uD574.\n       
    \n        \uD558\uB140 : \uADF8\uB798\uC11C \uC794\uD574\uAC00 \uB0A8\uB294 \uAC78\uC9C0\uB3C4
    \uBAA8\uB974\uC9C0\uC694, \uC8FC\uC778\uB2D8.\n        \n        \uB124\uBAA8
    : ...\uADF8\uAC74 \uC880 \uC88B\uB2E4."
  _dialogueLines: []
