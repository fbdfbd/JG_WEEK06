  _titleOverride: "\uCC9C\uBB38 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4"
  _bodyText: "\uCC9C\uBB38 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uCC9C\uBB38 \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
      \uCC3D\uBC16 \uD558\uB298\uB9CC \uD55C\uBC88 \uBCF4\uACE0 \uB36E\uC5B4 \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624\uB298\uC740 \uBCC4 \uC774\uC57C\uAE30 \uC548 \uD574\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uAD50\uC7AC\uB294 \uC7A0\uC2DC \uBBF8\uB8E8\uACE0, \uB2E4\uC74C\uC5D0
      \uB354 \uC624\uB798 \uBCF4\uAE30\uB85C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB2E4\uC74C\uC5D4 \uAF2D \uBCC4 \uB9CE\uC740 \uB0A0\uC5D0
      \uD574\uC694."
  _nemoLine: "(\uCC9C\uBB38 \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
    \uCC3D\uBC16 \uD558\uB298\uB9CC \uD55C\uBC88 \uBCF4\uACE0 \uB36E\uC5B4 \uB454\uB2E4.)"
