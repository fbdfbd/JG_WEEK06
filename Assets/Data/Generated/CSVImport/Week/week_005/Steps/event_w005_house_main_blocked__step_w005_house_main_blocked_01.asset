  m_Name: event_w005_house_main_blocked__step_w005_house_main_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "5\uC8FC\uCC28 - \uD1B5\uC81C"
  _bodyText: "(\uBC24\uC758 \uADF8\uB9BC\uC790\uAC00 \uB0B4\uB824\uC549\uC740 \uACC4\uB2E8
    \uC544\uB798. \uD558\uC778 \uB458\uC774 \uC545\uAE30\uC2E4 \uCABD\uC744 \uBCF4\uBA70
    \uC18D\uC0AD\uC778\uB2E4.)\r\n    \uD558\uC7781 : \uC5B4\uC81C \uB4E4\uC5C8\uC5B4?
    \uC544\uBB34\uB3C4 \uC5C6\uB294\uB370 \uAC74\uBC18 \uC18C\uB9AC\uAC00 \uB0AC\uB2E4\uB2C8\uAE4C.\r\n   
    \uD558\uC7782 : \uBC14\uB78C \uC18C\uB9AC\uACA0\uC9C0. \uD558\uC9C0\uB9CC \uAF2D
    \uB204\uAC00 \uD55C \uC74C\uC529 \uB204\uB974\uB294 \uAC83 \uAC19\uAE34 \uD558\uB354\uB77C.\r\n   
    \uB124\uBAA8 : \uD53C\uC544\uB178\uAC00 \uD63C\uC790 \uB178\uB798\uD574?\r\n   
    \r\n\r\n\uD558\uC7781 : \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8. \uADF8\uB0E5
    \uCC3D\uBB38\uC774 \uB35C\uCEF9\uAC70\uB9AC\uB294 \uC18C\uB9AC\uC600\uC5B4\uC694.\r\n   
    \uB124\uBAA8 : \uD53C\uC544\uB178 \uC18C\uB9AC \uAC19\uB2E4\uACE0 \uD588\uC796\uC544.\r\n   
    \uD558\uC7782 : \uBC24\uC5D0\uB294 \uBAA8\uB4E0 \uC18C\uB9AC\uAC00 \uD06C\uAC8C
    \uB4E4\uB824\uC11C \uCC29\uAC01\uD55C \uAC81\uB2C8\uB2E4.\r\n    \uB124\uBAA8
    : \uCE58... \uB2E4\uB4E4 \uB098\uD55C\uD14C\uB9CC \uBE44\uBC00\uC774\uC57C."
