  _titleOverride: "\uBD80\uC5CC\uC758 \uAE30\uBCF8\uACFC \uC7AC\uB8CC\uB97C \uAC00\uB974\uCE5C\uB2E4"
  _bodyText: "\uBD80\uC5CC\uC758 \uAE30\uBCF8\uACFC \uC7AC\uB8CC\uB97C \uAC00\uB974\uCE5C\uB2E4
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBD80\uC5CC \uB3C4\uAD6C\uC640 \uAE30\uBCF8 \uC7AC\uB8CC\uC758 \uC4F0\uC784\uC744
      \uD558\uB098\uC529 \uC9DA\uC73C\uBA70 \uAD50\uC7AC\uB97C \uC77D\uC5B4 \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uB2EC\uACE0, \uC774\uAC74 \uC9E0 \uB370 \uC4F0\uB294 \uAC70\uC9C0?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uBD80\uC5CC\uC5D0\uC11C \uC9C0\uCF1C\uC57C \uD560 \uC21C\uC11C\uC640
      \uB3C4\uAD6C \uC774\uB984\uC744 \uCC28\uADFC\uD788 \uC775\uD788\uAC8C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uC74C\uC5D4 \uC81C\uAC00 \uC7AC\uB8CC\uB97C \uBA3C\uC800 \uB9DE\uD600
      \uBCFC\uB798\uC694."
  _nemoLine: "(\uBD80\uC5CC \uB3C4\uAD6C\uC640 \uAE30\uBCF8 \uC7AC\uB8CC\uC758 \uC4F0\uC784\uC744
    \uD558\uB098\uC529 \uC9DA\uC73C\uBA70 \uAD50\uC7AC\uB97C \uC77D\uC5B4 \uC900\uB2E4.)"
