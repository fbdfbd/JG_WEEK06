--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_cooking_direct__step_event_week_005_cooking_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC7AC\uB294 \uC774\uC720\uB97C \uC190\uC73C\uB85C \uC775\uD78C\uB2E4"
  _bodyText: "\uC694\uB9AC\uC640 \uBC30\uC2DD\uC758 \uC6D0\uB9AC 5\uC8FC\uCC28 Direct
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC8FC\uBC29 \uD55C\uCABD \uC791\uC740 \uC791\uC5C5\uB300. \uBC00\uAC00\uB8E8,
      \uB2EC\uAC40, \uC6B0\uC720\uAC00 \uC870\uAE08\uC529 \uC900\uBE44\uB418\uC5B4
      \uC788\uACE0, \uD558\uB140\uAC00 \uACC4\uB7C9\uCEF5\uC744 \uBCF4\uC5EC \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uB9DB\uC788\uAC8C \uB9CC\uB4DC\uB294
      \uAC83\uBCF4\uB2E4 \uBA3C\uC800, \uC5BC\uB9C8\uB098 \uB123\uB294\uC9C0 \uBC30\uC6B0\uB294
      \uB0A0\uC774\uC5D0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB0E5 \uB300\uCDA9 \uB123\uC73C\uBA74 \uC548 \uB3FC?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8\uB7EC\uBA74 \uB300\uCDA9 \uC2E4\uD328\uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544, \uC774\uB9CC\uD07C \uB123\uC73C\uB2C8\uAE4C \uBC18\uC8FD\uC774
      \uC544\uAE4C\uBCF4\uB2E4 \uB35C \uC9C8\uC5B4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uADF8\uB798\uC11C \uC7AC\uB294 \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADC0\uCC2E\uAE34 \uD55C\uB370 \uC774\uC720\uB294 \uC54C\uACA0\uB2E4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8 \uC815\uB3C4\uBA74 \uC624\uB298\uC740 \uCDA9\uBD84\uD788 \uC798\uD558\uC2E0
      \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uAD7D\uB294 \uAC83\uB3C4 \uD574 \uBCFC\uB798."
  _nemoLine: "(\uC8FC\uBC29 \uD55C\uCABD \uC791\uC740 \uC791\uC5C5\uB300. \uBC00\uAC00\uB8E8,
    \uB2EC\uAC40, \uC6B0\uC720\uAC00 \uC870\uAE08\uC529 \uC900\uBE44\uB418\uC5B4
    \uC788\uACE0, \uD558\uB140\uAC00 \uACC4\uB7C9\uCEF5\uC744 \uBCF4\uC5EC \uC900\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
