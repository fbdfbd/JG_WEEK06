  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_visitor_friend_3_blocked__step_event_week_005_visitor_friend_3_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC720\uD53C \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor friend_3 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC720\uD53C\uAC00 \uAE43\uD39C\uC744 \uB4E4\uC790, \uACBD\uBE44\uB300\uC7A5\uC774
      \uC9C0\uB3C4\uB97C \uD655 \uB09A\uC544\uCC44\uC11C \uD1B5\uC5D0 \uC9D1\uC5B4\uB123\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC601\uC9C0 \uC9C0\uB3C4\uB294 \uC7A5\uB09C\uC744 \uC704\uD55C \uB3C4\uAD6C\uAC00
      \uC544\uB2D9\uB2C8\uB2E4. \uD5C8\uBB34\uB9F9\uB791\uD55C \uC18C\uB9AC\uB85C
      \uC8FC\uC778\uB2D8\uC758 \uAE30\uB85D\uC744 \uC624\uC5FC\uC2DC\uD0A4\uC9C0
      \uB9C8\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC720\uD53C\uB97C \uAC10\uC2F8\uBA70) \uC544\uC800\uC528, \uADF8\uB0E5
      \uB18D\uB2F4\uC774\uC796\uC544\uC694! \uB108\uBB34 \uC815\uC0C9\uD558\uC9C0
      \uB9C8\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "(\uC5B4\uAE68\uB97C \uC73C\uC4F1\uD558\uBA70) \uB124\uBAA8\uC57C, \uC800
      \uC544\uC800\uC528 \uB108\uBB34 \uBB34\uC12D\uB2E4. \uC5EC\uAE30\uB294 \uC6C3\uC74C\uC18C\uB9AC\uB3C4
      \uAC80\uC5F4\uBC1B\uB294 \uACF3\uC774\uC57C? \uB098 \uADF8\uB0E5 \uB098\uAC08\uB798."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uB2F9\uD669\uD558\uBA70) \uC544\uB2C8, \uADF8\uAC8C \uC544\uB2C8\uB77C...
      \uBBF8\uC548\uD574, \uB0B4\uAC00 \uB098\uC911\uC5D0 \uC0AC\uACFC\uD560\uAC8C."
  _nemoLine: "(\uC720\uD53C\uAC00 \uAE43\uD39C\uC744 \uB4E4\uC790, \uACBD\uBE44\uB300\uC7A5\uC774
    \uC9C0\uB3C4\uB97C \uD655 \uB09A\uC544\uCC44\uC11C \uD1B5\uC5D0 \uC9D1\uC5B4\uB123\uB294\uB2E4.)"
