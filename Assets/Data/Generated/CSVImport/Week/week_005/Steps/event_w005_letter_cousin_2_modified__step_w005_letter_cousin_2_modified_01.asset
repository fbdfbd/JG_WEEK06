  m_Name: event_w005_letter_cousin_2_modified__step_w005_letter_cousin_2_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 \uD3B8\uC9C0 5\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C
    \uC548\uC5D0\uC11C \uB531\uB531\uD558\uACE0 \uC791\uC740 \uBB34\uC5B8\uAC00\uAC00
    \uB9CC\uC838\uC9C0\uB294 \uB290\uB08C\uC774\uB2E4.)\r\n    \uD558\uB140 : \uC8FC\uC778\uB2D8
    \uC55E\uC73C\uB85C \uC628 \uD3B8\uC9C0\uC785\uB2C8\uB2E4. \uC774\uBC88\uC5D4
    \uD3B8\uC9C0 \uB9D0\uACE0 \uB2E4\uB978 \uAC83\uB3C4 \uB4E4\uC5B4\uC788\uB294
    \uAC83 \uAC19\uB124\uC694.\r\n        \r\n\r\n\uD558\uB140 : \uC8FC\uC778\uB2D8,
    \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uC774 \uC5EC\uD589\uC9C0\uC5D0\uC11C \uC8FC\uC778\uB2D8
    \uC0DD\uAC01\uC774 \uB098\uC11C \uC791\uC740 \uC120\uBB3C\uC744 \uC900\uBE44\uD588\uB300\uC694.\r\n       
    \uB124\uBAA8 : \uC120\uBB3C? \uB098 \uC8FC\uB824\uACE0?\r\n        \uD558\uB140
    : \uB124. \uC138\uC0C1\uC5D0\uC11C \uC81C\uC77C \uC608\uC05C \uC870\uAC1C\uAECD\uB370\uAE30\uB97C
    \uCC3E\uC558\uB300\uC694. \uB2E4\uC74C\uC5D0 \uB9CC\uB098\uBA74 \uB204\uAD6C\uB3C4
    \uBAA8\uB974\uAC8C \uC8FC\uC778\uB2D8\uAED8\uB9CC \uC804\uD574\uC8FC\uACE0 \uC2F6\uC5B4
    \uD569\uB2C8\uB2E4.\r\n        \uB124\uBAA8 : \uC6B0\uC640... \uAC54\uB294 \uC5EC\uD589
    \uAC00\uC11C\uB3C4 \uB0B4 \uC0DD\uAC01\uC744 \uD588\uB124.\r\n        \uD558\uB140
    : \uC8FC\uC778\uB2D8\uACFC \uB458\uB9CC\uC758 \uBE44\uBC00\uC744 \uB9CC\uB4E4\uACE0
    \uC2F6\uC740\uAC00 \uBD05\uB2C8\uB2E4.\r\n        \uB124\uBAA8 : \uC751. \uB098\uB3C4
    \uAC54 \uB9CC\uB098\uBA74 \uC904 \uAC70 \uCC3E\uC544\uBD10\uC57C\uC9C0."
