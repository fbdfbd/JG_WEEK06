  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_visitor_friend_2_blocked__step_event_week_005_visitor_friend_2_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC00\uB9AC\uC544 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor friend_2 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC9C0\uB3C4\uB97C \uD3BC\uCE58\uB824 \uD558\uC790,
      \uC5B4\uB290\uC0C8 \uB2E4\uAC00\uC628 \uACBD\uBE44\uB300\uC7A5\uC774 \uC9C0\uB3C4
      \uCF00\uC774\uC2A4\uB97C \uC7A0\uADFC\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB3C4\uB828\uB2D8, \uC9C0\uB3C4\uB294 \uB180\uC787\uAC10\uC774 \uC544\uB2D9\uB2C8\uB2E4.
      \uC678\uBD80\uC778\uC5D0\uAC8C \uC601\uC9C0 \uC9C0\uD615\uC744 \uB178\uCD9C\uD558\uB294
      \uAC83\uC740 \uC8FC\uC778\uB2D8\uC758 \uBA85\uC5D0 \uC5B4\uAE0B\uB0A9\uB2C8\uB2E4.
      \uCC3D\uBC16 \uAD6C\uACBD\uC73C\uB85C \uB9CC\uC871\uD558\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uBB34\uC548\uD574\uD558\uBA70 \uC190\uC744 \uB5C0\uB2E4) ...\uADF8\uB0E5
      \uBB3C\uACE0\uAE30 \uC0AC\uB294 \uB370\uB9CC \uCC3E\uC544\uBCF4\uB824\uACE0
      \uD55C \uAC74\uB370. \uB108\uBB34 \uAE50\uAE50\uD574\uC694."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "(\uB124\uBAA8\uC758 \uC18C\uB9E4\uB97C \uC7A1\uC73C\uBA70) \uAD1C\uCC2E\uC544,
      \uB124\uBAA8\uC57C. \uC5EC\uAE30\uC11C \uADF8\uB0E5 \uBCF4\uB294 \uAC83\uB3C4
      \uCDA9\uBD84\uD788 \uC608\uBED0. \uC544\uC800\uC528 \uD654\uB098\uAC8C \uD558\uC9C0
      \uB9D0\uC790."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uD55C\uC228\uC744 \uC26C\uBA70) \uC751, \uBBF8\uC548\uD574. \uC5EC\uAE30\uC120
      \uB9C8\uC74C\uB300\uB85C \uD560 \uC218 \uC788\uB294 \uAC8C \uBCC4\uB85C \uC5C6\uB124."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC9C0\uB3C4\uB97C \uD3BC\uCE58\uB824 \uD558\uC790,
    \uC5B4\uB290\uC0C8 \uB2E4\uAC00\uC628 \uACBD\uBE44\uB300\uC7A5\uC774 \uC9C0\uB3C4
    \uCF00\uC774\uC2A4\uB97C \uC7A0\uADFC\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
