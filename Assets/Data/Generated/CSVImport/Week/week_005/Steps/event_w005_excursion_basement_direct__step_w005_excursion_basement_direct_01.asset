  m_Name: event_w005_excursion_basement_direct__step_w005_excursion_basement_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 5\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uB2A6\uC740 \uC624\uD6C4. \uC9C0\uD558\uC2E4 \uC548\uCABD \uAE30\uB465
    \uD558\uB098\uC5D0 \uAC00\uB290\uB2E4\uB780 \uC120\uB4E4\uC774 \uC5EC\uB7EC \uAC1C
    \uB098 \uC788\uB2E4. \uC5B4\uB5A4 \uAC74 \uC5F0\uD544\uC120 \uAC19\uACE0, \uC5B4\uB5A4
    \uAC74 \uCE7C\uB05D\uC73C\uB85C \uC0B4\uC9DD \uC0C8\uAE34 \uB4EF \uC595\uB2E4.
    \uC120 \uC606\uC5D4 \uB0A0\uC9DC\uCC98\uB7FC \uBCF4\uC774\uB294 \uC791\uC740
    \uC22B\uC790\uB3C4 \uC788\uB2E4.)\n        \n        \uB124\uBAA8 : \uC5B4? \uC774\uAC74
    \uB610 \uBB50\uC57C.\n        \n        (\uB124\uBAA8\uAC00 \uAE30\uB465 \uC606\uC5D0
    \uC11C \uBCF4\uC790, \uB9E8 \uC704 \uC120 \uD558\uB098\uAC00 \uC790\uAE30 \uBA38\uB9AC
    \uB192\uC774\uC640 \uBE44\uC2B7\uD558\uB2E4.)\n        \n        \uB124\uBAA8
    : ...\uC124\uB9C8.\n        \n\n(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uC7A0\uAE50
    \uB9DD\uC124\uC774\uB2E4\uAC00, \uAE30\uB465 \uC606\uC5D0 \uC870\uC6A9\uD788
    \uC120\uB2E4.)\n        \n        \uCC3D\uACE0\uC9C0\uAE30 : \uC5EC\uC12F \uC0B4\uBD80\uD130
    \uC801\uC5B4 \uB454 \uAC81\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : ...\uB0B4
    \uD0A4?\n        \n        \uCC3D\uACE0\uC9C0\uAE30 : \uC608. \uC8FC\uC778\uB2D8\uC774
    \uC9C0\uD558\uC2E4\uC5D0 \uC62C \uB54C\uB9C8\uB2E4, \uBC31\uC791\uB2D8\uAED8\uC11C
    \uBAB0\uB798 \uD45C\uC2DC\uD574 \uB450\uB77C\uACE0 \uD558\uC168\uB2F5\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uB0B4\uAC00 \uBAA8\uB974\uAC8C?\n        \n       
    \uCC3D\uACE0\uC9C0\uAE30 : \uC608. \uB108\uBB34 \uB300\uB193\uACE0 \uC7AC\uBA74
    \uC2EB\uC5B4\uD558\uC2E4\uAE4C \uBD10\uC694.\n        \n        \uB124\uBAA8
    : \uC65C? \uC0C1\uAD00 \uC5C6\uB294\uB370 \u314E\u314E"
