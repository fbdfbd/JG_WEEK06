  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w005_visitor_friend_2_blocked__step_w005_visitor_friend_2_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 5\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uCE5C\uAD6C 2\uAC00 \uC11C\uC7AC \uCC3D\uAC00\uC5D0 \uC11C\uC11C
    \uBC16\uC744 \uBA4D\uD558\uB2C8 \uBC14\uB77C\uBCF4\uACE0 \uC788\uB2E4. \uB124\uBAA8\uAC00
    \uADF8 \uC606\uC73C\uB85C \uB2E4\uAC00\uAC00 \uAC19\uC774 \uCC3D\uBC16 \uC601\uC9C0\uB97C
    \uB0B4\uB824\uB2E4\uBCF8\uB2E4.)\n        \n        \uCE5C\uAD6C 2 : \uC800\uAE30
    \uBA40\uB9AC \uBCF4\uC774\uB294 \uD638\uC218 \uB9D0\uC774\uC57C... \uAC70\uAE30
    \uC9C4\uC9DC \uC804\uC124\uC758 \uBB3C\uACE0\uAE30\uAC00 \uC0B4\uC544? \uC6B0\uB9AC
    \uC544\uBE60\uAC00 \uC61B\uB0A0 \uCC45\uC5D0\uC11C \uBD24\uB300.\n        \uB124\uBAA8
    : \uC804\uC124\uC758 \uBB3C\uACE0\uAE30? \uB098\uB3C4 \uC544\uC9C1 \uBABB \uBD24\uB294\uB370.
    \uC6B0\uB9AC \uBC31\uC791\uB2D8 \uC9C0\uB3C4\uC5D0\uC11C \uD55C\uBC88 \uCC3E\uC544\uBCFC\uAE4C?\n       
    \uCE5C\uAD6C 2 : (\uB9DD\uC124\uC774\uBA70) \uADF8\uB798\uB3C4 \uB3FC? \uBC31\uC791\uB2D8
    \uD5C8\uB77D \uC5C6\uC774 \uC9C0\uB3C4\uB97C \uBD10\uB3C4...\n        \n\n(\uB124\uBAA8\uAC00
    \uC9C0\uB3C4\uB97C \uD3BC\uCE58\uB824 \uD558\uC790, \uC5B4\uB290\uC0C8 \uB2E4\uAC00\uC628
    \uACBD\uBE44\uB300\uC7A5\uC774 \uC9C0\uB3C4 \uCF00\uC774\uC2A4\uB97C \uC7A0\uADFC\uB2E4.)\n       
    \uACBD\uBE44\uB300\uC7A5 : \uB3C4\uB828\uB2D8, \uC9C0\uB3C4\uB294 \uB180\uC787\uAC10\uC774
    \uC544\uB2D9\uB2C8\uB2E4. \uC678\uBD80\uC778\uC5D0\uAC8C \uC601\uC9C0 \uC9C0\uD615\uC744
    \uB178\uCD9C\uD558\uB294 \uAC83\uC740 \uC8FC\uC778\uB2D8\uC758 \uBA85\uC5D0 \uC5B4\uAE0B\uB0A9\uB2C8\uB2E4.
    \uCC3D\uBC16 \uAD6C\uACBD\uC73C\uB85C \uB9CC\uC871\uD558\uC2ED\uC2DC\uC624.\n       
    \uB124\uBAA8 : (\uBB34\uC548\uD574\uD558\uBA70 \uC190\uC744 \uB5C0\uB2E4) ...\uADF8\uB0E5
    \uBB3C\uACE0\uAE30 \uC0AC\uB294 \uB370\uB9CC \uCC3E\uC544\uBCF4\uB824\uACE0 \uD55C
    \uAC74\uB370. \uB108\uBB34 \uAE50\uAE50\uD574\uC694.\n        \uCE5C\uAD6C 2
    : (\uB124\uBAA8\uC758 \uC18C\uB9E4\uB97C \uC7A1\uC73C\uBA70) \uAD1C\uCC2E\uC544,
    \uB124\uBAA8\uC57C. \uC5EC\uAE30\uC11C \uADF8\uB0E5 \uBCF4\uB294 \uAC83\uB3C4
    \uCDA9\uBD84\uD788 \uC608\uBED0. \uC544\uC800\uC528 \uD654\uB098\uAC8C \uD558\uC9C0
    \uB9D0\uC790.\n        \uB124\uBAA8 : (\uD55C\uC228\uC744 \uC26C\uBA70) \uC751,
    \uBBF8\uC548\uD574. \uC5EC\uAE30\uC120 \uB9C8\uC74C\uB300\uB85C \uD560 \uC218
    \uC788\uB294 \uAC8C \uBCC4\uB85C \uC5C6\uB124."
