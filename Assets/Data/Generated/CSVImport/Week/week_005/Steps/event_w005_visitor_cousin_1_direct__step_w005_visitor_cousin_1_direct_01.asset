  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w005_visitor_cousin_1_direct__step_w005_visitor_cousin_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 5\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uC0AC\uCD0C 1\uC774 \uC11C\uC7AC \uCC3D\uBB38\uC744 \uD65C\uC9DD
    \uC5F4\uACE0 \uBC16\uC744 \uB0B4\uB2E4\uBCF4\uBA70 \uB124\uBAA8\uB97C \uBD80\uB978\uB2E4.
    \uBC31\uC791\uC740 \uD56D\uC0C1 \uD658\uAE30\uD560 \uB54C\uB9CC \uBB38\uC744
    \uC5F4\uC9C0\uB9CC, \uC0AC\uCD0C 1\uC740 \uBC14\uB78C \uADF8 \uC790\uCCB4\uB97C
    \uC990\uAE34\uB2E4.)\r\n        \r\n        \uC0AC\uCD0C 1 : \uB124\uBAA8\uC57C,
    \uC774\uCABD\uC73C\uB85C \uC640\uBD10. \uC5EC\uAE30\uC11C \uBCF4\uBA74 \uC800
    \uBA40\uB9AC \uC131\uBB38 \uBC16 \uC2DC\uC7A5\uC774 \uBCF4\uC774\uC9C0? \uC800\uAE30\uC11C
    \uD30C\uB294 \uC591\uAF2C\uCE58 \uB0C4\uC0C8\uAC00 \uC5EC\uAE30\uAE4C\uC9C0 \uB098\uB294
    \uAC83 \uAC19\uC9C0 \uC54A\uB0D0?\r\n        \uB124\uBAA8 : (\uCC3D\uAC00\uB85C
    \uB2E4\uAC00\uAC00 \uCF54\uB97C \uD081\uD081\uB300\uBA70) \uC9C4\uC9DC\uC694?
    \uC804 \uADF8\uB0E5 \uD480 \uB0C4\uC0C8\uBC16\uC5D0 \uC548 \uB098\uB294\uB370...\r\n       
    \uC0AC\uCD0C 1 : \uC0C1\uC0C1\uB825\uC744 \uBC1C\uD718\uD574\uBD10! \uC800\uAE30
    \uC0AC\uB78C \uBD81\uC801\uC774\uB294 \uC18C\uB9AC, \uB9D0 \uC6B8\uC74C\uC18C\uB9AC...
    \uBC31\uC791\uB2D8\uC740 \uC65C \uC774\uB7F0 \uBA85\uB2F9\uC744 \uB450\uACE0
    \uB9E8\uB0A0 \uC11C\uB958\uB9CC \uBCF4\uC2DC\uB294\uC9C0 \uBAB0\uB77C.\r\n       
    \r\n\r\n(\uB124\uBAA8\uAC00 \uCC3D\uD2C0\uC5D0 \uD131\uC744 \uAD34\uACE0 \uC0BC\uCD0C\uC758
    \uC774\uC57C\uAE30\uB97C \uB4E3\uB294\uB2E4.)\r\n        \uB124\uBAA8 : \uC0BC\uCD0C\uC740
    \uC800\uAE30 \uB098\uAC00\uBA74 \uBB50\uBD80\uD130 \uD574\uC694? \uC9C4\uC9DC
    \uC591\uAF2C\uCE58\uBD80\uD130 \uBA39\uC5B4\uC694?\r\n        \uC0AC\uCD0C 1
    : \uADF8\uB7FC! \uC2DC\uC6D0\uD55C \uD3EC\uB3C4 \uC8FC\uC2A4 \uD55C \uC794 \uB4E4\uC774\uCF1C\uACE0,
    \uAD11\uC7A5\uC5D0\uC11C \uCDA4\uCD94\uB294 \uC0AC\uB78C\uB4E4 \uAD6C\uACBD\uB3C4
    \uD558\uACE0... \uC5B4\uB54C, \uC0C1\uC0C1\uB9CC \uD574\uB3C4 \uADFC\uC0AC\uD558\uC9C0?\r\n       
    \uB124\uBAA8 : (\uB208\uC744 \uAC10\uC73C\uBA70) \uB124... \uBC31\uC791\uB2D8\uC774
    \uB4E4\uB824\uC8FC\uC2DC\uB294 \uC5ED\uC0AC \uC774\uC57C\uAE30\uBCF4\uB2E4 \uC0BC\uCD0C\uC774
    \uD574\uC8FC\uB294 \uC2DC\uC7A5 \uC774\uC57C\uAE30\uAC00 \uD6E8\uC52C \uC0DD\uC0DD\uD574\uC11C
    \uC88B\uC544\uC694. \uB098\uC911\uC5D0 \uAF2D \uAC19\uC774 \uAC00\uC694!"
