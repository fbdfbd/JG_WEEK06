  m_Name: event_w005_letter_cousin_2_direct__step_w005_letter_cousin_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 \uD3B8\uC9C0 5\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C
    \uC548\uC5D0\uC11C \uB531\uB531\uD558\uACE0 \uC791\uC740 \uBB34\uC5B8\uAC00\uAC00
    \uB9CC\uC838\uC9C0\uB294 \uB290\uB08C\uC774\uB2E4.)\r\n    \uD558\uB140 : \uC8FC\uC778\uB2D8
    \uC55E\uC73C\uB85C \uC628 \uD3B8\uC9C0\uC785\uB2C8\uB2E4. \uC774\uBC88\uC5D4
    \uD3B8\uC9C0 \uB9D0\uACE0 \uB2E4\uB978 \uAC83\uB3C4 \uB4E4\uC5B4\uC788\uB294
    \uAC83 \uAC19\uB124\uC694.\r\n        \r\n\r\n\uD558\uB140 : \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uC774
    \uC5EC\uD589 \uC911\uC5D0 \uD3B8\uC9C0\uB97C \uBCF4\uB0B4\uC168\uC5B4\uC694.
    \uC120\uBB3C \uC608\uACE0\uB3C4 \uC801\uD600 \uC788\uB124\uC694.\r\n        \uB124\uBAA8
    : \uC120\uBB3C? \uBB54\uB370? \uBE68\uB9AC \uC77D\uC5B4 \uC918.\r\n        (\uD558\uB140\uAC00
    \uBD09\uD22C\uB97C \uD3BC\uCE5C\uB2E4.)\r\n        \uB124\uBAA8 \uC548\uB155.
    \uC774\uBC88\uC5D0 \uC544\uBE60 \uB530\uB77C\uC11C \uBA40\uB9AC \uBC14\uB2E4\uC5D0
    \uC654\uB294\uB370, \uAC70\uAE30\uC11C \uC544\uC8FC \uC608\uC05C \uC870\uAC1C\uAECD\uB370\uAE30\uB97C
    \uC8FC\uC6E0\uC5B4. \uC774\uAC74 \uB0B4 \uBCF4\uBB3C\uC778\uB370 \uB108 \uC904\uAC8C.
    \uB2E4\uC74C\uBC88\uC5D0 \uB9CC\uB0A0 \uB54C \uACBD\uBE44\uB300\uC7A5 \uC544\uC800\uC528
    \uBAB0\uB798 \uB124 \uC8FC\uBA38\uB2C8\uC5D0 \uC3D9 \uB123\uC5B4\uC904\uAC8C.
    \uC783\uC5B4\uBC84\uB9AC\uBA74 \uC548 \uB3FC!\r\n        \uB124\uBAA8 : \uC870\uAC1C\uAECD\uB370\uAE30?
    \uBC14\uB2E4\uC5D0\uC11C \uC628 \uAC70\uC57C?\r\n        \uD558\uB140 : \uB124.
    \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uC774 \uC544\uC8FC \uC18C\uC911\uD558\uAC8C \uCC59\uACA8\uB450\uC2E0
    \uBAA8\uC591\uC785\uB2C8\uB2E4.\r\n        \uB124\uBAA8 : \uBAB0\uB798 \uC8FC\uBA38\uB2C8\uC5D0
    \uB123\uC5B4\uC900\uB300. \uC228\uBC14\uAF2D\uC9C8\uD558\uB294 \uAC83 \uAC19\uC544\uC11C
    \uC7AC\uBC0C\uACA0\uB2E4!"
