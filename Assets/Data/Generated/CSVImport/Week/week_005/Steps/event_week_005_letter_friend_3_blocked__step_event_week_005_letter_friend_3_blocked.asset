  _titleOverride: "\uC720\uD53C \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "letter friend_3 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uB294 \uC9C0\uC800\uBD84\uD55C \uC789\uD06C \uC790\uAD6D\uC744
      \uBCF4\uACE0 \uD600\uB97C \uCC28\uBA70 \uC138\uD0C1\uC2E4 \uBC14\uAD6C\uB2C8
      \uC544\uB798\uC5D0 \uD3B8\uC9C0\uB97C \uC228\uAE34\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uCC45\uC0C1 \uC704\uC5D0 \uB193\uC778 \uC789\uD06C
      \uBCD1\uC744 \uD754\uB4E4\uC5B4\uBCF4\uBA70 \uC2EC\uC2EC\uD574\uD558\uACE0
      \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\u2026\u2026\uB35C\uB801\uAC70\uB9AC\uB294 \uCE5C\uAD6C\uC758 \uC2B5\uAD00\uC774
      \uC62E\uC73C\uBA74 \uACE4\uB780\uD558\uB2C8\uAE4C\uC694."
  _nemoLine: "(\uD558\uB140\uB294 \uC9C0\uC800\uBD84\uD55C \uC789\uD06C \uC790\uAD6D\uC744
    \uBCF4\uACE0 \uD600\uB97C \uCC28\uBA70 \uC138\uD0C1\uC2E4 \uBC14\uAD6C\uB2C8
