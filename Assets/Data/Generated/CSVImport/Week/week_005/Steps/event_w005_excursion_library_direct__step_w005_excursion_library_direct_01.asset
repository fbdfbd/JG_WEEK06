  m_Name: event_w005_excursion_library_direct__step_w005_excursion_library_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 5\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uB124\uBAA8\uAC00 \uCCA0\uD559 \uCC45\uC744 \uC77D\uB2E4\uAC00 \uD55C
    \uD398\uC774\uC9C0\uC5D0\uC11C \uBA48\uCD98\uB2E4. \uB09C\uD574\uD55C \uBB38\uC7A5
    \uC606 \uC5EC\uBC31\uC5D0 \uC544\uC8FC \uC791\uACE0 \uC815\uAC08\uD55C \uD544\uCCB4\uB85C
    \uC8FC\uC11D\uC774 \uB2EC\uB7EC \uC788\uB2E4.)\n        \n        \uB124\uBAA8
    : \uC774 \uAE00\uC528... \uBC31\uC791\uB2D8 \uAE00\uC528\uC796\uC544.\n       
    (\uC190\uAC00\uB77D\uC73C\uB85C \uAE00\uC528\uB97C \uB530\uB77C\uAC04\uB2E4.
    '\uC774 \uAD6C\uC808\uC740 \uB108\uBB34 \uBE44\uAD00\uC801\uC774\uB2C8 \uBB34\uC2DC\uD574\uB3C4
    \uC88B\uB2E4'\uB77C\uACE0 \uC801\uD600 \uC788\uB2E4.)\n        \n        \uB124\uBAA8
    : \uB098 \uC77D\uC73C\uB77C\uACE0 \uC801\uC5B4\uB454 \uAC74\uAC00? \uC544\uB2C8\uBA74
    \uD63C\uC790 \uC77D\uB2E4 \uC801\uC73C\uC2E0 \uAC74\uAC00.\n        (\uB2E4\uC74C
    \uD398\uC774\uC9C0\uB97C \uB118\uAE30\uC790 '\uB124\uAC00 \uC774\uD574\uD558\uAE30\uC5D4
    \uC774 \uB2E8\uC5B4\uAC00 \uB354 \uC801\uC808\uD558\uACA0\uC9C0'\uB77C\uBA70
    \uC26C\uC6B4 \uB2E8\uC5B4\uAC00 \uC801\uD600 \uC788\uB2E4.)\n        \n\n(\uB124\uBAA8\uAC00
    \uC8FC\uC11D \uC606\uC5D0 \uC790\uAE30 \uC0DD\uAC01\uC744 \uC791\uAC8C \uB367\uBD99\uC5EC
    \uC801\uB294\uB2E4.)\n        \uB124\uBAA8 : '\uC800\uB294 \uC774 \uAD6C\uC808\uC774
    \uC624\uD788\uB824 \uC704\uB85C\uAC00 \uB418\uB294\uB370\uC694?'\n        (\uC606\uC5D0\uC11C
    \uC9C0\uCF1C\uBCF4\uB358 \uC0AC\uC11C\uAC00 \uC870\uC6A9\uD788 \uBBF8\uC18C \uC9D3\uB294\uB2E4.)\n       
    \uC0AC\uC11C : \uC8FC\uC778\uB2D8\uAED8\uC11C \uB098\uC911\uC5D0 \uC774 \uCC45\uC744
    \uB2E4\uC2DC \uD3BC\uCCD0\uBCF4\uC2DC\uBA74 \uBB34\uCC99 \uB180\uB77C\uC2DC\uACA0\uAD70\uC694.\n       
    \uB124\uBAA8 : \uB180\uB77C\uB77C\uACE0 \uC801\uB294 \uAC70\uC608\uC694. \uB098\uB3C4
    \uB0B4 \uC0DD\uAC01\uC774 \uC788\uB2E4\uB294 \uAC78 \uBCF4\uC5EC\uC918\uC57C\uC9C0.\n       
    \uB124\uBAA8 : (\uC791\uAC8C \uC911\uC5BC\uAC70\uB9AC\uBA70) ...\uB2F5\uC7A5
    \uC368\uC8FC\uC2DC\uBA74 \uB354 \uC88B\uACE0."
