  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_excursion_study_blocked__step_event_week_005_excursion_study_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC11C\uC7AC \uD1B5\uC81C"
  _bodyText: "excursion study Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC9D1\uC0AC\uAC00 \uCC28\uB97C \uB0B4\uC624\uBA70 \uC561\uC790\uB97C
      \uB2E4\uC2DC \uC815\uBC29\uD5A5\uC73C\uB85C \uB3CC\uB824\uB193\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uAED8\uC11C \uC774 \uC561\uC790\uC758 \uAC01\uB3C4\uAC00
      1\uB3C4\uB77C\uB3C4 \uD2C0\uC5B4\uC9C0\uB294 \uAC83\uC744 \uC6D0\uCE58 \uC54A\uC73C\uC2ED\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC70 \uADF8\uB0E5 \uB099\uC11C\uC796\uC544\uC694! \uC190\uB2D8\uC774\uB77C\uB3C4
      \uC624\uBA74 \uC5B4\uB5A1\uD574\uC694?"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uAED8\uC120 \"\uC774\uAC83\uC774 \uC774 \uBC29\uC5D0\uC11C
      \uAC00\uC7A5 \uAC00\uCE58 \uC788\uB294 \uBB38\uC11C\uB2E4\"\uB77C\uACE0 \uB9D0\uC500\uD558\uC168\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC5BC\uAD74\uC744 \uAC10\uC2F8\uBA70) \uC544... \uC81C\uBC1C... \uB9C8\uC74C\uB300\uB85C
      \uD558\uB294 \uAC83\uB3C4 \uC815\uB3C4\uAC00 \uC788\uC9C0."
  _nemoLine: "(\uC9D1\uC0AC\uAC00 \uCC28\uB97C \uB0B4\uC624\uBA70 \uC561\uC790\uB97C
    \uB2E4\uC2DC \uC815\uBC29\uD5A5\uC73C\uB85C \uB3CC\uB824\uB193\uB294\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
