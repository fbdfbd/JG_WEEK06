--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_engineering_modified__step_event_week_005_engineering_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC640\uC8FC\uB294 \uC21C\uC11C\uB85C \uBD80\uD488\uC744
    \uBCF8\uB2E4"
  _bodyText: "\uC7A5\uCE58 \uC124\uACC4\uC640 \uAE30\uCD08 \uACF5\uD559 5\uC8FC\uCC28
    Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC791\uC5C5\uB300 \uC704\uC5D0 \uC791\uC740 \uD1B1\uB2C8\uBC14\uD034,
      \uCD95, \uB098\uBB34 \uD310\uC774 \uB193\uC5EC \uC788\uB2E4. \uD558\uB140\uAC00
      \uD0DC\uC5FD \uC7A5\uCE58\uB97C \uD55C\uBC88 \uAC10\uC544 \uBCF4\uC774\uBA70
      \uC6C0\uC9C1\uC784\uC744 \uBCF4\uC5EC \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uD070 \uC7A5\uCE58\uB97C \uBCF4\uB294
      \uB300\uC2E0, \uC791\uC740 \uBD80\uD488\uC774 \uC5B4\uB5BB\uAC8C \uC774\uC5B4\uC9C0\uB294\uC9C0
      \uBCFC \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610 \uC22B\uC790 \uB9CE\uC544?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC624\uB298\uC740 \uC190\uC73C\uB85C \uBA3C\uC800 \uBD05\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uBD80\uD488\uB4E4\uC744 \uC0C9\uAE54\uBCC4\uB85C
      \uB098\uB220 \uB193\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC624\uB298\uC740 \uC870\uB9BD\uD55C\uB2E4\uACE0 \uC0DD\uAC01\uD558\uC9C0
      \uB9D0\uACE0, \uC11C\uB85C \uB3C4\uC640\uC8FC\uB294 \uC21C\uC11C\uB97C \uCC3E\uB294\uB2E4\uACE0
      \uC0DD\uAC01\uD574 \uBCF4\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB3C4\uC640\uC8FC\uB294 \uC21C\uC11C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uBA3C\uC800 \uB3C4\uB294 \uAC83, \uB530\uB77C \uB3C4\uB294 \uAC83,
      \uB9C8\uC9C0\uB9C9\uC5D0 \uC6C0\uC9C1\uC774\uB294 \uAC83\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\uADF8\uB807\uAC8C \uD558\uB2C8\uAE4C \uD6E8\uC52C \uBCF4\uAE30
      \uC27D\uB2E4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8\uB798\uC11C \uC7A5\uCE58\uB3C4 \uACB0\uAD6D \uD750\uB984\uC774
      \uC911\uC694\uD558\uB2F5\uB2C8\uB2E4."
  _nemoLine: "(\uC791\uC5C5\uB300 \uC704\uC5D0 \uC791\uC740 \uD1B1\uB2C8\uBC14\uD034,
    \uCD95, \uB098\uBB34 \uD310\uC774 \uB193\uC5EC \uC788\uB2E4. \uD558\uB140\uAC00
    \uD0DC\uC5FD \uC7A5\uCE58\uB97C \uD55C\uBC88 \uAC10\uC544 \uBCF4\uC774\uBA70
    \uC6C0\uC9C1\uC784\uC744 \uBCF4\uC5EC \uC900\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
