  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_visitor_cousin_2_direct__step_event_week_005_visitor_cousin_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9AC\uC548 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor cousin_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC9C0\uB3C4 \uC704\uC5D0 \uC791\uC740 \uC885\uC774\uBC30
      \uD558\uB098\uB97C \uC811\uC5B4 \uC62C\uB824\uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBD10\uBD10, \uC774\uAC8C \uC6B0\uB9AC\uC57C. \uC9C0\uAE08\uC740 \uC774
      \uC791\uC740 \uC11C\uC7AC\uC5D0 \uC788\uC9C0\uB9CC, \uC5B8\uC820\uAC00\uB294
      \uC774 \uC885\uC774\uBC30\uCC98\uB7FC \uBA40\uB9AC \uAC08 \uC218 \uC788\uC5B4."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "(\uC885\uC774\uBC30\uB97C \uBCF4\uBA70 \uC0B4\uC9DD \uBBF8\uC18C \uC9D3\uB294\uB2E4)
      \uB124\uBAA8 \uB124\uAC00 \uC788\uC73C\uBA74... \uB098\uB3C4 \uC870\uAE08\uC740
      \uC6A9\uAE30\uAC00 \uC0DD\uAE30\uB294 \uAC83 \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uCE58? \uBC31\uC791\uB2D8\uB3C4 \uC6B0\uB9AC\uAC00 \uC0AC\uC774\uC88B\uAC8C
      \uC9C0\uB0B4\uB294 \uAC74 \uC88B\uC544\uD558\uC2E4 \uAC70\uC57C. \uC544\uB9C8\uB3C4."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC9C0\uB3C4 \uC704\uC5D0 \uC791\uC740 \uC885\uC774\uBC30
    \uD558\uB098\uB97C \uC811\uC5B4 \uC62C\uB824\uB454\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
