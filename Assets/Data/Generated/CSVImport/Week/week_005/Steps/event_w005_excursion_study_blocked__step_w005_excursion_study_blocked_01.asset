  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w005_excursion_study_blocked__step_w005_excursion_study_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC 5\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uBC31\uC791\uC758 \uCC45\uC0C1 \uC704, \uAC00\uC7A5 \uC911\uC694\uD55C
    \uC9C1\uC778\uD568 \uC606\uC5D0 \uB0A1\uC740 \uC561\uC790 \uD558\uB098\uAC00
    \uB193\uC5EC \uC788\uB2E4. \uB124\uBAA8\uAC00 \uB2E4\uAC00\uAC00 \uBCF4\uB2C8,
    6\uC0B4 \uB54C \uC11C\uD234\uAC8C \uADF8\uB9B0 \uBC31\uC791\uC758 \uC5BC\uAD74\uACFC
    '\uC544\uC800\uC528 \uBC14\uBCF4'\uB77C\uACE0 \uC801\uD78C \uB099\uC11C \uC11C\uB958\uAC00
    \uC18C\uC911\uD558\uAC8C \uB07C\uC6CC\uC838 \uC788\uB2E4.)\r\n        \r\n       
    \uB124\uBAA8 : \uC73C\uC545, \uC774\uAC8C \uC65C \uC544\uC9C1\uB3C4 \uC5EC\uAE30
    \uC788\uC5B4!\r\n        (\uC5BC\uAD74\uC774 \uD654\uB048\uAC70\uB9AC\uB294\uC9C0
    \uB124\uBAA8\uAC00 \uC561\uC790\uB97C \uB4A4\uB85C \uB3CC\uB824\uB193\uC73C\uB824
    \uD558\uC9C0\uB9CC, \uC561\uC790\uB294 \uCC45\uC0C1 \uBC14\uB2E5\uC5D0 \uB2E8\uB2E8\uD788
    \uACE0\uC815\uB418\uC5B4 \uC788\uB2E4.)\r\n        \r\n        \uB124\uBAA8 :
    \uC9C4\uC9DC \uBABB \uB9D0\uB824. \uC774\uB7F0 \uCC3D\uD53C\uD55C \uAC78 \uC7A5\uC2DD\uD574
    \uB450\uB2E4\uB2C8.\r\n        \r\n\r\n(\uC9D1\uC0AC\uAC00 \uCC28\uB97C \uB0B4\uC624\uBA70
    \uC561\uC790\uB97C \uB2E4\uC2DC \uC815\uBC29\uD5A5\uC73C\uB85C \uB3CC\uB824\uB193\uB294\uB2E4.)\r\n       
    \uC9D1\uC0AC : \uC8FC\uC778\uB2D8\uAED8\uC11C \uC774 \uC561\uC790\uC758 \uAC01\uB3C4\uAC00
    1\uB3C4\uB77C\uB3C4 \uD2C0\uC5B4\uC9C0\uB294 \uAC83\uC744 \uC6D0\uCE58 \uC54A\uC73C\uC2ED\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : \uC774\uAC70 \uADF8\uB0E5 \uB099\uC11C\uC796\uC544\uC694! \uC190\uB2D8\uC774\uB77C\uB3C4
    \uC624\uBA74 \uC5B4\uB5A1\uD574\uC694?\r\n        \uC9D1\uC0AC : \uC8FC\uC778\uB2D8\uAED8\uC120
    \"\uC774\uAC83\uC774 \uC774 \uBC29\uC5D0\uC11C \uAC00\uC7A5 \uAC00\uCE58 \uC788\uB294
    \uBB38\uC11C\uB2E4\"\uB77C\uACE0 \uB9D0\uC500\uD558\uC168\uC2B5\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : (\uC5BC\uAD74\uC744 \uAC10\uC2F8\uBA70) \uC544... \uC81C\uBC1C...
    \uB9C8\uC74C\uB300\uB85C \uD558\uB294 \uAC83\uB3C4 \uC815\uB3C4\uAC00 \uC788\uC9C0."
