  _titleOverride: "\uBCC4\uC790\uB9AC\uC640 \uB2EC\uC758 \uD750\uB984\uC744 \uAC00\uB974\uCE5C\uB2E4"
  _bodyText: "\uBCC4\uC790\uB9AC\uC640 \uB2EC\uC758 \uD750\uB984\uC744 \uAC00\uB974\uCE5C\uB2E4
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBCC4\uC790\uB9AC \uADF8\uB9BC\uACFC \uB2EC\uC758 \uCC28\uC624\uB984\uC744
      \uC9DA\uC73C\uBA70 \uD558\uB298\uC758 \uADDC\uCE59\uC744 \uCC28\uADFC\uCC28\uADFC
      \uC124\uBA85\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4\uC81C \uBCF8 \uBCC4\uC774 \uC5EC\uAE30\uC5D0\uB3C4 \uC788\uC5B4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uD558\uB298\uC744 \uC62C\uB824\uB2E4\uBCF8 \uAE30\uC5B5\uACFC \uCC45\uC758
      \uADF8\uB9BC\uC744 \uB9DE\uCDB0 \uBCF4\uAC8C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uC74C\uC5D4 \uC81C\uAC00 \uBA3C\uC800 \uCC3E\uC544\uBCFC\uB798\uC694."
  _nemoLine: "(\uBCC4\uC790\uB9AC \uADF8\uB9BC\uACFC \uB2EC\uC758 \uCC28\uC624\uB984\uC744
    \uC9DA\uC73C\uBA70 \uD558\uB298\uC758 \uADDC\uCE59\uC744 \uCC28\uADFC\uCC28\uADFC
    \uC124\uBA85\uD55C\uB2E4.)"
