%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_excursion_garden_direct__step_event_week_005_excursion_garden_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: garden Direct
  _bodyText: "excursion garden Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140 \uB458\uC774 \uC11C\uB85C \uB208\uCE58\uB97C \uBCF4\uB2E4\uAC00,
      \uACB0\uAD6D \uD55C \uBA85\uC774 \uC870\uC2EC\uC2A4\uB7FD\uAC8C \uC785\uC744
      \uC5F0\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB9E4\uC77C \uAC19\uC740 \uC2DC\uAC04\uC5D0 \uBA39\uC774\uB97C \uB450\uAC8C
      \uD558\uC2E0 \uBD84\uC774 \uACC4\uC2ED\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB204\uAC00?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\u2026\u2026\uBC31\uC791\uB2D8\uC774\uC2ED\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC31\uC791\uB2D8\uC774?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8 \uCC3D\uAC00 \uADFC\uCC98\uB85C \uC0C8\uAC00 \uC790\uC8FC
      \uC624\uBA74, \uC8FC\uC778\uB2D8\uAED8\uC11C \uC88B\uC544\uD558\uC2E4 \uAC70\uB77C\uACE0
      \uD558\uC154\uC11C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uADF8\uB798\uC11C \uC598\uAC00 \uB098 \uC548 \uBB34\uC11C\uC6CC\uD574?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC774 \uC790\uB9AC\uB3C4, \uC2DC\uAC04\uB3C4, \uB2E4 \uB9DE\uCDB0
      \uB450\uC168\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uC57C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uC880\u2026 \uB108\uBB34 \uC798\uD574 \uB480\uB294\uB370."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC2EB\uC73C\uC168\uC2B5\uB2C8\uAE4C?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544\uB2C8. \uC2EB\uC9C4 \uC54A\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC0B0\uC0C8\uAC00 \uB124\uBAA8 \uCABD\uC73C\uB85C \uD55C \uAC78\uC74C
      \uB354 \uB2E4\uAC00\uC628\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\uC9C4\uC9DC\uC600\uB124. \uB098 \uB54C\uBB38\uC5D0 \uAE38\uB4E4\uC778
      \uAC70\uC796\uC544."
  _nemoLine: "(\uD558\uB140 \uB458\uC774 \uC11C\uB85C \uB208\uCE58\uB97C \uBCF4\uB2E4\uAC00,
    \uACB0\uAD6D \uD55C \uBA85\uC774 \uC870\uC2EC\uC2A4\uB7FD\uAC8C \uC785\uC744
    \uC5F0\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
