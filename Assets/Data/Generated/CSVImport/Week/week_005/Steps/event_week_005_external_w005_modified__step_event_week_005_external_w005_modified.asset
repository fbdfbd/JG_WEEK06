  _titleOverride: "\uADF8\uB9BC\uC790 \uAE30\uC0AC \uC18C\uBB38 \uC218\uC815"
  _bodyText: "external w005 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: bb92d18cb19ba9944ac71077eb8aa4c5, type: 2}
    _text: "\uC0AC\uC2E4\uC740 \uC601\uC8FC\uB2D8\uC774 \uB9C8\uC744 \uCD95\uC81C\uB97C
      \uD558\uB824\uACE0 \uBAB0\uB798 \uC120\uBB3C\uC744 \uC900\uBE44\uD558\uC2E0
      \uAC70\uB798\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC120\uBB3C\uC744 \uBAB0\uB798 \uC918?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uAE5C\uC9DD \uB180\uB77C\uAC8C \uD574\uC8FC\uB824\uACE0 \uB3C4\uB451\uB9DE\uC740
      \uCC99 \uC5F0\uAE30\uB97C \uD558\uC2E0 \uBAA8\uC591\uC774\uC5D0\uC694. \uCC38
      \uB2E4\uC815\uD55C \uBD84\uC774\uC8E0?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544, \uADF8\uB7FC \uADF8\uB9BC\uC790 \uAE30\uC0AC\uB294 \uADF8\uB0E5
      \uC601\uC8FC\uB2D8\uC774 \uBCC0\uC7A5\uD55C \uAC70\uAD6C\uB098!"
  _nemoLine: "\uC0AC\uC2E4\uC740 \uC601\uC8FC\uB2D8\uC774 \uB9C8\uC744 \uCD95\uC81C\uB97C
    \uD558\uB824\uACE0 \uBAB0\uB798 \uC120\uBB3C\uC744 \uC900\uBE44\uD558\uC2E0 \uAC70\uB798\uC694."
