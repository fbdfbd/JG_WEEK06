  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w005_excursion_garden_direct__step_w005_excursion_garden_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 5\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uB9D1\uC740 \uC624\uC804. \uB124\uBAA8\uAC00 \uC815\uC6D0 \uAC00\uC7A5\uC790\uB9AC
    \uBCA4\uCE58\uC5D0 \uC549\uC544 \uCC45\uC7A5\uC744 \uB118\uAE30\uACE0 \uC788\uB2E4.
    \uADF8\uB54C \uC791\uC740 \uC0B0\uC0C8 \uD55C \uB9C8\uB9AC\uAC00 \uB09C\uAC04\uC5D0
    \uB0B4\uB824\uC549\uB294\uB2E4.)\r\n        \r\n        \uB124\uBAA8 : \uC5B4?\r\n       
    \r\n        \uB124\uBAA8 : \uB108 \uB610 \uC654\uB124.\r\n        \r\n       
    (\uC0C8\uB294 \uC804\uD600 \uAC81\uB0B4\uC9C0 \uC54A\uACE0 \uACE0\uAC1C\uB97C
    \uAC38\uC6C3\uD55C\uB2E4. \uB124\uBAA8\uAC00 \uC190\uC744 \uC870\uAE08 \uB0B4\uBC00\uC790,
    \uC0B0\uC0C8\uB294 \uC624\uD788\uB824 \uB354 \uAC00\uAE4C\uC774 \uB2E4\uAC00\uC628\uB2E4.)\r\n       
    \r\n        \uB124\uBAA8 : \uBB50\uC57C.\r\n        \r\n        \uB124\uBAA8
    : \uB108 \uC0AC\uB78C \uC548 \uBB34\uC11C\uC6CC\uD574?\r\n        \r\n       
    (\uADF8 \uC21C\uAC04, \uB4A4\uCABD\uC5D0\uC11C \uD558\uB140 \uD558\uB098\uAC00
    \uB180\uB780 \uB4EF \uBA48\uCE6B\uD55C\uB2E4. \uB2E4\uB978 \uD558\uB140\uAC00
    \uAE09\uD788 \uC791\uC740 \uACE1\uC2DD \uC8FC\uBA38\uB2C8\uB97C \uAC10\uCD98\uB2E4.)\r\n       
    \r\n        \uB124\uBAA8 : \u2026\uC65C \uADF8\uB798?\r\n        \r\n       
    \uD558\uB140 : \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.\r\n        \r\n       
    (\uB124\uBAA8\uAC00 \uBCA4\uCE58 \uC544\uB798\uB97C \uBCF4\uB2C8, \uAC19\uC740
    \uC790\uB9AC\uC5D0 \uACE1\uC2DD \uBA87 \uC54C\uC774 \uC544\uC8FC \uAC00\uC9C0\uB7F0\uD788
    \uB193\uC5EC \uC788\uB2E4.)\r\n        \r\n        \uB124\uBAA8 : \uC774\uAC70
    \uB204\uAC00 \uB454 \uAC70\uC57C?\r\n        \r\n\r\n(\uD558\uB140 \uB458\uC774
    \uC11C\uB85C \uB208\uCE58\uB97C \uBCF4\uB2E4\uAC00, \uACB0\uAD6D \uD55C \uBA85\uC774
    \uC870\uC2EC\uC2A4\uB7FD\uAC8C \uC785\uC744 \uC5F0\uB2E4.)\r\n        \r\n       
    \uD558\uB140 : \uB9E4\uC77C \uAC19\uC740 \uC2DC\uAC04\uC5D0 \uBA39\uC774\uB97C
    \uB450\uAC8C \uD558\uC2E0 \uBD84\uC774 \uACC4\uC2ED\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.\r\n       
    \r\n        \uB124\uBAA8 : \uB204\uAC00?\r\n        \r\n        \uD558\uB140
    : \u2026\u2026\uBC31\uC791\uB2D8\uC774\uC2ED\uB2C8\uB2E4.\r\n        \r\n       
    \uB124\uBAA8 : \uBC31\uC791\uB2D8\uC774?\r\n        \r\n        \uD558\uB140
    : \uC8FC\uC778\uB2D8 \uCC3D\uAC00 \uADFC\uCC98\uB85C \uC0C8\uAC00 \uC790\uC8FC
    \uC624\uBA74, \uC8FC\uC778\uB2D8\uAED8\uC11C \uC88B\uC544\uD558\uC2E4 \uAC70\uB77C\uACE0
    \uD558\uC154\uC11C\uC694.\r\n        \r\n        \uB124\uBAA8 : \u2026\u2026\uADF8\uB798\uC11C
    \uC598\uAC00 \uB098 \uC548 \uBB34\uC11C\uC6CC\uD574?\r\n        \r\n        \uD558\uB140
    : \uB124. \uC774 \uC790\uB9AC\uB3C4, \uC2DC\uAC04\uB3C4, \uB2E4 \uB9DE\uCDB0
    \uB450\uC168\uB2F5\uB2C8\uB2E4.\r\n        \r\n        \uB124\uBAA8 : \uBB50\uC57C.\r\n       
    \r\n        \uB124\uBAA8 : \uADF8\uAC74 \uC880\u2026 \uB108\uBB34 \uC798\uD574
    \uB480\uB294\uB370.\r\n        \r\n        \uD558\uB140 : \uC2EB\uC73C\uC168\uC2B5\uB2C8\uAE4C?\r\n       
    \r\n        \uB124\uBAA8 : \uC544\uB2C8. \uC2EB\uC9C4 \uC54A\uC740\uB370.\r\n       
    \r\n        (\uC0B0\uC0C8\uAC00 \uB124\uBAA8 \uCABD\uC73C\uB85C \uD55C \uAC78\uC74C
    \uB354 \uB2E4\uAC00\uC628\uB2E4.)\r\n        \r\n        \uB124\uBAA8 : \u2026\uC9C4\uC9DC\uC600\uB124.
    \uB098 \uB54C\uBB38\uC5D0 \uAE38\uB4E4\uC778 \uAC70\uC796\uC544."
