%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_cooking_modified__step_event_week_005_cooking_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC21C\uC11C\uBD80\uD130 \uAE30\uC5B5\uD558\uAC8C \uD55C\uB2E4"
  _bodyText: "\uC694\uB9AC\uC640 \uBC30\uC2DD\uC758 \uC6D0\uB9AC 5\uC8FC\uCC28 Modified
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC8FC\uBC29 \uD55C\uCABD \uC791\uC740 \uC791\uC5C5\uB300. \uBC00\uAC00\uB8E8,
      \uB2EC\uAC40, \uC6B0\uC720\uAC00 \uC870\uAE08\uC529 \uC900\uBE44\uB418\uC5B4
      \uC788\uACE0, \uD558\uB140\uAC00 \uACC4\uB7C9\uCEF5\uC744 \uBCF4\uC5EC \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uB9DB\uC788\uAC8C \uB9CC\uB4DC\uB294
      \uAC83\uBCF4\uB2E4 \uBA3C\uC800, \uC5BC\uB9C8\uB098 \uB123\uB294\uC9C0 \uBC30\uC6B0\uB294
      \uB0A0\uC774\uC5D0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB0E5 \uB300\uCDA9 \uB123\uC73C\uBA74 \uC548 \uB3FC?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8\uB7EC\uBA74 \uB300\uCDA9 \uC2E4\uD328\uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uC791\uC740 \uADF8\uB987\uB4E4\uC744 \uD55C \uC904\uB85C
      \uB193\uC544 \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC591\uC744 \uC678\uC6B4\uB2E4\uACE0 \uC0DD\uAC01\uD558\uC9C0 \uB9D0\uACE0,
      \uC21C\uC11C\uB97C \uAE30\uC5B5\uD55C\uB2E4\uACE0 \uC0DD\uAC01\uD574 \uBCF4\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBA3C\uC800 \uC774\uAC70, \uADF8\uB2E4\uC74C \uC774\uAC70?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uADF8\uB7EC\uBA74 \uC22B\uC790\uAC00 \uC870\uAE08 \uC5B4\uB824\uC6CC\uB3C4
      \uC190\uC774 \uB35C \uD5F7\uAC08\uB824\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544, \uADF8\uAC74 \uD560 \uB9CC\uD558\uB2E4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8\uB798\uC11C \uC8FC\uBC29\uC740 \uC190\uC774 \uAE30\uC5B5\uD558\uAC8C
      \uB9CC\uB4DC\uB294 \uACF3\uC774\uAE30\uB3C4 \uD558\uB2F5\uB2C8\uB2E4."
  _nemoLine: "(\uC8FC\uBC29 \uD55C\uCABD \uC791\uC740 \uC791\uC5C5\uB300. \uBC00\uAC00\uB8E8,
    \uB2EC\uAC40, \uC6B0\uC720\uAC00 \uC870\uAE08\uC529 \uC900\uBE44\uB418\uC5B4
    \uC788\uACE0, \uD558\uB140\uAC00 \uACC4\uB7C9\uCEF5\uC744 \uBCF4\uC5EC \uC900\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
