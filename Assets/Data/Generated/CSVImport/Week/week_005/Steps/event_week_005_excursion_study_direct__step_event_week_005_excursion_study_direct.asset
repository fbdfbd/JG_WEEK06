  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_excursion_study_direct__step_event_week_005_excursion_study_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC11C\uC7AC \uD5C8\uAC00"
  _bodyText: "excursion study Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC561\uC790 \uC606\uC5D0 \uBE48 \uC885\uC774\uC640 \uAE43\uD39C \uD558\uB098\uAC00
      \uC815\uAC08\uD558\uAC8C \uB193\uC5EC \uC788\uB294 \uAC83\uC744 \uBC1C\uACAC\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uB610 \uBB50\uC57C? \uC0C8\uB85C \uADF8\uB9AC\uB77C\uB294
      \uAC74\uAC00?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC885\uC774 \uBC11\uC5D0 '\uC2E4\uB825\uC774 \uB298\uC5C8\uB294\uC9C0
      \uD655\uC778\uD558\uACA0\uB2E4'\uB77C\uB294 \uBC31\uC791\uC758 \uC9E7\uC740
      \uCABD\uC9C0\uAC00 \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD765, \uC9C0\uAE08 \uADF8\uB9AC\uBA74 \uD6E8\uC52C \uC798 \uADF8\uB9B4
      \uD150\uB370."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uD22C\uB35C\uB300\uBA74\uC11C\uB3C4 \uD39C\uC744
      \uB4E4\uC5B4 \uC561\uC790 \uC18D \uB099\uC11C \uC606\uC5D0 \uD604\uC7AC \uBC31\uC791\uC758
      \uC606\uBAA8\uC2B5\uC744 \uC870\uC2EC\uC2A4\uB808 \uADF8\uB9AC\uAE30 \uC2DC\uC791\uD55C\uB2E4.)"
  _nemoLine: "(\uC561\uC790 \uC606\uC5D0 \uBE48 \uC885\uC774\uC640 \uAE43\uD39C \uD558\uB098\uAC00
    \uC815\uAC08\uD558\uAC8C \uB193\uC5EC \uC788\uB294 \uAC83\uC744 \uBC1C\uACAC\uD55C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
