  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w005_letter_friend_1_direct__step_w005_letter_friend_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 5\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uC774\uBC88\uC5D4
    \uBD09\uD22C\uAC00 \uC880 \uAD6C\uACA8\uC838 \uC788\uACE0, \uAC89\uC5D0 '\uACBD\uBE44\uB300\uC7A5
    \uC544\uC800\uC528 \uBAB0\uB798!'\uB77C\uACE0 \uC791\uAC8C \uC801\uD600 \uC788\uB2E4.)\n   
    \uD558\uB140 : \uC8FC\uC778\uB2D8 \uC55E\uC73C\uB85C \uC628 \uD3B8\uC9C0\uC785\uB2C8\uB2E4.
    \uAF64\uB098 \uC7A5\uB09C\uC2A4\uB7EC\uC6B4 \uBB38\uAD6C\uAC00 \uC801\uD600 \uC788\uB124\uC694.\n       
    \n\n\uD558\uB140 : \uC9C0\uB09C\uBC88\uC5D0 \uAC19\uC774 \uB180\uB358 \uB610\uB798
    \uC190\uB2D8\uC774 \uBCF4\uB0B8 \uD3B8\uC9C0\uC785\uB2C8\uB2E4. \uC544\uC8FC
    \uBE44\uBC00\uC2A4\uB7EC\uC6B4 \uB0B4\uC6A9 \uAC19\uB124\uC694.\n        \uB124\uBAA8
    : \uBE68\uB9AC, \uBE68\uB9AC! \uBB50\uB77C\uACE0 \uC37C\uC5B4?\n        (\uD558\uB140\uAC00
    \uBD09\uD22C\uB97C \uD3BC\uCE5C\uB2E4.)\n        \uB124\uBAA8\uC57C! \uC800\uBC88\uC5D0
    \uACBD\uBE44\uB300\uC7A5 \uC544\uC800\uC528\uAC00 \uC6B0\uB9AC \uC9C0\uB3C4 \uBE8F\uC5B4\uAC04
    \uAC70 \uB108\uBB34\uD588\uC5B4. \uB2E4\uC74C\uC5D4 \uC544\uC800\uC528 \uC548
    \uBCFC \uB54C \uB098\uD55C\uD14C \uC719\uD06C\uD574 \uC918. \uADF8\uB7FC \uB0B4\uAC00
    \uBC16\uC5D0\uC11C \uB3CC\uBA69\uC774 \uB358\uC838\uC11C \uC2E0\uD638 \uC904\uAC8C!
    \uC6B0\uB9AC\uB07C\uB9AC \uD0C8\uCD9C\uD558\uB294 \uAC70\uC57C!\n        \uB124\uBAA8
    : \uC719\uD06C?\n        \uD558\uB140 : \uC8FC\uC778\uB2D8, \uACBD\uBE44\uB300\uC7A5\uB2D8
    \uBAB0\uB798 \uC2E0\uD638\uB97C \uC8FC\uACE0\uBC1B\uACE0 \uC2F6\uC740 \uBAA8\uC591\uC785\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uB3CC\uBA69\uC774 \uB358\uC9C0\uB294 \uC18C\uB9AC \uB4E4\uB9AC\uBA74
    \uC9C4\uC9DC \uC7AC\uBC0C\uACA0\uB2E4. \uC544\uC800\uC528\uAC00 \uAE5C\uC9DD
    \uB180\uB77C\uACA0\uC9C0?"
