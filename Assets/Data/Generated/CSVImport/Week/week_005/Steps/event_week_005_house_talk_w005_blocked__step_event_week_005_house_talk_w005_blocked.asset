  _titleOverride: w005 Blocked
  _bodyText: "house_talk w005 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: ea8bb1cd384c18f4c83d6f267d5433b5, type: 2}
    _text: "\uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8. \uADF8\uB0E5 \uCC3D\uBB38\uC774
      \uB35C\uCEF9\uAC70\uB9AC\uB294 \uC18C\uB9AC\uC600\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD53C\uC544\uB178 \uC18C\uB9AC \uAC19\uB2E4\uACE0 \uD588\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: 382a01f86413cfc439d75f63e427a411, type: 2}
    _text: "\uBC24\uC5D0\uB294 \uBAA8\uB4E0 \uC18C\uB9AC\uAC00 \uD06C\uAC8C \uB4E4\uB824\uC11C
      \uCC29\uAC01\uD55C \uAC81\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uCE58... \uB2E4\uB4E4 \uB098\uD55C\uD14C\uB9CC \uBE44\uBC00\uC774\uC57C."
  _nemoLine: "\uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8. \uADF8\uB0E5 \uCC3D\uBB38\uC774
    \uB35C\uCEF9\uAC70\uB9AC\uB294 \uC18C\uB9AC\uC600\uC5B4\uC694."
