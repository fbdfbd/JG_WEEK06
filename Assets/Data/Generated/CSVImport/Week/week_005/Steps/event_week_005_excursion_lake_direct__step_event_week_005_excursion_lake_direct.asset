%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_excursion_lake_direct__step_event_week_005_excursion_lake_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 \uD5C8\uAC00"
  _bodyText: "excursion lake Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uB9C8\uB978 \uC870\uAC01 \uD558\uB098\uB97C \uACE8\uB77C
      \uC190\uBC14\uB2E5 \uC704\uC5D0 \uC62C\uB824 \uBCF4\uC5EC \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC774\uAC74 \uAD1C\uCC2E\uC2B5\uB2C8\uB2E4. \uB2E4 \uC2DD\uACE0 \uB9C8\uB978
      \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uC9C4\uC9DC \uADF8\uB0A0 \uAC70\uAD6C\uB098."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC608. \uD638\uC218 \uC704\uC5D0\uC11C \uD130\uC9C0\uB358 \uC791\uC740
      \uBD88\uAF43 \uC911 \uD558\uB098\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC24\uC5D4 \uC5C4\uCCAD \uCEE4 \uBCF4\uC600\uB294\uB370."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC5B4\uB461\uACE0 \uBB3C \uC704\uC600\uC73C\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9DE\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB3C\uC5D0 \uBE44\uCE5C \uAC8C \uB354 \uC608\uBEE4\uC5B4. \uD558\uB298\uBCF4\uB2E4
      \uC544\uB798\uCABD\uC774 \uB354 \uBC18\uC9DD\uC600\uAC70\uB4E0."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC7A0\uAE50\uC774\uC5C8\uB294\uB370\uB3C4 \uAE30\uC5B5\uB098."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uAE08\uAC00\uB8E8 \uBB3B\uC740 \uC870\uAC01\uC744
      \uAC00\uB9CC\uD788 \uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADFC\uB370 \uC774\uB7F0 \uAC78 \uCE58\uC6B0\uACE0 \uB098\uBA74, \uC9C4\uC9DC
      \uC788\uC5C8\uB358 \uAC74\uC9C0 \uC880 \uC774\uC0C1\uD574."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8\uB798\uC11C \uC794\uD574\uAC00 \uB0A8\uB294 \uAC78\uC9C0\uB3C4
      \uBAA8\uB974\uC9C0\uC694, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uADF8\uAC74 \uC880 \uC88B\uB2E4."
  _nemoLine: "(\uD558\uB140\uAC00 \uB9C8\uB978 \uC870\uAC01 \uD558\uB098\uB97C \uACE8\uB77C
    \uC190\uBC14\uB2E5 \uC704\uC5D0 \uC62C\uB824 \uBCF4\uC5EC \uC900\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
