  m_Name: event_w005_letter_friend_1_modified__step_w005_letter_friend_1_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 5\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uC774\uBC88\uC5D4
    \uBD09\uD22C\uAC00 \uC880 \uAD6C\uACA8\uC838 \uC788\uACE0, \uAC89\uC5D0 '\uACBD\uBE44\uB300\uC7A5
    \uC544\uC800\uC528 \uBAB0\uB798!'\uB77C\uACE0 \uC791\uAC8C \uC801\uD600 \uC788\uB2E4.)\n   
    \uD558\uB140 : \uC8FC\uC778\uB2D8 \uC55E\uC73C\uB85C \uC628 \uD3B8\uC9C0\uC785\uB2C8\uB2E4.
    \uAF64\uB098 \uC7A5\uB09C\uC2A4\uB7EC\uC6B4 \uBB38\uAD6C\uAC00 \uC801\uD600 \uC788\uB124\uC694.\n       
    \n\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C
    \uB610\uB798 \uC190\uB2D8\uC774 \uB2E4\uC2DC \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uBB50\uB77C\uACE0 \uD588\uC5B4?\n        \uD558\uB140 : \uACBD\uBE44\uB300\uC7A5\uB2D8\uC774
    \uC870\uAE08 \uBB34\uC11C\uC6E0\uC9C0\uB9CC, \uADF8\uB798\uB3C4 \uC8FC\uC778\uB2D8\uC774\uB791
    \uAF2D \uB2E4\uC2DC \uB180\uACE0 \uC2F6\uB300\uC694.\n        \uB124\uBAA8 :
    \uC9C4\uC9DC?\n        \uD558\uB140 : \uB124. \uADF8\uB798\uC11C \uB2E4\uC74C\uC5D0
    \uB9CC\uB098\uBA74 \uB458\uB9CC\uC758 \uC2E0\uD638\uB97C \uB9CC\uB4E4\uC5B4\uC11C
    \uC7AC\uBC0C\uAC8C \uB180\uC790\uACE0 \uD569\uB2C8\uB2E4.\n        \uB124\uBAA8
    : \uC2E0\uD638? \uC5B4\uB5BB\uAC8C?\n        \uD558\uB140 : \uB208\uC9D3\uC744
    \uD558\uAC70\uB098, \uC18C\uB9AC\uB97C \uB0B4\uAC70\uB098... \uC6B0\uB9AC\uB07C\uB9AC\uB9CC
    \uC544\uB294 \uADDC\uCE59\uC744 \uB9CC\uB4E4\uC790\uACE0 \uD558\uB124\uC694.\n       
    \uB124\uBAA8 : \uC624. \uADF8\uB7FC \uB098\uB3C4 \uC5F0\uC2B5\uD574 \uAC00\uC57C\uACA0\uB2E4."
