  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_visitor_friend_2_direct__step_event_week_005_visitor_friend_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: friend_2 Direct
  _bodyText: "visitor friend_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC9C0\uB3C4 \uAD6C\uC11D\uC5D0 \uADF8\uB824\uC9C4
      \uD638\uC218 \uBB38\uC591\uC744 \uC190\uAC00\uB77D\uC73C\uB85C \uAC00\uB9AC\uD0A8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBD10\uBD10, \uC5EC\uAE30\uC57C. \uBC31\uC791\uB2D8\uC774 \uC608\uC804\uC5D0
      \uB9D0\uC500\uD574\uC8FC\uC168\uB294\uB370, \uC5EC\uAE30\uAC00 \uC218\uC2EC\uC774
      \uAE4A\uC5B4\uC11C \uC2E0\uBE44\uD55C \uC0DD\uBB3C\uC774 \uB9CE\uB300. \uB098\uC911\uC5D0
      \uC6B0\uB9AC \uAC19\uC774 \uAC00\uBCF4\uC790."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "(\uB208\uC744 \uBC18\uC9DD\uC774\uBA70) \uC9C4\uC9DC? \uB124\uAC00 \uAC19\uC774
      \uAC00\uC900\uB2E4\uBA74 \uB098\uB3C4 \uC6A9\uAE30 \uB0B4\uBCFC\uAC8C. \uBC31\uC791\uB2D8\uC774
      \uB108\uB97C \uBBFF\uACE0 \uC774\uB7F0 \uC9C0\uB3C4\uB97C \uBCF4\uAC8C \uD574\uC8FC\uC2DC\uB294
      \uAC8C \uCC38 \uBD80\uB7FD\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC73C\uC4F1\uD558\uBA70) \uB108\uB791 \uAC19\uC774 \uAC08 \uAC70\uBA74
      \uBC31\uC791\uB2D8\uB3C4 \uD5C8\uB77D\uD574\uC8FC\uC2E4 \uAC70\uC57C. \uC6B0\uB9AC\uAC00
      \uACF5\uBD80 \uC5F4\uC2EC\uD788 \uD558\uBA74 \uB9D0\uC774\uC57C!"
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC9C0\uB3C4 \uAD6C\uC11D\uC5D0 \uADF8\uB824\uC9C4
    \uD638\uC218 \uBB38\uC591\uC744 \uC190\uAC00\uB77D\uC73C\uB85C \uAC00\uB9AC\uD0A8\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
