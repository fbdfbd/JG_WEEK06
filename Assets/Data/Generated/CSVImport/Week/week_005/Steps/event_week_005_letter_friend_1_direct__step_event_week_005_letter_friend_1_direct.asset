  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_letter_friend_1_direct__step_event_week_005_letter_friend_1_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9C9\uC2A4 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "letter friend_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC9C0\uB09C\uBC88\uC5D0 \uAC19\uC774 \uB180\uB358 \uB610\uB798 \uC190\uB2D8\uC774
      \uBCF4\uB0B8 \uD3B8\uC9C0\uC785\uB2C8\uB2E4. \uC544\uC8FC \uBE44\uBC00\uC2A4\uB7EC\uC6B4
      \uB0B4\uC6A9 \uAC19\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBE68\uB9AC, \uBE68\uB9AC! \uBB50\uB77C\uACE0 \uC37C\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uD3BC\uCE5C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC719\uD06C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uACBD\uBE44\uB300\uC7A5\uB2D8 \uBAB0\uB798 \uC2E0\uD638\uB97C
      \uC8FC\uACE0\uBC1B\uACE0 \uC2F6\uC740 \uBAA8\uC591\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB3CC\uBA69\uC774 \uB358\uC9C0\uB294 \uC18C\uB9AC \uB4E4\uB9AC\uBA74
      \uC9C4\uC9DC \uC7AC\uBC0C\uACA0\uB2E4. \uC544\uC800\uC528\uAC00 \uAE5C\uC9DD
      \uB180\uB77C\uACA0\uC9C0?"
  _nemoLine: "\uC9C0\uB09C\uBC88\uC5D0 \uAC19\uC774 \uB180\uB358 \uB610\uB798 \uC190\uB2D8\uC774
    \uBCF4\uB0B8 \uD3B8\uC9C0\uC785\uB2C8\uB2E4. \uC544\uC8FC \uBE44\uBC00\uC2A4\uB7EC\uC6B4
    \uB0B4\uC6A9 \uAC19\uB124\uC694."
  _useCustomVisualState: 0
  _visualState: 0
