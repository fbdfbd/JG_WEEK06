  m_Name: event_w005_letter_friend_2_direct__step_w005_letter_friend_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 \uD3B8\uC9C0 5\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uD558\uC580 \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4.
    \uC9C0\uB09C\uBC88\uBCF4\uB2E4 \uC870\uAE08 \uB354 \uB450\uD23C\uD55C \uB290\uB08C\uC774\uB2E4.)\r\n   
    \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C \uC628 \uD3B8\uC9C0\uC785\uB2C8\uB2E4.
    \uC774\uBC88\uC5D4 \uAF64 \uAE38\uAC8C \uC4F4 \uBAA8\uC591\uC774\uB124\uC694.\r\n       
    \r\n\r\n\uD558\uB140 : \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798 \uC190\uB2D8\uC774
    \uBCF4\uB0B8 \uD3B8\uC9C0\uC785\uB2C8\uB2E4. \uBB50\uB77C\uACE0 \uC801\uC5C8\uB294\uC9C0
    \uAD81\uAE08\uD558\uC2DC\uC8E0?\r\n        \uB124\uBAA8 : \uC751! \uBE68\uB9AC
    \uC77D\uC5B4 \uC918.\r\n        (\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uD3BC\uCE5C\uB2E4.)\r\n       
    \uB124\uBAA8\uC5D0\uAC8C. \uC800\uBC88\uC5D0 \uACBD\uBE44\uB300\uC7A5 \uC544\uC800\uC528\uAC00
    \uB300\uD654 \uAE08\uC9C0\uB77C\uACE0 \uD588\uC744 \uB54C, \uB098\uB791 \uB208
    \uB9C8\uC8FC\uCE5C \uAC70 \uAE30\uC5B5\uB098? \uB124\uAC00 \uC2DC\uBB34\uB8E9\uD574
    \uBCF4\uC5EC\uC11C \uC0AC\uC2E4 \uC870\uAE08 \uAC71\uC815\uB410\uC5B4. \uB9D0\uC740
    \uBABB \uD588\uC9C0\uB9CC \uC6B0\uB9AC\uB294 \uB208\uB9CC \uBD10\uB3C4 \uD1B5\uD558\uB294
    \uC0AC\uC774\uC9C0? \uB2E4\uC74C\uC5D4 \uB0B4\uAC00 \uB354 \uC7AC\uBC0C\uB294
    \uCC45 \uC774\uC57C\uAE30\uB97C \uC900\uBE44\uD574 \uAC08\uAC8C.\r\n        \uB124\uBAA8
    : \uB0B4 \uB208\uC744 \uBD24\uB300.\r\n        \uD558\uB140 : \uC8FC\uC778\uB2D8\uC774
    \uC18D\uC0C1\uD574\uD558\uB294 \uAC78 \uB208\uCE58\uCC58\uB098 \uBD05\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : \uB9D0\uC740 \uC548 \uD574\uB3C4 \uC548\uB2E4\uB2C8... \uAC54\uB294
    \uC9C4\uC9DC \uC2E0\uAE30\uD55C \uC560\uC57C.\r\n        \uD558\uB140 : \uC8FC\uC778\uB2D8\uC744
    \uC544\uC8FC \uAE4A\uAC8C \uC0DD\uAC01\uD558\uACE0 \uC788\uB098 \uBD05\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : \uC751. \uB098\uB3C4 \uAC54\uB791 \uB208 \uB9C8\uC8FC\uCE58\uB294
    \uAC70 \uC88B\uC558\uC5B4."
