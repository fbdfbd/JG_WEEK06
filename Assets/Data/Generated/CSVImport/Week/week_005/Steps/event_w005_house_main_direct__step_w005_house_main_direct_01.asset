  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w005_house_main_direct__step_w005_house_main_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "5\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uBC24\uC758 \uADF8\uB9BC\uC790\uAC00 \uB0B4\uB824\uC549\uC740 \uACC4\uB2E8
    \uC544\uB798. \uD558\uC778 \uB458\uC774 \uC545\uAE30\uC2E4 \uCABD\uC744 \uBCF4\uBA70
    \uC18D\uC0AD\uC778\uB2E4.)\r\n    \uD558\uC7781 : \uC5B4\uC81C \uB4E4\uC5C8\uC5B4?
    \uC544\uBB34\uB3C4 \uC5C6\uB294\uB370 \uAC74\uBC18 \uC18C\uB9AC\uAC00 \uB0AC\uB2E4\uB2C8\uAE4C.\r\n   
    \uD558\uC7782 : \uBC14\uB78C \uC18C\uB9AC\uACA0\uC9C0. \uD558\uC9C0\uB9CC \uAF2D
    \uB204\uAC00 \uD55C \uC74C\uC529 \uB204\uB974\uB294 \uAC83 \uAC19\uAE34 \uD558\uB354\uB77C.\r\n   
    \uB124\uBAA8 : \uD53C\uC544\uB178\uAC00 \uD63C\uC790 \uB178\uB798\uD574?\r\n   
    \r\n\r\n\uD558\uC7781 : \uC800\uD0DD\uC774 \uB108\uBB34 \uC870\uC6A9\uD558\uBA74
    \uAC00\uB054 \uD53C\uC544\uB178\uAC00 \uC2EC\uC2EC\uD574\uC11C \uC2A4\uC2A4\uB85C
    \uC18C\uB9AC\uB97C \uB0B8\uB2E4\uB294 \uC774\uC57C\uAE30\uAC00 \uC788\uC5B4\uC694.\r\n   
    \uB124\uBAA8 : \uD53C\uC544\uB178\uB3C4 \uC2EC\uC2EC\uD574?\r\n    \uD558\uC7782
    : \uB124. \uC544\uBB34\uB3C4 \uC5F0\uC8FC\uD574 \uC8FC\uC9C0 \uC54A\uC73C\uBA74
    \uC544\uC8FC \uC791\uAC8C \uB529- \uD558\uACE0 \uC6B8\uB9B0\uB300\uC694.\r\n   
    \uB124\uBAA8 : \uD5C9, \uADC0\uC2E0\uC778\uAC00?\r\n    \uD558\uC7781 : \uADC0\uC2E0\uC774\uB77C\uAE30\uBCF4\uB2E8,
    \uB178\uB798\uD558\uACE0 \uC2F6\uC740 \uB9C8\uC74C\uC774 \uB0A8\uC740 \uAC70
    \uC544\uB2D0\uAE4C\uC694?\r\n    \uB124\uBAA8 : \uC870\uAE08 \uBB34\uC12D\uC9C0\uB9CC...
    \uB2E4\uC74C\uC5D4 \uB0B4\uAC00 \uAC00\uC11C \uD55C \uBC88 \uCCD0\uC904\uAE4C
    \uBD10."
