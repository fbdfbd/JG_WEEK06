  _titleOverride: "\uAE30\uB9C8 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4"
  _bodyText: "\uAE30\uB9C8 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uAE30\uB9C8 \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
      \uC790\uC138\uB9CC \uC7A0\uAE50 \uBCF4\uACE0 \uC218\uC5C5\uC744 \uB118\uAE34\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624\uB298\uC740 \uB9D0 \uD0C0\uB294 \uAC70 \uC548 \uBC30\uC6CC\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uBB34\uB9AC\uD558\uAC8C \uC9C4\uB3C4\uB97C \uB098\uAC00\uC9C0 \uC54A\uACE0
      \uB2E4\uC74C \uAE30\uD68C\uB85C \uBBF8\uB8EC\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB2E4\uC74C\uC5D4 \uB354 \uC624\uB798 \uD574\uC694."
  _nemoLine: "(\uAE30\uB9C8 \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
    \uC790\uC138\uB9CC \uC7A0\uAE50 \uBCF4\uACE0 \uC218\uC5C5\uC744 \uB118\uAE34\uB2E4.)"
