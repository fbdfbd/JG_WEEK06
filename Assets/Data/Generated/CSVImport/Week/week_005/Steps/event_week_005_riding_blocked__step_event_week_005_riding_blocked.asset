--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_riding_blocked__step_event_week_005_riding_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9D0 \uC704 \uC911\uC2EC\uC744 \uC5C4\uACA9\uD788 \uC7A1\uB294\uB2E4"
  _bodyText: "\uCCB4\uC804\uACFC \uC2B9\uB9C8 \uAE30\uCD08 5\uC8FC\uCC28 Blocked
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB9C8\uAD6C\uAC04 \uC55E. \uC791\uC740 \uD6C8\uB828\uC6A9 \uB9D0\uC774
      \uC900\uBE44\uB418\uC5B4 \uC788\uACE0, \uD558\uB140\uAC00 \uB124\uBAA8\uC758
      \uC7A5\uAC11\uC744 \uACE0\uCCD0 \uC900\uB2E4. \uACBD\uBE44\uB300\uC7A5\uC740
      \uACE0\uC090 \uAE38\uC774\uB97C \uB9DE\uCD94\uACE0 \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uBE68\uB9AC \uB2EC\uB9AC\uB294
      \uAC83\uBCF4\uB2E4 \uBA3C\uC800 \uB9D0 \uC704\uC5D0\uC11C \uADE0\uD615 \uC7A1\uB294
      \uAC78 \uBC30\uC6B8 \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2EC\uB9AC\uB294 \uAC74 \uC544\uC9C1 \uC548 \uD574?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC544\uC9C1\uC740 \uC544\uB2D9\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uBAB8\uC744 \uC55E\uC73C\uB85C \uC219\uC774\uC790,
      \uACBD\uBE44\uB300\uC7A5\uC774 \uC5B4\uAE68\uB97C \uBC14\uB85C \uC138\uC6B4\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uACE0\uC090\uB97C \uB2F9\uAE30\uAE30 \uC804\uC5D0 \uC790\uC138\uBD80\uD130
      \uACE0\uC815\uD558\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9D0\uC774 \uC870\uAE08\uB9CC \uC6C0\uC9C1\uC5EC\uB3C4 \uD754\uB4E4\uB9AC\uB294\uB370."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uD754\uB4E4\uB824\uB3C4 \uC911\uC2EC\uC744 \uC783\uC9C0 \uC54A\uB294
      \uAC8C \uAE30\uBCF8\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC2B9\uB9C8\uB294 \uC0DD\uAC01\uBCF4\uB2E4 \uC548 \uCE5C\uC808\uD558\uB124."
  _nemoLine: "(\uB9C8\uAD6C\uAC04 \uC55E. \uC791\uC740 \uD6C8\uB828\uC6A9 \uB9D0\uC774
    \uC900\uBE44\uB418\uC5B4 \uC788\uACE0, \uD558\uB140\uAC00 \uB124\uBAA8\uC758
    \uC7A5\uAC11\uC744 \uACE0\uCCD0 \uC900\uB2E4. \uACBD\uBE44\uB300\uC7A5\uC740
    \uACE0\uC090 \uAE38\uC774\uB97C \uB9DE\uCD94\uACE0 \uC788\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
