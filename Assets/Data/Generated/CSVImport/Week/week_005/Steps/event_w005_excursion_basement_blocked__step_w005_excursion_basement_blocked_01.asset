  m_Name: event_w005_excursion_basement_blocked__step_w005_excursion_basement_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 5\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uB2A6\uC740 \uC624\uD6C4. \uC9C0\uD558\uC2E4 \uC548\uCABD \uAE30\uB465
    \uD558\uB098\uC5D0 \uAC00\uB290\uB2E4\uB780 \uC120\uB4E4\uC774 \uC5EC\uB7EC \uAC1C
    \uB098 \uC788\uB2E4. \uC5B4\uB5A4 \uAC74 \uC5F0\uD544\uC120 \uAC19\uACE0, \uC5B4\uB5A4
    \uAC74 \uCE7C\uB05D\uC73C\uB85C \uC0B4\uC9DD \uC0C8\uAE34 \uB4EF \uC595\uB2E4.
    \uC120 \uC606\uC5D4 \uB0A0\uC9DC\uCC98\uB7FC \uBCF4\uC774\uB294 \uC791\uC740
    \uC22B\uC790\uB3C4 \uC788\uB2E4.)\r\n        \r\n        \uB124\uBAA8 : \uC5B4?
    \uC774\uAC74 \uB610 \uBB50\uC57C.\r\n        \r\n        (\uB124\uBAA8\uAC00
    \uAE30\uB465 \uC606\uC5D0 \uC11C \uBCF4\uC790, \uB9E8 \uC704 \uC120 \uD558\uB098\uAC00
    \uC790\uAE30 \uBA38\uB9AC \uB192\uC774\uC640 \uBE44\uC2B7\uD558\uB2E4.)\r\n       
    \r\n        \uB124\uBAA8 : ...\uC124\uB9C8.\r\n        \r\n\r\n(\uCC3D\uACE0\uC9C0\uAE30\uAC00
    \uAE09\uD788 \uAE30\uB465 \uC55E\uC5D0 \uC11C\uC11C \uC2DC\uC57C\uB97C \uAC00\uB9B0\uB2E4.)\r\n       
    \r\n        \uCC3D\uACE0\uC9C0\uAE30 : \uC8FC\uC778\uB2D8, \uC774\uCABD\uC740
    \uBCF4\uC2E4 \uAC8C \uC5C6\uC2B5\uB2C8\uB2E4.\r\n        \r\n        \uB124\uBAA8
    : \uC544\uB2CC\uB370. \uBB54\uAC00 \uC788\uC5C8\uB294\uB370.\r\n        \r\n       
    \uCC3D\uACE0\uC9C0\uAE30 : \uADF8\uB0E5 \uC624\uB798\uB41C \uD45C\uC2DC\uB4E4\uC785\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uAE30\uB465\uC5D0 \uC65C \uD45C\uC2DC\uB97C \uD574."
