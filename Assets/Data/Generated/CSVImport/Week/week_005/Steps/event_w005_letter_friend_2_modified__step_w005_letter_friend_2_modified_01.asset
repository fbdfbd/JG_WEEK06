  m_Name: event_w005_letter_friend_2_modified__step_w005_letter_friend_2_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 \uD3B8\uC9C0 5\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uD558\uC580 \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4.
    \uC9C0\uB09C\uBC88\uBCF4\uB2E4 \uC870\uAE08 \uB354 \uB450\uD23C\uD55C \uB290\uB08C\uC774\uB2E4.)\n   
    \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C \uC628 \uD3B8\uC9C0\uC785\uB2C8\uB2E4.
    \uC774\uBC88\uC5D4 \uAF64 \uAE38\uAC8C \uC4F4 \uBAA8\uC591\uC774\uB124\uC694.\n       
    \n\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C
    \uB610\uB798 \uC190\uB2D8\uC774 \uB2E4\uC2DC \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uBB50\uB77C\uACE0 \uD588\uC5B4?\n        \uD558\uB140 : \uC8FC\uC778\uB2D8\uC774
    \uC11C\uC7AC\uC5D0\uC11C \uC870\uC6A9\uD788 \uACF5\uBD80\uD558\uB294 \uBAA8\uC2B5\uC774
    \uC544\uC8FC \uBA4B\uC84C\uB2E4\uACE0 \uD558\uB124\uC694.\n        \uB124\uBAA8
    : \uC9C4\uC9DC? \uC794\uC18C\uB9AC \uC548 \uD558\uACE0?\n        \uD558\uB140
    : \uB124. \uADF8\uB9AC\uACE0 \uB9D0\uD558\uC9C0 \uC54A\uC544\uB3C4 \uC8FC\uC778\uB2D8\uC758
    \uB9C8\uC74C\uC744 \uB2E4 \uC54C\uACE0 \uC788\uC73C\uB2C8\uAE4C, \uC2AC\uD37C\uD558\uC9C0
    \uB9D0\uB77C\uACE0\uB3C4 \uD588\uC2B5\uB2C8\uB2E4.\n        \uB124\uBAA8 : \uC624...
    \uAC54\uAC00 \uC6EC\uC77C\uB85C \uADF8\uB7F0 \uB9D0\uC744 \uB2E4 \uD588\uB300.\n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8\uACFC \uB9C8\uC74C\uC774 \uC544\uC8FC \uC798
    \uD1B5\uD55C\uB2E4\uACE0 \uBBFF\uACE0 \uC788\uB098 \uBD05\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uADF8\uB7FC \uB2E4\uC74C\uC5D4 \uB0B4\uAC00 \uBA3C\uC800 \uB208
    \uB9DE\uCDB0\uC918\uC57C\uC9C0."
