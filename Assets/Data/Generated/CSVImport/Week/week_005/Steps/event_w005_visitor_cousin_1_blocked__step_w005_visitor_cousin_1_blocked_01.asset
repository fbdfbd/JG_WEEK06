  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w005_visitor_cousin_1_blocked__step_w005_visitor_cousin_1_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 5\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uC0AC\uCD0C 1\uC774 \uC11C\uC7AC \uCC3D\uBB38\uC744 \uD65C\uC9DD
    \uC5F4\uACE0 \uBC16\uC744 \uB0B4\uB2E4\uBCF4\uBA70 \uB124\uBAA8\uB97C \uBD80\uB978\uB2E4.
    \uBC31\uC791\uC740 \uD56D\uC0C1 \uD658\uAE30\uD560 \uB54C\uB9CC \uBB38\uC744
    \uC5F4\uC9C0\uB9CC, \uC0AC\uCD0C 1\uC740 \uBC14\uB78C \uADF8 \uC790\uCCB4\uB97C
    \uC990\uAE34\uB2E4.)\r\n        \r\n        \uC0AC\uCD0C 1 : \uB124\uBAA8\uC57C,
    \uC774\uCABD\uC73C\uB85C \uC640\uBD10. \uC5EC\uAE30\uC11C \uBCF4\uBA74 \uC800
    \uBA40\uB9AC \uC131\uBB38 \uBC16 \uC2DC\uC7A5\uC774 \uBCF4\uC774\uC9C0? \uC800\uAE30\uC11C
    \uD30C\uB294 \uC591\uAF2C\uCE58 \uB0C4\uC0C8\uAC00 \uC5EC\uAE30\uAE4C\uC9C0 \uB098\uB294
    \uAC83 \uAC19\uC9C0 \uC54A\uB0D0?\r\n        \uB124\uBAA8 : (\uCC3D\uAC00\uB85C
    \uB2E4\uAC00\uAC00 \uCF54\uB97C \uD081\uD081\uB300\uBA70) \uC9C4\uC9DC\uC694?
    \uC804 \uADF8\uB0E5 \uD480 \uB0C4\uC0C8\uBC16\uC5D0 \uC548 \uB098\uB294\uB370...\r\n       
    \uC0AC\uCD0C 1 : \uC0C1\uC0C1\uB825\uC744 \uBC1C\uD718\uD574\uBD10! \uC800\uAE30
    \uC0AC\uB78C \uBD81\uC801\uC774\uB294 \uC18C\uB9AC, \uB9D0 \uC6B8\uC74C\uC18C\uB9AC...
    \uBC31\uC791\uB2D8\uC740 \uC65C \uC774\uB7F0 \uBA85\uB2F9\uC744 \uB450\uACE0
    \uB9E8\uB0A0 \uC11C\uB958\uB9CC \uBCF4\uC2DC\uB294\uC9C0 \uBAB0\uB77C.\r\n       
    \r\n\r\n(\uB124\uBAA8\uAC00 \uCC3D\uBC16\uC73C\uB85C \uC0C1\uCCB4\uB97C \uB0B4\uBC00\uB824
    \uD558\uC790, \uC5B4\uB290\uC0C8 \uB098\uD0C0\uB09C \uAE30\uC0AC\uAC00 \uB124\uBAA8\uC758
    \uB4B7\uB35C\uBBF8\uB97C \uC0B4\uC9DD \uC7A1\uC544 \uB2F9\uAE34\uB2E4.)\r\n       
    \uAE30\uC0AC : \uB3C4\uB828\uB2D8, \uCD94\uB77D \uC704\uD5D8\uC774 \uC788\uC2B5\uB2C8\uB2E4.
    \uCC3D\uBB38\uC740 15\uB3C4 \uC774\uC0C1 \uC5F4\uC9C0 \uC54A\uB294 \uAC83\uC774
    \uADDC\uCE59\uC785\uB2C8\uB2E4.\r\n        \uB124\uBAA8 : (\uC544\uC26C\uC6B4
    \uB4EF \uCC3D\uBB38\uC5D0\uC11C \uBA40\uC5B4\uC9C0\uBA70) ...\uADF8\uB0E5 \uAD6C\uACBD\uB9CC
    \uD558\uB294 \uAC74\uB370 \uB108\uBB34\uD574\uC694.\r\n        \uC0AC\uCD0C 1
    : \uC5B4\uC774\uAD6C, \uAE30\uC0AC \uC591\uBC18. \uC560 \uAE30 \uC880 \uC0B4\uB824\uC8FC\uC1FC.
    \uC5EC\uAE30\uAC00 \uBB34\uC2A8 \uAC10\uC625\uB3C4 \uC544\uB2C8\uACE0.\r\n       
    \uB124\uBAA8 : (\uC0BC\uCD0C\uC758 \uC637\uC790\uB77D\uC744 \uC7A1\uC73C\uBA70)
    \uAD1C\uCC2E\uC544\uC694, \uC0BC\uCD0C. \uBC31\uC791\uB2D8\uC774 \uC81C\uAC00
    \uBC16\uC744 \uB108\uBB34 \uAD81\uAE08\uD574\uD560\uAE4C \uBD10 \uAC71\uC815\uB418\uC154\uC11C
    \uADF8\uB7EC\uB294 \uAC70 \uB2E4 \uC54C\uC544\uC694."
