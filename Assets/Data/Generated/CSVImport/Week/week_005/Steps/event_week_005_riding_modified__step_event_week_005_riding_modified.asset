%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_riding_modified__step_event_week_005_riding_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9D0\uACFC \uAC19\uC740 \uBC15\uC790\uB97C \uBA3C\uC800 \uC775\uD78C\uB2E4"
  _bodyText: "\uCCB4\uC804\uACFC \uC2B9\uB9C8 \uAE30\uCD08 5\uC8FC\uCC28 Modified
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB9C8\uAD6C\uAC04 \uC55E. \uC791\uC740 \uD6C8\uB828\uC6A9 \uB9D0\uC774
      \uC900\uBE44\uB418\uC5B4 \uC788\uACE0, \uD558\uB140\uAC00 \uB124\uBAA8\uC758
      \uC7A5\uAC11\uC744 \uACE0\uCCD0 \uC900\uB2E4. \uACBD\uBE44\uB300\uC7A5\uC740
      \uACE0\uC090 \uAE38\uC774\uB97C \uB9DE\uCD94\uACE0 \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uBE68\uB9AC \uB2EC\uB9AC\uB294
      \uAC83\uBCF4\uB2E4 \uBA3C\uC800 \uB9D0 \uC704\uC5D0\uC11C \uADE0\uD615 \uC7A1\uB294
      \uAC78 \uBC30\uC6B8 \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2EC\uB9AC\uB294 \uAC74 \uC544\uC9C1 \uC548 \uD574?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC544\uC9C1\uC740 \uC544\uB2D9\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uB9D0 \uBAA9\uC744 \uD55C \uBC88 \uC4F0\uB2E4\uB4EC\uAC8C
      \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC624\uB298\uC740 \uB9D0\uC744 \uD0C0\uB294 \uAC8C \uC544\uB2C8\uB77C,
      \uAC19\uC740 \uBC15\uC790\uB85C \uC6C0\uC9C1\uC778\uB2E4\uACE0 \uC0DD\uAC01\uD574
      \uBCF4\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC19\uC740 \uBC15\uC790?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC8FC\uC778\uB2D8\uC774 \uAE09\uD558\uBA74 \uB9D0\uB3C4 \uAE09\uD574\uC9C0\uACE0,
      \uC8FC\uC778\uB2D8\uC774 \uC548\uC815\uB418\uBA74 \uB9D0\uB3C4 \uD3B8\uD574\uC838\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\uADF8\uB807\uAC8C \uC0DD\uAC01\uD558\uB2C8\uAE4C \uC880 \uB35C
      \uBB34\uC12D\uB2E4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB9DE\uC544\uC694. \uADF8\uAC8C \uCCAB\uAC78\uC74C\uC774\uC5D0\uC694."
  _nemoLine: "(\uB9C8\uAD6C\uAC04 \uC55E. \uC791\uC740 \uD6C8\uB828\uC6A9 \uB9D0\uC774
    \uC900\uBE44\uB418\uC5B4 \uC788\uACE0, \uD558\uB140\uAC00 \uB124\uBAA8\uC758
    \uC7A5\uAC11\uC744 \uACE0\uCCD0 \uC900\uB2E4. \uACBD\uBE44\uB300\uC7A5\uC740
    \uACE0\uC090 \uAE38\uC774\uB97C \uB9DE\uCD94\uACE0 \uC788\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
