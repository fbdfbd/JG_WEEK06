  m_Name: event_week_005_riding_modified__step_event_week_005_riding_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uAE30\uB9C8 \uC218\uC5C5\uC744 \uC0C1\uC0C1 \uB180\uC774\uCC98\uB7FC
    \uD47C\uB2E4"
  _bodyText: "\uAE30\uB9C8 \uC218\uC5C5\uC744 \uC0C1\uC0C1 \uB180\uC774\uCC98\uB7FC
    \uD47C\uB2E4 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC2E4\uC81C \uD6C8\uB828 \uB300\uC2E0 \uB9D0\uC758 \uC6C0\uC9C1\uC784\uC744
      \uC0C1\uC0C1\uD558\uAC8C \uD558\uBA70 \uAE30\uCD08\uB97C \uC27D\uAC8C \uC124\uBA85\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC81C\uAC00 \uB9D0\uC774\uBA74 \uC5B4\uB514\uB85C \uB2EC\uB9AC\uACE0
      \uC2F6\uC744\uC9C0 \uC0DD\uAC01\uD558\uBA74 \uB3FC\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uAE34\uC7A5\uC744 \uC904\uC774\uB824 \uAC00\uBCBC\uC6B4 \uBE44\uC720\uB97C
      \uC11E\uC5B4 \uAD50\uC7AC \uB0B4\uC6A9\uC744 \uD480\uC5B4 \uC900\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uB180\uC774 \uAC19\uC544\uC11C \uB35C \uC5B4\uB835\uB2E4."
  _nemoLine: "(\uC2E4\uC81C \uD6C8\uB828 \uB300\uC2E0 \uB9D0\uC758 \uC6C0\uC9C1\uC784\uC744
    \uC0C1\uC0C1\uD558\uAC8C \uD558\uBA70 \uAE30\uCD08\uB97C \uC27D\uAC8C \uC124\uBA85\uD55C\uB2E4.)"
