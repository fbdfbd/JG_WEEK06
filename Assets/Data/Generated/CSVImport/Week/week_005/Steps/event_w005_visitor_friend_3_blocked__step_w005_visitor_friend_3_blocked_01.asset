  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w005_visitor_friend_3_blocked__step_w005_visitor_friend_3_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 5\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uB450 \uC18C\uB144\uC774 \uC9C0\uB3C4\uB97C \uBCF4\uBA70 \uC774\uC57C\uAE30\uB97C
    \uB098\uB204\uACE0 \uC788\uB2E4. \uCE5C\uAD6C 3\uC740 \uC9C0\uB3C4\uC758 \uC9C0\uD615\uBCF4\uB2E4\uB294
    \uADF8 \uC548\uC5D0 \uC228\uC5B4 \uC788\uC744 \uBC95\uD55C \uAD34\uBB3C\uB4E4\uC5D0
    \uB354 \uAD00\uC2EC\uC774 \uB9CE\uB2E4.)\n        \n        \uCE5C\uAD6C 3 :
    \uC57C, \uC5EC\uAE30 \uC774 \uAE4A\uC740 \uC232 \uC788\uC9C0? \uC5EC\uAE30 \uBD84\uBA85\uD788
    \uBA38\uB9AC \uC138 \uAC1C \uB2EC\uB9B0 \uAC1C\uAC00 \uC0B4 \uAC70\uC57C. \uC6B0\uB9AC
    \uC544\uBE60\uAC00 \uADF8\uB7AC\uC5B4, \uC5EC\uAE30 \uB4E4\uC5B4\uAC00\uBA74
    \uC544\uBB34\uB3C4 \uBABB \uB098\uC628\uB2E4\uACE0.\n        \uB124\uBAA8 : \uC5D0\uC774,
    \uADF8\uAC74 \uC804\uC124\uC774\uC9C0. \uBC31\uC791\uB2D8\uC774 \uC5EC\uAE30\uB294
    \uADF8\uB0E5 \uC9C0\uBC18\uC774 \uC57D\uD574\uC11C \uC704\uD5D8\uD558\uB2E4\uACE0
    \uD558\uC168\uC5B4.\n        \uCE5C\uAD6C 3 : \uC9C0\uBC18\uC774 \uC57D\uD55C
    \uAC8C \uC544\uB2C8\uB77C \uAD34\uBB3C\uC774 \uB545\uC744 \uD30C\uC11C \uADF8\uB7F0
    \uAC70\uB77C\uB2C8\uAE4C! \uC5EC\uAE30\uB2E4 '\uAD34\uBB3C \uC8FC\uC758'\uB77C\uACE0
    \uC801\uC5B4\uB458\uAE4C?\n        \n\n(\uCE5C\uAD6C 3\uC774 \uAE43\uD39C\uC744
    \uB4E4\uC790, \uACBD\uBE44\uB300\uC7A5\uC774 \uC9C0\uB3C4\uB97C \uD655 \uB09A\uC544\uCC44\uC11C
    \uD1B5\uC5D0 \uC9D1\uC5B4\uB123\uB294\uB2E4.)\n        \uACBD\uBE44\uB300\uC7A5
    : \uC601\uC9C0 \uC9C0\uB3C4\uB294 \uC7A5\uB09C\uC744 \uC704\uD55C \uB3C4\uAD6C\uAC00
    \uC544\uB2D9\uB2C8\uB2E4. \uD5C8\uBB34\uB9F9\uB791\uD55C \uC18C\uB9AC\uB85C \uC8FC\uC778\uB2D8\uC758
    \uAE30\uB85D\uC744 \uC624\uC5FC\uC2DC\uD0A4\uC9C0 \uB9C8\uC2ED\uC2DC\uC624.\n       
    \uB124\uBAA8 : (\uCE5C\uAD6C 3\uC744 \uAC10\uC2F8\uBA70) \uC544\uC800\uC528,
    \uADF8\uB0E5 \uB18D\uB2F4\uC774\uC796\uC544\uC694! \uB108\uBB34 \uC815\uC0C9\uD558\uC9C0
    \uB9C8\uC138\uC694.\n        \uCE5C\uAD6C 3 : (\uC5B4\uAE68\uB97C \uC73C\uC4F1\uD558\uBA70)
    \uB124\uBAA8\uC57C, \uC800 \uC544\uC800\uC528 \uB108\uBB34 \uBB34\uC12D\uB2E4.
    \uC5EC\uAE30\uB294 \uC6C3\uC74C\uC18C\uB9AC\uB3C4 \uAC80\uC5F4\uBC1B\uB294 \uACF3\uC774\uC57C?
    \uB098 \uADF8\uB0E5 \uB098\uAC08\uB798.\n        \uB124\uBAA8 : (\uB2F9\uD669\uD558\uBA70)
    \uC544\uB2C8, \uADF8\uAC8C \uC544\uB2C8\uB77C... \uBBF8\uC548\uD574, \uB0B4\uAC00
    \uB098\uC911\uC5D0 \uC0AC\uACFC\uD560\uAC8C."
  _dialogueLines: []
