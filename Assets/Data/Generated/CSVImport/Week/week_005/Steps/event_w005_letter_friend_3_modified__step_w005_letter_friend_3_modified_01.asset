  m_Name: event_w005_letter_friend_3_modified__step_w005_letter_friend_3_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 5\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C
    \uADC0\uD241\uC774\uC5D0 \uBCF4\uB77C\uC0C9 \uC789\uD06C \uC790\uAD6D\uC774 \uBC88\uC838
    \uC788\uB2E4.)\r\n    \uD558\uB140 : \uC8FC\uC778\uB2D8 \uC55E\uC73C\uB85C \uC628
    \uD3B8\uC9C0\uC785\uB2C8\uB2E4. \uC774\uBC88\uC5D4 \uC789\uD06C\uB97C \uC880
    \uD758\uB9B0 \uBAA8\uC591\uC774\uB124\uC694.\r\n        \r\n\r\n\uD558\uB140
    : \uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC9C0\uB09C\uBC88\uC5D0 \uC11C\uC7AC\uC5D0\uC11C
    \uC788\uC5C8\uB358 \uC77C\uC744 \uC544\uC8FC \uB9C8\uBC95 \uAC19\uC740 \uC77C\uB85C
    \uAE30\uC5B5\uD558\uACE0 \uC788\uB124\uC694.\r\n        \uB124\uBAA8 : \uB9C8\uBC95?
    \uBB34\uC2A8 \uB9C8\uBC95?\r\n        \uD558\uB140 : \uC789\uD06C \uBCD1 \uD558\uB098\uB97C
    \uB9CC\uC9C0\uB294 \uC21C\uAC04\uC5D0\uB3C4 \uC2E0\uBE44\uD55C \uC77C\uC774 \uC77C\uC5B4\uB098\uB294
    \uAC83 \uAC19\uC558\uB300\uC694. \uC8FC\uC778\uB2D8\uACFC \uD568\uAED8 \uC788\uC73C\uBA74
    \uBAA8\uB4E0 \uAC8C \uD2B9\uBCC4\uD574 \uBCF4\uC778\uB2E4\uACE0 \uD569\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : \uC789\uD06C \uBCD1\uC774 \uD2B9\uBCC4\uD574 \uBCF4\uC778\uB2E4\uACE0?\r\n       
    \uD558\uB140 : \uB124. \uC8FC\uC778\uB2D8\uACFC \uB178\uB294 \uAC8C \uADF8\uB9CC\uD07C
    \uC990\uAC70\uC6E0\uB098 \uBD05\uB2C8\uB2E4.\r\n        \uB124\uBAA8 : \uAC54\uB294
    \uC9C4\uC9DC \uD2B9\uC774\uD574. \uADF8\uB798\uB3C4 \uB2E4\uC74C\uC5D4 \uBB34\uC2A8
    \uC18C\uB9B4 \uD560\uC9C0 \uAD81\uAE08\uD574."
