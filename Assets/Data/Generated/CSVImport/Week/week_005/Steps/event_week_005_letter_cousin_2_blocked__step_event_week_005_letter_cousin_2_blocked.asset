  _titleOverride: cousin_2 Blocked
  _bodyText: "letter cousin_2 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uB294 \uBD09\uD22C \uC18D\uC758 \uB531\uB531\uD55C \uBB3C\uAC74\uC744
      \uD655\uC778\uD558\uB354\uB2C8 \"\uC678\uBD80 \uBB3C\uAC74\uC740 \uC704\uD5D8\uD574\"\uB77C\uBA70
      \uD1B5\uC9F8\uB85C \uBC18\uB0A9\uD568\uC5D0 \uB123\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uCC3D\uAC00\uC5D0 \uC11C\uC11C \uC0AC\uCD0C 2\uAC00
      \uC5EC\uD589\uC744 \uC798 \uAC14\uC744\uAE4C \uBA4D\uD558\uB2C8 \uC0DD\uAC01\uD558\uACE0
      \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\u2026\u2026\uC774\uB7F0 \uAC74 \uB098\uC911\uC5D0 \uAC80\uC0AC\uAC00
      \uB05D\uB09C \uB4A4\uC5D0 \uB4DC\uB824\uC57C\uC9C0."
  _nemoLine: "(\uD558\uB140\uB294 \uBD09\uD22C \uC18D\uC758 \uB531\uB531\uD55C \uBB3C\uAC74\uC744
    \uD655\uC778\uD558\uB354\uB2C8 \"\uC678\uBD80 \uBB3C\uAC74\uC740 \uC704\uD5D8\uD574\"\uB77C\uBA70
    \uD1B5\uC9F8\uB85C \uBC18\uB0A9\uD568\uC5D0 \uB123\uB294\uB2E4.)"
