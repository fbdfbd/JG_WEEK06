--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_astronomy_modified__step_event_week_005_astronomy_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C \uAC19\uC740 \uBCC4\uBD80\uD130 \uC775\uD78C\uB2E4"
  _bodyText: "\uBCC4\uC790\uB9AC\uC640 \uD56D\uD574 5\uC8FC\uCC28 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBC24. \uC11C\uC7AC \uCC3D\uAC00\uC640 \uD14C\uB77C\uC2A4\uC5D0 \uC791\uC740
      \uBCC4\uC790\uB9AC\uD310\uACFC \uBC29\uC704\uCE68\uC774 \uB193\uC5EC \uC788\uB2E4.
      \uD558\uB140\uAC00 \uCC3D\uBB38\uC744 \uC5F4\uC5B4 \uBC24\uD558\uB298\uC744
      \uBCF4\uC5EC \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uBCC4\uC758 \uC774\uB984\uBCF4\uB2E4
      \uBA3C\uC800 \uAE38\uC7A1\uC774 \uBCC4\uC744 \uCC3E\uB294 \uC5F0\uC2B5\uC744
      \uD560 \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB0E5 \uC608\uC05C \uBCC4 \uBCF4\uB294 \uC2DC\uAC04\uC774 \uC544\uB2C8\uAD6C\uB098."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uBCC4\uC790\uB9AC\uD310 \uC704\uC5D0 \uC791\uC740
      \uC740\uC0C9 \uAD6C\uC2AC\uC744 \uC62C\uB824 \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uAE38\uC7A1\uC774 \uBCC4\uB9CC
      \uBA3C\uC800 \uCE5C\uAD6C\uCC98\uB7FC \uAE30\uC5B5\uD574 \uBCFC\uAE4C\uC694?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uCE5C\uAD6C\uCC98\uB7FC?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uB298 \uAC19\uC740 \uC790\uB9AC\uC5D0 \uBA3C\uC800 \uB208\uC5D0
      \uB744\uB294 \uBCC4\uC774\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544, \uADF8\uB807\uAC8C \uC0DD\uAC01\uD558\uB2C8\uAE4C \uC26C\uC6CC.
      \uC81C\uC77C \uBA3C\uC800 \uC778\uC0AC\uD558\uB294 \uBCC4\uC774\uB124."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB9DE\uC544\uC694. \uADF8 \uBCC4\uBD80\uD130 \uC775\uD788\uBA74 \uB429\uB2C8\uB2E4."
  _nemoLine: "(\uBC24. \uC11C\uC7AC \uCC3D\uAC00\uC640 \uD14C\uB77C\uC2A4\uC5D0 \uC791\uC740
    \uBCC4\uC790\uB9AC\uD310\uACFC \uBC29\uC704\uCE68\uC774 \uB193\uC5EC \uC788\uB2E4.
    \uD558\uB140\uAC00 \uCC3D\uBB38\uC744 \uC5F4\uC5B4 \uBC24\uD558\uB298\uC744 \uBCF4\uC5EC
    \uC900\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
