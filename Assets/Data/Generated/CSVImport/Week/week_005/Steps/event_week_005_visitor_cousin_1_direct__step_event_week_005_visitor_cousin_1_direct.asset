  _titleOverride: cousin_1 Direct
  _bodyText: "visitor cousin_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uCC3D\uD2C0\uC5D0 \uD131\uC744 \uAD34\uACE0 \uC0BC\uCD0C\uC758
      \uC774\uC57C\uAE30\uB97C \uB4E3\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC0BC\uCD0C\uC740 \uC800\uAE30 \uB098\uAC00\uBA74 \uBB50\uBD80\uD130
      \uD574\uC694? \uC9C4\uC9DC \uC591\uAF2C\uCE58\uBD80\uD130 \uBA39\uC5B4\uC694?"
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uADF8\uB7FC! \uC2DC\uC6D0\uD55C \uD3EC\uB3C4 \uC8FC\uC2A4 \uD55C \uC794
      \uB4E4\uC774\uCF1C\uACE0, \uAD11\uC7A5\uC5D0\uC11C \uCDA4\uCD94\uB294 \uC0AC\uB78C\uB4E4
      \uAD6C\uACBD\uB3C4 \uD558\uACE0... \uC5B4\uB54C, \uC0C1\uC0C1\uB9CC \uD574\uB3C4
      \uADFC\uC0AC\uD558\uC9C0?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uB208\uC744 \uAC10\uC73C\uBA70) \uB124... \uBC31\uC791\uB2D8\uC774
      \uB4E4\uB824\uC8FC\uC2DC\uB294 \uC5ED\uC0AC \uC774\uC57C\uAE30\uBCF4\uB2E4
      \uC0BC\uCD0C\uC774 \uD574\uC8FC\uB294 \uC2DC\uC7A5 \uC774\uC57C\uAE30\uAC00
      \uD6E8\uC52C \uC0DD\uC0DD\uD574\uC11C \uC88B\uC544\uC694. \uB098\uC911\uC5D0
      \uAF2D \uAC19\uC774 \uAC00\uC694!"
  _nemoLine: "(\uB124\uBAA8\uAC00 \uCC3D\uD2C0\uC5D0 \uD131\uC744 \uAD34\uACE0 \uC0BC\uCD0C\uC758
    \uC774\uC57C\uAE30\uB97C \uB4E3\uB294\uB2E4.)"
