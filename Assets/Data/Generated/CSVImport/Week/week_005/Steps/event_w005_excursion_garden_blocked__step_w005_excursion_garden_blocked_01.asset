  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w005_excursion_garden_blocked__step_w005_excursion_garden_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 5\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uB9D1\uC740 \uC624\uC804. \uB124\uBAA8\uAC00 \uC815\uC6D0 \uAC00\uC7A5\uC790\uB9AC
    \uBCA4\uCE58\uC5D0 \uC549\uC544 \uCC45\uC7A5\uC744 \uB118\uAE30\uACE0 \uC788\uB2E4.
    \uADF8\uB54C \uC791\uC740 \uC0B0\uC0C8 \uD55C \uB9C8\uB9AC\uAC00 \uB09C\uAC04\uC5D0
    \uB0B4\uB824\uC549\uB294\uB2E4.)\n        \n        \uB124\uBAA8 : \uC5B4?\n       
    \n        \uB124\uBAA8 : \uB108 \uB610 \uC654\uB124.\n        \n        (\uC0C8\uB294
    \uC804\uD600 \uAC81\uB0B4\uC9C0 \uC54A\uACE0 \uACE0\uAC1C\uB97C \uAC38\uC6C3\uD55C\uB2E4.
    \uB124\uBAA8\uAC00 \uC190\uC744 \uC870\uAE08 \uB0B4\uBC00\uC790, \uC0B0\uC0C8\uB294
    \uC624\uD788\uB824 \uB354 \uAC00\uAE4C\uC774 \uB2E4\uAC00\uC628\uB2E4.)\n       
    \n        \uB124\uBAA8 : \uBB50\uC57C.\n        \n        \uB124\uBAA8 : \uB108
    \uC0AC\uB78C \uC548 \uBB34\uC11C\uC6CC\uD574?\n        \n        (\uADF8 \uC21C\uAC04,
    \uB4A4\uCABD\uC5D0\uC11C \uD558\uB140 \uD558\uB098\uAC00 \uB180\uB780 \uB4EF
    \uBA48\uCE6B\uD55C\uB2E4. \uB2E4\uB978 \uD558\uB140\uAC00 \uAE09\uD788 \uC791\uC740
    \uACE1\uC2DD \uC8FC\uBA38\uB2C8\uB97C \uAC10\uCD98\uB2E4.)\n        \n       
    \uB124\uBAA8 : \u2026\uC65C \uADF8\uB798?\n        \n        \uD558\uB140 : \uC544\uB2D9\uB2C8\uB2E4,
    \uC8FC\uC778\uB2D8.\n        \n        (\uB124\uBAA8\uAC00 \uBCA4\uCE58 \uC544\uB798\uB97C
    \uBCF4\uB2C8, \uAC19\uC740 \uC790\uB9AC\uC5D0 \uACE1\uC2DD \uBA87 \uC54C\uC774
    \uC544\uC8FC \uAC00\uC9C0\uB7F0\uD788 \uB193\uC5EC \uC788\uB2E4.)\n        \n       
    \uB124\uBAA8 : \uC774\uAC70 \uB204\uAC00 \uB454 \uAC70\uC57C?\n        \n\n(\uD558\uB140\uAC00
    \uAE09\uD788 \uBCA4\uCE58 \uC544\uB798 \uACE1\uC2DD\uC744 \uC190\uC218\uAC74\uC73C\uB85C
    \uC4F8\uC5B4 \uB2F4\uB294\uB2E4.)\n        \n        \uD558\uB140 : \uC0C8\uAC00
    \uC790\uAFB8 \uB0B4\uB824\uC640 \uC5B4\uC9C0\uB7FD\uD600\uC11C \uCE58\uC6B0\uB824\uB358
    \uAC81\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.\n        \n        \uB124\uBAA8 : \uADFC\uB370
    \uC65C \uB9E8\uB0A0 \uC5EC\uAE30 \uC640?\n        \n        \uD558\uB140 : \uD587\uBE5B\uC774
    \uC88B\uACE0, \uC0C8\uAC00 \uC88B\uC544\uD560 \uB9CC\uD55C \uC790\uB9AC\uC778\uAC00
    \uBCF4\uC9C0\uC694.\n        \n        \uB124\uBAA8 : \uADF8\uAC83\uCE58\uACE4
    \uB108\uBB34 \uC548 \uB3C4\uB9DD\uAC00\uB294\uB370.\n        \n        \uD558\uB140
    : \uC0AC\uB78C \uC190\uC744 \uB35C \uD0C0\uC11C \uADF8\uB7F0 \uC0C8\uB3C4 \uC788\uB2F5\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uC774\uC0C1\uD558\uAE34 \uD55C\uB370, \uC608\uC058\uBA74
    \uB410\uB098.\n        \n        (\uC0B0\uC0C8\uAC00 \uC9E7\uAC8C \uC6B8\uACE0\uB294
    \uB0A0\uC544\uAC04\uB2E4.)\n        \n        \uB124\uBAA8 : \uAC00\uB124....\uC870\uAE08
    \uB354 \uC788\uC5B4\uB3C4 \uB410\uB294\uB370."
