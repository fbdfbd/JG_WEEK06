  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_excursion_garden_blocked__step_event_week_005_excursion_garden_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: garden Blocked
  _bodyText: "excursion garden Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uAE09\uD788 \uBCA4\uCE58 \uC544\uB798 \uACE1\uC2DD\uC744
      \uC190\uC218\uAC74\uC73C\uB85C \uC4F8\uC5B4 \uB2F4\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC0C8\uAC00 \uC790\uAFB8 \uB0B4\uB824\uC640 \uC5B4\uC9C0\uB7FD\uD600\uC11C
      \uCE58\uC6B0\uB824\uB358 \uAC81\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADFC\uB370 \uC65C \uB9E8\uB0A0 \uC5EC\uAE30 \uC640?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uD587\uBE5B\uC774 \uC88B\uACE0, \uC0C8\uAC00 \uC88B\uC544\uD560 \uB9CC\uD55C
      \uC790\uB9AC\uC778\uAC00 \uBCF4\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC83\uCE58\uACE4 \uB108\uBB34 \uC548 \uB3C4\uB9DD\uAC00\uB294\uB370."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC0AC\uB78C \uC190\uC744 \uB35C \uD0C0\uC11C \uADF8\uB7F0 \uC0C8\uB3C4
      \uC788\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uC0C1\uD558\uAE34 \uD55C\uB370, \uC608\uC058\uBA74 \uB410\uB098."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC0B0\uC0C8\uAC00 \uC9E7\uAC8C \uC6B8\uACE0\uB294 \uB0A0\uC544\uAC04\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC00\uB124....\uC870\uAE08 \uB354 \uC788\uC5B4\uB3C4 \uB410\uB294\uB370."
  _nemoLine: "(\uD558\uB140\uAC00 \uAE09\uD788 \uBCA4\uCE58 \uC544\uB798 \uACE1\uC2DD\uC744
    \uC190\uC218\uAC74\uC73C\uB85C \uC4F8\uC5B4 \uB2F4\uB294\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
