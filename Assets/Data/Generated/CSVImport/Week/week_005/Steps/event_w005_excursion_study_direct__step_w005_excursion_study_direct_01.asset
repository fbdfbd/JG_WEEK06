  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w005_excursion_study_direct__step_w005_excursion_study_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC 5\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uBC31\uC791\uC758 \uCC45\uC0C1 \uC704, \uAC00\uC7A5 \uC911\uC694\uD55C
    \uC9C1\uC778\uD568 \uC606\uC5D0 \uB0A1\uC740 \uC561\uC790 \uD558\uB098\uAC00
    \uB193\uC5EC \uC788\uB2E4. \uB124\uBAA8\uAC00 \uB2E4\uAC00\uAC00 \uBCF4\uB2C8,
    6\uC0B4 \uB54C \uC11C\uD234\uAC8C \uADF8\uB9B0 \uBC31\uC791\uC758 \uC5BC\uAD74\uACFC
    '\uC544\uC800\uC528 \uBC14\uBCF4'\uB77C\uACE0 \uC801\uD78C \uB099\uC11C \uC11C\uB958\uAC00
    \uC18C\uC911\uD558\uAC8C \uB07C\uC6CC\uC838 \uC788\uB2E4.)\r\n        \r\n       
    \uB124\uBAA8 : \uC73C\uC545, \uC774\uAC8C \uC65C \uC544\uC9C1\uB3C4 \uC5EC\uAE30
    \uC788\uC5B4!\r\n        (\uC5BC\uAD74\uC774 \uD654\uB048\uAC70\uB9AC\uB294\uC9C0
    \uB124\uBAA8\uAC00 \uC561\uC790\uB97C \uB4A4\uB85C \uB3CC\uB824\uB193\uC73C\uB824
    \uD558\uC9C0\uB9CC, \uC561\uC790\uB294 \uCC45\uC0C1 \uBC14\uB2E5\uC5D0 \uB2E8\uB2E8\uD788
    \uACE0\uC815\uB418\uC5B4 \uC788\uB2E4.)\r\n        \r\n        \uB124\uBAA8 :
    \uC9C4\uC9DC \uBABB \uB9D0\uB824. \uC774\uB7F0 \uCC3D\uD53C\uD55C \uAC78 \uC7A5\uC2DD\uD574
    \uB450\uB2E4\uB2C8.\r\n        \r\n\r\n(\uC561\uC790 \uC606\uC5D0 \uBE48 \uC885\uC774\uC640
    \uAE43\uD39C \uD558\uB098\uAC00 \uC815\uAC08\uD558\uAC8C \uB193\uC5EC \uC788\uB294
    \uAC83\uC744 \uBC1C\uACAC\uD55C\uB2E4.)\r\n        \uB124\uBAA8 : \uC774\uAC74
    \uB610 \uBB50\uC57C? \uC0C8\uB85C \uADF8\uB9AC\uB77C\uB294 \uAC74\uAC00?\r\n       
    (\uC885\uC774 \uBC11\uC5D0 '\uC2E4\uB825\uC774 \uB298\uC5C8\uB294\uC9C0 \uD655\uC778\uD558\uACA0\uB2E4'\uB77C\uB294
    \uBC31\uC791\uC758 \uC9E7\uC740 \uCABD\uC9C0\uAC00 \uC788\uB2E4.)\r\n       
    \uB124\uBAA8 : \uD765, \uC9C0\uAE08 \uADF8\uB9AC\uBA74 \uD6E8\uC52C \uC798 \uADF8\uB9B4
    \uD150\uB370.\r\n        (\uB124\uBAA8\uAC00 \uD22C\uB35C\uB300\uBA74\uC11C\uB3C4
    \uD39C\uC744 \uB4E4\uC5B4 \uC561\uC790 \uC18D \uB099\uC11C \uC606\uC5D0 \uD604\uC7AC
    \uBC31\uC791\uC758 \uC606\uBAA8\uC2B5\uC744 \uC870\uC2EC\uC2A4\uB808 \uADF8\uB9AC\uAE30
    \uC2DC\uC791\uD55C\uB2E4.)"
