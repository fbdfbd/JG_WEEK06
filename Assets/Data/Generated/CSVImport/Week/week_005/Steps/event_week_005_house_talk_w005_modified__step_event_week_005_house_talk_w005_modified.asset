  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_house_talk_w005_modified__step_event_week_005_house_talk_w005_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: w005 Modified
  _bodyText: "house_talk w005 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: ea8bb1cd384c18f4c83d6f267d5433b5, type: 2}
    _text: "\uD53C\uC544\uB178 \uC904\uC774 \uBC24\uC5D0 \uAE30\uC628\uC774 \uB0AE\uC544\uC9C0\uBA74
      \uC218\uCD95\uD558\uBA74\uC11C \uAC00\uB054 \uB775- \uD558\uB294 \uC18C\uB9AC\uAC00
      \uB098\uAE30\uB3C4 \uD55C\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC904\uC774 \uC904\uC5B4\uB4E4\uC5B4\uC11C?"
  - _speaker: {fileID: 11400000, guid: 382a01f86413cfc439d75f63e427a411, type: 2}
    _text: "\uB124. \uD53C\uC544\uB178\uAC00 \"\uCD94\uC6CC\uC694~\" \uD558\uACE0
      \uAE30\uC9C0\uAC1C\uB97C \uCF1C\uB294 \uC18C\uB9AC\uB77C\uACE0 \uC0DD\uAC01\uD558\uBA74
      \uB3FC\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544, \uD53C\uC544\uB178\uB3C4 \uC7A0\uAF2C\uB300\uD558\uB294 \uAC70\uAD6C\uB098!"
  - _speaker: {fileID: 11400000, guid: ea8bb1cd384c18f4c83d6f267d5433b5, type: 2}
    _text: "\uB9DE\uC544\uC694. \uC544\uC8FC \uC790\uC5F0\uC2A4\uB7EC\uC6B4 \uC77C\uC774\uB2C8
      \uB180\uB77C\uC9C0 \uB9C8\uC138\uC694, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD788\uD788, \uC2E0\uAE30\uD558\uB2E4. \uD53C\uC544\uB178 \uC7A0\uAF2C\uB300
      \uC18C\uB9AC \uB098\uB3C4 \uB4E4\uC5B4\uBCF4\uACE0 \uC2F6\uC5B4."
  _nemoLine: "\uD53C\uC544\uB178 \uC904\uC774 \uBC24\uC5D0 \uAE30\uC628\uC774 \uB0AE\uC544\uC9C0\uBA74
    \uC218\uCD95\uD558\uBA74\uC11C \uAC00\uB054 \uB775- \uD558\uB294 \uC18C\uB9AC\uAC00
    \uB098\uAE30\uB3C4 \uD55C\uB300\uC694."
  _useCustomVisualState: 0
  _visualState: 0
