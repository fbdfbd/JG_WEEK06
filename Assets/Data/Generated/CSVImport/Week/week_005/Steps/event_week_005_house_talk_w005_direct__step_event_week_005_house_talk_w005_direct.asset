  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_house_talk_w005_direct__step_event_week_005_house_talk_w005_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC218\uC0C1\uD55C \uD53C\uC544\uB178 \uC18C\uBB38 \uD5C8\uAC00"
  _bodyText: "house_talk w005 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: ea8bb1cd384c18f4c83d6f267d5433b5, type: 2}
    _text: "\uC800\uD0DD\uC774 \uB108\uBB34 \uC870\uC6A9\uD558\uBA74 \uAC00\uB054
      \uD53C\uC544\uB178\uAC00 \uC2EC\uC2EC\uD574\uC11C \uC2A4\uC2A4\uB85C \uC18C\uB9AC\uB97C
      \uB0B8\uB2E4\uB294 \uC774\uC57C\uAE30\uAC00 \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD53C\uC544\uB178\uB3C4 \uC2EC\uC2EC\uD574?"
  - _speaker: {fileID: 11400000, guid: 382a01f86413cfc439d75f63e427a411, type: 2}
    _text: "\uB124. \uC544\uBB34\uB3C4 \uC5F0\uC8FC\uD574 \uC8FC\uC9C0 \uC54A\uC73C\uBA74
      \uC544\uC8FC \uC791\uAC8C \uB529- \uD558\uACE0 \uC6B8\uB9B0\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5C9, \uADC0\uC2E0\uC778\uAC00?"
  - _speaker: {fileID: 11400000, guid: ea8bb1cd384c18f4c83d6f267d5433b5, type: 2}
    _text: "\uADC0\uC2E0\uC774\uB77C\uAE30\uBCF4\uB2E8, \uB178\uB798\uD558\uACE0
      \uC2F6\uC740 \uB9C8\uC74C\uC774 \uB0A8\uC740 \uAC70 \uC544\uB2D0\uAE4C\uC694?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC870\uAE08 \uBB34\uC12D\uC9C0\uB9CC... \uB2E4\uC74C\uC5D4 \uB0B4\uAC00
      \uAC00\uC11C \uD55C \uBC88 \uCCD0\uC904\uAE4C \uBD10."
  _nemoLine: "\uC800\uD0DD\uC774 \uB108\uBB34 \uC870\uC6A9\uD558\uBA74 \uAC00\uB054
    \uD53C\uC544\uB178\uAC00 \uC2EC\uC2EC\uD574\uC11C \uC2A4\uC2A4\uB85C \uC18C\uB9AC\uB97C
    \uB0B8\uB2E4\uB294 \uC774\uC57C\uAE30\uAC00 \uC788\uC5B4\uC694."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
