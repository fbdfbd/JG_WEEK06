  m_Name: event_w005_visitor_friend_1_blocked__step_w005_visitor_friend_1_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 5\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uB450 \uC18C\uB144\uC774 \uBC31\uC791\uC758 \uC601\uC9C0 \uC9C0\uB3C4\uB97C
    \uD3BC\uCCD0\uB193\uACE0 \uBA38\uB9AC\uB97C \uB9DE\uB300\uACE0 \uC788\uB2E4.
    \uCE5C\uAD6C 1\uC774 \uC9C0\uB3C4 \uC704\uC758 \uD55C \uC9C0\uC810\uC744 \uCF55
    \uCC0D\uC73C\uBA70 \uB208\uC744 \uBE5B\uB0B8\uB2E4.)\n        \n        \uCE5C\uAD6C
    1 : \uB124\uBAA8, \uC5EC\uAE30 \uBD10! \uC800\uBC88\uC5D0 \uC6B0\uB9AC \uC544\uBE60\uAC00
    \uB9D0\uD574\uC900 \uBE44\uBC00 \uB3D9\uAD74\uC774 \uC5EC\uAE30\uCBE4\uC77C\uAC78?
    \uC6B0\uB9AC \uB0B4\uC77C \uC5EC\uAE30\uB85C \uBAA8\uD5D8 \uAC00\uC790!\n       
    \uB124\uBAA8 : \uBE44\uBC00 \uB3D9\uAD74? \uC9C4\uC9DC \uBCF4\uBB3C \uC788\uB294
    \uAC70 \uC544\uB0D0? \uB098\uB3C4 \uAC00\uBCF4\uACE0 \uC2F6\uC5B4!\n        \uCE5C\uAD6C
    1 : \uADF8\uB7FC \uC5EC\uAE30\uB2E4 \uD45C\uC2DC\uD574\uB46C. \uC78A\uC5B4\uBC84\uB9AC\uC9C0
    \uC54A\uAC8C!\n        \n\n(\uCE5C\uAD6C 1\uC774 \uD39C\uC744 \uB4E4\uC790\uB9C8\uC790
    \uACBD\uBE44\uB300\uC7A5\uC774 \uB2E4\uAC00\uC640 \uC9C0\uB3C4\uB97C \uAC00\uB85C\uB9C9\uB294\uB2E4.)\n       
    \uACBD\uBE44\uB300\uC7A5 : \uC601\uC9C0 \uC9C0\uB3C4\uB294 \uAD70\uC0AC \uAE30\uBC00\uACFC
    \uAC19\uC2B5\uB2C8\uB2E4. \uD568\uBD80\uB85C \uD45C\uC2DD\uC744 \uB0A8\uAE30\uB294
    \uD589\uC704\uB294 \uBC18\uC5ED\uC5D0 \uC900\uD558\uB294 \uC5C4\uBC8C\uC5D0 \uCC98\uD574\uC9C8
    \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n        \uCE5C\uAD6C 1 : (\uAE5C\uC9DD \uB180\uB77C
    \uD39C\uC744 \uB5A8\uC5B4\uB728\uB9AC\uBA70) \uBC14, \uBC18\uC5ED\uC694? \uADF8\uB0E5
    \uB3D9\uAD74 \uD45C\uC2DC \uC880 \uD558\uB824\uB358 \uAC74\uB370...\n       
    \uB124\uBAA8 : (\uACBD\uBE44\uB300\uC7A5 \uC55E\uC744 \uB9C9\uC73C\uBA70) \uC544\uC800\uC528,
    \uC560\uD55C\uD14C \uB108\uBB34 \uAC81\uC8FC\uC9C0 \uB9C8\uC138\uC694! \uCE5C\uAD6C
    1, \uBBF8\uC548\uD574. \uBC31\uC791\uB2D8\uC774 \uC774\uB7F0 \uAC70\uC5D0 \uB418\uAC8C
    \uC608\uBBFC\uD558\uC2DC\uAC70\uB4E0.\n        \uCE5C\uAD6C 1 : \uB098... \uBB34\uC11C\uC6CC\uC11C
    \uB354 \uBABB \uC788\uACA0\uC5B4. \uADF8\uB0E5 \uB098\uAC08\uB798..."
