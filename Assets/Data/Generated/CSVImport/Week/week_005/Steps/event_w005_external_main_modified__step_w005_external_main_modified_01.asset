  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w005_external_main_modified__step_w005_external_main_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "5\uCC28 - \uC218\uC815"
  _bodyText: "(\uC131\uBB38 \uADFC\uCC98, \uBCF4\uBD80\uC0C1\uC774 \uC9D0\uC744 \uD480\uBA70
    \uD558\uB140\uB4E4\uC5D0\uAC8C \uC2DC\uC7A5 \uD1B5 \uC18C\uC2DD\uC744 \uC804\uD55C\uB2E4.)\r\n   
    \uBCF4\uBD80\uC0C1 : \uC774\uBC88\uC5D0 \uC774\uC6C3 \uB9C8\uC744 \uC601\uC8FC\uB124
    \uCC3D\uACE0\uAC00 \uD138\uB838\uB2E4\uC9C0 \uBB50\uC57C? \uADF8\uB7F0\uB370
    \uC2E0\uAE30\uD558\uAC8C\uB3C4 \uAE08\uD654\uB9CC \uC3D9 \uBE7C\uAC00\uACE0 \uAC00\uB09C\uD55C
    \uC0AC\uB78C\uB4E4 \uC9D1 \uC55E\uC5D0 \uB480\uB2E4\uB354\uAD70.\r\n    \uD558\uB140
    : \uC5B4\uBA38, \uADF8\uB7FC \uADF8 \uC18C\uBB38\uC758 '\uADF8\uB9BC\uC790 \uAE30\uC0AC'\uAC00
    \uC9C4\uC9DC \uC788\uB294 \uAC70\uC57C?\r\n    \uB124\uBAA8 : \uADF8\uB9BC\uC790
    \uAE30\uC0AC? \uB098\uC05C \uC0AC\uB78C\uC774\uC57C?\r\n    \r\n\r\n\uBCF4\uBD80\uC0C1
    : \uC0AC\uC2E4\uC740 \uC601\uC8FC\uB2D8\uC774 \uB9C8\uC744 \uCD95\uC81C\uB97C
    \uD558\uB824\uACE0 \uBAB0\uB798 \uC120\uBB3C\uC744 \uC900\uBE44\uD558\uC2E0 \uAC70\uB798\uC694.\r\n   
    \uB124\uBAA8 : \uC120\uBB3C\uC744 \uBAB0\uB798 \uC918?\r\n    \uD558\uB140 :
    \uAE5C\uC9DD \uB180\uB77C\uAC8C \uD574\uC8FC\uB824\uACE0 \uB3C4\uB451\uB9DE\uC740
    \uCC99 \uC5F0\uAE30\uB97C \uD558\uC2E0 \uBAA8\uC591\uC774\uC5D0\uC694. \uCC38
    \uB2E4\uC815\uD55C \uBD84\uC774\uC8E0?\r\n    \uB124\uBAA8 : \uC544, \uADF8\uB7FC
    \uADF8\uB9BC\uC790 \uAE30\uC0AC\uB294 \uADF8\uB0E5 \uC601\uC8FC\uB2D8\uC774 \uBCC0\uC7A5\uD55C
    \uAC70\uAD6C\uB098!"
