  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_external_w005_blocked__step_event_week_005_external_w005_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uADF8\uB9BC\uC790 \uAE30\uC0AC \uC18C\uBB38 \uD1B5\uC81C"
  _bodyText: "external w005 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: bb92d18cb19ba9944ac71077eb8aa4c5, type: 2}
    _text: "(\uC785\uC744 \uAFB9 \uB2E4\uBB3C\uBA70) \uC544\uC774\uACE0, \uC81C\uAC00
      \uD5DB\uC18C\uB9AC\uB97C \uD588\uB124\uC694. \uADF8\uB0E5 \uC2DC\uC7A5\uD1B5
      \uC7A5\uB09C\uAFBC\uB4E4 \uC774\uC57C\uAE30\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uB3C4\uB451\uB188 \uC774\uC57C\uAE30\uB294 \uB4E4\uC5B4\uC11C
      \uC88B\uC744 \uAC70 \uC5C6\uC5B4\uC694. \uC5B4\uC11C \uC11C\uC7AC\uB85C \uAC00\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAE08\uD654\uB97C \uB098\uB220\uC92C\uB2E4\uBA70! \uADF8\uAC8C \uC65C
      \uB3C4\uB451\uC774\uC57C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB0A8\uC758 \uAC83\uC744 \uAC00\uC838\uAC00\uBA74 \uBB34\uC870\uAC74
      \uB3C4\uB451\uC774\uC9C0\uC694. \uBC31\uC791\uB2D8\uC774 \uB4E4\uC73C\uC2DC\uBA74
      \uB178\uD558\uC2E4 \uAC70\uC608\uC694."
  _nemoLine: "(\uC785\uC744 \uAFB9 \uB2E4\uBB3C\uBA70) \uC544\uC774\uACE0, \uC81C\uAC00
    \uD5DB\uC18C\uB9AC\uB97C \uD588\uB124\uC694. \uADF8\uB0E5 \uC2DC\uC7A5\uD1B5
    \uC7A5\uB09C\uAFBC\uB4E4 \uC774\uC57C\uAE30\uC785\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
