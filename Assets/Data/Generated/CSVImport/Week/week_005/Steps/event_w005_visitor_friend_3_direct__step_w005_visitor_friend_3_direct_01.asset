  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w005_visitor_friend_3_direct__step_w005_visitor_friend_3_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 5\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uB450 \uC18C\uB144\uC774 \uC9C0\uB3C4\uB97C \uBCF4\uBA70 \uC774\uC57C\uAE30\uB97C
    \uB098\uB204\uACE0 \uC788\uB2E4. \uCE5C\uAD6C 3\uC740 \uC9C0\uB3C4\uC758 \uC9C0\uD615\uBCF4\uB2E4\uB294
    \uADF8 \uC548\uC5D0 \uC228\uC5B4 \uC788\uC744 \uBC95\uD55C \uAD34\uBB3C\uB4E4\uC5D0
    \uB354 \uAD00\uC2EC\uC774 \uB9CE\uB2E4.)\r\n        \r\n        \uCE5C\uAD6C
    3 : \uC57C, \uC5EC\uAE30 \uC774 \uAE4A\uC740 \uC232 \uC788\uC9C0? \uC5EC\uAE30
    \uBD84\uBA85\uD788 \uBA38\uB9AC \uC138 \uAC1C \uB2EC\uB9B0 \uAC1C\uAC00 \uC0B4
    \uAC70\uC57C. \uC6B0\uB9AC \uC544\uBE60\uAC00 \uADF8\uB7AC\uC5B4, \uC5EC\uAE30
    \uB4E4\uC5B4\uAC00\uBA74 \uC544\uBB34\uB3C4 \uBABB \uB098\uC628\uB2E4\uACE0.\r\n       
    \uB124\uBAA8 : \uC5D0\uC774, \uADF8\uAC74 \uC804\uC124\uC774\uC9C0. \uBC31\uC791\uB2D8\uC774
    \uC5EC\uAE30\uB294 \uADF8\uB0E5 \uC9C0\uBC18\uC774 \uC57D\uD574\uC11C \uC704\uD5D8\uD558\uB2E4\uACE0
    \uD558\uC168\uC5B4.\r\n        \uCE5C\uAD6C 3 : \uC9C0\uBC18\uC774 \uC57D\uD55C
    \uAC8C \uC544\uB2C8\uB77C \uAD34\uBB3C\uC774 \uB545\uC744 \uD30C\uC11C \uADF8\uB7F0
    \uAC70\uB77C\uB2C8\uAE4C! \uC5EC\uAE30\uB2E4 '\uAD34\uBB3C \uC8FC\uC758'\uB77C\uACE0
    \uC801\uC5B4\uB458\uAE4C?\r\n        \r\n\r\n(\uB124\uBAA8\uAC00 \uC9C0\uB3C4
    \uC606\uC5D0 \uC788\uB294 \uBE48 \uC885\uC774\uB97C \uB0B4\uBC00\uBA70 \uB9D0\uD55C\uB2E4.)\r\n       
    \uB124\uBAA8 : \uC5EC\uAE30\uB2E4 \uADF8\uB824\uBD10. \uB124\uAC00 \uC0DD\uAC01\uD558\uB294
    \uAD34\uBB3C. \uB098\uC911\uC5D0 \uB0B4\uAC00 \uBC31\uC791\uB2D8\uD55C\uD14C
    \uBCF4\uC5EC\uC8FC\uBA74\uC11C \"\uC5EC\uAE30 \uC9C4\uC9DC \uAD34\uBB3C \uC788\uB294\uC9C0
    \uD655\uC778\uD574\uC8FC\uC138\uC694\"\uB77C\uACE0 \uBB3C\uC5B4\uBCFC\uAC8C.\r\n       
    \uCE5C\uAD6C 3 : \uC624, \uC9C4\uC9DC? \uBC31\uC791\uB2D8\uC774 \uC548 \uD63C\uB0B4\uC2E4\uAE4C?\r\n       
    \uB124\uBAA8 : (\uC6C3\uC73C\uBA70) \uB0B4\uAC00 \uBB3C\uC5B4\uBCF4\uB294 \uAC74
    \uAD1C\uCC2E\uC544. \uC544\uC800\uC528\uB294 \uB0B4 \uC9C8\uBB38\uC774\uB77C\uBA74
    \uAF64 \uC9C4\uC9C0\uD558\uAC8C \uB300\uB2F5\uD574\uC8FC\uC2DC\uAC70\uB4E0.\r\n       
    \uCE5C\uAD6C 3 : (\uC5F4\uC2EC\uD788 \uADF8\uB9AC\uAE30 \uC2DC\uC791\uD558\uBA70)
    \uC88B\uC544, \uADF8\uB7FC \uC138\uC0C1\uC5D0\uC11C \uC81C\uC77C \uBB34\uC11C\uC6B4
    \uB188\uC73C\uB85C \uADF8\uB824\uC8FC\uC9C0!"
