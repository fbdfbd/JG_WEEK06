  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_visitor_cousin_1_blocked__step_event_week_005_visitor_cousin_1_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE74\uC774\uC548 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor cousin_1 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uCC3D\uBC16\uC73C\uB85C \uC0C1\uCCB4\uB97C \uB0B4\uBC00\uB824
      \uD558\uC790, \uC5B4\uB290\uC0C8 \uB098\uD0C0\uB09C \uAE30\uC0AC\uAC00 \uB124\uBAA8\uC758
      \uB4B7\uB35C\uBBF8\uB97C \uC0B4\uC9DD \uC7A1\uC544 \uB2F9\uAE34\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: bb92d18cb19ba9944ac71077eb8aa4c5, type: 2}
    _text: "\uB3C4\uB828\uB2D8, \uCD94\uB77D \uC704\uD5D8\uC774 \uC788\uC2B5\uB2C8\uB2E4.
      \uCC3D\uBB38\uC740 15\uB3C4 \uC774\uC0C1 \uC5F4\uC9C0 \uC54A\uB294 \uAC83\uC774
      \uADDC\uCE59\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC544\uC26C\uC6B4 \uB4EF \uCC3D\uBB38\uC5D0\uC11C \uBA40\uC5B4\uC9C0\uBA70)
      ...\uADF8\uB0E5 \uAD6C\uACBD\uB9CC \uD558\uB294 \uAC74\uB370 \uB108\uBB34\uD574\uC694."
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uC5B4\uC774\uAD6C, \uAE30\uC0AC \uC591\uBC18. \uC560 \uAE30 \uC880 \uC0B4\uB824\uC8FC\uC1FC.
      \uC5EC\uAE30\uAC00 \uBB34\uC2A8 \uAC10\uC625\uB3C4 \uC544\uB2C8\uACE0."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC0BC\uCD0C\uC758 \uC637\uC790\uB77D\uC744 \uC7A1\uC73C\uBA70) \uAD1C\uCC2E\uC544\uC694,
      \uC0BC\uCD0C. \uBC31\uC791\uB2D8\uC774 \uC81C\uAC00 \uBC16\uC744 \uB108\uBB34
      \uAD81\uAE08\uD574\uD560\uAE4C \uBD10 \uAC71\uC815\uB418\uC154\uC11C \uADF8\uB7EC\uB294
      \uAC70 \uB2E4 \uC54C\uC544\uC694."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uCC3D\uBC16\uC73C\uB85C \uC0C1\uCCB4\uB97C \uB0B4\uBC00\uB824
    \uD558\uC790, \uC5B4\uB290\uC0C8 \uB098\uD0C0\uB09C \uAE30\uC0AC\uAC00 \uB124\uBAA8\uC758
    \uB4B7\uB35C\uBBF8\uB97C \uC0B4\uC9DD \uC7A1\uC544 \uB2F9\uAE34\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
