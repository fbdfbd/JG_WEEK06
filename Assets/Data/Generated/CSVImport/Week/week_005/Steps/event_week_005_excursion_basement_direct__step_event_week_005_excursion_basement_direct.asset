  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_excursion_basement_direct__step_event_week_005_excursion_basement_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: basement Direct
  _bodyText: "excursion basement Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uC7A0\uAE50 \uB9DD\uC124\uC774\uB2E4\uAC00,
      \uAE30\uB465 \uC606\uC5D0 \uC870\uC6A9\uD788 \uC120\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC5EC\uC12F \uC0B4\uBD80\uD130 \uC801\uC5B4 \uB454 \uAC81\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uB0B4 \uD0A4?"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC608. \uC8FC\uC778\uB2D8\uC774 \uC9C0\uD558\uC2E4\uC5D0 \uC62C \uB54C\uB9C8\uB2E4,
      \uBC31\uC791\uB2D8\uAED8\uC11C \uBAB0\uB798 \uD45C\uC2DC\uD574 \uB450\uB77C\uACE0
      \uD558\uC168\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB0B4\uAC00 \uBAA8\uB974\uAC8C?"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC608. \uB108\uBB34 \uB300\uB193\uACE0 \uC7AC\uBA74 \uC2EB\uC5B4\uD558\uC2E4\uAE4C
      \uBD10\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C? \uC0C1\uAD00 \uC5C6\uB294\uB370 \u314E\u314E"
  _nemoLine: "(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uC7A0\uAE50 \uB9DD\uC124\uC774\uB2E4\uAC00,
    \uAE30\uB465 \uC606\uC5D0 \uC870\uC6A9\uD788 \uC120\uB2E4.)"
