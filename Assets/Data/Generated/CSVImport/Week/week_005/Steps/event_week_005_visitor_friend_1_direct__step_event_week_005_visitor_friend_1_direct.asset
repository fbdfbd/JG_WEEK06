  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_visitor_friend_1_direct__step_event_week_005_visitor_friend_1_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: friend_1 Direct
  _bodyText: "visitor friend_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC9C0\uB3C4 \uAD6C\uC11D\uC5D0 \uC544\uC8FC \uC791\uAC8C
      \uC5F0\uD544\uB85C \uBCC4\uD45C\uB97C \uADF8\uB824 \uB123\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC88B\uC544, \uC6B0\uB9AC\uB9CC \uC544\uB294 \uD45C\uC2DC\uC57C. \uB098\uC911\uC5D0
      \uBC31\uC791\uB2D8\uD55C\uD14C \uD5C8\uB77D\uBC1B\uACE0 \uAE30\uC0AC\uB2D8\uB4E4\uC774\uB791
      \uAC19\uC774 \uAC00\uBCF4\uC790. \uB0B4\uAC00 \uAF2D \uC544\uC800\uC528 \uC124\uB4DD\uD574\uBCFC\uAC8C."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uC5ED\uC2DC \uB124\uBAA8! \uB108\uB294 \uBC31\uC791\uB2D8 \uC544\uB4E4\uC774\uB77C
      \uADF8\uB7F0\uC9C0 \uBE7D\uC774 \uB4E0\uB4E0\uD558\uB124. \uB098\uB3C4 \uB108\uCC98\uB7FC
      \uC774\uB7F0 \uBA4B\uC9C4 \uC11C\uC7AC \uAC16\uACE0 \uC2F6\uB2E4!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC6C3\uC73C\uBA70) \uB108 \uC624\uBA74 \uC5B8\uC81C\uB4E0 \uAC19\uC774
      \uBCF4\uBB3C \uCC3E\uAE30 \uACC4\uD68D \uC9DC\uC904\uAC8C. \uC6B0\uB9AC\uB9CC\uC758
      \uBE44\uBC00 \uAE30\uC9C0\uB098 \uB2E4\uB984\uC5C6\uC73C\uB2C8\uAE4C!"
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC9C0\uB3C4 \uAD6C\uC11D\uC5D0 \uC544\uC8FC \uC791\uAC8C
    \uC5F0\uD544\uB85C \uBCC4\uD45C\uB97C \uADF8\uB824 \uB123\uB294\uB2E4.)"
