  m_Name: event_w005_house_main_modified__step_w005_house_main_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "5\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uBC24\uC758 \uADF8\uB9BC\uC790\uAC00 \uB0B4\uB824\uC549\uC740 \uACC4\uB2E8
    \uC544\uB798. \uD558\uC778 \uB458\uC774 \uC545\uAE30\uC2E4 \uCABD\uC744 \uBCF4\uBA70
    \uC18D\uC0AD\uC778\uB2E4.)\n    \uD558\uC7781 : \uC5B4\uC81C \uB4E4\uC5C8\uC5B4?
    \uC544\uBB34\uB3C4 \uC5C6\uB294\uB370 \uAC74\uBC18 \uC18C\uB9AC\uAC00 \uB0AC\uB2E4\uB2C8\uAE4C.\n   
    \uD558\uC7782 : \uBC14\uB78C \uC18C\uB9AC\uACA0\uC9C0. \uD558\uC9C0\uB9CC \uAF2D
    \uB204\uAC00 \uD55C \uC74C\uC529 \uB204\uB974\uB294 \uAC83 \uAC19\uAE34 \uD558\uB354\uB77C.\n   
    \uB124\uBAA8 : \uD53C\uC544\uB178\uAC00 \uD63C\uC790 \uB178\uB798\uD574?\n   
    \n\n\uD558\uC7781 : \uD53C\uC544\uB178 \uC904\uC774 \uBC24\uC5D0 \uAE30\uC628\uC774
    \uB0AE\uC544\uC9C0\uBA74 \uC218\uCD95\uD558\uBA74\uC11C \uAC00\uB054 \uB775-
    \uD558\uB294 \uC18C\uB9AC\uAC00 \uB098\uAE30\uB3C4 \uD55C\uB300\uC694.\n    \uB124\uBAA8
    : \uC904\uC774 \uC904\uC5B4\uB4E4\uC5B4\uC11C?\n    \uD558\uC7782 : \uB124. \uD53C\uC544\uB178\uAC00
    \"\uCD94\uC6CC\uC694~\" \uD558\uACE0 \uAE30\uC9C0\uAC1C\uB97C \uCF1C\uB294 \uC18C\uB9AC\uB77C\uACE0
    \uC0DD\uAC01\uD558\uBA74 \uB3FC\uC694.\n    \uB124\uBAA8 : \uC544, \uD53C\uC544\uB178\uB3C4
    \uC7A0\uAF2C\uB300\uD558\uB294 \uAC70\uAD6C\uB098!\n    \uD558\uC7781 : \uB9DE\uC544\uC694.
    \uC544\uC8FC \uC790\uC5F0\uC2A4\uB7EC\uC6B4 \uC77C\uC774\uB2C8 \uB180\uB77C\uC9C0
    \uB9C8\uC138\uC694, \uC8FC\uC778\uB2D8.\n    \uB124\uBAA8 : \uD788\uD788, \uC2E0\uAE30\uD558\uB2E4.
    \uD53C\uC544\uB178 \uC7A0\uAF2C\uB300 \uC18C\uB9AC \uB098\uB3C4 \uB4E4\uC5B4\uBCF4\uACE0
    \uC2F6\uC5B4."
