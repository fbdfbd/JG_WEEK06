--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_cooking_blocked__step_event_week_005_cooking_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uACC4\uB7C9\uBD80\uD130 \uC5C4\uACA9\uD788 \uC775\uD78C\uB2E4"
  _bodyText: "\uC694\uB9AC\uC640 \uBC30\uC2DD\uC758 \uC6D0\uB9AC 5\uC8FC\uCC28 Blocked
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC8FC\uBC29 \uD55C\uCABD \uC791\uC740 \uC791\uC5C5\uB300. \uBC00\uAC00\uB8E8,
      \uB2EC\uAC40, \uC6B0\uC720\uAC00 \uC870\uAE08\uC529 \uC900\uBE44\uB418\uC5B4
      \uC788\uACE0, \uD558\uB140\uAC00 \uACC4\uB7C9\uCEF5\uC744 \uBCF4\uC5EC \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uB9DB\uC788\uAC8C \uB9CC\uB4DC\uB294
      \uAC83\uBCF4\uB2E4 \uBA3C\uC800, \uC5BC\uB9C8\uB098 \uB123\uB294\uC9C0 \uBC30\uC6B0\uB294
      \uB0A0\uC774\uC5D0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB0E5 \uB300\uCDA9 \uB123\uC73C\uBA74 \uC548 \uB3FC?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8\uB7EC\uBA74 \uB300\uCDA9 \uC2E4\uD328\uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uBC00\uAC00\uB8E8\uB97C \uD55C\uAEBC\uBC88\uC5D0
      \uBD93\uC790, \uACBD\uBE44\uB300\uC7A5\uC774 \uACC4\uB7C9\uCEF5\uC744 \uB2E4\uC2DC
      \uB0B4\uB824\uB193\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uAC10\uC774 \uC544\uB2C8\uB77C \uC591\uC73C\uB85C \uD558\uC2ED\uC2DC\uC624.
      \uC8FC\uBC29\uC740 \uACC4\uC0B0\uC774 \uBA3C\uC800\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBA39\uB294 \uAC74\uB370 \uC65C \uC774\uB807\uAC8C \uC22B\uC790\uAC00
      \uB9CE\uC544."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uBA39\uB294 \uC77C\uC774\uB2C8\uAE4C \uB354 \uADF8\uB807\uC2B5\uB2C8\uB2E4.
      \uB2E4\uC2DC \uC7AC\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC30\uACE0\uD508\uB370 \uC790\uAFB8 \uB290\uB824\uC838."
  _nemoLine: "(\uC8FC\uBC29 \uD55C\uCABD \uC791\uC740 \uC791\uC5C5\uB300. \uBC00\uAC00\uB8E8,
    \uB2EC\uAC40, \uC6B0\uC720\uAC00 \uC870\uAE08\uC529 \uC900\uBE44\uB418\uC5B4
    \uC788\uACE0, \uD558\uB140\uAC00 \uACC4\uB7C9\uCEF5\uC744 \uBCF4\uC5EC \uC900\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
