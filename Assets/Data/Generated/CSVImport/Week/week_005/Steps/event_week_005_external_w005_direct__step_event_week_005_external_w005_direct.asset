  _titleOverride: w005 Direct
  _bodyText: "external w005 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: bb92d18cb19ba9944ac71077eb8aa4c5, type: 2}
    _text: "\uB098\uC05C \uBD80\uC790\uB4E4 \uAC83\uB9CC \uBE8F\uC5B4\uC11C \uB098\uB220\uC8FC\uB294
      \uC758\uC801\uC774\uB798\uC694. \uC5BC\uAD74\uC744 \uC544\uBB34\uB3C4 \uBAA8\uB978\uB2E4\uC9C0
      \uBB61\uB2C8\uAE4C?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5BC\uAD74\uC774 \uC5C6\uC5B4? \uC9C4\uC9DC \uADF8\uB9BC\uC790\uCC98\uB7FC
      \uB2E4\uB2C8\uB098 \uBD10!"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uAC80\uC740 \uC637\uC744 \uC785\uACE0 \uBC24\uD558\uB298\uC744 \uB0A0\uC544\uB2E4\uB2CC\uB300\uC694.
      \uC8FC\uC778\uB2D8\uCC98\uB7FC \uCC29\uD55C \uC544\uC774\uB294 \uC9C0\uCF1C\uC900\uB2E4\uACE0
      \uD558\uB354\uB77C\uACE0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640, \uC6B0\uB9AC \uC800\uD0DD\uC5D0\uB3C4 \uC62C\uAE4C? \uB098\uB3C4
      \uB9CC\uB098\uC11C \uB0B4 \uAC04\uC2DD \uC880 \uB098\uB220\uC8FC\uACE0 \uC2F6\uC5B4."
  _nemoLine: "\uB098\uC05C \uBD80\uC790\uB4E4 \uAC83\uB9CC \uBE8F\uC5B4\uC11C \uB098\uB220\uC8FC\uB294
    \uC758\uC801\uC774\uB798\uC694. \uC5BC\uAD74\uC744 \uC544\uBB34\uB3C4 \uBAA8\uB978\uB2E4\uC9C0
    \uBB61\uB2C8\uAE4C?"
