  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w005_excursion_library_blocked__step_w005_excursion_library_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 5\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uB124\uBAA8\uAC00 \uCCA0\uD559 \uCC45\uC744 \uC77D\uB2E4\uAC00 \uD55C
    \uD398\uC774\uC9C0\uC5D0\uC11C \uBA48\uCD98\uB2E4. \uB09C\uD574\uD55C \uBB38\uC7A5
    \uC606 \uC5EC\uBC31\uC5D0 \uC544\uC8FC \uC791\uACE0 \uC815\uAC08\uD55C \uD544\uCCB4\uB85C
    \uC8FC\uC11D\uC774 \uB2EC\uB7EC \uC788\uB2E4.)\r\n        \r\n        \uB124\uBAA8
    : \uC774 \uAE00\uC528... \uBC31\uC791\uB2D8 \uAE00\uC528\uC796\uC544.\r\n       
    (\uC190\uAC00\uB77D\uC73C\uB85C \uAE00\uC528\uB97C \uB530\uB77C\uAC04\uB2E4.
    '\uC774 \uAD6C\uC808\uC740 \uB108\uBB34 \uBE44\uAD00\uC801\uC774\uB2C8 \uBB34\uC2DC\uD574\uB3C4
    \uC88B\uB2E4'\uB77C\uACE0 \uC801\uD600 \uC788\uB2E4.)\r\n        \r\n       
    \uB124\uBAA8 : \uB098 \uC77D\uC73C\uB77C\uACE0 \uC801\uC5B4\uB454 \uAC74\uAC00?
    \uC544\uB2C8\uBA74 \uD63C\uC790 \uC77D\uB2E4 \uC801\uC73C\uC2E0 \uAC74\uAC00.\r\n       
    (\uB2E4\uC74C \uD398\uC774\uC9C0\uB97C \uB118\uAE30\uC790 '\uB124\uAC00 \uC774\uD574\uD558\uAE30\uC5D4
    \uC774 \uB2E8\uC5B4\uAC00 \uB354 \uC801\uC808\uD558\uACA0\uC9C0'\uB77C\uBA70
    \uC26C\uC6B4 \uB2E8\uC5B4\uAC00 \uC801\uD600 \uC788\uB2E4.)\r\n        \r\n\r\n(\uB3C4\uC11C\uAD00
    \uC0AC\uC11C\uAC00 \uB2E4\uAC00\uC640 \uD3EC\uC2A4\uD2B8\uC787\uC73C\uB85C \uD574\uB2F9
    \uC8FC\uC11D\uC744 \uAC00\uB9AC\uB824 \uD55C\uB2E4.)\r\n        \uC0AC\uC11C
    : \uB3C4\uB828\uB2D8, \uC8FC\uC778\uB2D8\uAED8\uC11C \uBCF8\uC778\uC758 \uBA54\uBAA8\uAC00
    \uB3C4\uB828\uB2D8\uC758 \uC0AC\uACE0\uB97C \uC81C\uD55C\uD560 \uC218 \uC788\uC73C\uB2C8
    \uAC00\uB824\uB450\uB77C \uD558\uC168\uC2B5\uB2C8\uB2E4.\r\n        \uB124\uBAA8
    : (\uC0AC\uC11C\uC758 \uC190\uC744 \uB9C9\uC73C\uBA70) \uC544\uB2C8\uC694, \uAC00\uB9AC\uC9C0
    \uB9C8\uC138\uC694.\r\n        \uC0AC\uC11C : \uD558\uC9C0\uB9CC \uC8FC\uC778\uB2D8\uC758
    \uBA85\uB839\uC785\uB2C8\uB2E4.\r\n        \uB124\uBAA8 : \uB0B4 \uBA38\uB9BF\uC18D\uAE4C\uC9C0
    \uC790\uAE30 \uC0DD\uAC01\uC73C\uB85C \uCC44\uC6B0\uB824\uB294 \uAC8C \uB204\uAD70\uB370
    \uC774\uC81C \uC640\uC11C... \uADF8\uB0E5 \uB458\uB798\uC694. \uC774\uAC74 \uB0B4
    \uCC45\uC774\uC5D0\uC694."
