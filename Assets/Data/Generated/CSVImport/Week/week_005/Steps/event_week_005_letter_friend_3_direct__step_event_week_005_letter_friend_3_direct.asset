  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_005_letter_friend_3_direct__step_event_week_005_letter_friend_3_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC720\uD53C \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "letter friend_3 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798 \uC190\uB2D8\uC774
      \uBCF4\uB0B8 \uD3B8\uC9C0\uC785\uB2C8\uB2E4. \uC789\uD06C \uC694\uC815 \uC774\uC57C\uAE30\uB97C
      \uC37C\uB2E4\uB294\uB370\uC694?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC694\uC815? \uC789\uD06C\uC5D0 \uC694\uC815\uC774 \uC0B4\uC544?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uD3BC\uCE5C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC54\uAC00 \uC694\uC815\uC774\uB791 \uD611\uC0C1\uC744 \uD588\uB300!"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC815\uB9D0 \uBBFF\uAE30 \uD798\uB4E0 \uC774\uC57C\uAE30\uC9C0\uB9CC
      \uC7AC\uBC0C\uAE34 \uD558\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uADF8\uB54C \uB0B4\uAC00 \uC789\uD06C \uBCD1 \uC7A1\uC740
      \uAC83\uB3C4 \uC694\uC815\uC774 \uB3C4\uC640\uC900 \uAC74\uAC00? \uAC54\uB791
      \uC788\uC73C\uBA74 \uC2EC\uC2EC\uD560 \uD2C8\uC774 \uC5C6\uC5B4."
  _nemoLine: "\uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798 \uC190\uB2D8\uC774
    \uBCF4\uB0B8 \uD3B8\uC9C0\uC785\uB2C8\uB2E4. \uC789\uD06C \uC694\uC815 \uC774\uC57C\uAE30\uB97C
    \uC37C\uB2E4\uB294\uB370\uC694?"
  _useCustomVisualState: 0
  _visualState: 0
