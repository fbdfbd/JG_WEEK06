  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w005_external_main_blocked__step_w005_external_main_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "5\uCC28 - \uD1B5\uC81C"
  _bodyText: "(\uC131\uBB38 \uADFC\uCC98, \uBCF4\uBD80\uC0C1\uC774 \uC9D0\uC744 \uD480\uBA70
    \uD558\uB140\uB4E4\uC5D0\uAC8C \uC2DC\uC7A5 \uD1B5 \uC18C\uC2DD\uC744 \uC804\uD55C\uB2E4.)\n   
    \uBCF4\uBD80\uC0C1 : \uC774\uBC88\uC5D0 \uC774\uC6C3 \uB9C8\uC744 \uC601\uC8FC\uB124
    \uCC3D\uACE0\uAC00 \uD138\uB838\uB2E4\uC9C0 \uBB50\uC57C? \uADF8\uB7F0\uB370
    \uC2E0\uAE30\uD558\uAC8C\uB3C4 \uAE08\uD654\uB9CC \uC3D9 \uBE7C\uAC00\uACE0 \uAC00\uB09C\uD55C
    \uC0AC\uB78C\uB4E4 \uC9D1 \uC55E\uC5D0 \uB480\uB2E4\uB354\uAD70.\n    \uD558\uB140
    : \uC5B4\uBA38, \uADF8\uB7FC \uADF8 \uC18C\uBB38\uC758 '\uADF8\uB9BC\uC790 \uAE30\uC0AC'\uAC00
    \uC9C4\uC9DC \uC788\uB294 \uAC70\uC57C?\n    \uB124\uBAA8 : \uADF8\uB9BC\uC790
    \uAE30\uC0AC? \uB098\uC05C \uC0AC\uB78C\uC774\uC57C?\n    \n\n\uBCF4\uBD80\uC0C1
    : (\uC785\uC744 \uAFB9 \uB2E4\uBB3C\uBA70) \uC544\uC774\uACE0, \uC81C\uAC00 \uD5DB\uC18C\uB9AC\uB97C
    \uD588\uB124\uC694. \uADF8\uB0E5 \uC2DC\uC7A5\uD1B5 \uC7A5\uB09C\uAFBC\uB4E4
    \uC774\uC57C\uAE30\uC785\uB2C8\uB2E4.\n    \uD558\uB140 : \uC8FC\uC778\uB2D8,
    \uB3C4\uB451\uB188 \uC774\uC57C\uAE30\uB294 \uB4E4\uC5B4\uC11C \uC88B\uC744 \uAC70
    \uC5C6\uC5B4\uC694. \uC5B4\uC11C \uC11C\uC7AC\uB85C \uAC00\uC138\uC694.\n   
    \uB124\uBAA8 : \uAE08\uD654\uB97C \uB098\uB220\uC92C\uB2E4\uBA70! \uADF8\uAC8C
    \uC65C \uB3C4\uB451\uC774\uC57C?\n    \uD558\uB140 : \uB0A8\uC758 \uAC83\uC744
    \uAC00\uC838\uAC00\uBA74 \uBB34\uC870\uAC74 \uB3C4\uB451\uC774\uC9C0\uC694. \uBC31\uC791\uB2D8\uC774
    \uB4E4\uC73C\uC2DC\uBA74 \uB178\uD558\uC2E4 \uAC70\uC608\uC694."
