  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_external_main_blocked__step_w009_external_main_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "9\uCC28 - \uD1B5\uC81C"
  _bodyText: "\uBC31\uC791\uB2D8\uC758 \uBE44\uBC00 \uC720\uC5B8\uC7A5\r\n    \r\n   
    (\uC131\uC778\uC2DD \uC804\uB0A0 \uBC24, \uC9D1\uBB34\uC2E4 \uADFC\uCC98 \uC5B4\uB450\uC6B4
    \uBCF5\uB3C4. \uBCC0\uD638\uC0AC\uC640 \uC9D1\uC0AC\uAC00 \uB0AE\uC740 \uBAA9\uC18C\uB9AC\uB85C
    \uC11C\uB958\uB97C \uD655\uC778\uD55C\uB2E4.)\r\n    \r\n    \uBCC0\uD638\uC0AC
    : \uBC31\uC791\uB2D8\uC774 \uC774\uBC88 \uC131\uC778\uC2DD \uB54C \uACF5\uAC1C\uD560
    \uC720\uC5B8\uC7A5\uC5D0 '\uADF8 \uB0B4\uC6A9'\uC744 \uC9C4\uC9DC \uB123\uC73C\uC2E0
    \uAC74\uAC00\uC694? \uC601\uC9C0\uC758 \uC808\uBC18\uC744...\r\n    \uC9D1\uC0AC
    : \uC27F! \uC8FC\uC778\uB2D8\uC774 \uB4E4\uC73C\uC2DC\uBA74 \uC548 \uB429\uB2C8\uB2E4.
    \uC774\uAC74 \uAC00\uBB38\uC758 \uADFC\uAC04\uC744 \uD754\uB4E4 \uC218\uB3C4
    \uC788\uB294 \uACB0\uC815\uC785\uB2C8\uB2E4.\r\n    \uB124\uBAA8 : \uC720\uC5B8\uC7A5?
    \uC601\uC9C0\uC758 \uC808\uBC18\uC744 \uC5B4\uB5BB\uAC8C \uD55C\uB2E4\uB294 \uAC70\uC57C?\r\n   
    \r\n\r\n- \uC9D1\uC0AC : (\uB124\uBAA8\uB97C \uBCF4\uACE0 \uC11C\uB958\uB97C
    \uAE09\uD788 \uB4F1 \uB4A4\uB85C \uC228\uAE30\uBA70) \uC8FC\uC778\uB2D8, \uC544\uC9C1
    \uC8FC\uBB34\uC2DC\uC9C0 \uC54A\uC558\uC2B5\uB2C8\uAE4C? \uC774\uAC74 \uADF8\uB0E5
    \uC138\uAE08 \uC815\uC0B0 \uC11C\uB958\uC785\uB2C8\uB2E4.\r\n    \uBCC0\uD638\uC0AC
    : \uB124, \uB3C4\uB828\uB2D8\uC740 \uBAA8\uB974\uC154\uB3C4 \uB418\uB294 \uC544\uC8FC
    \uC9C0\uB8E8\uD55C \uC22B\uC790 \uB180\uC774\uC77C \uBFD0\uC774\uC5D0\uC694.
    \uB0B4\uC77C\uC744 \uC704\uD574 \uC5B4\uC11C \uCE68\uC18C\uB85C \uAC00\uC2DC\uC8E0.\r\n   
    \uB124\uBAA8 : \uC601\uC9C0\uC758 \uC808\uBC18\uC774\uB77C\uBA70! \uB098 \uB2E4
    \uB4E4\uC5C8\uC5B4! \uB0B4\uAC00 \uBC31\uC791\uC774 \uB418\uB294 \uAC8C \uC2EB\uC740
    \uAC70\uC57C?"
