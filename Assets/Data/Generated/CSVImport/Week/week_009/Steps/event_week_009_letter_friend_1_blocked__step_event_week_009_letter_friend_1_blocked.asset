  _titleOverride: friend_1 Blocked
  _bodyText: "letter friend_1 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uB294 \uD3B8\uC9C0\uB97C \uBCF4\uB354\uB2C8 \uC870\uC6A9\uD788
      \uBC31\uC791\uB2D8\uC758 \uC9D1\uBB34\uC2E4\uB85C \uBCF4\uB0B8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uCC3D\uBC16 \uAD6C\uB984\uC744 \uBCF4\uBA70 \uC774\uC81C
      \uC544\uC774\uB85C \uC9C0\uB0B4\uB294 \uAC83\uB3C4 \uC624\uB298\uC774 \uB05D\uC774\uAD6C\uB098,
      \uD558\uACE0 \uC0DD\uAC01\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\u2026\u2026\uC774\uB7F0 \uC911\uC694\uD55C \uC57D\uC18D\uC740 \uBC31\uC791\uB2D8\uB3C4
      \uC544\uC154\uC57C \uD560 \uD14C\uB2C8\uAE4C\uC694."
  _nemoLine: "(\uD558\uB140\uB294 \uD3B8\uC9C0\uB97C \uBCF4\uB354\uB2C8 \uC870\uC6A9\uD788
    \uBC31\uC791\uB2D8\uC758 \uC9D1\uBB34\uC2E4\uB85C \uBCF4\uB0B8\uB2E4.)"
