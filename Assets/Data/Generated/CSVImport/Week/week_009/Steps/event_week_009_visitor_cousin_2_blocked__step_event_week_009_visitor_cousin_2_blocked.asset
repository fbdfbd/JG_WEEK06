  _titleOverride: "\uB9AC\uC548 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor cousin_2 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "(\uC6B8\uC74C\uC744 \uD130\uB728\uB9AC\uBA70) \uBBF8\uC548\uD574, \uB124\uBAA8\uC57C!
      \uB09C \uBABB \uD574! \uBC31\uC791\uB2D8\uB3C4 \uBB34\uC12D\uACE0 \uC6B0\uB9AC
      \uC544\uBE60\uB3C4 \uBB34\uC11C\uC6CC! \uB108\uB791 \uAC19\uC774 \uC788\uB2E4\uAC04
      \uB098\uAE4C\uC9C0 \uC8FD\uC744 \uAC83 \uAC19\uC544!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uBD80\uB7EC\uC9C4 \uAE43\uD39C\uC744 \uBCF4\uBA70 \uCC28\uAC11\uAC8C)
      \uACB0\uAD6D \uB108\uB3C4 \uB611\uAC19\uAD6C\uB098. \uBC31\uC791\uB2D8\uC758
      \uADDC\uCE59 \uC544\uB798\uC11C \uBC8C\uBC8C \uB5A8\uAE30\uB9CC \uD558\uB294
      \uAC81\uC7C1\uC774. \uB2E4\uC2DC\uB294 \uB0B4 \uC11C\uC7AC\uC5D0 \uBC1C \uB4E4\uC774\uC9C0
      \uB9C8."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "(\uB3C4\uB9DD\uCE58\uB4EF \uC0AC\uB77C\uC9D0)"
  _nemoLine: "(\uC6B8\uC74C\uC744 \uD130\uB728\uB9AC\uBA70) \uBBF8\uC548\uD574, \uB124\uBAA8\uC57C!
    \uB09C \uBABB \uD574! \uBC31\uC791\uB2D8\uB3C4 \uBB34\uC12D\uACE0 \uC6B0\uB9AC
    \uC544\uBE60\uB3C4 \uBB34\uC11C\uC6CC! \uB108\uB791 \uAC19\uC774 \uC788\uB2E4\uAC04
    \uB098\uAE4C\uC9C0 \uC8FD\uC744 \uAC83 \uAC19\uC544!"
