  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_letter_cousin_2_direct__step_event_week_009_letter_cousin_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: cousin_2 Direct
  _bodyText: "letter cousin_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC0AC\uCD0C 2 \uB3C4\uB828\uB2D8\uC774 \uB5A8\uB9AC\uB294
      \uC9C4\uC2EC\uC744 \uB2F4\uC544 \uB9C8\uC9C0\uB9C9 \uC778\uC0AC\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uC81C \uC5B4\uB978 \uB418\uBA74 \uAC54\uB791 \uBABB \uB178\uB294
      \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB0B4 \uB9C8\uC74C\uC18D\uC758 \uBC31\uC791\uB2D8\uC740 \uB108\uBFD0\uC774\uB798...
      \uBC14\uBCF4, \uB2F9\uC5F0\uD558\uC9C0."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uC774 \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uAED8 \uC815\uB9D0
      \uD070 \uD76C\uB9DD\uC774 \uB418\uC5B4\uC8FC\uC168\uB098 \uBD05\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uB0B4\uAC00 \uBE68\uB9AC \uBC31\uC791\uC774 \uB3FC\uC11C \uAC54\uB97C
      \uC790\uC720\uB86D\uAC8C \uD574\uC904 \uAC70\uC57C. \uADF8\uAC8C \uB0B4 \uC57D\uC18D\uC774\uC57C."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC0AC\uCD0C 2 \uB3C4\uB828\uB2D8\uC774 \uB5A8\uB9AC\uB294
    \uC9C4\uC2EC\uC744 \uB2F4\uC544 \uB9C8\uC9C0\uB9C9 \uC778\uC0AC\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
