  m_Name: event_w009_visitor_friend_3_blocked__step_w009_visitor_friend_3_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 9\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uC131\uC778\uC2DD \uBC14\uB85C \uC804\uB0A0 \uBC24. \uC11C\uC7AC\uC758
    \uCD1B\uBD88\uC774 \uACE0\uC694\uD558\uAC8C \uD0C0\uC624\uB974\uACE0 \uC788\uB2E4.
    \uCE5C\uAD6C 3\uC740 \uC624\uB298\uB9CC\uD07C\uC740 \uCC3D\uBB38\uC774 \uC544\uB2CC
    \uC815\uBB38\uC73C\uB85C, \uBC31\uC791\uB2D8\uC758 \uD5C8\uB77D\uC744 \uBC1B\uACE0
    \uB2F9\uB2F9\uD558\uAC8C \uB4E4\uC5B4\uC628\uB2E4. \uADF8\uC758 \uC190\uC5D0\uB294
    \uC5B4\uB9B4 \uC801 \uB124\uBAA8\uC640 \uD568\uAED8 \uB180\uB358 \uB0A1\uC740
    \uB098\uBB34 \uCE7C\uC774 \uB4E4\uB824 \uC788\uB2E4.)\n        \n        \uCE5C\uAD6C
    3 : \uB124\uBAA8, \uC774\uC81C \uB0B4\uC77C\uC774\uBA74 \uB10C \uC9C4\uC9DC \uBC31\uC791\uB2D8\uC758
    \uD6C4\uACC4\uC790\uB85C\uC11C \uC0AC\uB78C\uB4E4 \uC55E\uC5D0 \uC11C\uACA0\uC9C0.
    \uC774 \uB098\uBB34 \uCE7C... \uAE30\uC5B5\uB098? \uC6B0\uB9AC\uAC00 \uC11C\uC7AC
    \uAD6C\uC11D\uC5D0\uC11C \uBC31\uC791\uB2D8 \uBAB0\uB798 \uAE30\uC0AC \uB180\uC774
    \uD560 \uB54C \uC37C\uB358 \uAC70\uC796\uC544. \uC774\uC81C \uC774\uAC74 \uB098\uD55C\uD14C
    \uD544\uC694 \uC5C6\uC5B4. \uB10C \uB0B4\uC77C\uBD80\uD130 \uC9C4\uC9DC \uC9C4\uAC80\uC744
    \uCC28\uAC8C \uB420 \uD14C\uB2C8\uAE4C. \uC774\uAC74 '\uC544\uC774 \uB124\uBAA8'\uC640\uC758
    \uB9C8\uC9C0\uB9C9 \uC791\uBCC4 \uC778\uC0AC\uC57C.\n        \n\n- (\uB124\uBAA8\uAC00
    \uB098\uBB34 \uCE7C\uC744 \uBC1B\uC544 \uBC31\uC791\uB2D8\uC774 \uBB3C\uB824\uC8FC\uC2E4
    \uAC00\uBB38\uC758 \uAC80 \uAC70\uCE58\uB300 \uC606\uC5D0 \uB098\uB780\uD788
    \uB193\uB294\uB2E4.)\uB124\uBAA8 : \uACE0\uB9C8\uC6CC. \uC774 \uB098\uBB34 \uCE7C\uC740
    \uB0B4\uAC00 \uC5B4\uB514\uC11C \uC654\uB294\uC9C0 \uC78A\uC9C0 \uC54A\uAC8C
    \uD574\uC904 \uAC70\uC57C. \uBC31\uC791\uB2D8\uC758 \uAC00\uB974\uCE68\uB300\uB85C
    \uC5C4\uACA9\uD558\uB418, \uB108\uC640 \uB098\uB204\uC5C8\uB358 \uC774 \uC21C\uC218\uD55C
    \uB9C8\uC74C\uC744 \uC783\uC9C0 \uC54A\uB294 \uC8FC\uC778\uC774 \uB420\uAC8C.\n       
    \uCE5C\uAD6C 3 : (\uB208\uC2DC\uC6B8\uC774 \uBD89\uC5B4\uC9C0\uBA70) \uB124\uBAA8...
    \uB10C \uC815\uB9D0 \uBA4B\uC9C4 \uC5B4\uB978\uC774 \uB410\uAD6C\uB098. \uBC31\uC791\uB2D8\uC774
    \uB110 \uC65C \uADF8\uB807\uAC8C \uADC0\uD558\uAC8C \uC5EC\uAE30\uC168\uB294\uC9C0
    \uC774\uC81C \uC54C \uAC83 \uAC19\uC544. \uB0B4\uC77C \uC131\uC778\uC2DD\uC7A5\uC5D0\uC11C
    \uC138\uC0C1\uC5D0\uC11C \uC81C\uC77C \uD06C\uAC8C \uBC15\uC218 \uCCD0\uC904\uAC8C!"
