  _titleOverride: "\uC678\uAD50 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4"
  _bodyText: "\uC678\uAD50 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC678\uAD50 \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
      \uC778\uC0AC \uC608\uBC95\uB9CC \uC9DA\uACE0 \uB118\uC5B4\uAC04\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624\uB298\uC740 \uB9D0 \uACE0\uB974\uB294 \uAC74 \uC548 \uBC30\uC6CC?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uC9D1\uC911\uC774 \uD750\uD2B8\uB7EC\uC9C0\uAE30 \uC804\uC5D0 \uC218\uC5C5\uC744
      \uC9E7\uAC8C \uB05D\uB0B8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB2E4\uC74C\uC5D4 \uC9C4\uC9DC\uCC98\uB7FC \uD574 \uBCF4\uC790."
  _nemoLine: "(\uC678\uAD50 \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
    \uC778\uC0AC \uC608\uBC95\uB9CC \uC9DA\uACE0 \uB118\uC5B4\uAC04\uB2E4.)"
