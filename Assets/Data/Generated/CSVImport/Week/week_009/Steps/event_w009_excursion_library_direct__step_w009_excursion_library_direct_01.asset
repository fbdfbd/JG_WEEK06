  m_Name: event_w009_excursion_library_direct__step_w009_excursion_library_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 9\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uB178\uC744\uC774 \uC9C0\uB294 \uC624\uD6C4, \uB3C4\uC11C\uAD00\uC758
    \uC2A4\uD14C\uC778\uB4DC\uAE00\uB77C\uC2A4\uB97C \uD1B5\uD574 \uC77C\uACF1 \uBE5B\uAE54\uC758
    \uD587\uC0B4\uC774 \uC11C\uAC00\uC5D0 \uB0B4\uB824\uC549\uB294\uB2E4. \uB124\uBAA8\uAC00
    \uCC3D\uAC00 \uC790\uB9AC\uC5D0 \uC549\uC544 \uC870\uC6A9\uD788 \uC2DC\uC9D1\uC744
    \uC77D\uACE0 \uC788\uB2E4.)\r\n        \uD558\uB140 : \uC8FC\uC778\uB2D8, \uB178\uC744\uBE5B\uC5D0
    \uBE44\uCE5C \uBAA8\uC2B5\uC774 \uB9C8\uCE58 \uADF8\uB9BC \uAC19\uC544\uC694.
    \uC815\uB9D0 \uD3C9\uD654\uB85C\uC6CC \uBCF4\uC774\uC2DC\uB124\uC694.\r\n       
    \r\n\r\n\uD558\uB140 : \uC8FC\uC778\uB2D8\uC774\uB77C\uBA74 \uBD84\uBA85 \uADF8\uB7F4
    \uC218 \uC788\uC744 \uAC70\uC608\uC694. \uC8FC\uC778\uB2D8\uC758 \uC774\uB984\uC740
    \uC774 \uB3C4\uC11C\uAD00\uC5D0\uC11C \uAC00\uC7A5 \uBE5B\uB098\uB294 \uCC45\uC5D0
    \uC801\uD790 \uAC70\uB2C8\uAE4C\uC694.\r\n        \uB124\uBAA8 : \uACE0\uB9C8\uC6CC.
    \uADF8 \uBBF8\uB798\uB97C \uC704\uD574\uC11C \uC9C0\uAE08 \uC774 \uC21C\uAC04\uC744
    \uC78A\uC9C0 \uC54A\uACE0 \uAE30\uC5B5\uD574\uB458\uB798."
