  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_law_modified__step_event_week_009_law_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC774\uD574\uB418\uB294 \uD310\uACB0\uBB38\uC744 \uC4F0\uAC8C
    \uD55C\uB2E4"
  _bodyText: "\uC81C\uAD6D\uBC95\uACFC \uC601\uC9C0 \uD589\uC815 9\uC8FC\uCC28 Modified
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC11C\uC7AC. \uC774\uBC88\uC5D4 \uC9E7\uC740 \uD310\uACB0\uBB38 \uCD08\uC548\uACFC
      \uBE48 \uAE30\uB85D\uC9C0\uAC00 \uB193\uC5EC \uC788\uB2E4. \uBE44\uC11C\uB294
      \uC55E\uC120 \uC0AC\uB840 \uD558\uB098\uB97C \uACE8\uB77C \uAC04\uB2E8\uD55C
      \uD310\uACB0\uBB38 \uD615\uC2DD\uC73C\uB85C \uC815\uB9AC\uD574 \uBCF4\uAC8C
      \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uB204\uAC00 \uC633\uC740\uC9C0\uB9CC
      \uACE0\uB974\uB294 \uAC8C \uC544\uB2C8\uB77C, \uADF8 \uD310\uB2E8\uC744 \uBB38\uC7A5\uC73C\uB85C
      \uB0A8\uAE30\uB294 \uC5F0\uC2B5\uC744 \uD574 \uBCFC \uAC81\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD310\uB2E8\uB3C4 \uD588\uB294\uB370 \uAE00\uAE4C\uC9C0 \uC368\uC57C
      \uD574?"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uB0A8\uAE30\uC9C0 \uC54A\uC73C\uBA74 \uB2E4\uC74C\uC5D0 \uB2E4\uC2DC
      \uD754\uB4E4\uB9AC\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBE44\uC11C\uAC00 \uCD08\uC548 \uC606\uC5D0 \uC9E7\uC740 \uC608\uC2DC
      \uBB38\uC7A5\uC744 \uD558\uB098 \uC801\uC5B4 \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uBB34\uAC81\uAC8C \uC4F4\uB2E4\uACE0 \uC88B\uC740 \uD310\uACB0\uBB38\uC774
      \uB418\uB294 \uAC74 \uC544\uB2D9\uB2C8\uB2E4. \uC774\uD574\uB418\uAC8C \uC4F0\uB294
      \uAC8C \uBA3C\uC800\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uB4E4 \uC77D\uACE0 \uBC14\uB85C \uC54C\uC544\uC57C \uD55C\uB2E4\uB294
      \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uB124. \uC8FC\uC778\uB2D8\uC758 \uD310\uB2E8\uC740 \uC815\uD655\uD574\uC57C
      \uD558\uACE0, \uAE30\uB85D\uC740 \uBD84\uBA85\uD574\uC57C \uD558\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC74C. \uADF8\uAC74 \uC880 \uB0A9\uB4DD\uB41C\uB2E4."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uADF8\uB7FC \uC624\uB298\uC740 \uADF8 \uBC29\uD5A5\uC73C\uB85C \uC368
      \uBCF4\uC2DC\uC8E0."
  _nemoLine: "(\uC11C\uC7AC. \uC774\uBC88\uC5D4 \uC9E7\uC740 \uD310\uACB0\uBB38 \uCD08\uC548\uACFC
    \uBE48 \uAE30\uB85D\uC9C0\uAC00 \uB193\uC5EC \uC788\uB2E4. \uBE44\uC11C\uB294
    \uC55E\uC120 \uC0AC\uB840 \uD558\uB098\uB97C \uACE8\uB77C \uAC04\uB2E8\uD55C
    \uD310\uACB0\uBB38 \uD615\uC2DD\uC73C\uB85C \uC815\uB9AC\uD574 \uBCF4\uAC8C \uD55C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
