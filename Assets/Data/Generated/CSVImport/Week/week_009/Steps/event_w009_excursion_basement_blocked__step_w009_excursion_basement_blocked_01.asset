  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_excursion_basement_blocked__step_w009_excursion_basement_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 9\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uC9C0\uD558\uC2E4 \uAE4A\uC740 \uACF3, \uAC11\uC790\uAE30 \uD2C8\uC0C8\uB85C
    \uBD88\uC5B4\uC628 \uCC2C\uBC14\uB78C\uC5D0 \uD558\uB140\uAC00 \uB4E4\uACE0 \uC788\uB358
    \uCD1B\uBD88\uC774 \uD6C5 \uAEBC\uC838\uBC84\uB9B0\uB2E4. \uC0AC\uBC29\uC774
    \uC644\uC804\uD55C \uCE60\uD751 \uAC19\uC740 \uC5B4\uB460\uC5D0 \uC7A0\uAE34\uB2E4.)\r\n       
    \uD558\uB140 : \uAE84\uC545! \uC8FC, \uC8FC\uC778\uB2D8! \uC8C4\uC1A1\uD574\uC694,
    \uBD88\uC774 \uAEBC\uC84C\uC5B4\uC694! \uC5B4\uB5A1\uD558\uC8E0?\r\n        \r\n\r\n(\uC5B4\uB460
    \uC18D\uC5D0\uC11C \uACBD\uBE44\uB300\uC7A5\uC758 \uD06C\uACE0 \uB2E8\uB2E8\uD55C
    \uC190\uC774 \uB124\uBAA8\uC758 \uC190\uBAA9\uC744 \uB09A\uC544\uCC44\uB4EF \uC7A1\uB294\uB2E4.)\r\n       
    \uACBD\uBE44\uB300\uC7A5 : \uB2F9\uD669\uD558\uC9C0 \uB9C8\uC2ED\uC2DC\uC624.
    \uC774\uB7F0 \uD1B5\uC81C\uB418\uC9C0 \uC54A\uB294 \uB3CC\uBC1C \uC0C1\uD669
    \uB54C\uBB38\uC5D0 \uC81C\uAC00 \uC544\uAC00\uC528\uC758 \uC9C0\uD558\uC2E4 \uCD9C\uC785\uC744
    \uBC18\uB300\uD558\uB294 \uAC83\uC785\uB2C8\uB2E4. \uC81C \uBC1C\uC18C\uB9AC\uB9CC
    \uB530\uB77C\uC624\uC2ED\uC2DC\uC624.\r\n        \uB124\uBAA8 : \uC544, \uC54C\uACA0\uC5B4\uC694...\r\n       
    \uACBD\uBE44\uB300\uC7A5 : \uC800\uD0DD\uC758 \uC8FC\uC778\uC774 \uB420 \uBD84\uC774\uB77C\uBA74,
    \uBCF8\uC778\uC758 \uC2DC\uC57C\uAC00 \uB2FF\uC9C0 \uC54A\uB294 \uACF3\uC740
    \uD568\uBD80\uB85C \uB4E4\uC774\uC9C0 \uC54A\uB294 \uAC83\uC774 \uCCA0\uCE59\uC785\uB2C8\uB2E4."
