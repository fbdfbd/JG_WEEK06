  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_letter_friend_2_direct__step_event_week_009_letter_friend_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC00\uB9AC\uC544\uC758 \uD3B8\uC9C0 \uD5C8\uAC00"
  _bodyText: "letter friend_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uBBF8\uB798\uC758 \uB3D9\uBC18\uC790\uB85C\uC11C
      \uC57D\uC18D\uC744 \uBCF4\uB0B4\uC654\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBBF8\uB798\uC758 \uB3D9\uBC18\uC790?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9AC\uBCF8 \uAC00\uB974\uCCD0\uC8FC\uB7EC \uC628\uB300! \uC5ED\uC2DC
      \uAC54\uB294 \uACC4\uD68D\uC774 \uB2E4 \uC788\uAD6C\uB098."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uC758 \uAC00\uC7A5 \uB4E0\uB4E0\uD55C \uBA38\uB9AC\uAC00
      \uB418\uC5B4\uC904 \uCE5C\uAD6C\uB97C \uB450\uC168\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uAC54\uB791 \uD568\uAED8\uB77C\uBA74 \uC5B4\uB5A4 \uC5B4\uB824\uC6B4
      \uBC95\uC804\uB3C4 \uB2E4 \uC77D\uC744 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uBBF8\uB798\uC758 \uB3D9\uBC18\uC790\uB85C\uC11C
    \uC57D\uC18D\uC744 \uBCF4\uB0B4\uC654\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
