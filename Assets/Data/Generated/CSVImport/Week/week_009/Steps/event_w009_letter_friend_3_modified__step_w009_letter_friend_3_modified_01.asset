  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_letter_friend_3_modified__step_w009_letter_friend_3_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 9\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uC544\uC8FC \uD654\uB824\uD55C \uB099\uC11C\uC640
    \uBB34\uC9C0\uAC1C\uC0C9 \uC789\uD06C\uAC00 \uAC00\uB4DD\uD55C \uBD09\uD22C\uB97C
    \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C\uC5D4 '\uB124\uBAA8\uB97C \uC704\uD55C
    \uC740\uD558\uC218 \uC9C0\uB3C4'\uB77C\uACE0 \uC801\uD600 \uC788\uB2E4.)\n       
    \uD558\uB140 : \uC774\uC81C \uC815\uB9D0 \uB9C8\uC9C0\uB9C9 \uD3B8\uC9C0\uC778
    \uAC83 \uAC19\uC2B5\uB2C8\uB2E4. \uB0B4\uC6A9\uC774 \uC544\uC8FC \uBC85\uCC28\uB124\uC694.\n       
    \n\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC5B4\uB514\uC5D0
    \uC788\uB4E0 \uC8FC\uC778\uB2D8\uC758 \uB9C8\uC74C\uC774 \uC5B8\uC81C\uB098 \uC790\uC720\uB86D\uAE38
    \uBC14\uB780\uB300\uC694.\n        \uB124\uBAA8 : \uB0B4 \uB9C8\uC74C\uC774 \uC790\uC720\uB86D\uAE38
    \uBC14\uB780\uB2E4\uACE0?\n        \uD558\uB140 : \uB124. \uBC31\uC791\uB2D8\uC758
    \uB4A4\uB97C \uC774\uC5B4 \uBB34\uAC70\uC6B4 \uCC45\uC784\uC744 \uB9E1\uAC8C
    \uB418\uB354\uB77C\uB3C4, \uAD6C\uB984\uACFC \uBCC4\uC744 \uBCF4\uBA70 \uC6C3\uB358
    \uADF8 \uB9C8\uC74C\uB9CC\uC740 \uC783\uC9C0 \uB9D0\uB77C\uACE0 \uD569\uB2C8\uB2E4.
    \uB098\uC911\uC5D0 \uB2E4\uC2DC \uB9CC\uB098\uBA74 \uB204\uAC00 \uB354 \uD589\uBCF5\uD558\uAC8C
    \uC6C3\uB294\uC9C0 \uB0B4\uAE30\uD558\uC790\uACE0 \uD558\uB124\uC694.\n       
    \uB124\uBAA8 : \uC88B\uC544. \uB0B4\uAC00 \uBC31\uC791\uB2D8\uC774 \uB418\uC5B4\uB3C4
    \uC6C3\uC74C \uB0B4\uAE30\uB294 \uC808\uB300 \uC548 \uC9C8 \uAC70\uC57C!"
