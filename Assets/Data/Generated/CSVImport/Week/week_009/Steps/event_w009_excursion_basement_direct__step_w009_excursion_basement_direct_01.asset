  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_excursion_basement_direct__step_w009_excursion_basement_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 9\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uC9C0\uD558\uC2E4 \uAE4A\uC740 \uACF3, \uAC11\uC790\uAE30 \uD2C8\uC0C8\uB85C
    \uBD88\uC5B4\uC628 \uCC2C\uBC14\uB78C\uC5D0 \uD558\uB140\uAC00 \uB4E4\uACE0 \uC788\uB358
    \uCD1B\uBD88\uC774 \uD6C5 \uAEBC\uC838\uBC84\uB9B0\uB2E4. \uC0AC\uBC29\uC774
    \uC644\uC804\uD55C \uCE60\uD751 \uAC19\uC740 \uC5B4\uB460\uC5D0 \uC7A0\uAE34\uB2E4.)\r\n       
    \uD558\uB140 : \uAE84\uC545! \uC8FC, \uC8FC\uC778\uB2D8! \uC8C4\uC1A1\uD574\uC694,
    \uBD88\uC774 \uAEBC\uC84C\uC5B4\uC694! \uC5B4\uB5A1\uD558\uC8E0?\r\n        \r\n\r\n\uD558\uB140
    : \uD751, \uD6CC\uCA4D... \uBB34\uC11C\uC6CC\uC694, \uC8FC\uC778\uB2D8.\r\n       
    \uB124\uBAA8 : \uC774\uB9AC \uC640, \uB0B4 \uC190 \uC7A1\uC544. \uB0B4\uAC00
    \uAE38\uC744 \uC544\uB2C8\uAE4C \uC785\uAD6C \uCABD\uC73C\uB85C \uCC9C\uCC9C\uD788
    \uAC78\uC5B4\uAC00\uC790. \uBCBD \uC9DA\uC73C\uBA74\uC11C \uB530\uB77C\uC624\uBA74
    \uB3FC.\r\n        \uD558\uB140 : (\uB124\uBAA8\uC758 \uC190\uC744 \uAF49 \uC7A1\uC73C\uBA70)
    \uC8FC\uC778\uB2D8... \uC815\uB9D0 \uAC15\uD574\uC9C0\uC168\uB124\uC694. \uC608\uC804
    \uAC19\uC73C\uBA74 \uAC19\uC774 \uC6B0\uC168\uC744 \uD150\uB370.\r\n        \uB124\uBAA8
    : \uB098\uB3C4 \uC774\uC81C \uACE7 \uC5B4\uB978\uC778\uAC78. \uC774 \uC815\uB3C4
    \uC5B4\uB460\uCBE4\uC740 \uBB34\uC12D\uC9C0 \uC54A\uC544."
