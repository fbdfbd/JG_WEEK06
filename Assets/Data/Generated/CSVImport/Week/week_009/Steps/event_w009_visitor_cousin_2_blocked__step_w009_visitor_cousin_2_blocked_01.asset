  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_visitor_cousin_2_blocked__step_w009_visitor_cousin_2_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 9\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uB124\uBAA8\uAC00 \uBC31\uC791\uB2D8\uC758 \uC18C\uC911\uD55C \uAE43\uD39C\uC744
    \uB9CC\uC9C0\uC791\uAC70\uB9AC\uB2E4 \uC0AC\uCD0C 2\uC5D0\uAC8C \uAC74\uB124.
    \uC0AC\uCD0C 2\uB294 \uC0AC\uCD0C 1\uC774 \uAC00\uC838\uC628 \uD53C \uBB3B\uC740
    \uBAA8\uC790\uB97C \uBCF4\uACE0 \uBAB8\uC744 \uBC8C\uBC8C \uB5A8\uACE0 \uC788\uC5B4.)\n       
    \n        \uC0AC\uCD0C 2 : \uC800 \uBAA8\uC790... \uC6B0\uB9AC \uC544\uBE60 \uBC29\uC5D0
    \uC788\uB358 \uAC74\uB370... \uB124\uBAA8\uC57C, \uC800\uAE30 \uBB3B\uC740 \uAC70
    \uC9C4\uC9DC \uD53C\uC57C? \uC6B0\uB9AC \uC544\uBE60\uAC00 \uC815\uB9D0... \uB124
    \uBD80\uBAA8\uB2D8\uC744...\n        \uB124\uBAA8 : (\uAE43\uD39C\uC744 \uC0AC\uCD0C
    2\uC758 \uC190\uC5D0 \uAF49 \uC950\uC5EC\uC8FC\uBA70) \uC0AC\uCD0C 2, \uC120\uD0DD\uD574.
    \uB108\uD76C \uC544\uBC84\uC9C0\uCC98\uB7FC \uB098\uB97C \uD30C\uBA78\uC2DC\uD0AC
    \uAC74\uC9C0, \uC544\uB2C8\uBA74 \uB098\uB97C \uB3C4\uC640 \uBC31\uC791\uB2D8\uC758
    \uC774 \uC704\uC120\uC801\uC778 \uC11C\uC7AC\uB97C \uBD80\uC220 \uAC74\uC9C0.\n       
    \n\n- (\uC9D1\uC0AC\uAC00 \uB2E4\uAC00\uC640 \uC0AC\uCD0C 2\uC758 \uC190\uC5D0\uC11C
    \uAE43\uD39C\uC744 \uBE8F\uC73C\uB824 \uD558\uC790, \uC0AC\uCD0C 2\uAC00 \uAC81\uC5D0
    \uC9C8\uB824 \uAE43\uD39C\uC744 \uBC14\uB2E5\uC5D0 \uB5A8\uC5B4\uB728\uB824 \uBD80\uB7EC\uB728\uB9B0\uB2E4.)\n       
    - \uC9D1\uC0AC : \uC8FC\uC778\uB2D8\uC758 \uC9D1\uBB34 \uB3C4\uAD6C\uB97C \uD30C\uC190\uD558\uB2E4\uB2C8!
    \uB2F9\uC7A5 \uC774 \uBB34\uB840\uD55C \uC790\uB97C \uB04C\uC5B4\uB0B4\uB77C!\n       
    \uC0AC\uCD0C 2 : (\uC6B8\uC74C\uC744 \uD130\uB728\uB9AC\uBA70) \uBBF8\uC548\uD574,
    \uB124\uBAA8\uC57C! \uB09C \uBABB \uD574! \uBC31\uC791\uB2D8\uB3C4 \uBB34\uC12D\uACE0
    \uC6B0\uB9AC \uC544\uBE60\uB3C4 \uBB34\uC11C\uC6CC! \uB108\uB791 \uAC19\uC774
    \uC788\uB2E4\uAC04 \uB098\uAE4C\uC9C0 \uC8FD\uC744 \uAC83 \uAC19\uC544!\n       
    \uB124\uBAA8 : (\uBD80\uB7EC\uC9C4 \uAE43\uD39C\uC744 \uBCF4\uBA70 \uCC28\uAC11\uAC8C)
    \uACB0\uAD6D \uB108\uB3C4 \uB611\uAC19\uAD6C\uB098. \uBC31\uC791\uB2D8\uC758
    \uADDC\uCE59 \uC544\uB798\uC11C \uBC8C\uBC8C \uB5A8\uAE30\uB9CC \uD558\uB294
    \uAC81\uC7C1\uC774. \uB2E4\uC2DC\uB294 \uB0B4 \uC11C\uC7AC\uC5D0 \uBC1C \uB4E4\uC774\uC9C0
    \uB9C8.\n        \uC0AC\uCD0C 2 : (\uB3C4\uB9DD\uCE58\uB4EF \uC0AC\uB77C\uC9D0)"
