  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_excursion_library_blocked__step_w009_excursion_library_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 9\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uB178\uC744\uC774 \uC9C0\uB294 \uC624\uD6C4, \uB3C4\uC11C\uAD00\uC758
    \uC2A4\uD14C\uC778\uB4DC\uAE00\uB77C\uC2A4\uB97C \uD1B5\uD574 \uC77C\uACF1 \uBE5B\uAE54\uC758
    \uD587\uC0B4\uC774 \uC11C\uAC00\uC5D0 \uB0B4\uB824\uC549\uB294\uB2E4. \uB124\uBAA8\uAC00
    \uCC3D\uAC00 \uC790\uB9AC\uC5D0 \uC549\uC544 \uC870\uC6A9\uD788 \uC2DC\uC9D1\uC744
    \uC77D\uACE0 \uC788\uB2E4.)\r\n        \uD558\uB140 : \uC8FC\uC778\uB2D8, \uB178\uC744\uBE5B\uC5D0
    \uBE44\uCE5C \uBAA8\uC2B5\uC774 \uB9C8\uCE58 \uADF8\uB9BC \uAC19\uC544\uC694.
    \uC815\uB9D0 \uD3C9\uD654\uB85C\uC6CC \uBCF4\uC774\uC2DC\uB124\uC694.\r\n       
    \r\n\r\n(\uACBD\uBE44\uB300\uC7A5\uC774 \uCD1B\uBD88\uC744 \uAC00\uC838\uC640
    \uD14C\uC774\uBE14\uC5D0 \uB193\uC73C\uBA70 \uBD84\uC704\uAE30\uB97C \uAE6C\uB2E4.)\r\n       
    \uACBD\uBE44\uB300\uC7A5 : \uD574\uAC00 \uC84C\uC2B5\uB2C8\uB2E4. \uC5B4\uB450\uC6B4
    \uACF3\uC5D0\uC11C \uCC45\uC744 \uC77D\uC73C\uBA74 \uC2DC\uB825\uC774 \uC0C1\uD569\uB2C8\uB2E4.
    \uAC10\uC0C1\uC740 \uADF8\uB9CC\uB450\uACE0 \uC774\uC81C \uADF8\uB9CC \uBCF8\uAD00\uC73C\uB85C
    \uB3CC\uC544\uAC00 \uD6C8\uB828\uC744 \uC900\uBE44\uD558\uC2ED\uC2DC\uC624.\r\n       
    \uB124\uBAA8 : \uC544\uC800\uC528\uB294 \uC774 \uC544\uB984\uB2E4\uC6B4 \uD48D\uACBD\uC744
    \uC880 \uC990\uAE30\uC2E4 \uC904 \uBAA8\uB974\uC2DC\uB124\uC694. \uB531 \uC624
    \uBD84\uB9CC \uB354 \uC788\uB2E4\uAC00 \uAC08\uAC8C\uC694.\r\n        \uACBD\uBE44\uB300\uC7A5
    : \uC2DC\uAC04 \uC5C4\uC218\uB294 \uC9C0\uB3C4\uC790\uC758 \uAE30\uBCF8\uC785\uB2C8\uB2E4.
    \uB2F9\uC7A5 \uCC45\uC744 \uB36E\uC73C\uC2ED\uC2DC\uC624."
