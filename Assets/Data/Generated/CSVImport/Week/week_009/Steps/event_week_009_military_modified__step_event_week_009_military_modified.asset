--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_military_modified__step_event_week_009_military_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0A8\uACA8 \uB454 \uD798\uAE4C\uC9C0 \uC9C4\uD615\uC73C\uB85C
    \uBCF8\uB2E4"
  _bodyText: "\uAD70\uC0AC \uC804\uB7B5\uACFC \uBC29\uC5B4 \uC9C4\uD615 9\uC8FC\uCC28
    Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBAA8\uB798\uD310 \uC704\uC5D0 \uBCD1\uC815 \uB9D0\uC774 \uB354 \uB298\uC5B4\uB098\uACE0,
      \uC774\uBC88\uC5D4 \uC801\uC774 \uC5B4\uB514\uC11C \uB4E4\uC5B4\uC624\uB294\uC9C0
      \uC815\uD574\uC9C4 \uC0C1\uD0DC\uC5D0\uC11C \uC9C4\uD615\uC744 \uC9DC \uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC624\uB298\uC740 \uC9C0\uD615 \uC704\uC5D0 \uC0AC\uB78C\uC744 \uC5B9\uC5B4
      \uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB4DC\uB514\uC5B4 \uB9D0 \uC4F0\uB124."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB124. \uB300\uC2E0 \uC774\uC720 \uC5C6\uC774 \uB450\uBA74 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uBCD1\uC815 \uB9D0 \uC138 \uAC1C\uB97C
      \uB530\uB85C \uB5BC\uC5B4 \uC606\uC5D0 \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC804\uBD80 \uC55E\uC5D0 \uC138\uC6B4\uB2E4\uACE0 \uC88B\uC740 \uC9C4\uD615\uC740
      \uC544\uB2D9\uB2C8\uB2E4. \uB0A8\uACA8 \uB450\uB294 \uC790\uB9AC\uB3C4 \uC9C4\uD615\uC758
      \uC77C\uBD80\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548 \uC4F0\uB294 \uB9D0\uB3C4 \uD544\uC694\uD558\uB2E4\uB294 \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB124. \uB0A8\uACA8 \uB454 \uD798\uC774 \uB9C8\uC9C0\uB9C9\uC5D0 \uC120\uC744
      \uC9C0\uD0A4\uAE30\uB3C4 \uD558\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uC880 \uB9C8\uC74C\uC5D0 \uB4E0\uB2E4. \uB2E4 \uAEBC\uB0B4\uB193\uB294
      \uAC8C \uB2A5\uC0AC\uB294 \uC544\uB2C8\uB124."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uBC14\uB85C \uADF8\uAC81\uB2C8\uB2E4."
  _nemoLine: "(\uBAA8\uB798\uD310 \uC704\uC5D0 \uBCD1\uC815 \uB9D0\uC774 \uB354 \uB298\uC5B4\uB098\uACE0,
    \uC774\uBC88\uC5D4 \uC801\uC774 \uC5B4\uB514\uC11C \uB4E4\uC5B4\uC624\uB294\uC9C0
    \uC815\uD574\uC9C4 \uC0C1\uD0DC\uC5D0\uC11C \uC9C4\uD615\uC744 \uC9DC \uBCF8\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
