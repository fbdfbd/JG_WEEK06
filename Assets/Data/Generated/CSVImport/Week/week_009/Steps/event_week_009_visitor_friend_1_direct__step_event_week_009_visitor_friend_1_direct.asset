  _titleOverride: "\uB9C9\uC2A4 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor friend_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "(\uC6C3\uC73C\uBA70) \uC5ED\uC2DC \uB0B4 \uCE5C\uAD6C \uB124\uBAA8\uB2F5\uB124!
      \uC774\uC81C \uC774 \uC11C\uC7AC\uB294 \uB354 \uC774\uC0C1 \uAC07\uD78C \uACF3\uC774
      \uC544\uB2C8\uB77C \uC138\uC0C1\uC744 \uD5A5\uD574 \uC5F4\uB9B0 \uACF3\uC774
      \uB418\uACA0\uC5B4. \uB10C \uCD5C\uACE0\uC758 \uBC31\uC791\uC774 \uB420 \uAC70\uC57C!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uB9C9\uC2A4\uC758 \uC190\uC744 \uAF49 \uC7A1\uC73C\uBA70) \uC544\uB2C8,
      \uC6B0\uB9AC\uB294 \uCD5C\uACE0\uC758 \uB3D9\uB8CC\uAC00 \uB420 \uAC70\uC57C.
      \uB0B4\uC77C \uBCF4\uC790!"
  _nemoLine: "(\uC6C3\uC73C\uBA70) \uC5ED\uC2DC \uB0B4 \uCE5C\uAD6C \uB124\uBAA8\uB2F5\uB124!
    \uC774\uC81C \uC774 \uC11C\uC7AC\uB294 \uB354 \uC774\uC0C1 \uAC07\uD78C \uACF3\uC774
    \uC544\uB2C8\uB77C \uC138\uC0C1\uC744 \uD5A5\uD574 \uC5F4\uB9B0 \uACF3\uC774
    \uB418\uACA0\uC5B4. \uB10C \uCD5C\uACE0\uC758 \uBC31\uC791\uC774 \uB420 \uAC70\uC57C!"
