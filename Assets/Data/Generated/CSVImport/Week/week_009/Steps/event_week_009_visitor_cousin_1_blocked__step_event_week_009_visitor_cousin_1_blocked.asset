  _titleOverride: "\uCE74\uC774\uC548 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor cousin_1 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC8FC\uC778\uB2D8! \uC800\uC790\uC758 \uB18D\uAC04\uC785\uB2C8\uB2E4.
      \uC81C\uBC1C \uC9C4\uC815\uD558\uC2ED\uC2DC\uC624!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uCC45\uC0C1\uC744 \uC5CE\uC744 \uB4EF\uC774 \uCE74\uC774\uC628\uC5D0\uAC8C
      \uC18C\uB9AC\uCE5C\uB2E4) \uB098\uAC00! \uB2F9\uC7A5 \uB0B4 \uC9D1\uC5D0\uC11C
      \uB098\uAC00! \uBC31\uC791\uB2D8\uC774 \uC0B4\uC778\uC790\uB4E0 \uC544\uB2C8\uB4E0,
      \uB2F9\uC2E0 \uAC19\uC740 \uC778\uAC04\uC774 \uB0B4 \uBD80\uBAA8\uB2D8\uC744
      \uC785\uC5D0 \uC62C\uB9AC\uB294 \uAC74 \uCC38\uC744 \uC218 \uC5C6\uC5B4! \uD558\uC9C0\uB9CC...
      (\uCE58\uC6CC\uC9C0\uB294 \uBAA8\uC790\uB97C \uBCF4\uBA70) \uBC31\uC791\uB2D8\uAED8
      \uC804\uD574. \uB354 \uC774\uC0C1 \uD5A5\uC218 \uB0C4\uC0C8\uB85C \uC774 \uD53C\uBE44\uB9B0\uB0B4\uB97C
      \uAC00\uB9B4 \uC218 \uC5C6\uC744 \uAC70\uB77C\uACE0!"
  _nemoLine: "\uC8FC\uC778\uB2D8! \uC800\uC790\uC758 \uB18D\uAC04\uC785\uB2C8\uB2E4.
    \uC81C\uBC1C \uC9C4\uC815\uD558\uC2ED\uC2DC\uC624!"
