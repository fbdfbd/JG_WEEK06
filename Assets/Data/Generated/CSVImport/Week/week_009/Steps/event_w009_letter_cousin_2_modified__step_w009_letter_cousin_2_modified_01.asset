  m_Name: event_w009_letter_cousin_2_modified__step_w009_letter_cousin_2_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 \uD3B8\uC9C0 9\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uC544\uC8FC \uC587\uACE0 \uC12C\uC138\uD55C \uC885\uC774\uB85C
    \uB41C \uD3B8\uC9C0\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C\uC5D0 '\uC601\uC6D0\uD55C
    \uBE44\uBC00 \uCE5C\uAD6C'\uB77C\uACE0 \uC801\uD600 \uC788\uB2E4.)\r\n       
    \r\n\r\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uC774
    \uC8FC\uC778\uB2D8\uACFC \uD568\uAED8\uD560 \uBBF8\uB798\uB97C \uAFC8\uAFB8\uBA70
    \uC6A9\uAE30\uB97C \uB0B4\uACE0 \uC788\uC2B5\uB2C8\uB2E4.\r\n        \uB124\uBAA8
    : \uBB34\uC2A8 \uC6A9\uAE30?\r\n        \uD558\uB140 : \uB098\uC911\uC5D0 \uC131\uC778\uC774
    \uB418\uC5B4 \uB2E4\uC2DC \uB9CC\uB0A0 \uB54C, \uC8FC\uC778\uB2D8 \uC55E\uC5D0
    \uBD80\uB044\uB7FD\uC9C0 \uC54A\uC740 \uC0AC\uB78C\uC774 \uB418\uC5B4 \uB098\uD0C0\uB098\uACA0\uB300\uC694.
    \uADF8\uB54C\uAE4C\uC9C0 \uC11C\uB85C\uC758 \uC790\uB9AC\uC5D0\uC11C \uCD5C\uC120\uC744
    \uB2E4\uD558\uC790\uACE0 \uD569\uB2C8\uB2E4.\r\n        \uB124\uBAA8 : \uADF8\uB798.
    \uB098\uB3C4 \uC5EC\uAE30\uC11C \uBC31\uC791\uB2D8 \uACF5\uBD80 \uC5F4\uC2EC\uD788
    \uD558\uACE0 \uC788\uC744\uAC8C. \uAC54\uB791 \uB2E4\uC2DC \uB9CC\uB0A0 \uB0A0\uC774
    \uAE30\uB2E4\uB824\uC838."
