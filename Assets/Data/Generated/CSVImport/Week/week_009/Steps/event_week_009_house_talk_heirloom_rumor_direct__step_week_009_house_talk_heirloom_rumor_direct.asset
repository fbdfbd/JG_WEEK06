  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_house_talk_heirloom_rumor_direct__step_week_009_house_talk_heirloom_rumor_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uAE30\uC774\uD55C \uAC00\uBCF4 \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "\uAE30\uC774\uD55C \uAC00\uBCF4 \uC18C\uBB38 - \uD5C8\uB77D \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC131\uC778\uC2DD \uB54C \uC4F0\uC774\uB294 \uAC00\uBCF4\uB294 \uC2A4\uC2A4\uB85C
      \uC8FC\uC778\uC744 \uC54C\uC544\uBCF8\uB2E4\uB294 \uB9D0\uC774 \uD558\uC778\uB4E4
      \uC0AC\uC774\uC5D0 \uB3D5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC815\uB9D0 \uBB3C\uAC74\uC774 \uC0AC\uB78C\uC744 \uACE0\uB97C \uC218
      \uC788\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC0C1\uC9D5\uC801\uC778 \uD45C\uD604\uC774\uACA0\uC9C0\uC694. \uB2E4\uB9CC
      \uADF8\uB9CC\uD07C \uBAA8\uB450\uAC00 \uADF8 \uC758\uC2DD\uC744 \uC911\uC694\uD558\uAC8C
      \uC5EC\uAE34\uB2E4\uB294 \uB73B\uC774\uAE30\uB3C4 \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB807\uB2E4\uBA74 \uBB34\uC12D\uAE30\uBCF4\uB2E4... \uC800\uB3C4
      \uC81C\uB300\uB85C \uC11C \uC788\uC5B4\uC57C\uACA0\uB124."
  _nemoLine: "\uC131\uC778\uC2DD \uB54C \uC4F0\uC774\uB294 \uAC00\uBCF4\uB294 \uC2A4\uC2A4\uB85C
    \uC8FC\uC778\uC744 \uC54C\uC544\uBCF8\uB2E4\uB294 \uB9D0\uC774 \uD558\uC778\uB4E4
    \uC0AC\uC774\uC5D0 \uB3D5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
