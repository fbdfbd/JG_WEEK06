  _titleOverride: "\uAE30\uC774\uD55C \uAC00\uBCF4 \uC18C\uBB38 - \uD1B5\uC81C"
  _bodyText: "\uAE30\uC774\uD55C \uAC00\uBCF4 \uC18C\uBB38 - \uD1B5\uC81C \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uAC00\uBCF4\uAC00 \uC8FC\uC778\uC744 \uACE0\uB978\uB2E4\uB294 \uC18C\uBB38\uC740
      \uC2DC\uD5D8\uCC98\uB7FC \uB4E4\uB9AC\uC9C0 \uC54A\uAC8C \uB20C\uB7EC \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC00\uBCF4 \uC598\uAE30 \uB610 \uB098\uC654\uC5B4\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uC778\uB4E4 \uC0AC\uC774 \uB9D0\uC740 \uD758\uB824\uB4E3\uACE0,
      \uC911\uC694\uD55C \uAC74 \uC900\uBE44\uC640 \uD0DC\uB3C4\uB77C\uACE0\uB9CC
      \uC9DA\uC5B4 \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uAD1C\uD788 \uC18C\uBB38\uC5D0 \uD718\uB458\uB9AC\uC9C4 \uC54A\uC744\uB798."
  _nemoLine: "(\uAC00\uBCF4\uAC00 \uC8FC\uC778\uC744 \uACE0\uB978\uB2E4\uB294 \uC18C\uBB38\uC740
    \uC2DC\uD5D8\uCC98\uB7FC \uB4E4\uB9AC\uC9C0 \uC54A\uAC8C \uB20C\uB7EC \uB454\uB2E4.)"
