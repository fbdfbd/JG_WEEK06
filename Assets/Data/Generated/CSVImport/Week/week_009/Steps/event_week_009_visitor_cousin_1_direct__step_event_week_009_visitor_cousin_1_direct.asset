  _titleOverride: "\uCE74\uC774\uC548 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor cousin_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "(\uB2F9\uD669\uD55C \uB4EF \uC6C3\uC73C\uBA70) \uC5B4\uD5C8, \uB9D0\uC774
      \uC2EC\uD558\uB124. \uB09C \uADF8\uC800 \uC99D\uAC70\uB97C \uAC00\uC838\uC628
      \uAC83\uBFD0\uC774\uC57C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uBC31\uC791\uB2D8\uC758 \uAE43\uD39C\uC744 \uC0AC\uCD0C 1\uC758 \uBAA9
      \uADFC\uCC98\uB85C \uACA8\uB204\uBA70) \uC9C4\uC2E4\uC774 \uBB50\uB4E0, \uC774
      \uC11C\uC7AC\uC758 \uC8FC\uC778\uC740 \uB098\uC57C. \uBC31\uC791\uB2D8\uC774
      \uB098\uB97C \uC18D\uC600\uB2E4\uBA74 \uB0B4\uAC00 \uC2EC\uD310\uD574. \uD558\uC9C0\uB9CC
      \uB0B4 \uC11C\uC7AC\uB97C \uB354\uB7FD\uD788\uACE0 \uB098\uB97C \uD754\uB4E0
      \uB300\uAC00\uB294 \uC0BC\uCD0C\uC774 \uBA3C\uC800 \uCE58\uB974\uAC8C \uB420
      \uAC70\uC57C. \uB2F9\uC7A5 \uAEBC\uC838!"
  _nemoLine: "(\uB2F9\uD669\uD55C \uB4EF \uC6C3\uC73C\uBA70) \uC5B4\uD5C8, \uB9D0\uC774
    \uC2EC\uD558\uB124. \uB09C \uADF8\uC800 \uC99D\uAC70\uB97C \uAC00\uC838\uC628
    \uAC83\uBFD0\uC774\uC57C."
