  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_letter_friend_1_direct__step_w009_letter_friend_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 9\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uC815\uAC08\uD55C \uBD09\uD22C\uB97C \uB4E4\uACE0
    \uC628\uB2E4. \uAC89\uC5D0\uB294 '\uCD5C\uD6C4\uC758 \uACC4\uC57D\uC11C'\uB77C\uACE0
    \uBE44\uC7A5\uD558\uAC8C \uC801\uD600 \uC788\uB2E4.)\r\n        \r\n\r\n\uD558\uB140
    : \uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uD3C9\uC0DD\uC758 \uC57D\uC18D\uC744
    \uC801\uC5B4 \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\r\n        \uB124\uBAA8 : \uCD5C\uD6C4\uC758
    \uACC4\uC57D\uC11C? \uBB50\uC57C, \uBB34\uC11C\uC6CC!\r\n        (\uD558\uB140\uAC00
    \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)\r\n        \uB124\uBAA8, \uB0B4\uC77C\uBD80\uD130
    \uC6B0\uB9B0 \uC9C4\uC9DC \uC5B4\uB978\uC774\uC57C. \uC774\uC81C \uC0AC\uCD0C
    1 \uAC19\uC740 \uBC40 \uAC19\uC740 \uB188\uB4E4\uC774 \uB110 \uAD34\uB86D\uD788\uC9C0
    \uBABB\uD558\uAC8C \uB0B4\uAC00 \uB124 \uC81C\uC77C \uB0A0\uCE74\uB85C\uC6B4
    \uCE7C\uC774 \uB420\uAC8C. \uB10C \uBA4B\uC9C4 \uBC31\uC791\uB2D8\uC774 \uB3FC\uC11C
    \uB098\uB791 \uC774 \uB113\uC740 \uC138\uC0C1\uC744 \uB2E4 \uB4A4\uC9D1\uACE0
    \uB2E4\uB2C8\uC790. \uC78A\uC9C0 \uB9C8, \uC6B0\uB9B0 \uC601\uC6D0\uD55C \uB2E8\uC9DD\uC774\uC57C!\r\n       
    \uB124\uBAA8 : \uB0B4 \uC81C\uC77C \uB0A0\uCE74\uB85C\uC6B4 \uCE7C... \uAC54\uB294
    \uC9C4\uC9DC \uBA4B\uC9C4 \uB9D0\uC744 \uC798\uD574.\r\n        \uD558\uB140
    : \uC8FC\uC778\uB2D8 \uACC1\uC5D0 \uC774\uB7F0 \uB4E0\uB4E0\uD55C \uAE30\uC0AC\uAC00
    \uC788\uC73C\uB2C8 \uBC31\uC791\uB2D8\uB3C4 \uC548\uC2EC\uD558\uC2DC\uACA0\uB124\uC694.\r\n       
    \uB124\uBAA8 : \uC751. \uC774 \uD3B8\uC9C0, \uB0B4 \uBCF4\uBB3C\uD568 \uC81C\uC77C
    \uAE4A\uC740 \uACF3\uC5D0 \uB123\uC5B4\uC918. \uC6B0\uB9AC \uACC4\uC57D\uC11C\uB2C8\uAE4C!"
