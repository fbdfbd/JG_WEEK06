--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_diplomacy_modified__step_event_week_009_diplomacy_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uAC70\uC808\uC744 \uB2E4\uB978 \uC81C\uC548\uC73C\uB85C \uB3CC\uB9B0\uB2E4"
  _bodyText: "\uC678\uAD50\uC220\uACFC \uC218\uC0AC\uD559 9\uC8FC\uCC28 Modified
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC751\uC811\uC2E4. \uC774\uBC88\uC5D4 \uC9E7\uC740 \uC0C1\uD669\uADF9
      \uD615\uC2DD\uC774\uB2E4. \uBE44\uC11C\uB294 \uC190\uB2D8 \uC5ED, \uD558\uB140\uB294
      \uC911\uC7AC \uC5ED\uC744 \uB9E1\uACE0, \uB124\uBAA8\uB294 \uC608\uC758\uB97C
      \uC783\uC9C0 \uC54A\uC73C\uBA74\uC11C\uB3C4 \uAC70\uC808\uD558\uB294 \uB9D0\uC744
      \uC5F0\uC2B5\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC624\uB298\uC740 \uBC1B\uC544\uB4E4\uC774\uB294 \uBC95\uC774 \uC544\uB2C8\uB77C,
      \uBD80\uB4DC\uB7FD\uAC8C \uAC70\uC808\uD558\uB294 \uBC95\uC744 \uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC70\uC808\uC740 \uADF8\uB0E5 \uC548 \uB41C\uB2E4\uACE0 \uD558\uBA74
      \uB418\uB294 \uC904 \uC54C\uC558\uB294\uB370."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uADF8\uAC8C \uC81C\uC77C \uC26C\uC6B0\uBA74\uC11C\uB3C4 \uC81C\uC77C
      \uAC70\uCE60\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uCC28\uB97C \uD55C \uC794 \uB193\uC73C\uBA70 \uB9D0\uC758
      \uD750\uB984\uC744 \uB04A\uC9C0 \uC54A\uAC8C \uB3C4\uC640\uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uAC70\uC808\uD55C\uB2E4\uACE0 \uC0DD\uAC01\uD558\uC9C0 \uB9D0\uACE0,
      \uB2E4\uB978 \uC790\uB9AC\uB85C \uC62E\uACA8 \uB193\uB294\uB2E4\uACE0 \uC0DD\uAC01\uD574
      \uBCF4\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uB978 \uC790\uB9AC\uB85C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \u201C\uC9C0\uAE08\uC740 \uC5B4\uB835\uC9C0\uB9CC, \uC774\uCABD\uC740
      \uAC00\uB2A5\uD569\uB2C8\uB2E4\u201D \uAC19\uC740 \uC2DD\uC73C\uB85C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544. \uADF8\uB7FC \uD6E8\uC52C \uBD80\uB4DC\uB7FD\uB124."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB9DE\uC544\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uC368\uBA39\uC744 \uB370\uAC00 \uB9CE\uACA0\uB2E4."
  _nemoLine: "(\uC751\uC811\uC2E4. \uC774\uBC88\uC5D4 \uC9E7\uC740 \uC0C1\uD669\uADF9
    \uD615\uC2DD\uC774\uB2E4. \uBE44\uC11C\uB294 \uC190\uB2D8 \uC5ED, \uD558\uB140\uB294
    \uC911\uC7AC \uC5ED\uC744 \uB9E1\uACE0, \uB124\uBAA8\uB294 \uC608\uC758\uB97C
    \uC783\uC9C0 \uC54A\uC73C\uBA74\uC11C\uB3C4 \uAC70\uC808\uD558\uB294 \uB9D0\uC744
    \uC5F0\uC2B5\uD55C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
