  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_external_main_direct__step_w009_external_main_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "9\uCC28 - \uD5C8\uB77D"
  _bodyText: "\uBC31\uC791\uB2D8\uC758 \uBE44\uBC00 \uC720\uC5B8\uC7A5\n    \n   
    (\uC131\uC778\uC2DD \uC804\uB0A0 \uBC24, \uC9D1\uBB34\uC2E4 \uADFC\uCC98 \uC5B4\uB450\uC6B4
    \uBCF5\uB3C4. \uBCC0\uD638\uC0AC\uC640 \uC9D1\uC0AC\uAC00 \uB0AE\uC740 \uBAA9\uC18C\uB9AC\uB85C
    \uC11C\uB958\uB97C \uD655\uC778\uD55C\uB2E4.)\n    \n    \uBCC0\uD638\uC0AC :
    \uBC31\uC791\uB2D8\uC774 \uC774\uBC88 \uC131\uC778\uC2DD \uB54C \uACF5\uAC1C\uD560
    \uC720\uC5B8\uC7A5\uC5D0 '\uADF8 \uB0B4\uC6A9'\uC744 \uC9C4\uC9DC \uB123\uC73C\uC2E0
    \uAC74\uAC00\uC694? \uC601\uC9C0\uC758 \uC808\uBC18\uC744...\n    \uC9D1\uC0AC
    : \uC27F! \uC8FC\uC778\uB2D8\uC774 \uB4E4\uC73C\uC2DC\uBA74 \uC548 \uB429\uB2C8\uB2E4.
    \uC774\uAC74 \uAC00\uBB38\uC758 \uADFC\uAC04\uC744 \uD754\uB4E4 \uC218\uB3C4
    \uC788\uB294 \uACB0\uC815\uC785\uB2C8\uB2E4.\n    \uB124\uBAA8 : \uC720\uC5B8\uC7A5?
    \uC601\uC9C0\uC758 \uC808\uBC18\uC744 \uC5B4\uB5BB\uAC8C \uD55C\uB2E4\uB294 \uAC70\uC57C?\n   
    \n\n- \uC9D1\uC0AC : \uBC31\uC791\uB2D8\uC774 \uC8FC\uC778\uB2D8\uC744 \uB108\uBB34
    \uC0AC\uB791\uD558\uC154\uC11C, \uC601\uC9C0\uC758 \uC808\uBC18\uC744 \uB5BC\uC5B4
    \uC8FC\uC778\uB2D8\uB9CC\uC758 \uD2B9\uBCC4\uD55C '\uAFC8\uC758 \uB3C4\uC2DC'\uB97C
    \uB9CC\uB4E4\uB77C\uACE0 \uD558\uC2E0 \uC18C\uBB38\uC774 \uC788\uC5B4\uC694.\n   
    \uB124\uBAA8 : \uB098\uB9CC\uC758 \uB3C4\uC2DC? \uB0B4\uAC00 \uD558\uACE0 \uC2F6\uC740
    \uAC78 \uB2E4 \uD560 \uC218 \uC788\uB294 \uACF3\uC774\uC57C?\n    \uBCC0\uD638\uC0AC
    : \uB124. \uC8FC\uC778\uB2D8\uC758 \uADF8 \uB9D1\uC740 \uD638\uAE30\uC2EC\uC73C\uB85C
    \uC138\uC0C1\uC744 \uB354 \uC544\uB984\uB2F5\uAC8C \uBC14\uAFD4\uBCF4\uB77C\uB294
    \uBC31\uC791\uB2D8\uC758 \uB9C8\uC9C0\uB9C9 \uC2DC\uD5D8\uC774\uC790 \uC120\uBB3C\uC774\uC9C0\uC694.\n   
    \uB124\uBAA8 : \uC6B0\uC640... \uBC31\uC791\uB2D8\uC740 \uC815\uB9D0 \uB2E4 \uACC4\uD68D\uC774
    \uC788\uC73C\uC2DC\uAD6C\uB098. \uB098 \uC9C4\uC9DC \uBA4B\uC9C4 \uB3C4\uC2DC\uB97C
    \uB9CC\uB4E4 \uAC70\uC57C!"
