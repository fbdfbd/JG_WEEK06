  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_letter_cousin_2_modified__step_event_week_009_letter_cousin_2_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9AC\uC548\uC758 \uD3B8\uC9C0 \uC218\uC815"
  _bodyText: "letter cousin_2 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uC774 \uC8FC\uC778\uB2D8\uACFC
      \uD568\uAED8\uD560 \uBBF8\uB798\uB97C \uAFC8\uAFB8\uBA70 \uC6A9\uAE30\uB97C
      \uB0B4\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB34\uC2A8 \uC6A9\uAE30?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB098\uC911\uC5D0 \uC131\uC778\uC774 \uB418\uC5B4 \uB2E4\uC2DC \uB9CC\uB0A0
      \uB54C, \uC8FC\uC778\uB2D8 \uC55E\uC5D0 \uBD80\uB044\uB7FD\uC9C0 \uC54A\uC740
      \uC0AC\uB78C\uC774 \uB418\uC5B4 \uB098\uD0C0\uB098\uACA0\uB300\uC694. \uADF8\uB54C\uAE4C\uC9C0
      \uC11C\uB85C\uC758 \uC790\uB9AC\uC5D0\uC11C \uCD5C\uC120\uC744 \uB2E4\uD558\uC790\uACE0
      \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB798. \uB098\uB3C4 \uC5EC\uAE30\uC11C \uBC31\uC791\uB2D8 \uACF5\uBD80
      \uC5F4\uC2EC\uD788 \uD558\uACE0 \uC788\uC744\uAC8C. \uAC54\uB791 \uB2E4\uC2DC
      \uB9CC\uB0A0 \uB0A0\uC774 \uAE30\uB2E4\uB824\uC838."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uC774 \uC8FC\uC778\uB2D8\uACFC
    \uD568\uAED8\uD560 \uBBF8\uB798\uB97C \uAFC8\uAFB8\uBA70 \uC6A9\uAE30\uB97C \uB0B4\uACE0
    \uC788\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
