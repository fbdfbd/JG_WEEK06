  _titleOverride: "\uC7A5\uBD80\uC640 \uB3C8\uC758 \uD750\uB984\uC744 \uAC00\uB974\uCE5C\uB2E4"
  _bodyText: "\uC7A5\uBD80\uC640 \uB3C8\uC758 \uD750\uB984\uC744 \uAC00\uB974\uCE5C\uB2E4
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC7A5\uBD80\uC758 \uD56D\uBAA9\uACFC \uC218\uC785\xB7\uC9C0\uCD9C\uC758
      \uD750\uB984\uC744 \uC9DA\uC73C\uBA70 \uAE30\uBCF8\uC744 \uC775\uD788\uAC8C
      \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB4E4\uC5B4\uC628 \uAC83\uACFC \uB098\uAC04 \uAC78 \uAC19\uC774 \uBD10\uC57C
      \uD558\uB294 \uAC70\uAD6C\uB098."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uC22B\uC790\uB97C \uADF8\uB0E5 \uC678\uC6B0\uC9C0 \uC54A\uAC8C \uD558\uB824\uACE0
      \uD750\uB984\uC744 \uD568\uAED8 \uC9DA\uC5B4 \uC900\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uC81C \uC7A5\uBD80\uAC00 \uC65C \uD544\uC694\uD55C\uC9C0 \uC54C
      \uAC83 \uAC19\uC544."
  _nemoLine: "(\uC7A5\uBD80\uC758 \uD56D\uBAA9\uACFC \uC218\uC785\xB7\uC9C0\uCD9C\uC758
    \uD750\uB984\uC744 \uC9DA\uC73C\uBA70 \uAE30\uBCF8\uC744 \uC775\uD788\uAC8C \uD55C\uB2E4.)"
