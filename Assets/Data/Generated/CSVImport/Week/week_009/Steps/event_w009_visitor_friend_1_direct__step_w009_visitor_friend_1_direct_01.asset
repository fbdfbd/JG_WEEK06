  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_visitor_friend_1_direct__step_w009_visitor_friend_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 9\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uC131\uC778\uC2DD \uC804\uB0A0 \uBC24, \uCE5C\uAD6C 1\uC774 \uC815\uC911\uD558\uAC8C
    \uC11C\uC7AC \uBB38\uC744 \uB450\uB4DC\uB9AC\uACE0 \uB4E4\uC5B4\uC640. \uB450
    \uC0AC\uB78C\uC740 \uC774\uC81C \uB354 \uC774\uC0C1 \uC228\uBC14\uAF2D\uC9C8\uD558\uB4EF
    \uB180\uB358 \uC544\uC774\uB4E4\uC774 \uC544\uB2C8\uC57C. \uCE5C\uAD6C 1\uC740
    \uBC31\uC791\uB2D8\uC758 \uC11C\uC7AC\uC5D0 \uC5B4\uC6B8\uB9AC\uB294 \uC815\uC911\uD55C
    \uC778\uC0AC\uB97C \uAC74\uB124.)\r\n        \r\n        \uCE5C\uAD6C 1 : \uB124\uBAA8\uC57C,
    \uC774\uC81C \uB0B4\uC77C\uC774\uBA74 \uB10C \uC774 \uC11C\uC7AC\uC758 \uC815\uC2DD
    \uC8FC\uC778\uC774\uC790 \uBC31\uC791\uB2D8\uC758 \uD6C4\uACC4\uC790\uAC00 \uB418\uACA0\uC9C0?
    \uC0AC\uCD0C 1 \uAC19\uC740 \uC0AC\uB78C\uB4E4\uC774 \uC544\uBB34\uB9AC \uD754\uB4E4\uC5B4\uB3C4
    \uB10C \uD754\uB4E4\uB9AC\uC9C0 \uC54A\uC744 \uAC70\uB77C\uB294 \uAC70 \uC54C\uC544.
    \uC790, \uC774\uAC74 \uB0B4 \uB9C8\uC9C0\uB9C9 \uC120\uBB3C\uC774\uC57C.\r\n       
    (\uCE5C\uAD6C 1\uC774 \uD22C\uBC15\uD558\uC9C0\uB9CC \uC815\uC131\uC774 \uB2F4\uAE34
    \uC9C1\uC811 \uAE4E\uC740 \uB098\uBB34 \uC778\uC7A5\uC744 \uB0B4\uBBFC\uB2E4.)\r\n       
    \r\n\r\n- (\uB124\uBAA8\uAC00 \uCE5C\uAD6C 1\uC758 \uB098\uBB34 \uC778\uC7A5\uC744
    \uB4E4\uACE0 \uC11C\uC7AC \uBCBD\uBA74\uC758 \uBE48 \uC591\uD53C\uC9C0\uC5D0
    \uAFB9 \uCC0D\uB294\uB2E4.)\r\n        - \uB124\uBAA8 : \uC774\uAC74 \uB0B4 \uCCAB
    \uBC88\uC9F8 \uACF5\uC2DD \uC120\uC5B8\uC774\uC57C. \uC55E\uC73C\uB85C \uC774
    \uC11C\uC7AC\uB294 \uBC31\uC791\uB2D8\uC758 \uC9C0\uD61C\uC640 \uC6B0\uB9AC\uC758
    \uC6B0\uC815\uC774 \uACF5\uC874\uD558\uB294 \uACF3\uC774 \uB420 \uAC70\uC57C.
    \uC0AC\uCD0C 1 \uAC19\uC740 \uC801\uB4E4\uC774 \uAC10\uD788 \uBC1C\uBD99\uC774\uC9C0
    \uBABB\uD558\uAC8C \uB9D0\uC774\uC57C.\r\n        \uCE5C\uAD6C 1 : (\uC6C3\uC73C\uBA70)
    \uC5ED\uC2DC \uB0B4 \uCE5C\uAD6C \uB124\uBAA8\uB2F5\uB124! \uC774\uC81C \uC774
    \uC11C\uC7AC\uB294 \uB354 \uC774\uC0C1 \uAC07\uD78C \uACF3\uC774 \uC544\uB2C8\uB77C
    \uC138\uC0C1\uC744 \uD5A5\uD574 \uC5F4\uB9B0 \uACF3\uC774 \uB418\uACA0\uC5B4.
    \uB10C \uCD5C\uACE0\uC758 \uBC31\uC791\uC774 \uB420 \uAC70\uC57C!\r\n       
    \uB124\uBAA8 : (\uCE5C\uAD6C 1\uC758 \uC190\uC744 \uAF49 \uC7A1\uC73C\uBA70)
    \uC544\uB2C8, \uC6B0\uB9AC\uB294 \uCD5C\uACE0\uC758 \uB3D9\uB8CC\uAC00 \uB420
    \uAC70\uC57C. \uB0B4\uC77C \uBCF4\uC790!"
