  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_visitor_cousin_1_direct__step_w009_visitor_cousin_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 9\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uC0AC\uCD0C 1\uC774 \uD53C\uC640 \uD759\uC774 \uC5C9\uACA8 \uBD99\uC740
    \uB0A1\uC740 \uBAA8\uC790\uB97C \uBC31\uC791\uB2D8\uC758 \uC815\uAC08\uD55C \uCC45\uC0C1
    \uC704, \uBC31\uC791\uB2D8\uC758 \uC11C\uBA85\uC774 \uC801\uD78C \uC11C\uB958\uB4E4
    \uC704\uC5D0 \uB358\uC838\uB193\uB294\uB2E4. \uC11C\uC7AC\uC758 \uC6B0\uC544\uD55C
    \uC7A5\uBBF8 \uD5A5\uC218 \uB0C4\uC0C8\uAC00 \uC21C\uC2DD\uAC04\uC5D0 \uBE44\uB9BF\uD55C
    \uD53C \uB0C4\uC0C8\uB85C \uB354\uB7FD\uD600\uC9C4\uB2E4.)\n        \n       
    \uC0AC\uCD0C 1 : \uC57C, \uB124\uBAA8. \uC774 \uBAA8\uC790 \uB0C4\uC0C8 \uB9E1\uC544\uBD10.
    \uC774\uAC8C \uB124 \uC544\uBC84\uC9C0\uAC00 \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uD758\uB9B0
    \uD53C \uB0C4\uC0C8\uB2E4. \uBC31\uC791\uB2D8\uC774 \uB9E8\uB0A0 \uBFCC\uB824\uB300\uB294
    \uADF8 \uAC00\uC2DD\uC801\uC778 \uC7A5\uBBF8 \uD5A5\uC218 \uBC11\uC5D0 \uBB50\uAC00
    \uC228\uACA8\uC838 \uC788\uB294\uC9C0 \uC774\uC81C \uC54C\uACA0\uB0D0? \uB10C
    \uC9C0\uAE08 \uBD80\uBAA8\uB97C \uC8FD\uAC8C \uBC29\uCE58\uD55C \uC790\uC758
    \uD488\uC5D0\uC11C \uACF5\uC8FC \uB300\uC811\uBC1B\uC73C\uBA70 \uC0B4\uACE0 \uC788\uB294
    \uAC70\uC57C.\n        \n\n- (\uB124\uBAA8\uAC00 \uBC31\uC791\uB2D8\uC758 \uC11C\uB958\uAC00
    \uAD6C\uACA8\uC9C0\uB4E0 \uB9D0\uB4E0 \uBAA8\uC790\uB97C \uB09A\uC544\uCC44 \uBC14\uB2E5\uC73C\uB85C
    \uB0B4\uD33D\uAC1C\uCE5C\uB2E4.)\n        - \uB124\uBAA8 : \uC0BC\uCD0C, \uC774\uAC8C
    \uC6B0\uB9AC \uC544\uBC84\uC9C0\uC758 \uD53C\uB77C\uACE0\uC694? \uADF8\uB7FC
    \uC0BC\uCD0C\uC740 \uADF8\uB54C \uC5B4\uB514\uC11C \uBB50 \uD558\uACE0 \uC788\uC5C8\uB294\uB370?
    \uAD6C\uACBD\uB9CC \uD588\uC5B4? \uC544\uB2C8\uBA74 \uC0BC\uCD0C\uC774 \uC8FD\uC600\uC5B4?\n       
    \uC0AC\uCD0C 1 : (\uB2F9\uD669\uD55C \uB4EF \uC6C3\uC73C\uBA70) \uC5B4\uD5C8,
    \uB9D0\uC774 \uC2EC\uD558\uB124. \uB09C \uADF8\uC800 \uC99D\uAC70\uB97C \uAC00\uC838\uC628
    \uAC83\uBFD0\uC774\uC57C.\n        \uB124\uBAA8 : (\uBC31\uC791\uB2D8\uC758 \uAE43\uD39C\uC744
    \uC0AC\uCD0C 1\uC758 \uBAA9 \uADFC\uCC98\uB85C \uACA8\uB204\uBA70) \uC9C4\uC2E4\uC774
    \uBB50\uB4E0, \uC774 \uC11C\uC7AC\uC758 \uC8FC\uC778\uC740 \uB098\uC57C. \uBC31\uC791\uB2D8\uC774
    \uB098\uB97C \uC18D\uC600\uB2E4\uBA74 \uB0B4\uAC00 \uC2EC\uD310\uD574. \uD558\uC9C0\uB9CC
    \uB0B4 \uC11C\uC7AC\uB97C \uB354\uB7FD\uD788\uACE0 \uB098\uB97C \uD754\uB4E0
    \uB300\uAC00\uB294 \uC0BC\uCD0C\uC774 \uBA3C\uC800 \uCE58\uB974\uAC8C \uB420
    \uAC70\uC57C. \uB2F9\uC7A5 \uAEBC\uC838!"
  _dialogueLines: []
