  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_letter_friend_3_direct__step_w009_letter_friend_3_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 9\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uC544\uC8FC \uD654\uB824\uD55C \uB099\uC11C\uC640
    \uBB34\uC9C0\uAC1C\uC0C9 \uC789\uD06C\uAC00 \uAC00\uB4DD\uD55C \uBD09\uD22C\uB97C
    \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C\uC5D4 '\uB124\uBAA8\uB97C \uC704\uD55C
    \uC740\uD558\uC218 \uC9C0\uB3C4'\uB77C\uACE0 \uC801\uD600 \uC788\uB2E4.)\r\n       
    \uD558\uB140 : \uC774\uC81C \uC815\uB9D0 \uB9C8\uC9C0\uB9C9 \uD3B8\uC9C0\uC778
    \uAC83 \uAC19\uC2B5\uB2C8\uB2E4. \uB0B4\uC6A9\uC774 \uC544\uC8FC \uBC85\uCC28\uB124\uC694.\r\n       
    \r\n\r\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC5B4\uB978\uC774
    \uB41C \uD6C4\uC758 \uBAA8\uD5D8 \uC9C0\uB3C4\uB97C \uADF8\uB824 \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : \uBAA8\uD5D8 \uC9C0\uB3C4?\r\n        (\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C
    \uD3BC\uCE5C\uB2E4.)\r\n        \uB124\uBAA8! \uB0B4\uC77C\uBD80\uD130 \uC6B0\uB9B0
    \uC9C4\uC9DC \uC790\uC720\uC57C! \uBC31\uC791\uB2D8\uC774 \uC8FC\uC2DC\uB294
    \uC601\uC9C0\uB3C4 \uC88B\uC9C0\uB9CC, \uB098\uB791 \uC800 \uD558\uB298 \uB108\uBA38
    \uC740\uD558\uC218\uAE4C\uC9C0 \uBAA8\uD5D8 \uAC00\uB294 \uAC70 \uC78A\uC9C0
    \uB9C8! \uB10C \uCD5C\uACE0\uC758 \uBC31\uC791\uC774 \uB418\uACE0, \uB09C \uCD5C\uACE0\uC758
    \uBAA8\uD5D8\uAC00\uAC00 \uB3FC\uC11C \uB2E4\uC2DC \uB9CC\uB098\uB294 \uAC70\uC57C.
    \uB9CC\uC57D \uB124\uAC00 \uC11C\uC7AC\uC5D0\uB9CC \uBC15\uD600 \uC788\uC73C\uBA74
    \uB0B4\uAC00 \uC9C4\uC9DC\uB85C \uCC3D\uBB38\uC5D0 \uB9E4\uB2EC\uB824\uC11C \uB110
    \uB04C\uACE0 \uB098\uAC08 \uAC70\uB2C8\uAE4C \uAC01\uC624\uD574!\r\n        \uB124\uBAA8
    : \uC740\uD558\uC218 \uBAA8\uD5D8... \uAC54\uB77C\uBA74 \uC9C4\uC9DC \uBC30\uB77C\uB3C4
    \uB9CC\uB4E4\uC5B4 \uC62C \uAC83 \uAC19\uC544.\r\n        \uD558\uB140 : \uC8FC\uC778\uB2D8\uC758
    \uC55E\uB0A0\uC774 \uC740\uD558\uC218\uCC98\uB7FC \uBC1D\uAE38 \uBC14\uB77C\uB294
    \uC9C4\uC2EC\uC774 \uB290\uAEF4\uC9C0\uB124\uC694.\r\n        \uB124\uBAA8 :
    \uD558\uD558, \uB098 \uC808\uB300 \uC11C\uC7AC\uC5D0\uB9CC \uC788\uC9C0 \uC54A\uC744
    \uAC70\uC57C. \uAC54\uB791 \uC57D\uC18D\uD588\uC73C\uB2C8\uAE4C!"
