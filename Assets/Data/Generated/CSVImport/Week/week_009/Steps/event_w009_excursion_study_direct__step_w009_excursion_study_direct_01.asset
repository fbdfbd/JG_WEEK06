  m_Name: event_w009_excursion_study_direct__step_w009_excursion_study_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC 9\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uB2A6\uC740 \uBC24, \uC11C\uC7AC\uC5D0 \uD640\uB85C \uC549\uC544
    \uCD1B\uBD88\uC744 \uCF20 \uCC44 \uAC00\uBB38\uC758 \uBE44\uBC00 \uC7A5\uBD80\uB97C
    \uC0B4\uD53C\uB358 \uC8FC\uC778\uB2D8. \uAC11\uC790\uAE30 \uCC3D\uBC16\uC5D0\uC11C
    \uBD88\uC5B4\uC628 \uBC14\uB78C\uC5D0 \uCD1B\uBD88\uC774 \uC77C\uB801\uC774\uBA70
    \uBCBD\uC5D0 \uD070 \uADF8\uB9BC\uC790\uAC00 \uC9C4\uB2E4.)\n        \n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8, \uC544\uC9C1 \uC548 \uC8FC\uBB34\uC168\uC5B4\uC694?
    \uB108\uBB34 \uBB34\uB9AC\uD558\uC2DC\uBA74 \uB0B4\uC77C \uC218\uB828\uC5D0 \uC9C0\uC7A5\uC774
    \uC0DD\uAE38 \uD150\uB370...\n        \n\n- \uB124\uBAA8 : \uC774\uC81C \uACE7
    \uC131\uC778\uC2DD\uC778\uB370, \uB0B4\uAC00 \uC544\uBB34\uAC83\uB3C4 \uBAA8\uB974\uBA74
    \uC548 \uB418\uC796\uC544. \uC774 \uC7A5\uBD80 \uC18D\uC5D0 \uC6B0\uB9AC \uAC00\uBB38\uC774
    \uC65C \uC608\uC804\uBCF4\uB2E4 \uD798\uB4E4\uC5B4\uC84C\uB294\uC9C0 \uB2F5\uC774
    \uC788\uB294 \uAC83 \uAC19\uC544.\n        \uD558\uB140 : \uC8FC\uC778\uB2D8...
    \uB208 \uBC11\uC774 \uD02D\uD558\uC138\uC694. \uC815\uB9D0 \uAC00\uBB38\uC744
    \uC544\uB07C\uB294 \uB9C8\uC74C\uC774 \uB300\uB2E8\uD558\uC2DC\uB124\uC694.\n       
    \uB124\uBAA8 : \uB0B4\uAC00 \uC544\uB2C8\uBA74 \uB204\uAC00 \uC6B0\uB9AC \uC800\uD0DD\uC744
    \uC9C0\uD0A4\uACA0\uC5B4. \uC870\uAE08\uB9CC \uB354 \uBCF4\uACE0 \uAC08\uAC8C."
