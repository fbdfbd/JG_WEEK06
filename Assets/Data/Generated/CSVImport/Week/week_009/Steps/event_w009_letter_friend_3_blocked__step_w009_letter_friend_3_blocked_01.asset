  m_Name: event_w009_letter_friend_3_blocked__step_w009_letter_friend_3_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 9\uC8FC\uCC28 - \uD1B5\uC81C"
  _bodyText: "(\uD558\uB140\uAC00 \uC544\uC8FC \uD654\uB824\uD55C \uB099\uC11C\uC640
    \uBB34\uC9C0\uAC1C\uC0C9 \uC789\uD06C\uAC00 \uAC00\uB4DD\uD55C \uBD09\uD22C\uB97C
    \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C\uC5D4 '\uB124\uBAA8\uB97C \uC704\uD55C
    \uC740\uD558\uC218 \uC9C0\uB3C4'\uB77C\uACE0 \uC801\uD600 \uC788\uB2E4.)\r\n       
    \uD558\uB140 : \uC774\uC81C \uC815\uB9D0 \uB9C8\uC9C0\uB9C9 \uD3B8\uC9C0\uC778
    \uAC83 \uAC19\uC2B5\uB2C8\uB2E4. \uB0B4\uC6A9\uC774 \uC544\uC8FC \uBC85\uCC28\uB124\uC694.\r\n       
    \r\n\r\n(\uD558\uB140\uB294 \uD654\uB824\uD55C \uB099\uC11C\uB97C \uBCF4\uACE0\uB294
    \"\uC131\uC778\uC2DD \uB0A0\uC740 \uC870\uC6A9\uD788 \uBCF4\uB0B4\uC57C\uC9C0\"\uB77C\uBA70
    \uD3B8\uC9C0\uD568 \uBC11\uBC14\uB2E5\uC5D0 \uB123\uC5B4 \uB454\uB2E4.)\r\n       
    (\uB124\uBAA8\uB294 \uCC3D\uBC16 \uAD6C\uB984\uC744 \uBCF4\uBA70 \uC774\uC81C
    \uC9C4\uC9DC \uC5B4\uB978\uC774\uB124, \uD558\uACE0 \uC870\uC6A9\uD788 \uB3CC\uC544\uC120\uB2E4.)\r\n       
    \uD558\uB140 : \u2026\u2026\uC774\uB7F0 \uC18C\uB780\uC2A4\uB7EC\uC6B4 \uC6B0\uC815\uC740
    \uC7A0\uC2DC \uBB3B\uC5B4\uB450\uB294 \uAC8C \uC8FC\uC778\uB2D8\uAED8 \uC88B\uACA0\uC5B4\uC694."
