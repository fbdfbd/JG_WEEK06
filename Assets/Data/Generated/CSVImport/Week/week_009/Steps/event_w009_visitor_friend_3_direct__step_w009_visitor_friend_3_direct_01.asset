  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_visitor_friend_3_direct__step_w009_visitor_friend_3_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 9\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uC131\uC778\uC2DD \uBC14\uB85C \uC804\uB0A0 \uBC24. \uC11C\uC7AC\uC758
    \uCD1B\uBD88\uC774 \uACE0\uC694\uD558\uAC8C \uD0C0\uC624\uB974\uACE0 \uC788\uB2E4.
    \uCE5C\uAD6C 3\uC740 \uC624\uB298\uB9CC\uD07C\uC740 \uCC3D\uBB38\uC774 \uC544\uB2CC
    \uC815\uBB38\uC73C\uB85C, \uBC31\uC791\uB2D8\uC758 \uD5C8\uB77D\uC744 \uBC1B\uACE0
    \uB2F9\uB2F9\uD558\uAC8C \uB4E4\uC5B4\uC628\uB2E4. \uADF8\uC758 \uC190\uC5D0\uB294
    \uC5B4\uB9B4 \uC801 \uB124\uBAA8\uC640 \uD568\uAED8 \uB180\uB358 \uB0A1\uC740
    \uB098\uBB34 \uCE7C\uC774 \uB4E4\uB824 \uC788\uB2E4.)\r\n        \r\n       
    \uCE5C\uAD6C 3 : \uB124\uBAA8, \uC774\uC81C \uB0B4\uC77C\uC774\uBA74 \uB10C \uC9C4\uC9DC
    \uBC31\uC791\uB2D8\uC758 \uD6C4\uACC4\uC790\uB85C\uC11C \uC0AC\uB78C\uB4E4 \uC55E\uC5D0
    \uC11C\uACA0\uC9C0. \uC774 \uB098\uBB34 \uCE7C... \uAE30\uC5B5\uB098? \uC6B0\uB9AC\uAC00
    \uC11C\uC7AC \uAD6C\uC11D\uC5D0\uC11C \uBC31\uC791\uB2D8 \uBAB0\uB798 \uAE30\uC0AC
    \uB180\uC774 \uD560 \uB54C \uC37C\uB358 \uAC70\uC796\uC544. \uC774\uC81C \uC774\uAC74
    \uB098\uD55C\uD14C \uD544\uC694 \uC5C6\uC5B4. \uB10C \uB0B4\uC77C\uBD80\uD130
    \uC9C4\uC9DC \uC9C4\uAC80\uC744 \uCC28\uAC8C \uB420 \uD14C\uB2C8\uAE4C. \uC774\uAC74
    '\uC544\uC774 \uB124\uBAA8'\uC640\uC758 \uB9C8\uC9C0\uB9C9 \uC791\uBCC4 \uC778\uC0AC\uC57C.\r\n       
    \r\n\r\n- (\uB124\uBAA8\uAC00 \uB098\uBB34 \uCE7C\uC744 \uCE5C\uAD6C 3\uC5D0\uAC8C
    \uB2E4\uC2DC \uAC74\uB124\uBA70 \uADF8\uC758 \uC190\uC744 \uAF49 \uC7A1\uB294\uB2E4.)\r\n       
    - \uB124\uBAA8 : \uC544\uB2C8, \uC774\uAC74 \uB124\uAC00 \uAC00\uC9C0\uACE0 \uC788\uC5B4
    \uC918. \uADF8\uB9AC\uACE0 \uB0B4\uC77C \uB0B4\uAC00 \uC131\uC778\uC2DD\uC744
    \uB9C8\uCE58\uACE0 \uB098\uC62C \uB54C, \uC774 \uB098\uBB34 \uCE7C\uC744 \uB4E4\uACE0
    \uB098\uB97C \uB9DE\uC774\uD574 \uC918. \uB0B4\uAC00 \uC544\uBB34\uB9AC \uB192\uC740
    \uC790\uB9AC\uC5D0 \uC62C\uB77C\uB3C4 \uB108\uC5D0\uAC90 \uC5B8\uC81C\uB098 \uD568\uAED8
    \uB6F0\uC5B4\uB180\uB358 \uCE5C\uAD6C\uB77C\uB294 \uAC78 \uC99D\uBA85\uD574 \uC918.\r\n       
    \uCE5C\uAD6C 3 : (\uD658\uD558\uAC8C \uC6C3\uC73C\uBA70) \uADF8\uB798! \uB124\uAC00
    \uBC31\uC791\uB2D8\uC774 \uB418\uC5B4\uB3C4 \uB09C \uC5B8\uC81C\uB098 \uB124
    \uACC1\uC5D0\uC11C \uD568\uAED8 \uB2EC\uB9B4 \uAC70\uC57C. \uC6B0\uB9AC\uB4E4\uC758
    \uC6B0\uC815\uC740 \uC774\uC81C\uBD80\uD130 \uC9C4\uC9DC \uC2DC\uC791\uC774\uB77C\uACE0!
    \uC131\uC778\uC2DD\uC7A5\uC5D0\uC11C \uBCF4\uC790, \uB098\uC758 \uCE5C\uAD6C!"
  _dialogueLines: []
