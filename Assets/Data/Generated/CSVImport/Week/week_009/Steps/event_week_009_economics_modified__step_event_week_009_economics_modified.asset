%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_economics_modified__step_event_week_009_economics_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBA3C\uC800 \uBB34\uB108\uC9C8 \uACF3\uBD80\uD130 \uBC1B\uCE5C\uB2E4"
  _bodyText: "\uD654\uD3D0 \uACBD\uC81C\uC640 \uD68C\uACC4 \uAE30\uCD08 9\uC8FC\uCC28
    Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC11C\uC7AC. \uC774\uBC88\uC5D4 \uC791\uC740 \uC608\uC0B0\uD45C\uAC00
      \uB193\uC5EC \uC788\uB2E4. \uB2E4\uB9AC \uC218\uB9AC, \uCC3D\uACE0 \uBCF4\uAC15,
      \uCD95\uC81C \uC900\uBE44 \uAC19\uC740 \uD56D\uBAA9 \uC911 \uB458\uB9CC \uBA3C\uC800
      \uC120\uD0DD\uD574\uC57C \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uACC4\uC0B0\uBCF4\uB2E4 \uC6B0\uC120\uC21C\uC704\uB97C
      \uBCF4\uB294 \uC5F0\uC2B5\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC14B \uB2E4 \uD558\uBA74 \uC548 \uB3FC?"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC548 \uB420 \uB54C\uAC00 \uB354 \uB9CE\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBE44\uC11C\uAC00 \uD56D\uBAA9 \uCE74\uB4DC\uB4E4\uC744 \uC601\uD5A5
      \uC21C\uC11C\uB85C \uB2E4\uC2DC \uB193\uAC8C \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uB3C8\uC744 \uC138\uB294 \uC218\uC5C5\uC774\uB77C\uACE0 \uC0DD\uAC01\uD558\uC9C0
      \uB9D0\uACE0, \uBA3C\uC800 \uBB34\uB108\uC9C8 \uAC78 \uBC1B\uCCD0 \uB450\uB294
      \uC218\uC5C5\uC774\uB77C\uACE0 \uC0DD\uAC01\uD574 \uBCF4\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544. \uADF8\uB7FC \uD6E8\uC52C \uC774\uD574\uB41C\uB2E4."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC608\uC0B0\uC740 \uC560\uC815\uC774 \uC544\uB2C8\uB77C \uC21C\uC11C\uB97C
      \uC815\uD558\uB294 \uC77C\uC774\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uC880 \uCC28\uAC11\uC9C0\uB9CC \uB9DE\uB294 \uB9D0\uC774\uB124."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uADF8\uB798\uC11C \uAE30\uB85D\uC774 \uD544\uC694\uD55C \uAC81\uB2C8\uB2E4."
  _nemoLine: "(\uC11C\uC7AC. \uC774\uBC88\uC5D4 \uC791\uC740 \uC608\uC0B0\uD45C\uAC00
    \uB193\uC5EC \uC788\uB2E4. \uB2E4\uB9AC \uC218\uB9AC, \uCC3D\uACE0 \uBCF4\uAC15,
    \uCD95\uC81C \uC900\uBE44 \uAC19\uC740 \uD56D\uBAA9 \uC911 \uB458\uB9CC \uBA3C\uC800
    \uC120\uD0DD\uD574\uC57C \uD55C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
