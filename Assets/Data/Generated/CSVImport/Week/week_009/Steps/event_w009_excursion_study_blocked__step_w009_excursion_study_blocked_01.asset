  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_excursion_study_blocked__step_w009_excursion_study_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC 9\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uB2A6\uC740 \uBC24, \uC11C\uC7AC\uC5D0 \uD640\uB85C \uC549\uC544
    \uCD1B\uBD88\uC744 \uCF20 \uCC44 \uAC00\uBB38\uC758 \uBE44\uBC00 \uC7A5\uBD80\uB97C
    \uC0B4\uD53C\uB358 \uC8FC\uC778\uB2D8. \uAC11\uC790\uAE30 \uCC3D\uBC16\uC5D0\uC11C
    \uBD88\uC5B4\uC628 \uBC14\uB78C\uC5D0 \uCD1B\uBD88\uC774 \uC77C\uB801\uC774\uBA70
    \uBCBD\uC5D0 \uD070 \uADF8\uB9BC\uC790\uAC00 \uC9C4\uB2E4.)\r\n        \r\n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8, \uC544\uC9C1 \uC548 \uC8FC\uBB34\uC168\uC5B4\uC694?
    \uB108\uBB34 \uBB34\uB9AC\uD558\uC2DC\uBA74 \uB0B4\uC77C \uC218\uB828\uC5D0 \uC9C0\uC7A5\uC774
    \uC0DD\uAE38 \uD150\uB370...\r\n        \r\n\r\n(\uACBD\uBE44\uB300\uC7A5\uC774
    \uBB38\uC744 \uC5F4\uACE0 \uB4E4\uC5B4\uC640 \uCD1B\uBD88\uC744 \uAEBC\uBC84\uB9B0\uB2E4.)\r\n       
    \uACBD\uBE44\uB300\uC7A5 : \uBC24\uC774 \uAE4A\uC5C8\uC2B5\uB2C8\uB2E4. \uC9C0\uB3C4\uC790\uB294
    \uC790\uC2E0\uC758 \uBAB8 \uC0C1\uD0DC\uB97C \uAD00\uB9AC\uD558\uB294 \uAC83\uB3C4
    \uC758\uBB34\uC785\uB2C8\uB2E4. \uB2F9\uC7A5 \uCE68\uC18C\uB85C \uB4DC\uC2ED\uC2DC\uC624.\r\n       
    \uB124\uBAA8 : \uD558\uC9C0\uB9CC \uC774 \uC11C\uB958\uB9CC \uB2E4 \uC77D\uC73C\uBA74
    \uC6B0\uB9AC \uC601\uC9C0\uC758 \uBB38\uC81C\uB97C \uD574\uACB0\uD560 \uC218
    \uC788\uC744 \uAC83 \uAC19\uC740\uB370...\r\n        \uACBD\uBE44\uB300\uC7A5
    : \uB0B4\uC77C \uC544\uCE68\uC758 \uB9D1\uC740 \uC815\uC2E0\uC73C\uB85C \uBCF4\uC2DC\uB294
    \uAC8C \uB354 \uC815\uD655\uD569\uB2C8\uB2E4. \uACE0\uC9D1 \uBD80\uB9AC\uC9C0
    \uB9C8\uC2ED\uC2DC\uC624."
