  _titleOverride: "\uBC31\uC791\uC758 \uC720\uC5B8\uC7A5 - \uD1B5\uC81C"
  _bodyText: "\uBC31\uC791\uC758 \uC720\uC5B8\uC7A5 - \uD1B5\uC81C \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBC31\uC791\uC758 \uC720\uC5B8\uC7A5 \uC774\uC57C\uAE30\uB294 \uC9C0\uB098\uCE5C
      \uC704\uD611\uCC98\uB7FC \uB4E4\uB9AC\uC9C0 \uC54A\uAC8C \uC811\uC5B4 \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC720\uC5B8\uC7A5 \uC598\uAE30\uAE4C\uC9C0 \uB098\uC640\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD655\uC2E4\uD558\uC9C0 \uC54A\uC740 \uB9D0\uC740 \uB35C\uC5B4\uB0B4\uACE0,
      \uC131\uC778\uC2DD \uC804\uC774\uB77C \uC8FC\uBCC0\uC774 \uC220\uB801\uC778\uB2E4\uACE0\uB9CC
      \uC124\uBA85\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uC544\uC9C1\uC740 \uD568\uBD80\uB85C \uBBFF\uC9C0 \uC54A\uC744\uB798."
  _nemoLine: "(\uBC31\uC791\uC758 \uC720\uC5B8\uC7A5 \uC774\uC57C\uAE30\uB294 \uC9C0\uB098\uCE5C
    \uC704\uD611\uCC98\uB7FC \uB4E4\uB9AC\uC9C0 \uC54A\uAC8C \uC811\uC5B4 \uB454\uB2E4.)"
