  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_excursion_basement_direct__step_event_week_009_excursion_basement_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 \uD5C8\uAC00"
  _bodyText: "excursion basement Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uD751, \uD6CC\uCA4D... \uBB34\uC11C\uC6CC\uC694, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uB9AC \uC640, \uB0B4 \uC190 \uC7A1\uC544. \uB0B4\uAC00 \uAE38\uC744
      \uC544\uB2C8\uAE4C \uC785\uAD6C \uCABD\uC73C\uB85C \uCC9C\uCC9C\uD788 \uAC78\uC5B4\uAC00\uC790.
      \uBCBD \uC9DA\uC73C\uBA74\uC11C \uB530\uB77C\uC624\uBA74 \uB3FC."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "(\uB124\uBAA8\uC758 \uC190\uC744 \uAF49 \uC7A1\uC73C\uBA70) \uC8FC\uC778\uB2D8...
      \uC815\uB9D0 \uAC15\uD574\uC9C0\uC168\uB124\uC694. \uC608\uC804 \uAC19\uC73C\uBA74
      \uAC19\uC774 \uC6B0\uC168\uC744 \uD150\uB370."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uC774\uC81C \uACE7 \uC5B4\uB978\uC778\uAC78. \uC774 \uC815\uB3C4
      \uC5B4\uB460\uCBE4\uC740 \uBB34\uC12D\uC9C0 \uC54A\uC544."
  _nemoLine: "\uD751, \uD6CC\uCA4D... \uBB34\uC11C\uC6CC\uC694, \uC8FC\uC778\uB2D8."
