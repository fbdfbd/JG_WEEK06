  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_external_will_news_direct__step_week_009_external_will_news_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC31\uC791\uC758 \uC720\uC5B8\uC7A5 - \uD5C8\uB77D"
  _bodyText: "\uBC31\uC791\uC758 \uC720\uC5B8\uC7A5 - \uD5C8\uB77D \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC131\uC778\uC2DD\uC774 \uAC00\uAE4C\uC6CC\uC9C0\uBA70 \uBC31\uC791\uC758
      \uC720\uC5B8\uC7A5\uACFC \uC601\uC9C0 \uBD84\uD560\uC744 \uB458\uB7EC\uC2FC
      \uC18C\uBB38\uC774 \uB3CC\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC8C\uC368 \uADF8\uB7F0 \uC774\uC57C\uAE30\uAE4C\uC9C0 \uD558\uB294\uAD6C\uB098."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC911\uC694\uD55C \uC2DC\uAE30\uC77C\uC218\uB85D \uC0AC\uB78C\uB4E4\uC774
      \uC55E\uC9C8\uB7EC \uD574\uC11D\uC744 \uBD99\uC774\uACE4 \uD569\uB2C8\uB2E4.
      \uADF8\uB798\uC11C \uB354 \uCC28\uBD84\uD788 \uB4E3\uACE0 \uAC00\uB824\uC57C
      \uD558\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uBB34\uAC81\uC9C0\uB9CC, \uADF8\uB798\uC11C \uB354 \uB611\uBC14\uB85C
      \uBCF4\uACE0 \uC2F6\uC5B4."
  _nemoLine: "\uC131\uC778\uC2DD\uC774 \uAC00\uAE4C\uC6CC\uC9C0\uBA70 \uBC31\uC791\uC758
    \uC720\uC5B8\uC7A5\uACFC \uC601\uC9C0 \uBD84\uD560\uC744 \uB458\uB7EC\uC2FC \uC18C\uBB38\uC774
    \uB3CC\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
