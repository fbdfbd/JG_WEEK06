  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_excursion_lake_blocked__step_event_week_009_excursion_lake_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: lake Blocked
  _bodyText: "excursion lake Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uBE44\uC11D \uC55E\uC5D0 \uBA48\uCDB0
      \uC11C\uC11C \uB124\uBAA8\uC5D0\uAC8C \uBB35\uB150\uC744 \uAD8C\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uAC10\uC815\uC801\uC778 \uB9F9\uC138\uBCF4\uB2E4\uB294 \uC2E4\uC9C8\uC801\uC778
      \uC548\uBAA9\uC744 \uBCF4\uC5EC\uC8FC\uC2ED\uC2DC\uC624. \uAC00\uBB38\uC740
      \uC608\uC05C \uB9D0\uB85C \uC9C0\uCF1C\uC9C0\uB294 \uAC83\uC774 \uC544\uB2D9\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC800\uB3C4 \uC54C\uC544\uC694. \uD558\uC9C0\uB9CC \uB9C8\uC74C\uC18D\uC73C\uB85C
      \uB2E4\uC9D0\uD558\uB294 \uAC83\uB3C4 \uC911\uC694\uD558\uC796\uC544\uC694."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB2E4\uC9D0\uC740 \uCC45\uC784\uAC10 \uC788\uB294 \uD589\uB3D9\uC73C\uB85C
      \uC99D\uBA85\uB420 \uB54C\uB9CC \uAC00\uCE58\uAC00 \uC788\uC2B5\uB2C8\uB2E4.
      \uC624\uB298 \uC218\uB828\uC774 \uB05D\uB09C \uB4A4\uC5D0 \uB2E4\uC2DC \uC0DD\uAC01\uD558\uC2ED\uC2DC\uC624."
  _nemoLine: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uBE44\uC11D \uC55E\uC5D0 \uBA48\uCDB0
    \uC11C\uC11C \uB124\uBAA8\uC5D0\uAC8C \uBB35\uB150\uC744 \uAD8C\uD55C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
