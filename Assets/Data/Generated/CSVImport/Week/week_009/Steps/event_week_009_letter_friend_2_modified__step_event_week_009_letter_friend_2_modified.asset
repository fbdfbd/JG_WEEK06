  _titleOverride: friend_2 Modified
  _bodyText: "letter friend_2 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC55E\uC73C\uB85C \uC8FC\uC778\uB2D8\uC774
      \uAC78\uC5B4\uAC08 \uAE38\uC5D0 \uD56D\uC0C1 \uB4F1\uBD88\uC774 \uB418\uC5B4\uC8FC\uACA0\uB2E4\uACE0
      \uC57D\uC18D\uD588\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB4F1\uBD88?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC8FC\uC778\uB2D8\uC774 \uAC00\uBB38\uC758 \uC8FC\uC778\uC774
      \uB418\uC5B4 \uACE0\uB3C5\uD55C \uACB0\uC815\uC744 \uB0B4\uB824\uC57C \uD560
      \uB54C, \uC5B8\uC81C\uB098 \uACC1\uC5D0\uC11C \uD568\uAED8 \uACE0\uBBFC\uD574
      \uC8FC\uACA0\uB2E4\uACE0 \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640... \uAC54\uB294 \uC815\uB9D0 \uC5B4\uB978\uC2A4\uB7EC\uC6CC.
      \uB098\uB3C4 \uAC54\uB97C \uBBFF\uACE0 \uC758\uC9C0\uD560 \uAC70\uC57C."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC55E\uC73C\uB85C \uC8FC\uC778\uB2D8\uC774
    \uAC78\uC5B4\uAC08 \uAE38\uC5D0 \uD56D\uC0C1 \uB4F1\uBD88\uC774 \uB418\uC5B4\uC8FC\uACA0\uB2E4\uACE0
    \uC57D\uC18D\uD588\uC2B5\uB2C8\uB2E4."
