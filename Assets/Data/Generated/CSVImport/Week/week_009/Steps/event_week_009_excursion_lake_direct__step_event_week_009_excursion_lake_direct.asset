  _titleOverride: "\uD638\uC218 \uD5C8\uAC00"
  _bodyText: "excursion lake Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uC740 \uC774\uBBF8 \uADF8\uB7F0 \uD6CC\uB96D\uD55C
      \uBD84\uC774 \uB418\uC5B4\uAC00\uACE0 \uACC4\uC138\uC694. \uD638\uC218\uB3C4
      \uC8FC\uC778\uB2D8\uC758 \uAD73\uAC74\uD55C \uB9C8\uC74C\uC744 \uC54C\uACE0
      \uC788\uC744 \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uB098\uC911\uC5D0 \uC5B4\uB5A4 \uD30C\uB3C4\uAC00 \uBC00\uB824\uC640\uB3C4,
      \uC774 \uD638\uC218\uCC98\uB7FC \uD754\uB4E4\uB9BC \uC5C6\uC774 \uAC00\uBB38\uC744
      \uC9C0\uD0A4\uB294 \uC548\uC8FC\uC778\uC774 \uB420\uAC8C."
  _nemoLine: "\uC8FC\uC778\uB2D8\uC740 \uC774\uBBF8 \uADF8\uB7F0 \uD6CC\uB96D\uD55C
    \uBD84\uC774 \uB418\uC5B4\uAC00\uACE0 \uACC4\uC138\uC694. \uD638\uC218\uB3C4
    \uC8FC\uC778\uB2D8\uC758 \uAD73\uAC74\uD55C \uB9C8\uC74C\uC744 \uC54C\uACE0 \uC788\uC744
    \uAC70\uC608\uC694."
