  _titleOverride: "\uC804\uC220 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4"
  _bodyText: "\uC804\uC220 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC804\uC220 \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
      \uC9C0\uD615 \uADF8\uB9BC\uB9CC \uBCF4\uACE0 \uBCF8\uACA9\uC801\uC778 \uC124\uBA85\uC740
      \uBBF8\uB8EC\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624\uB298\uC740 \uBCD1\uC0AC \uC774\uC57C\uAE30 \uC548 \uD574?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uBB34\uAC81\uAC8C \uB290\uAEF4\uC9C0\uC9C0 \uC54A\uAC8C \uC9E7\uAC8C\uB9CC
      \uBCF4\uACE0 \uB118\uAE34\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uC74C\uC5D4 \uC9C0\uB3C4\uB791 \uAC19\uC774 \uBCF4\uBA74 \uC88B\uACA0\uB2E4."
  _nemoLine: "(\uC804\uC220 \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
    \uC9C0\uD615 \uADF8\uB9BC\uB9CC \uBCF4\uACE0 \uBCF8\uACA9\uC801\uC778 \uC124\uBA85\uC740
    \uBBF8\uB8EC\uB2E4.)"
