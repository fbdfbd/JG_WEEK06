--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_military_blocked__step_event_week_009_military_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC55E\uB9CC \uB450\uAECD\uAC8C \uC138\uC6B0\uC9C0 \uC54A\uB294\uB2E4"
  _bodyText: "\uAD70\uC0AC \uC804\uB7B5\uACFC \uBC29\uC5B4 \uC9C4\uD615 9\uC8FC\uCC28
    Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBAA8\uB798\uD310 \uC704\uC5D0 \uBCD1\uC815 \uB9D0\uC774 \uB354 \uB298\uC5B4\uB098\uACE0,
      \uC774\uBC88\uC5D4 \uC801\uC774 \uC5B4\uB514\uC11C \uB4E4\uC5B4\uC624\uB294\uC9C0
      \uC815\uD574\uC9C4 \uC0C1\uD0DC\uC5D0\uC11C \uC9C4\uD615\uC744 \uC9DC \uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC624\uB298\uC740 \uC9C0\uD615 \uC704\uC5D0 \uC0AC\uB78C\uC744 \uC5B9\uC5B4
      \uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB4DC\uB514\uC5B4 \uB9D0 \uC4F0\uB124."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB124. \uB300\uC2E0 \uC774\uC720 \uC5C6\uC774 \uB450\uBA74 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uAC00\uC7A5 \uC55E\uC5D0 \uBCD1\uB825\uC744 \uBAB0\uC544\uB450\uC790,
      \uACBD\uBE44\uB300\uC7A5\uC774 \uACE7\uBC14\uB85C \uB4A4\uCABD \uC77C\uBD80\uB97C
      \uBE44\uC6CC \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC55E\uB9CC \uB450\uAECD\uAC8C \uC138\uC6B0\uC9C0 \uB9C8\uC2ED\uC2DC\uC624.
      \uB4A4\uAC00 \uBE44\uBA74 \uBB34\uB108\uC9D1\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9C9\uB294 \uB370 \uD798 \uC918\uC57C \uB418\uB294 \uAC70 \uC544\uB2C8\uC57C?"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB9C9\uB294 \uAC83\uACFC \uBC84\uD2F0\uB294 \uAC83\uC740 \uB2E4\uB985\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uADF8\uAC74 \uC880 \uD5F7\uAC08\uB9AC\uB124."
  _nemoLine: "(\uBAA8\uB798\uD310 \uC704\uC5D0 \uBCD1\uC815 \uB9D0\uC774 \uB354 \uB298\uC5B4\uB098\uACE0,
    \uC774\uBC88\uC5D4 \uC801\uC774 \uC5B4\uB514\uC11C \uB4E4\uC5B4\uC624\uB294\uC9C0
    \uC815\uD574\uC9C4 \uC0C1\uD0DC\uC5D0\uC11C \uC9C4\uD615\uC744 \uC9DC \uBCF8\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
