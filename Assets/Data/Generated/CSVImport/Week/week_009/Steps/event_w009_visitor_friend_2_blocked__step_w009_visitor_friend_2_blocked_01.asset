  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_visitor_friend_2_blocked__step_w009_visitor_friend_2_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 9\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uC131\uC778\uC2DD \uC804\uB0A0 \uBC24, \uC11C\uC7AC\uC758 \uACF5\uAE30\uB294
    \uC5C4\uC219\uD558\uBA74\uC11C\uB3C4 \uB530\uB73B\uD558\uB2E4. \uCE5C\uAD6C 2\uAC00
    \uBC31\uC791\uB2D8\uC774 \uB124\uBAA8\uB97C \uC704\uD574 \uC900\uBE44\uD55C \uD654\uB824\uD55C
    \uC815\uBCF5\uC744 \uBCF4\uBA70 \uAC10\uD0C4\uD55C\uB2E4. \uAC74 \uAC8C\uC784\uC5D0\uC11C\uC758
    \uB9C8\uC9C0\uB9C9 \uBC29\uBB38\uC774\uC790, \uC544\uC774\uB85C\uC11C \uB098\uB204\uB294
    \uB9C8\uC9C0\uB9C9 \uB300\uD654\uB2E4.)\r\n        \r\n        \uCE5C\uAD6C 2
    : \uB124\uBAA8, \uB4DC\uB514\uC5B4 \uB0B4\uC77C\uC774\uB124. \uC0AC\uCD0C 1\uC758
    \uC774\uAC04\uC9C8\uB3C4, \uC0AC\uCD0C 2\uC758 \uBD88\uC548\uD568\uB3C4 \uC774\uC81C
    \uB108\uB97C \uD754\uB4E4\uC9C0 \uBABB\uD574. \uB10C \uC774\uBBF8 \uBC31\uC791\uB2D8\uC758
    \uD6CC\uB96D\uD55C \uD6C4\uACC4\uC790\uC774\uC790, \uC6B0\uB9AC\uB4E4\uC758 \uB2F9\uB2F9\uD55C
    \uB9AC\uB354\uB2C8\uAE4C. \uC774 \uC11C\uC7AC\uC758 \uBAA8\uB4E0 \uCC45\uACFC
    \uC9C0\uD61C\uAC00 \uB0B4\uC77C \uB124 \uBAB8\uC744 \uAC10\uC2F8\uB294 \uAC11\uC637\uC774
    \uB418\uC5B4\uC904 \uAC70\uC57C.\r\n        \r\n\r\n- (\uB124\uBAA8\uAC00 \uC815\uBCF5\uC758
    \uC637\uAE43\uC744 \uB2E4\uB4EC\uC73C\uBA70 \uBC31\uC791\uB2D8\uC758 \uC758\uC790\uB97C
    \uC751\uC2DC\uD55C\uB2E4.)\r\n        - \uB124\uBAA8 : \uBC31\uC791\uB2D8\uC774
    \uAC78\uC5B4\uC624\uC2E0 \uACE0\uB3C5\uD55C \uAE38\uC744 \uC774\uC81C \uB0B4\uAC00
    \uD568\uAED8 \uAC78\uC73C\uB824 \uD574. \uC5C4\uACA9\uD568 \uC18D\uC5D0 \uC228\uACA8\uC9C4
    \uADF8\uBD84\uC758 \uAE4A\uC740 \uC0AC\uB791\uC744 \uAC00\uC2B4\uC5D0 \uC0C8\uAE30\uACE0,
    \uC774 \uAC00\uBB38\uC744 \uAC00\uC7A5 \uC815\uC758\uB85C\uC6B4 \uACF3\uC73C\uB85C
    \uB9CC\uB4E4 \uAC70\uC57C. \uC9C0\uCF1C\uBD10 \uC918, \uCE5C\uAD6C 2.\r\n       
    \uCE5C\uAD6C 2 : (\uD5C8\uB9AC\uB97C \uC219\uC5EC \uC815\uC911\uD788 \uC778\uC0AC\uD558\uBA70)
    \uB098\uC758 \uC8FC\uC778\uB2D8, \uB0B4\uC77C \uB2F9\uC2E0\uC758 \uAC00\uC7A5
    \uC601\uAD11\uC2A4\uB7EC\uC6B4 \uC21C\uAC04\uC744 \uB4A4\uC5D0\uC11C \uBB35\uBB35\uD788
    \uC9C0\uD0A4\uACA0\uC2B5\uB2C8\uB2E4. \uB2F9\uC2E0\uC740 \uCD5C\uACE0\uC758 \uBC31\uC791\uC774
    \uB420 \uAC81\uB2C8\uB2E4."
