  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_excursion_study_blocked__step_event_week_009_excursion_study_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC11C\uC7AC \uD1B5\uC81C"
  _bodyText: "excursion study Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uBB38\uC744 \uC5F4\uACE0 \uB4E4\uC5B4\uC640
      \uCD1B\uBD88\uC744 \uAEBC\uBC84\uB9B0\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uBC24\uC774 \uAE4A\uC5C8\uC2B5\uB2C8\uB2E4. \uC9C0\uB3C4\uC790\uB294
      \uC790\uC2E0\uC758 \uBAB8 \uC0C1\uD0DC\uB97C \uAD00\uB9AC\uD558\uB294 \uAC83\uB3C4
      \uC758\uBB34\uC785\uB2C8\uB2E4. \uB2F9\uC7A5 \uCE68\uC18C\uB85C \uB4DC\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD558\uC9C0\uB9CC \uC774 \uC11C\uB958\uB9CC \uB2E4 \uC77D\uC73C\uBA74
      \uC6B0\uB9AC \uC601\uC9C0\uC758 \uBB38\uC81C\uB97C \uD574\uACB0\uD560 \uC218
      \uC788\uC744 \uAC83 \uAC19\uC740\uB370..."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB0B4\uC77C \uC544\uCE68\uC758 \uB9D1\uC740 \uC815\uC2E0\uC73C\uB85C
      \uBCF4\uC2DC\uB294 \uAC8C \uB354 \uC815\uD655\uD569\uB2C8\uB2E4. \uACE0\uC9D1
      \uBD80\uB9AC\uC9C0 \uB9C8\uC2ED\uC2DC\uC624."
  _nemoLine: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uBB38\uC744 \uC5F4\uACE0 \uB4E4\uC5B4\uC640
    \uCD1B\uBD88\uC744 \uAEBC\uBC84\uB9B0\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
