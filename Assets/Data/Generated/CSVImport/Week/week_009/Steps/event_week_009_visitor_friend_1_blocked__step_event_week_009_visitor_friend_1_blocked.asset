      \uBAA8\uC2B5\uC744 \uAE30\uB2E4\uB9B4\uAC8C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uACE0\uB9C8\uC6CC. \uBC31\uC791\uB2D8\uC774 \uB2E6\uC544\uB193\uC73C\uC2E0
      \uC774 \uAE38\uC744 \uB108\uC640 \uD568\uAED8 \uAC77\uAC8C \uB418\uC5B4 \uAE30\uBED0."
  _nemoLine: "\uBA4B\uC9C0\uB2E4, \uB124\uBAA8! \uBC31\uC791\uB2D8\uB3C4 \uB124 \uC774\uB7F0
    \uBAA8\uC2B5\uC744 \uBCF4\uC2DC\uBA74 \uC815\uB9D0 \uC790\uB791\uC2A4\uB7EC\uC6CC\uD558\uC2E4
