  _bodyText: "visitor friend_1 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uBA4B\uC9C0\uB2E4, \uB124\uBAA8! \uBC31\uC791\uB2D8\uB3C4 \uB124 \uC774\uB7F0
      \uBAA8\uC2B5\uC744 \uBCF4\uC2DC\uBA74 \uC815\uB9D0 \uC790\uB791\uC2A4\uB7EC\uC6CC\uD558\uC2E4
