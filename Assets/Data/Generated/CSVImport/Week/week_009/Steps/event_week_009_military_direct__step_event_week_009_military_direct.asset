  _titleOverride: "\uBCD1\uB825 \uBC30\uCE58\uC640 \uBA85\uB839\uC758 \uAE30\uBCF8\uC744
    \uAC00\uB974\uCE5C\uB2E4"
  _bodyText: "\uBCD1\uB825 \uBC30\uCE58\uC640 \uBA85\uB839\uC758 \uAE30\uBCF8\uC744
    \uAC00\uB974\uCE5C\uB2E4 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC9C0\uD615\uACFC \uBCD1\uB825 \uBC30\uCE58\uB97C \uC9DA\uC73C\uBA70
      \uAE30\uBCF8\uC801\uC778 \uBA85\uB839 \uCCB4\uACC4\uB97C \uC124\uBA85\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC19\uC740 \uBCD1\uB825\uC774\uC5B4\uB3C4 \uC5B4\uB514\uC5D0 \uB450\uB290\uB0D0\uAC00
      \uB354 \uC911\uC694\uD558\uB124."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uC22B\uC790\uBCF4\uB2E4 \uC704\uCE58\uC640 \uD0C0\uC774\uBC0D\uC774
      \uC911\uC694\uD558\uB2E4\uB294 \uC810\uC744 \uC9DA\uC5B4 \uC900\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD55C \uBC88\uC5D0 \uB2E4 \uC6C0\uC9C1\uC774\uBA74 \uC548 \uB418\uB294
      \uC774\uC720\uB97C \uC54C\uACA0\uC5B4."
  _nemoLine: "(\uC9C0\uD615\uACFC \uBCD1\uB825 \uBC30\uCE58\uB97C \uC9DA\uC73C\uBA70
    \uAE30\uBCF8\uC801\uC778 \uBA85\uB839 \uCCB4\uACC4\uB97C \uC124\uBA85\uD55C\uB2E4.)"
