  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_letter_friend_2_direct__step_w009_letter_friend_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 \uD3B8\uC9C0 9\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uAE08\uC0C9 \uC2E4\uB85C \uBB36\uC778 \uC544\uC8FC
    \uACE0\uAE09\uC2A4\uB7EC\uC6B4 \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4.
    \uAC89\uC5D0\uB294 '\uC131\uC778(\u6210\u4EBA)\uC758 \uC11C\uC57D'\uC774\uB77C
    \uC801\uD600 \uC788\uB2E4.)\n        \n\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774
    \uBBF8\uB798\uC758 \uB3D9\uBC18\uC790\uB85C\uC11C \uC57D\uC18D\uC744 \uBCF4\uB0B4\uC654\uC2B5\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uBBF8\uB798\uC758 \uB3D9\uBC18\uC790?\n        (\uD558\uB140\uAC00
    \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)\n        \uB124\uBAA8\uC5D0\uAC8C. \uB0B4\uC77C
    \uC131\uC778\uC2DD\uC774 \uB05D\uB098\uBA74, \uB09C \uB124 \uACC1\uC5D0\uC11C
    \uAC00\uC7A5 \uC815\uC9C1\uD55C \uC870\uC5B8\uC790\uAC00 \uB420 \uAC70\uC57C.
    \uB124\uAC00 \uBC31\uC791\uB2D8\uC758 \uB4A4\uB97C \uC774\uC5B4 \uC774 \uC601\uC9C0\uB97C
    \uC774\uB04C \uB54C, \uB204\uAD6C\uC5D0\uAC8C\uB3C4 \uD718\uB458\uB9AC\uC9C0
    \uC54A\uAC8C \uB0B4\uAC00 \uC9C0\uCF1C\uC904\uAC8C. \uADF8\uB7EC\uB2C8\uAE4C
    \uB10C \uB9C8\uC74C \uB193\uACE0 \uB124 \uB73B\uC744 \uD3BC\uCCD0. \uB9AC\uBCF8
    \uBB36\uB294 \uBC95\uC740... \uB0B4\uAC00 \uB0B4\uC77C \uC544\uCE68\uC5D0 \uC9C1\uC811
    \uAC00\uC11C \uAC00\uB974\uCCD0\uC904\uAC8C.\n        \uB124\uBAA8 : \uB9AC\uBCF8
    \uAC00\uB974\uCCD0\uC8FC\uB7EC \uC628\uB300! \uC5ED\uC2DC \uAC54\uB294 \uACC4\uD68D\uC774
    \uB2E4 \uC788\uAD6C\uB098.\n        \uD558\uB140 : \uC8FC\uC778\uB2D8\uC758 \uAC00\uC7A5
    \uB4E0\uB4E0\uD55C \uBA38\uB9AC\uAC00 \uB418\uC5B4\uC904 \uCE5C\uAD6C\uB97C \uB450\uC168\uB124\uC694.\n       
    \uB124\uBAA8 : \uC751. \uAC54\uB791 \uD568\uAED8\uB77C\uBA74 \uC5B4\uB5A4 \uC5B4\uB824\uC6B4
    \uBC95\uC804\uB3C4 \uB2E4 \uC77D\uC744 \uC218 \uC788\uC744 \uAC83 \uAC19\uC544."
