  _titleOverride: friend_3 Blocked
  _bodyText: "letter friend_3 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uB294 \uD654\uB824\uD55C \uB099\uC11C\uB97C \uBCF4\uACE0\uB294
      \"\uC131\uC778\uC2DD \uB0A0\uC740 \uC870\uC6A9\uD788 \uBCF4\uB0B4\uC57C\uC9C0\"\uB77C\uBA70
      \uD3B8\uC9C0\uD568 \uBC11\uBC14\uB2E5\uC5D0 \uB123\uC5B4 \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uCC3D\uBC16 \uAD6C\uB984\uC744 \uBCF4\uBA70 \uC774\uC81C
      \uC9C4\uC9DC \uC5B4\uB978\uC774\uB124, \uD558\uACE0 \uC870\uC6A9\uD788 \uB3CC\uC544\uC120\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\u2026\u2026\uC774\uB7F0 \uC18C\uB780\uC2A4\uB7EC\uC6B4 \uC6B0\uC815\uC740
      \uC7A0\uC2DC \uBB3B\uC5B4\uB450\uB294 \uAC8C \uC8FC\uC778\uB2D8\uAED8 \uC88B\uACA0\uC5B4\uC694."
  _nemoLine: "(\uD558\uB140\uB294 \uD654\uB824\uD55C \uB099\uC11C\uB97C \uBCF4\uACE0\uB294
    \"\uC131\uC778\uC2DD \uB0A0\uC740 \uC870\uC6A9\uD788 \uBCF4\uB0B4\uC57C\uC9C0\"\uB77C\uBA70
    \uD3B8\uC9C0\uD568 \uBC11\uBC14\uB2E5\uC5D0 \uB123\uC5B4 \uB454\uB2E4.)"
