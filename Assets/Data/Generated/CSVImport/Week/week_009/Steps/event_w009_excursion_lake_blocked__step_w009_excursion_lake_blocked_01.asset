  m_Name: event_w009_excursion_lake_blocked__step_w009_excursion_lake_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 9\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uD638\uC22B\uAC00 \uAC00\uC7A5\uC790\uB9AC\uC5D0 \uC138\uC6CC\uC9C4
    \uB0A1\uC740 \uBE44\uC11D \uC55E. \uAC00\uBB38\uC758 \uCD08\uB300 \uC548\uC8FC\uC778\uC774
    \uC138\uC6E0\uB2E4\uB294 \uB9F9\uC138\uC758 \uBB38\uAD6C\uAC00 \uC0C8\uACA8\uC838
    \uC788\uB2E4.)\r\n        \uD558\uB140 : \uC774\uC81C \uACE7 \uC131\uC778\uC774
    \uB418\uC2DC\uB124\uC694, \uC8FC\uC778\uB2D8. \uC774 \uD638\uC218 \uC55E\uC5D0\uC11C
    \uAC00\uBB38\uC758 \uC601\uC560\uB85C\uC11C \uB9F9\uC138\uD588\uB358 \uC120\uB300\uB4E4\uC758
    \uC774\uC57C\uAE30\uB97C \uAE30\uC5B5\uD558\uC2DC\uB098\uC694?\r\n        \r\n\r\n(\uACBD\uBE44\uB300\uC7A5\uC774
    \uBE44\uC11D \uC55E\uC5D0 \uBA48\uCDB0 \uC11C\uC11C \uB124\uBAA8\uC5D0\uAC8C
    \uBB35\uB150\uC744 \uAD8C\uD55C\uB2E4.)\r\n        \uACBD\uBE44\uB300\uC7A5 :
    \uAC10\uC815\uC801\uC778 \uB9F9\uC138\uBCF4\uB2E4\uB294 \uC2E4\uC9C8\uC801\uC778
    \uC548\uBAA9\uC744 \uBCF4\uC5EC\uC8FC\uC2ED\uC2DC\uC624. \uAC00\uBB38\uC740 \uC608\uC05C
    \uB9D0\uB85C \uC9C0\uCF1C\uC9C0\uB294 \uAC83\uC774 \uC544\uB2D9\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : \uC800\uB3C4 \uC54C\uC544\uC694. \uD558\uC9C0\uB9CC \uB9C8\uC74C\uC18D\uC73C\uB85C
    \uB2E4\uC9D0\uD558\uB294 \uAC83\uB3C4 \uC911\uC694\uD558\uC796\uC544\uC694.\r\n       
    \uACBD\uBE44\uB300\uC7A5 : \uB2E4\uC9D0\uC740 \uCC45\uC784\uAC10 \uC788\uB294
    \uD589\uB3D9\uC73C\uB85C \uC99D\uBA85\uB420 \uB54C\uB9CC \uAC00\uCE58\uAC00 \uC788\uC2B5\uB2C8\uB2E4.
    \uC624\uB298 \uC218\uB828\uC774 \uB05D\uB09C \uB4A4\uC5D0 \uB2E4\uC2DC \uC0DD\uAC01\uD558\uC2ED\uC2DC\uC624."
