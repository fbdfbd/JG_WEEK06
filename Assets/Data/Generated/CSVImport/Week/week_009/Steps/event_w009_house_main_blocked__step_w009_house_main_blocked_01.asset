  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_house_main_blocked__step_w009_house_main_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "9\uC8FC\uCC28 \uC18C\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uC131\uC778\uC2DD \uC804\uB0A0 \uBC24, \uC8FC\uBC29 \uADFC\uCC98.
    \uD558\uC778\uB4E4\uC774 \uAD73\uAC8C \uB2EB\uD78C \uC5F0\uD68C\uC7A5 \uBB38\uC744
    \uBCF4\uBA70 \uC18D\uC0AD\uC778\uB2E4.)\n    \n    \uD558\uC778 1 : \uB0B4\uC77C
    \uC131\uC778\uC2DD \uB54C \uBC31\uC791\uB2D8\uC774 \uC8FC\uC778\uB2D8\uAED8 \uC8FC\uC2E4
    \uAC00\uBB38\uC758 \uAC00\uBCF4 \uB9D0\uC774\uC57C... \uADF8\uAC8C \uC2A4\uC2A4\uB85C
    \uC8FC\uC778\uC744 \uC120\uD0DD\uD55C\uB2E4\uB294 \uAC8C \uC9C4\uC9DC\uC77C\uAE4C?\n   
    \uD558\uC778 2 : \uC790\uACA9\uC774 \uC5C6\uB294 \uC790\uAC00 \uB9CC\uC9C0\uBA74
    \uAC80\uAC8C \uBCC0\uD574\uBC84\uB9B0\uB2E4\uB294 \uC18C\uBB38\uC774 \uC788\uB354\uB77C\uACE0.\n   
    \uB124\uBAA8 : \uAC00\uBCF4\uAC00 \uB098\uB97C \uC120\uD0DD\uD55C\uB2E4\uACE0?
    \uB0B4\uAC00 \uB9CC\uC84C\uB294\uB370 \uBCC0\uD558\uBA74 \uC5B4\uB5A1\uD574?\n   
    \n\n- \uD558\uC778 1 : \uC544\uC774\uACE0, \uC800\uD76C\uAC00 \uADFC\uAC70 \uC5C6\uB294
    \uAD34\uB2F4\uC744 \uB298\uC5B4\uB1A8\uB124\uC694. \uADF8\uB0E5 \uD3C9\uBC94\uD55C
    \uBCF4\uC11D\uC77C \uBFD0\uC785\uB2C8\uB2E4.\n    \uB124\uBAA8 : \uC544\uAE4C\uB294
    \uAC80\uAC8C \uBCC0\uD55C\uB2E4\uBA70! \uB098 \uC9C0\uAE08 \uB108\uBB34 \uB5A8\uB9B0\uB2E8
    \uB9D0\uC774\uC57C.\n    \uD558\uC778 2 : \uC8FC\uC778\uB2D8\uC740 \uC644\uBCBD\uD558\uC2DC\uB2C8\uAE4C
    \uC808\uB300 \uADF8\uB7F4 \uC77C \uC5C6\uC2B5\uB2C8\uB2E4. \uC5B4\uC11C \uAC00\uC11C
    \uC8FC\uBB34\uC138\uC694.\n    \uB124\uBAA8 : \uAC70\uC9D3\uB9D0... \uB2E4\uB4E4
    \uBB54\uAC00\uB97C \uC228\uAE30\uACE0 \uC788\uC5B4."
