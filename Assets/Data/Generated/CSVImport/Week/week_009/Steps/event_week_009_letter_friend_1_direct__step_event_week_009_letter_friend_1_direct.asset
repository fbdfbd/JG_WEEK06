  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_letter_friend_1_direct__step_event_week_009_letter_friend_1_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: friend_1 Direct
  _bodyText: "letter friend_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uD3C9\uC0DD\uC758 \uC57D\uC18D\uC744
      \uC801\uC5B4 \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uCD5C\uD6C4\uC758 \uACC4\uC57D\uC11C? \uBB50\uC57C, \uBB34\uC11C\uC6CC!"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB0B4 \uC81C\uC77C \uB0A0\uCE74\uB85C\uC6B4 \uCE7C... \uAC54\uB294 \uC9C4\uC9DC
      \uBA4B\uC9C4 \uB9D0\uC744 \uC798\uD574."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8 \uACC1\uC5D0 \uC774\uB7F0 \uB4E0\uB4E0\uD55C \uAE30\uC0AC\uAC00
      \uC788\uC73C\uB2C8 \uBC31\uC791\uB2D8\uB3C4 \uC548\uC2EC\uD558\uC2DC\uACA0\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uC774 \uD3B8\uC9C0, \uB0B4 \uBCF4\uBB3C\uD568 \uC81C\uC77C \uAE4A\uC740
      \uACF3\uC5D0 \uB123\uC5B4\uC918. \uC6B0\uB9AC \uACC4\uC57D\uC11C\uB2C8\uAE4C!"
  _nemoLine: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uD3C9\uC0DD\uC758 \uC57D\uC18D\uC744
    \uC801\uC5B4 \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
