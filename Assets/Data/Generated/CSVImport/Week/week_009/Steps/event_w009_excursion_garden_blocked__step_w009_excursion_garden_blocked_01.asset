  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_excursion_garden_blocked__step_w009_excursion_garden_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 9\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uC815\uC6D0 \uC628\uC2E4 \uC606, \uB124\uBAA8\uAC00 \uC88B\uC544\uD558\uB294
    \uAF43\uB4E4\uC774 \uB9CC\uAC1C\uD55C \uACF3\uC5D0 \uC791\uC740 \uD14C\uC774\uBE14\uACFC
    \uCC3B\uC794 \uC138\uD2B8\uAC00 \uC900\uBE44\uB418\uC5B4 \uC788\uB2E4.)\r\n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uB0A0\uC528\uAC00 \uB108\uBB34
    \uC88B\uC544\uC11C \uC5EC\uAE30\uC11C \uCC28\uB97C \uB9C8\uC2DC\uB294 \uAC74
    \uC5B4\uB5A8\uAE4C\uC694? \uC8FC\uC778\uB2D8\uC774 \uC9C1\uC811 \uACE0\uB978
    \uAF43\uCC28\uC608\uC694.\r\n        \r\n\r\n(\uACBD\uBE44\uB300\uC7A5\uC774
    \uC2DC\uACC4\uB97C \uBCF4\uBA70 \uCC3B\uC794\uC744 \uB0B4\uB824\uB193\uB294\uB2E4.)\r\n       
    \uACBD\uBE44\uB300\uC7A5 : \uD734\uC2DD\uC740 15\uBD84\uC785\uB2C8\uB2E4. \uADF8
    \uB4A4\uC5D0\uB294 \uB2E4\uC2DC \uC2E4\uB0B4 \uC218\uB828\uC774 \uC608\uC815\uB418\uC5B4
    \uC788\uC2B5\uB2C8\uB2E4. \uC8FC\uC778\uC73C\uB85C\uC11C\uC758 \uC5EC\uC720\uB3C4
    \uC88B\uC9C0\uB9CC, \uC808\uC81C\uB97C \uC78A\uC9C0 \uB9C8\uC2ED\uC2DC\uC624.\r\n       
    \uB124\uBAA8 : \uC544\uC800\uC528\uB3C4 \uCC38... \uC5EC\uAE30\uAE4C\uC9C0 \uC640\uC11C
    \uC2DC\uAC04 \uD0C0\uB839\uC774\uC5D0\uC694? \uB531 \uD55C \uC794\uB9CC \uB354
    \uB9C8\uC2E4\uAC8C\uC694.\r\n        \uACBD\uBE44\uB300\uC7A5 : \uC57D\uC18D\uC740
    \uACE7 \uADDC\uC728\uC785\uB2C8\uB2E4. \uD55C \uC794\uB9CC \uB354 \uB9C8\uC2DC\uACE0
    \uBC14\uB85C \uC774\uB3D9\uD558\uC2DC\uC8E0."
