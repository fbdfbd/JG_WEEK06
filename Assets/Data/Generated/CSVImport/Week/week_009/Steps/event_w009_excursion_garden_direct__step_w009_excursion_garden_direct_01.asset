  m_Name: event_w009_excursion_garden_direct__step_w009_excursion_garden_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 9\uCC28 \uBC29\uBB38 - \uC218\uB77D\uB124\uBAA8 :
    \uC6B0\uC640, \uB0B4\uAC00 \uC88B\uC544\uD558\uB294 \uAF43 \uD5A5\uAE30\uAC00
    \uC5EC\uAE30\uAE4C\uC9C0 \uB098! \uC5ED\uC2DC \uBC16\uC5D0\uC11C \uB9C8\uC2DC\uB294
    \uCC28\uAC00 \uC81C\uC77C \uB9DB\uC788\uC5B4."
  _bodyText: "(\uC815\uC6D0 \uC628\uC2E4 \uC606, \uB124\uBAA8\uAC00 \uC88B\uC544\uD558\uB294
    \uAF43\uB4E4\uC774 \uB9CC\uAC1C\uD55C \uACF3\uC5D0 \uC791\uC740 \uD14C\uC774\uBE14\uACFC
    \uCC3B\uC794 \uC138\uD2B8\uAC00 \uC900\uBE44\uB418\uC5B4 \uC788\uB2E4.)\r\n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uB0A0\uC528\uAC00 \uB108\uBB34
    \uC88B\uC544\uC11C \uC5EC\uAE30\uC11C \uCC28\uB97C \uB9C8\uC2DC\uB294 \uAC74
    \uC5B4\uB5A8\uAE4C\uC694? \uC8FC\uC778\uB2D8\uC774 \uC9C1\uC811 \uACE0\uB978
    \uAF43\uCC28\uC608\uC694.\r\n        \r\n\r\n\uD558\uB140 : \uC8FC\uC778\uB2D8\uC774
    \uD589\uBCF5\uD574\uD558\uC2DC\uB2C8 \uC800\uB3C4 \uAE30\uC058\uB124\uC694. \uC800\uAE30
    \uB098\uBE44\uAC00 \uC8FC\uC778\uB2D8 \uCC3B\uC794 \uADFC\uCC98\uB85C \uB0A0\uC544\uC624\uACE0
    \uC788\uC5B4\uC694.\r\n        \uB124\uBAA8 : \uD788\uD788, \uB098\uBE44\uB3C4
    \uC774 \uD5A5\uAE30\uAC00 \uC88B\uC740\uAC00 \uBD10. \uC6B0\uB9AC \uAC19\uC774
    \uC870\uAE08\uB9CC \uB354 \uC788\uB2E4 \uAC00\uC790."
