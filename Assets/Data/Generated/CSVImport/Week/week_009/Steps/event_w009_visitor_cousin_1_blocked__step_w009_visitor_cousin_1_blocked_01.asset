  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_visitor_cousin_1_blocked__step_w009_visitor_cousin_1_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 9\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uC0AC\uCD0C 1\uC774 \uD53C\uC640 \uD759\uC774 \uC5C9\uACA8 \uBD99\uC740
    \uB0A1\uC740 \uBAA8\uC790\uB97C \uBC31\uC791\uB2D8\uC758 \uC815\uAC08\uD55C \uCC45\uC0C1
    \uC704, \uBC31\uC791\uB2D8\uC758 \uC11C\uBA85\uC774 \uC801\uD78C \uC11C\uB958\uB4E4
    \uC704\uC5D0 \uB358\uC838\uB193\uB294\uB2E4. \uC11C\uC7AC\uC758 \uC6B0\uC544\uD55C
    \uC7A5\uBBF8 \uD5A5\uC218 \uB0C4\uC0C8\uAC00 \uC21C\uC2DD\uAC04\uC5D0 \uBE44\uB9BF\uD55C
    \uD53C \uB0C4\uC0C8\uB85C \uB354\uB7FD\uD600\uC9C4\uB2E4.)\n        \n       
    \uC0AC\uCD0C 1 : \uC57C, \uB124\uBAA8. \uC774 \uBAA8\uC790 \uB0C4\uC0C8 \uB9E1\uC544\uBD10.
    \uC774\uAC8C \uB124 \uC544\uBC84\uC9C0\uAC00 \uB9C8\uC9C0\uB9C9\uC73C\uB85C \uD758\uB9B0
    \uD53C \uB0C4\uC0C8\uB2E4. \uBC31\uC791\uB2D8\uC774 \uB9E8\uB0A0 \uBFCC\uB824\uB300\uB294
    \uADF8 \uAC00\uC2DD\uC801\uC778 \uC7A5\uBBF8 \uD5A5\uC218 \uBC11\uC5D0 \uBB50\uAC00
    \uC228\uACA8\uC838 \uC788\uB294\uC9C0 \uC774\uC81C \uC54C\uACA0\uB0D0? \uB10C
    \uC9C0\uAE08 \uBD80\uBAA8\uB97C \uC8FD\uAC8C \uBC29\uCE58\uD55C \uC790\uC758
    \uD488\uC5D0\uC11C \uACF5\uC8FC \uB300\uC811\uBC1B\uC73C\uBA70 \uC0B4\uACE0 \uC788\uB294
    \uAC70\uC57C.\n        \n\n- (\uC9D1\uC0AC\uAC00 \uACBD\uC545\uD558\uBA70 \uBAA8\uC790\uB97C
    \uCE58\uC6B0\uB824 \uD558\uC790, \uB124\uBAA8\uAC00 \uCC98\uC74C\uC73C\uB85C
    \uC9D1\uC0AC\uC758 \uC190\uC744 \uB9E4\uBAB0\uCC28\uAC8C \uCCD0\uB0B8\uB2E4.)\uB124\uBAA8
    : \uC190 \uB300\uC9C0 \uB9C8! (\uC0AC\uCD0C 1\uC744 \uD5A5\uD574 \uB5A8\uB9AC\uB294
    \uBAA9\uC18C\uB9AC\uB85C) \uC0BC\uCD0C, \uC774\uAC8C \uC815\uB9D0 \uC6B0\uB9AC
    \uC544\uBC84\uC9C0\uC758 \uAC83\uC774\uB77C\uACE0\uC694? \uAC10\uD788 \uC774
    \uB354\uB7EC\uC6B4 \uAC78 \uBC31\uC791\uB2D8\uC758 \uCC45\uC0C1\uC5D0 \uC62C\uB824?\n       
    \uC9D1\uC0AC : \uC8FC\uC778\uB2D8! \uC800\uC790\uC758 \uB18D\uAC04\uC785\uB2C8\uB2E4.
    \uC81C\uBC1C \uC9C4\uC815\uD558\uC2ED\uC2DC\uC624!\n        \uB124\uBAA8 : (\uCC45\uC0C1\uC744
    \uC5CE\uC744 \uB4EF\uC774 \uC0AC\uCD0C 1\uC5D0\uAC8C \uC18C\uB9AC\uCE5C\uB2E4)
    \uB098\uAC00! \uB2F9\uC7A5 \uB0B4 \uC9D1\uC5D0\uC11C \uB098\uAC00! \uBC31\uC791\uB2D8\uC774
    \uC0B4\uC778\uC790\uB4E0 \uC544\uB2C8\uB4E0, \uB2F9\uC2E0 \uAC19\uC740 \uC778\uAC04\uC774
    \uB0B4 \uBD80\uBAA8\uB2D8\uC744 \uC785\uC5D0 \uC62C\uB9AC\uB294 \uAC74 \uCC38\uC744
    \uC218 \uC5C6\uC5B4! \uD558\uC9C0\uB9CC... (\uCE58\uC6CC\uC9C0\uB294 \uBAA8\uC790\uB97C
    \uBCF4\uBA70) \uBC31\uC791\uB2D8\uAED8 \uC804\uD574. \uB354 \uC774\uC0C1 \uD5A5\uC218
    \uB0C4\uC0C8\uB85C \uC774 \uD53C\uBE44\uB9B0\uB0B4\uB97C \uAC00\uB9B4 \uC218
    \uC5C6\uC744 \uAC70\uB77C\uACE0!"
