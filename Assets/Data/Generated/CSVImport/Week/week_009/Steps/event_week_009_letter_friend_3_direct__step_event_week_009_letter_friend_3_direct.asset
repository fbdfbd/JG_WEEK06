  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_letter_friend_3_direct__step_event_week_009_letter_friend_3_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: friend_3 Direct
  _bodyText: "letter friend_3 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC5B4\uB978\uC774 \uB41C
      \uD6C4\uC758 \uBAA8\uD5D8 \uC9C0\uB3C4\uB97C \uADF8\uB824 \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBAA8\uD5D8 \uC9C0\uB3C4?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC740\uD558\uC218 \uBAA8\uD5D8... \uAC54\uB77C\uBA74 \uC9C4\uC9DC \uBC30\uB77C\uB3C4
      \uB9CC\uB4E4\uC5B4 \uC62C \uAC83 \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uC758 \uC55E\uB0A0\uC774 \uC740\uD558\uC218\uCC98\uB7FC
      \uBC1D\uAE38 \uBC14\uB77C\uB294 \uC9C4\uC2EC\uC774 \uB290\uAEF4\uC9C0\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD558\uD558, \uB098 \uC808\uB300 \uC11C\uC7AC\uC5D0\uB9CC \uC788\uC9C0
      \uC54A\uC744 \uAC70\uC57C. \uAC54\uB791 \uC57D\uC18D\uD588\uC73C\uB2C8\uAE4C!"
  _nemoLine: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC5B4\uB978\uC774 \uB41C
    \uD6C4\uC758 \uBAA8\uD5D8 \uC9C0\uB3C4\uB97C \uADF8\uB824 \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
