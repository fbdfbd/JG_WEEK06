  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_external_will_news_modified__step_week_009_external_will_news_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC31\uC791\uC758 \uC720\uC5B8\uC7A5 - \uC218\uC815"
  _bodyText: "\uBC31\uC791\uC758 \uC720\uC5B8\uC7A5 - \uC218\uC815 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC720\uC5B8\uC7A5 \uC774\uC57C\uAE30\uAC00 \uB098\uC624\uAE34 \uD558\uC9C0\uB9CC,
      \uB300\uBD80\uBD84\uC740 \uC55E\uC11C\uAC04 \uCD94\uCE21\uC5D0 \uAC00\uAE5D\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uAC81\uBA39\uC73C\uB77C\uACE0 \uD37C\uC9C0\uB294 \uB9D0\uC77C
      \uC218\uB3C4 \uC788\uB124."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uB9DE\uC2B5\uB2C8\uB2E4. \uADF8\uB798\uC11C \uC18C\uBB38\uC5D0 \uB04C\uB824\uAC00\uAE30\uBCF4\uB2E4,
      \uC2E4\uC81C\uB85C \uC815\uD574\uC9C4 \uC808\uCC28\uB97C \uBCF4\uB294 \uD3B8\uC774
      \uC88B\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC54C\uACA0\uC5B4. \uD754\uB4E4\uB9AC\uAE30\uBCF4\uB2E4 \uAE30\uB2E4\uB824
      \uBCFC\uB798."
  _nemoLine: "\uC720\uC5B8\uC7A5 \uC774\uC57C\uAE30\uAC00 \uB098\uC624\uAE34 \uD558\uC9C0\uB9CC,
    \uB300\uBD80\uBD84\uC740 \uC55E\uC11C\uAC04 \uCD94\uCE21\uC5D0 \uAC00\uAE5D\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
