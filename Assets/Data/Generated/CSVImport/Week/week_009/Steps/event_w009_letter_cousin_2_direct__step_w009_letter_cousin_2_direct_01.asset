  m_Name: event_w009_letter_cousin_2_direct__step_w009_letter_cousin_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 \uD3B8\uC9C0 9\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uC544\uC8FC \uC587\uACE0 \uC12C\uC138\uD55C \uC885\uC774\uB85C
    \uB41C \uD3B8\uC9C0\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C\uC5D0 '\uC601\uC6D0\uD55C
    \uBE44\uBC00 \uCE5C\uAD6C'\uB77C\uACE0 \uC801\uD600 \uC788\uB2E4.)\r\n       
    \r\n\r\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uC0AC\uCD0C 2 \uB3C4\uB828\uB2D8\uC774
    \uB5A8\uB9AC\uB294 \uC9C4\uC2EC\uC744 \uB2F4\uC544 \uB9C8\uC9C0\uB9C9 \uC778\uC0AC\uB97C
    \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\r\n        \uB124\uBAA8 : \uC774\uC81C \uC5B4\uB978
    \uB418\uBA74 \uAC54\uB791 \uBABB \uB178\uB294 \uAC70\uC57C?\r\n        (\uD558\uB140\uAC00
    \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)\r\n        \uB124\uBAA8, \uB09C \uC544\uBE60\uAC00
    \uC2DC\uD0A4\uB294 \uB300\uB85C \uC0B4\uC544\uC57C \uD560\uC9C0\uB3C4 \uBAB0\uB77C.
    \uD558\uC9C0\uB9CC \uB0B4 \uB9C8\uC74C\uC18D\uC758 \uBC31\uC791\uB2D8\uC740 \uC5B8\uC81C\uB098
    \uB108\uBFD0\uC774\uC57C. \uB124\uAC00 \uC774 \uAC00\uBB38\uC758 \uC8FC\uC778\uC774
    \uB418\uBA74, \uADF8\uB550 \uB098\uB3C4 \uC544\uBE60 \uB208\uCE58 \uC548 \uBCF4\uACE0
    \uB108\uD55C\uD14C \uB9E4\uC77C \uB180\uB7EC \uAC08\uAC8C. \uC6B0\uB9AC \uADF8\uB54C\uAE4C\uC9C0
    \uAF2D \uAC74\uAC15\uD558\uAC8C \uB2E4\uC2DC \uB9CC\uB098\uC790. \uB10C \uB0B4
    \uC0DD\uC560 \uCD5C\uACE0\uC758 \uCE5C\uAD6C\uC57C.\r\n        \uB124\uBAA8 :
    \uB0B4 \uB9C8\uC74C\uC18D\uC758 \uBC31\uC791\uB2D8\uC740 \uB108\uBFD0\uC774\uB798...
    \uBC14\uBCF4, \uB2F9\uC5F0\uD558\uC9C0.\r\n        \uD558\uB140 : \uC8FC\uC778\uB2D8\uC774
    \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uAED8 \uC815\uB9D0 \uD070 \uD76C\uB9DD\uC774
    \uB418\uC5B4\uC8FC\uC168\uB098 \uBD05\uB2C8\uB2E4.\r\n        \uB124\uBAA8 :
    \uC751. \uB0B4\uAC00 \uBE68\uB9AC \uBC31\uC791\uC774 \uB3FC\uC11C \uAC54\uB97C
    \uC790\uC720\uB86D\uAC8C \uD574\uC904 \uAC70\uC57C. \uADF8\uAC8C \uB0B4 \uC57D\uC18D\uC774\uC57C."
