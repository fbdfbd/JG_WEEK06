  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_house_talk_heirloom_rumor_modified__step_week_009_house_talk_heirloom_rumor_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uAE30\uC774\uD55C \uAC00\uBCF4 \uC18C\uBB38 - \uC218\uC815"
  _bodyText: "\uAE30\uC774\uD55C \uAC00\uBCF4 \uC18C\uBB38 - \uC218\uC815 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uAC00\uBCF4\uAC00 \uC8FC\uC778\uC744 \uACE0\uB978\uB2E4\uB294 \uB9D0\uC774
      \uC788\uC9C0\uB9CC, \uB108\uBB34 \uC2E0\uBE44\uD558\uAC8C\uB9CC \uB4E4\uC744
      \uD544\uC694\uB294 \uC5C6\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uACB0\uAD6D \uC0AC\uB78C\uC774 \uC900\uBE44\uB418\uC5B4
      \uC788\uB290\uB0D0\uAC00 \uB354 \uC911\uC694\uD558\uB2E4\uB294 \uAC70\uC9C0?"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC608, \uADF8\uB7F0 \uB9C8\uC74C\uAC00\uC9D0\uC744 \uC77C\uAE68\uC6B0\uB294
      \uB9D0\uC5D0 \uAC00\uAE5D\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC54C\uACA0\uC5B4. \uADF8\uB7FC \uAC81\uB0B4\uAE30\uBCF4\uB2E4 \uC900\uBE44\uD560\uB798."
  _nemoLine: "\uAC00\uBCF4\uAC00 \uC8FC\uC778\uC744 \uACE0\uB978\uB2E4\uB294 \uB9D0\uC774
    \uC788\uC9C0\uB9CC, \uB108\uBB34 \uC2E0\uBE44\uD558\uAC8C\uB9CC \uB4E4\uC744
    \uD544\uC694\uB294 \uC5C6\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
