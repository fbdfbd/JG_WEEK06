  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_visitor_cousin_2_direct__step_w009_visitor_cousin_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 9\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uB124\uBAA8\uAC00 \uBC31\uC791\uB2D8\uC758 \uC18C\uC911\uD55C \uAE43\uD39C\uC744
    \uB9CC\uC9C0\uC791\uAC70\uB9AC\uB2E4 \uC0AC\uCD0C 2\uC5D0\uAC8C \uAC74\uB124.
    \uC0AC\uCD0C 2\uB294 \uC0AC\uCD0C 1\uC774 \uAC00\uC838\uC628 \uD53C \uBB3B\uC740
    \uBAA8\uC790\uB97C \uBCF4\uACE0 \uBAB8\uC744 \uBC8C\uBC8C \uB5A8\uACE0 \uC788\uC5B4.)\r\n       
    \r\n        \uC0AC\uCD0C 2 : \uC800 \uBAA8\uC790... \uC6B0\uB9AC \uC544\uBE60
    \uBC29\uC5D0 \uC788\uB358 \uAC74\uB370... \uB124\uBAA8\uC57C, \uC800\uAE30 \uBB3B\uC740
    \uAC70 \uC9C4\uC9DC \uD53C\uC57C? \uC6B0\uB9AC \uC544\uBE60\uAC00 \uC815\uB9D0...
    \uB124 \uBD80\uBAA8\uB2D8\uC744...\r\n        \uB124\uBAA8 : (\uAE43\uD39C\uC744
    \uC0AC\uCD0C 2\uC758 \uC190\uC5D0 \uAF49 \uC950\uC5EC\uC8FC\uBA70) \uC0AC\uCD0C
    2, \uC120\uD0DD\uD574. \uB108\uD76C \uC544\uBC84\uC9C0\uCC98\uB7FC \uB098\uB97C
    \uD30C\uBA78\uC2DC\uD0AC \uAC74\uC9C0, \uC544\uB2C8\uBA74 \uB098\uB97C \uB3C4\uC640
    \uBC31\uC791\uB2D8\uC758 \uC774 \uC704\uC120\uC801\uC778 \uC11C\uC7AC\uB97C \uBD80\uC220
    \uAC74\uC9C0.\r\n        \r\n\r\n- (\uC0AC\uCD0C 2\uAC00 \uB5A8\uB9AC\uB294 \uC190\uC73C\uB85C
    \uBD80\uB7EC\uC9C0\uAE30 \uC9C1\uC804\uAE4C\uC9C0 \uAE43\uD39C\uC744 \uAF49 \uC954
    \uCC44, \uBC31\uC791\uB2D8\uC758 \uC11C\uB958 \uC704\uC5D0 '\uB3C4\uC640\uC918'\uB77C\uACE0
    \uC801\uB294\uB2E4.)\r\n        - \uC0AC\uCD0C 2 : \uB124\uBAA8\uC57C, \uC6B0\uB9AC
    \uC544\uBE60\uB294 \uAD34\uBB3C\uC774\uC57C. \uB9E4\uC77C \uBC24 \uBC31\uC791\uB2D8\uC744
    \uBB34\uB108\uB728\uB9B4 \uACC4\uD68D\uB9CC \uC138\uC6B0\uACE0 \uC788\uC5B4.
    \uD558\uC9C0\uB9CC \uB09C \uBC31\uC791\uB2D8\uB3C4 \uBBFF\uC9C0 \uC54A\uC544.
    \uADF8\uBD84\uC740 \uC6B0\uB9AC \uC544\uBE60\uBCF4\uB2E4 \uB354 \uBB34\uC11C\uC6B4
    \uAC78 \uC228\uAE30\uACE0 \uACC4\uC2DC\uB2C8\uAE4C...\r\n        \uB124\uBAA8
    : (\uC0AC\uCD0C 2\uC758 \uC5B4\uAE68\uB97C \uAC10\uC2F8\uBA70) \uC54C\uC544.
    \uADF8\uB798\uC11C \uC6B0\uB9AC\uB07C\uB9AC \uD798\uC744 \uD569\uCCD0\uC57C \uD574.
    \uC774 \uC11C\uC7AC\uC5D0 \uC788\uB294 \uBAA8\uB4E0 \uAE30\uB85D\uC744 \uC6B0\uB9AC\uAC00
    \uBA3C\uC800 \uC77D\uACE0, \uBC31\uC791\uB2D8\uC774 \uC624\uAE30 \uC804\uC5D0
    \uC9C4\uC2E4\uC744 \uD30C\uD5E4\uCE58\uC790.\r\n        \uC0AC\uCD0C 2 : (\uB208\uBB3C\uC744
    \uB2E6\uC73C\uBA70) \uC751... \uBC31\uC791\uB2D8\uC774 \uC624\uC2DC\uBA74 \uB124\uAC00
    \uC2DC\uCF1C\uC11C \uD588\uB2E4\uACE0 \uB9D0\uD574. \uB0B4\uAC00 \uB2E4 \uB4A4\uC9D1\uC5B4\uC4F8\uAC8C.
    \uB10C \uAF2D \uC774 \uAC00\uBB38\uC758 \uC9C4\uC9DC \uC8FC\uC778\uC774 \uB418\uC5B4\uC57C
    \uD574."
  _dialogueLines: []
