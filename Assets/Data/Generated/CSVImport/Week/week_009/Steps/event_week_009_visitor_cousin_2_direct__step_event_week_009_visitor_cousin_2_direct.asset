  _titleOverride: cousin_2 Direct
  _bodyText: "visitor cousin_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC0AC\uCD0C 2\uC758 \uC5B4\uAE68\uB97C \uAC10\uC2F8\uBA70) \uC54C\uC544.
      \uADF8\uB798\uC11C \uC6B0\uB9AC\uB07C\uB9AC \uD798\uC744 \uD569\uCCD0\uC57C
      \uD574. \uC774 \uC11C\uC7AC\uC5D0 \uC788\uB294 \uBAA8\uB4E0 \uAE30\uB85D\uC744
      \uC6B0\uB9AC\uAC00 \uBA3C\uC800 \uC77D\uACE0, \uBC31\uC791\uB2D8\uC774 \uC624\uAE30
      \uC804\uC5D0 \uC9C4\uC2E4\uC744 \uD30C\uD5E4\uCE58\uC790."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "(\uB208\uBB3C\uC744 \uB2E6\uC73C\uBA70) \uC751... \uBC31\uC791\uB2D8\uC774
      \uC624\uC2DC\uBA74 \uB124\uAC00 \uC2DC\uCF1C\uC11C \uD588\uB2E4\uACE0 \uB9D0\uD574.
      \uB0B4\uAC00 \uB2E4 \uB4A4\uC9D1\uC5B4\uC4F8\uAC8C. \uB10C \uAF2D \uC774 \uAC00\uBB38\uC758
      \uC9C4\uC9DC \uC8FC\uC778\uC774 \uB418\uC5B4\uC57C \uD574."
  _nemoLine: "(\uC0AC\uCD0C 2\uC758 \uC5B4\uAE68\uB97C \uAC10\uC2F8\uBA70) \uC54C\uC544.
    \uADF8\uB798\uC11C \uC6B0\uB9AC\uB07C\uB9AC \uD798\uC744 \uD569\uCCD0\uC57C \uD574.
    \uC774 \uC11C\uC7AC\uC5D0 \uC788\uB294 \uBAA8\uB4E0 \uAE30\uB85D\uC744 \uC6B0\uB9AC\uAC00
    \uBA3C\uC800 \uC77D\uACE0, \uBC31\uC791\uB2D8\uC774 \uC624\uAE30 \uC804\uC5D0
    \uC9C4\uC2E4\uC744 \uD30C\uD5E4\uCE58\uC790."
