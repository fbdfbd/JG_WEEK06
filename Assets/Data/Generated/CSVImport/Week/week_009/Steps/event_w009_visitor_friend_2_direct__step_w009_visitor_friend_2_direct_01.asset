  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_visitor_friend_2_direct__step_w009_visitor_friend_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 9\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D (\uB124\uBAA8\uAC00
    \uCE5C\uAD6C 2\uC758 \uC190\uC744 \uC7A1\uACE0 \uC11C\uC7AC \uC911\uC559\uC5D0\uC11C
    \uC57D\uC18D\uD55C\uB2E4.)"
  _bodyText: "(\uC131\uC778\uC2DD \uC804\uB0A0 \uBC24, \uC11C\uC7AC\uC758 \uACF5\uAE30\uB294
    \uC5C4\uC219\uD558\uBA74\uC11C\uB3C4 \uB530\uB73B\uD558\uB2E4. \uCE5C\uAD6C 2\uAC00
    \uBC31\uC791\uB2D8\uC774 \uB124\uBAA8\uB97C \uC704\uD574 \uC900\uBE44\uD55C \uD654\uB824\uD55C
    \uC815\uBCF5\uC744 \uBCF4\uBA70 \uAC10\uD0C4\uD55C\uB2E4. \uAC74 \uAC8C\uC784\uC5D0\uC11C\uC758
    \uB9C8\uC9C0\uB9C9 \uBC29\uBB38\uC774\uC790, \uC544\uC774\uB85C\uC11C \uB098\uB204\uB294
    \uB9C8\uC9C0\uB9C9 \uB300\uD654\uB2E4.)\n        \n        \uCE5C\uAD6C 2 : \uB124\uBAA8,
    \uB4DC\uB514\uC5B4 \uB0B4\uC77C\uC774\uB124. \uC0AC\uCD0C 1\uC758 \uC774\uAC04\uC9C8\uB3C4,
    \uC0AC\uCD0C 2\uC758 \uBD88\uC548\uD568\uB3C4 \uC774\uC81C \uB108\uB97C \uD754\uB4E4\uC9C0
    \uBABB\uD574. \uB10C \uC774\uBBF8 \uBC31\uC791\uB2D8\uC758 \uD6CC\uB96D\uD55C
    \uD6C4\uACC4\uC790\uC774\uC790, \uC6B0\uB9AC\uB4E4\uC758 \uB2F9\uB2F9\uD55C \uB9AC\uB354\uB2C8\uAE4C.
    \uC774 \uC11C\uC7AC\uC758 \uBAA8\uB4E0 \uCC45\uACFC \uC9C0\uD61C\uAC00 \uB0B4\uC77C
    \uB124 \uBAB8\uC744 \uAC10\uC2F8\uB294 \uAC11\uC637\uC774 \uB418\uC5B4\uC904
    \uAC70\uC57C.\n        \n\n- \uB124\uBAA8 : \uBC31\uC791\uB2D8\uC740 \uB098\uB97C
    \uC704\uD574 \uC774 \uC11C\uC7AC\uB97C \uC9C0\uD0A4\uC168\uC9C0\uB9CC, \uB098\uB294
    \uB108\uD76C\uC640 \uD568\uAED8 \uC774 \uC11C\uC7AC\uC758 \uBB38\uC744 \uC5F4
    \uAC70\uC57C. \uC6B0\uB9AC\uAC00 \uD568\uAED8 \uBC30\uC6B4 \uC9C0\uD61C\uB85C
    \uC774 \uC601\uC9C0\uB97C \uB354 \uBC1D\uAC8C \uBE44\uCD94\uC790. \uC774\uAC74
    \uBC31\uC791\uB2D8\uB3C4 \uAE30\uBED0\uD558\uC2E4 \uB0B4\uC77C\uC758 \uCCAB \uBC88\uC9F8
    \uBCC0\uD654\uC57C!\n        \uCE5C\uAD6C 2 : (\uC190\uC744 \uB9C8\uC8FC \uC7A1\uC73C\uBA70)
    \uADF8\uB798! \uBC31\uC791\uB2D8\uC758 \uC720\uC0B0 \uC704\uC5D0 \uC6B0\uB9AC\uC758
    \uAFC8\uC744 \uC313\uC544 \uC62C\uB9AC\uC790. \uB124\uBAA8, \uB10C \uC5ED\uB300
    \uCD5C\uACE0\uC758 \uC8FC\uC778\uB2D8\uC774 \uB420 \uAC70\uC57C. \uC131\uC778\uC2DD\uC7A5\uC5D0\uC11C
    \uBCF4\uC790!"
