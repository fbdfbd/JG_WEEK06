  _titleOverride: "\uC608\uBC95\uACFC \uD611\uC0C1\uC758 \uAE30\uBCF8\uC744 \uAC00\uB974\uCE5C\uB2E4"
  _bodyText: "\uC608\uBC95\uACFC \uD611\uC0C1\uC758 \uAE30\uBCF8\uC744 \uAC00\uB974\uCE5C\uB2E4
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC0AC\uC808\uC744 \uB9DE\uB294 \uC608\uBC95\uACFC \uB9D0\uC758 \uC21C\uC11C\uB97C
      \uC9DA\uC73C\uBA70 \uD611\uC0C1\uC758 \uAE30\uCD08\uB97C \uC124\uBA85\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBA3C\uC800 \uBB3C\uB7EC\uB098\uB294 \uCC99\uD574\uC57C \uB354 \uB9CE\uC774
      \uB4E4\uC744 \uC218 \uC788\uB294 \uAC70\uAD6C\uB098."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uB9D0\uD22C\uC640 \uC21C\uC11C\uAC00 \uAD00\uACC4\uB97C \uBC14\uAFBC\uB2E4\uB294
      \uC810\uC744 \uC9DA\uC5B4 \uC900\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC0DD\uAC01\uBCF4\uB2E4 \uBA3C\uC800 \uB4E3\uB294 \uAC8C \uB354 \uC5B4\uB835\uB124."
  _nemoLine: "(\uC0AC\uC808\uC744 \uB9DE\uB294 \uC608\uBC95\uACFC \uB9D0\uC758 \uC21C\uC11C\uB97C
    \uC9DA\uC73C\uBA70 \uD611\uC0C1\uC758 \uAE30\uCD08\uB97C \uC124\uBA85\uD55C\uB2E4.)"
