--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_009_diplomacy_direct__step_event_week_009_diplomacy_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBD80\uB4DC\uB7FD\uAC8C \uAC70\uC808\uD558\uB294 \uB9D0\uC744
    \uC775\uD78C\uB2E4"
  _bodyText: "\uC678\uAD50\uC220\uACFC \uC218\uC0AC\uD559 9\uC8FC\uCC28 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC751\uC811\uC2E4. \uC774\uBC88\uC5D4 \uC9E7\uC740 \uC0C1\uD669\uADF9
      \uD615\uC2DD\uC774\uB2E4. \uBE44\uC11C\uB294 \uC190\uB2D8 \uC5ED, \uD558\uB140\uB294
      \uC911\uC7AC \uC5ED\uC744 \uB9E1\uACE0, \uB124\uBAA8\uB294 \uC608\uC758\uB97C
      \uC783\uC9C0 \uC54A\uC73C\uBA74\uC11C\uB3C4 \uAC70\uC808\uD558\uB294 \uB9D0\uC744
      \uC5F0\uC2B5\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC624\uB298\uC740 \uBC1B\uC544\uB4E4\uC774\uB294 \uBC95\uC774 \uC544\uB2C8\uB77C,
      \uBD80\uB4DC\uB7FD\uAC8C \uAC70\uC808\uD558\uB294 \uBC95\uC744 \uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC70\uC808\uC740 \uADF8\uB0E5 \uC548 \uB41C\uB2E4\uACE0 \uD558\uBA74
      \uB418\uB294 \uC904 \uC54C\uC558\uB294\uB370."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uADF8\uAC8C \uC81C\uC77C \uC26C\uC6B0\uBA74\uC11C\uB3C4 \uC81C\uC77C
      \uAC70\uCE60\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u201C\uC88B\uC740 \uC81C\uC548\uC774\uC9C0\uB9CC, \uC9C0\uAE08\uC740
      \uBC1B\uC544\uB4E4\uC774\uAE30 \uC5B4\uB835\uC2B5\uB2C8\uB2E4.\u201D"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC544\uC8FC \uC88B\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uC548 \uB41C\uB2E4\uACE0 \uB9D0\uD588\uB294\uB370\uB3C4
      \uB35C \uB0A0\uCE74\uB86D\uB124."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uB124. \uAC70\uC808\uC740 \uB0B4\uC6A9\uBCF4\uB2E4 \uD615\uC2DD\uC774
      \uC624\uB798 \uB0A8\uC744 \uB54C\uB3C4 \uC788\uC73C\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC678\uAD50\uAC00 \uD53C\uACE4\uD55C \uC774\uC720\uB97C \uC54C\uACA0\uB2E4."
  _nemoLine: "(\uC751\uC811\uC2E4. \uC774\uBC88\uC5D4 \uC9E7\uC740 \uC0C1\uD669\uADF9
    \uD615\uC2DD\uC774\uB2E4. \uBE44\uC11C\uB294 \uC190\uB2D8 \uC5ED, \uD558\uB140\uB294
    \uC911\uC7AC \uC5ED\uC744 \uB9E1\uACE0, \uB124\uBAA8\uB294 \uC608\uC758\uB97C
    \uC783\uC9C0 \uC54A\uC73C\uBA74\uC11C\uB3C4 \uAC70\uC808\uD558\uB294 \uB9D0\uC744
    \uC5F0\uC2B5\uD55C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
