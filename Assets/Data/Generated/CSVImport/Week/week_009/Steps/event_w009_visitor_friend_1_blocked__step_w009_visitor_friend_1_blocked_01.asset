  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w009_visitor_friend_1_blocked__step_w009_visitor_friend_1_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 9\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uC131\uC778\uC2DD \uC804\uB0A0 \uBC24, \uCE5C\uAD6C 1\uC774 \uC815\uC911\uD558\uAC8C
    \uC11C\uC7AC \uBB38\uC744 \uB450\uB4DC\uB9AC\uACE0 \uB4E4\uC5B4\uC640. \uB450
    \uC0AC\uB78C\uC740 \uC774\uC81C \uB354 \uC774\uC0C1 \uC228\uBC14\uAF2D\uC9C8\uD558\uB4EF
    \uB180\uB358 \uC544\uC774\uB4E4\uC774 \uC544\uB2C8\uC57C. \uCE5C\uAD6C 1\uC740
    \uBC31\uC791\uB2D8\uC758 \uC11C\uC7AC\uC5D0 \uC5B4\uC6B8\uB9AC\uB294 \uC815\uC911\uD55C
    \uC778\uC0AC\uB97C \uAC74\uB124.)\r\n        \r\n        \uCE5C\uAD6C 1 : \uB124\uBAA8\uC57C,
    \uC774\uC81C \uB0B4\uC77C\uC774\uBA74 \uB10C \uC774 \uC11C\uC7AC\uC758 \uC815\uC2DD
    \uC8FC\uC778\uC774\uC790 \uBC31\uC791\uB2D8\uC758 \uD6C4\uACC4\uC790\uAC00 \uB418\uACA0\uC9C0?
    \uC0AC\uCD0C 1 \uAC19\uC740 \uC0AC\uB78C\uB4E4\uC774 \uC544\uBB34\uB9AC \uD754\uB4E4\uC5B4\uB3C4
    \uB10C \uD754\uB4E4\uB9AC\uC9C0 \uC54A\uC744 \uAC70\uB77C\uB294 \uAC70 \uC54C\uC544.
    \uC790, \uC774\uAC74 \uB0B4 \uB9C8\uC9C0\uB9C9 \uC120\uBB3C\uC774\uC57C.\r\n       
    (\uCE5C\uAD6C 1\uC774 \uD22C\uBC15\uD558\uC9C0\uB9CC \uC815\uC131\uC774 \uB2F4\uAE34
    \uC9C1\uC811 \uAE4E\uC740 \uB098\uBB34 \uC778\uC7A5\uC744 \uB0B4\uBBFC\uB2E4.)\r\n       
    \r\n\r\n- (\uB124\uBAA8\uAC00 \uB098\uBB34 \uC778\uC7A5\uC744 \uBC1B\uC544 \uBC31\uC791\uB2D8\uC758
    \uD669\uAE08 \uC778\uC7A5 \uC606\uC5D0 \uB098\uB780\uD788 \uB454\uB2E4.)\r\n       
    - \uB124\uBAA8 : \uBC31\uC791\uB2D8\uC774 \uAC00\uB974\uCCD0\uC8FC\uC2E0 \uAC00\uBB38\uC758
    \uBB34\uAC8C\uC640, \uB124\uAC00 \uC900 \uC774 \uB530\uB73B\uD55C \uC6B0\uC815.
    \uB458 \uB2E4 \uB0B4 \uC18C\uC911\uD55C \uBCF4\uBB3C\uC774\uC57C. \uB098\uB294
    \uBC31\uC791\uB2D8\uC758 \uBC29\uC2DD\uC744 \uC774\uC5B4\uBC1B\uC544 \uC774 \uC601\uC9C0\uB97C
    \uC9C0\uD0A4\uB294 \uC5C4\uACA9\uD558\uACE0\uB3C4 \uC790\uC560\uB85C\uC6B4 \uC8FC\uC778\uC774
    \uB420\uAC8C.\r\n        \uCE5C\uAD6C 1 : \uBA4B\uC9C0\uB2E4, \uB124\uBAA8! \uBC31\uC791\uB2D8\uB3C4
    \uB124 \uC774\uB7F0 \uBAA8\uC2B5\uC744 \uBCF4\uC2DC\uBA74 \uC815\uB9D0 \uC790\uB791\uC2A4\uB7EC\uC6CC\uD558\uC2E4
    \uAC70\uC57C. \uB0B4\uC77C \uC131\uC778\uC2DD\uC7A5\uC5D0\uC11C \uB124 \uB2F9\uB2F9\uD55C
    \uBAA8\uC2B5\uC744 \uAE30\uB2E4\uB9B4\uAC8C.\r\n        \uB124\uBAA8 : \uACE0\uB9C8\uC6CC.
    \uBC31\uC791\uB2D8\uC774 \uB2E6\uC544\uB193\uC73C\uC2E0 \uC774 \uAE38\uC744 \uB108\uC640
    \uD568\uAED8 \uAC77\uAC8C \uB418\uC5B4 \uAE30\uBED0."
