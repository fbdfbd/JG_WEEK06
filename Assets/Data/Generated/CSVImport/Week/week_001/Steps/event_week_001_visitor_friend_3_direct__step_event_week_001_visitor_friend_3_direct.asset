  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_visitor_friend_3_direct__step_event_week_001_visitor_friend_3_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC720\uD53C \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor friend_3 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uD55C\uAC78\uC74C \uBB3C\uB7EC\uB09C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uC800\uAE30 \uB098\uBB34\uB294 \uBE0C\uB85C\uCF5C\uB9AC \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548 \uB2EE\uC558\uC5B4."
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uB2EE\uC558\uC5B4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548 \uB2EE\uC558\uC5B4!"
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uADF8\uB7FC \uAC00\uAE4C\uC774 \uAC00\uC11C \uB2E4\uC2DC \uBCF4\uC790."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uC751. \uADF8\uAC74 \uC880 \uAD81\uAE08\uD55C\uB370."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB458\uC740 \uCC3D\uAC00\uC5D0 \uBD99\uC5B4\uC11C \uBC16\uC744 \uD55C\uCC38
      \uB0B4\uB2E4\uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uC800 \uC0C8\uB294 \uCF69 \uAC19\uC544. \uC800 \uAC1C\uB294 \uBC30\uCD94
      \uAC19\uC544. \uC800 \uB9C8\uCC28\uB294 \uD638\uBC15\uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB108 \uC9C4\uC9DC \uC774\uC0C1\uD55C\uB370 \uC7AC\uBC0C\uB124."
  _nemoLine: "(\uD558\uB140\uAC00 \uD55C\uAC78\uC74C \uBB3C\uB7EC\uB09C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
