  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w001_excursion_library_direct__step_w001_excursion_library_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 1\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uB124\uBAA8\uAC00 \uC800\uD0DD \uB0B4\uBD80 \uB3C4\uC11C\uAD00 \uBB38\uC744
    \uBE7C\uAF3C \uC5F0\uB2E4.)\r\n        \r\n                    \uB124\uBAA8 :
    \uC6B0\uC640\u2026\r\n        \r\n                    \uB124\uBAA8 : \uCC45 \uC9C4\uC9DC
    \uB9CE\uB2E4.\r\n        \r\n                    (\uB192\uC740 \uCC45\uC7A5 \uC704\uC5D0
    \uAE08\uBC15\uC774 \uB4E4\uC5B4\uAC04 \uCEE4\uB2E4\uB780 \uCC45 \uD55C \uAD8C\uC774
    \uBC18\uC9DD\uC778\uB2E4.)\r\n        \r\n                    \uB124\uBAA8 :
    \uC5B4? \uC800\uAC70 \uBC18\uC9DD\uBC18\uC9DD\uD55C\uB2E4.\r\n        \r\n                   
    \uB124\uBAA8 : \uC800\uAC70 \uBCF4\uACE0 \uC2F6\uC740\uB370.\r\n        \r\n                   
    \uB192\uC740 \uCC45\uC740 \uD63C\uC790 \uAEBC\uB0B4\uBA74 \uC704\uD5D8\uD558\uACE0,
    \uB3C4\uC11C\uAD00 \uCC45\uC740 \uD568\uBD80\uB85C \uB9CC\uC9C0\uBA74 \uC548
    \uB41C\uB2E4\uACE0 \uB4E4\uC740 \uC801\uC774 \uC788\uB2E4.\r\n        \r\n\r\n(\uC11C\uACE0\uAD00\uB9AC\uC778\uC774
    \uC0AC\uB2E4\uB9AC\uB97C \uB04C\uACE0 \uC628\uB2E4.)\r\n        \r\n                       
    \uC11C\uACE0\uAD00\uB9AC\uC778 : \uC8FC\uC778\uB2D8, \uC800 \uCC45\uC774 \uAD81\uAE08\uD558\uC168\uC2B5\uB2C8\uAE4C?\r\n       
    \r\n                        \uB124\uBAA8 : \uC751. \uC800 \uBC18\uC9DD\uC774\uB294
    \uAC70.\r\n        \r\n                        \uC11C\uACE0\uAD00\uB9AC\uC778
    : \uD63C\uC790 \uAEBC\uB0B4\uC2DC\uBA74 \uC704\uD5D8\uD558\uB2C8 \uC81C\uAC00
    \uB0B4\uB824\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4.\r\n        \r\n                       
    \uB124\uBAA8 : \uC9C4\uC9DC\uC694?\r\n        \r\n                        \uC11C\uACE0\uAD00\uB9AC\uC778
    : \uC608. \uB300\uC2E0 \uC870\uC2EC\uD574\uC11C \uBCF4\uC154\uC57C \uD569\uB2C8\uB2E4.\r\n       
    \r\n                        \uB124\uBAA8 : \uC751! \uC870\uC2EC\uD560\uB798\uC694!\r\n       
    \r\n                        (\uC11C\uACE0\uAD00\uB9AC\uC778\uC774 \uCC45\uC744
    \uB0B4\uB824 \uC900\uB2E4. \uB124\uBAA8\uB294 \uBC14\uB2E5\uC5D0 \uCABC\uADF8\uB824
    \uC549\uC544 \uCC45\uC744 \uD3BC\uCE5C\uB2E4.)\r\n        \r\n                       
    \uB124\uBAA8 : \uC6B0\uC640\u2026 \uADF8\uB9BC\uC774\uB2E4.\r\n        \r\n                       
    \uB124\uBAA8 : \uC774\uAC70 \uC608\uC058\uB2E4.\r\n        \r\n                       
    \uB124\uBAA8 : \uB2E4\uB978 \uAC83\uB3C4 \uBCF4\uACE0 \uC2F6\uC5B4."
