  m_Name: event_w001_excursion_basement_blocked__step_w001_excursion_basement_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 1\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uB124\uBAA8\uAC00 \uC0AC\uC6A9\uC778\uACFC \uC228\uBC14\uAF2D\uC9C8\uC744
    \uD558\uACE0 \uC788\uB2E4.)\r\n        \r\n                    \uB124\uBAA8 :
    \uAF2D\uAF2D \uC228\uC5B4\uB77C\u2026\r\n        \r\n                    \uB124\uBAA8
    : \uC5B4\uB514 \uC228\uC9C0?\r\n        \r\n                    (\uB124\uBAA8\uAC00
    \uBCF5\uB3C4\uB97C \uB450\uB9AC\uBC88\uAC70\uB9AC\uB2E4 \uBC18\uCBE4 \uC5F4\uB9B0
    \uC9C0\uD558\uC2E4 \uBB38\uC744 \uBC1C\uACAC\uD55C\uB2E4.)\r\n        \r\n                   
    \uB124\uBAA8 : \uC5B4? \uC5EC\uAE30 \uC228\uC73C\uBA74 \uBABB\uCC38\uACA0\uC9C0?\r\n       
    \r\n\r\n(\uB124\uBAA8\uAC00 \uC9C0\uD558\uC2E4\uB85C \uB4E4\uC5B4\uAC00\uB824\uB294
    \uC21C\uAC04 \uCC3D\uACE0\uC9C0\uAE30\uAC00 \uBB38 \uC55E\uC744 \uB9C9\uB294\uB2E4.)\r\n       
    \r\n                        \uC9D1\uC0AC\uC7A5 : \uC8FC\uC778\uB2D8, \uC5EC\uAE34
    \uC548 \uB429\uB2C8\uB2E4.\r\n        \r\n                        \uB124\uBAA8
    : \uC65C\uC694? \uC5EC\uAE30 \uB531 \uC88B\uC740\uB370.\r\n        \r\n                       
    \uC9D1\uC0AC\uC7A5  : \uC5EC\uAE34 \uBB3C\uAC74\uC774 \uB9CE\uC544\uC11C \uB2E4\uCE58\uC2E4
    \uC218 \uC788\uC2B5\uB2C8\uB2E4.\r\n        \r\n                        \uB124\uBAA8
    : \uC800 \uC870\uC2EC\uD560 \uAC74\uB370\uC694.\r\n        \r\n                       
    \uC9D1\uC0AC\uC7A5: \uC548 \uB429\uB2C8\uB2E4. \uB2E4\uB978 \uACF3\uC5D0 \uC228\uC73C\uC2DC\uC9C0\uC694.\r\n       
    \r\n                        \uB124\uBAA8 : \uC5D0\uC774\u2026\r\n        \r\n                       
    \uB124\uBAA8 : \uC54C\uACA0\uC5B4\uC694.\r\n        \r\n                       
    (\uB124\uBAA8\uB294 \uC2DC\uBB34\uB8E9\uD55C \uCC44 \uB3CC\uC544\uAC04\uB2E4.)"
