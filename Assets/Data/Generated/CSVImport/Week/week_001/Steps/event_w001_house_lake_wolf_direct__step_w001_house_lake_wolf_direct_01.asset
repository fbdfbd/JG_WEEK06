  m_Name: event_w001_house_lake_wolf_direct__step_w001_house_lake_wolf_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 \uAD00\uB828 \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uBCF5\uB3C4 \uAD6C\uC11D. \uD558\uB140 \uB458\uC774 \uC791\uC740
    \uBAA9\uC18C\uB9AC\uB85C \uC774\uC57C\uAE30\uD558\uACE0 \uC788\uB2E4.)\r\n       
    \r\n        \uD558\uB1401 : \uD6C4\uBB38 \uCABD \uBB38\uC81C\uB97C \uBE68\uB9AC
    \uD574\uACB0\uD558\uBA74 \uC88B\uACA0\uB294\uB370\u2026\r\n        \r\n       
    \uD558\uB1402 : \uADF8\uB188\uC774 \uC6CC\uB099 \uB0A0\uC314\uC11C \uC7A1\uD788\uC9C8
    \uC54A\uB098\uBD10.\r\n        \r\n        \uB124\uBAA8 : \uD6C4\uBB38\uC5D0
    \uBB50 \uC788\uC5B4?\r\n        \r\n        \uD558\uB1401 : \u2026\u2026\r\n       
    \r\n\r\n\uD558\uB1401 : \uC8FC\uC778\uB2D8, \uD6C4\uBB38 \uCABD\uC5D4 \uB291\uB300\uAC00
    \uB3C8\uB2E4\uB294 \uB9D0\uC774 \uC788\uC5B4\uC694.\r\n        \r\n        \uB124\uBAA8
    : \uB291\uB300?\r\n        \r\n        \uD558\uB1402 : \uB124. \uADF8\uB798\uC11C
    \uB2E4\uB4E4 \uC870\uC2EC\uD558\uB294 \uAC70\uC608\uC694.\r\n        \r\n       
    \uB124\uBAA8 : \uC9C4\uC9DC \uC788\uC5B4?\r\n        \r\n        \uD558\uB1401
    : \uC18C\uBB38\uC774 \uC2EC\uC0C1\uCC2E\uB2F5\uB2C8\uB2E4.\r\n        \r\n       
    \uB124\uBAA8 : \uD5C9\u2026\r\n        \r\n        \uB124\uBAA8 : \uBB34\uC12D\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uADFC\uB370 \uC870\uAE08 \uAD81\uAE08\uD574."
