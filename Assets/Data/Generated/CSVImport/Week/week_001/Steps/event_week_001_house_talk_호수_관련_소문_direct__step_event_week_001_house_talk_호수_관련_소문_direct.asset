  m_Name: "event_week_001_house_talk_\uD638\uC218_\uAD00\uB828_\uC18C\uBB38_direct__step_event_week_001_house_talk_\uD638\uC218_\uAD00\uB828_\uC18C\uBB38_direct"
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218_\uAD00\uB828_\uC18C\uBB38 Direct"
  _bodyText: "house_talk \uD638\uC218_\uAD00\uB828_\uC18C\uBB38 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uD6C4\uBB38 \uCABD\uC5D4 \uB291\uB300\uAC00 \uB3C8\uB2E4\uB294
      \uB9D0\uC774 \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB291\uB300?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uADF8\uB798\uC11C \uB2E4\uB4E4 \uC870\uC2EC\uD558\uB294 \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC \uC788\uC5B4?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC18C\uBB38\uC774 \uC2EC\uC0C1\uCC2E\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5C9\u2026"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB34\uC12D\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADFC\uB370 \uC870\uAE08 \uAD81\uAE08\uD574."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uD6C4\uBB38 \uCABD\uC5D4 \uB291\uB300\uAC00 \uB3C8\uB2E4\uB294
    \uB9D0\uC774 \uC788\uC5B4\uC694."
