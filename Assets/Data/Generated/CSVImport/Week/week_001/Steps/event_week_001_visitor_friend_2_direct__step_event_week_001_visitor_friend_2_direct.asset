  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_visitor_friend_2_direct__step_event_week_001_visitor_friend_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC00\uB9AC\uC544 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor friend_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uBC00\uB9AC\uC544 \uC55E\uC73C\uB85C \uAC04\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB108\uB294 \uC65C \uC548 \uB180\uC544?"
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uC637 \uB354\uB7EC\uC6CC\uC9C0\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5E5? \uB09C \uAD1C\uCC2E\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uB108\uB294 \uADF8\uB798 \uBCF4\uC5EC."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: '?'
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uB108 \uC774\uC0C1\uD574."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: ..?
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC7A0\uAE50 \uB458\uC774 \uB9C8\uC8FC\uBCF4\uB2E4\uAC00, \uBC00\uB9AC\uC544\uAC00
      \uB124\uBAA8 \uC637\uC5D0 \uBB3B\uC740 \uBA3C\uC9C0\uB97C \uD138\uC5B4 \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uC5EC\uAE30 \uBA3C\uC9C0 \uBB3B\uC5C8\uC5B4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026..?"
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uC548 \uD138\uBA74 \uC9C0\uC800\uBD84\uD574 \uBCF4\uC5EC."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uACE0\uB9C8\uC6CC."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uC751."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uBC00\uB9AC\uC544 \uC55E\uC73C\uB85C \uAC04\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
