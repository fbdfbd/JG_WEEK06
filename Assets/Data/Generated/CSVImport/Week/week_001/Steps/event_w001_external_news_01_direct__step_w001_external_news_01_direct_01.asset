  m_Name: event_w001_external_news_01_direct__step_w001_external_news_01_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC18C\uC2DD 1\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uBC14\uAE65\uC5D0\uC11C \uB4E4\uC740 \uC774\uC57C\uAE30\uB97C
    \uC815\uB9AC\uD558\uACE0 \uC788\uB2E4.)\n        \n        \uD558\uB140\uAC00
    \uCD95\uC81C\uB97C \uD64D\uBCF4\uD558\uB294 \uAE00\uC744 \uBC1C\uACAC\uD588\uB2E4.\n       
    \n\n\uB124\uBAA8 :\uADF8\uAC70 \uBB50\uC57C?\n            \n            \uD558\uB140
    : \uB9C8\uC744 \uC911\uC559\uC5D0\uC11C \uCD95\uC81C\uAC00 \uC5F4\uB9B0\uB2E4\uB294
    \uAE00\uC774\uC5D0\uC694, \uC8FC\uC778\uB2D8.\n            \n            \uB124\uBAA8
    : \uCD95\uC81C?\n            \n            \uD558\uB140 : \uB124. \uCC9C\uB3C4
    \uAC78\uACE0, \uAC04\uC2DD\uB3C4 \uD314\uACE0, \uB178\uB798\uB3C4 \uD55C\uB300\uC694.\n           
    \n            \uB124\uBAA8 : \uC6B0\uC640. \uB9DB\uC788\uB294 \uAC83\uB3C4 \uB9CE\uC544?\n           
    \n            \uD558\uB140 : \uB124. \uB2EC\uCF64\uD55C \uAC83\uB3C4 \uB9CE\uB2E4\uACE0
    \uB4E4\uC5C8\uC5B4\uC694.\n            \n            \uB124\uBAA8 : \uB098\uB3C4
    \uAC00 \uBCF4\uACE0 \uC2F6\uB2E4.\n            \n            \uD558\uB140 : \uC815\uB9D0
    \uC88B\uC544\uD558\uC2E4 \uAC83 \uAC19\uB124\uC694, \uC8FC\uC778\uB2D8.\n           
    \n            \uD6C4\uC18D \uD6A8\uACFC : \uCD95\uC81C \uD655\uC778 \uC774\uBCA4\uD2B8
    \uBC1C\uC0DD"
