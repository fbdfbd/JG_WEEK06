MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_excursion_garden_direct__step_event_week_001_excursion_garden_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: garden Direct
  _bodyText: "excursion garden Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD6C4\uBB38\uC740 \uC5F4\uB824 \uC788\uACE0, \uBA40\uCC0D\uC774 \uACBD\uBE44\uAC00
      \uB300\uAE30 \uC911\uC774\uB2E4. \uB124\uBAA8\uB294 \uADF8\uAC78 \uBAA8\uB978
      \uCC44 \uBC16\uC73C\uB85C \uB098\uAC04\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uBE44 \uC5B4\uB514 \uAC14\uC9C0?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC870\uAE08 \uB354 \uAC77\uC790 \uC800\uD0DD \uB4A4
      \uD638\uC218\uAC00 \uBCF4\uC778\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640\u2026 \uC5EC\uAE30 \uC9C4\uC9DC \uD06C\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD638\uC218\uB294 \uD587\uBE5B\uC744 \uBC1B\uC544 \uBC18\uC9DD\uC774\uACE0,
      \uAC08\uB300\uAC00 \uBC14\uB78C\uC5D0 \uD754\uB4E4\uB9B0\uB2E4. \uB098\uBE44\uB294
      \uB193\uCCE4\uC9C0\uB9CC \uBB3C\uAC00\uC640 \uAC08\uB300\uBC2D\uC774 \uC2E0\uAE30\uD574
      \uD55C\uCC38 \uAD6C\uACBD\uD558\uAC8C \uB41C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB3C\uC774 \uBC18\uC9DD\uBC18\uC9DD\uD574."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBA40\uB9AC\uC11C \uC9C0\uCF1C\uBCF4\uB358 \uACBD\uBE44\uB300\uC7A5\uC774
      \uB2E4\uAC00\uC628\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC774\uC81C \uB3CC\uC544\uAC00\uC2DC\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC8C\uC368\uC694?"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC624\uB798 \uACC4\uC2DC\uBA74 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uC54C\uACA0\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uC74C\uC5D0 \uB610 \uC624\uACE0 \uC2F6\uC740\uB370."
  _nemoLine: "(\uD6C4\uBB38\uC740 \uC5F4\uB824 \uC788\uACE0, \uBA40\uCC0D\uC774 \uACBD\uBE44\uAC00
    \uB300\uAE30 \uC911\uC774\uB2E4. \uB124\uBAA8\uB294 \uADF8\uAC78 \uBAA8\uB978
    \uCC44 \uBC16\uC73C\uB85C \uB098\uAC04\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
