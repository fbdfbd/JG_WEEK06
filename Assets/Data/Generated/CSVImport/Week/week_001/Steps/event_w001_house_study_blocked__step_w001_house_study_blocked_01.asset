  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w001_house_study_blocked__step_w001_house_study_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC \uAD00\uB828 \uC18C\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uC11C\uC7AC \uC55E \uBCF5\uB3C4. \uD558\uB140 \uB458\uC774 \uBC1C\uC18C\uB9AC\uB97C
    \uC8FD\uC774\uBA70 \uC9C0\uB098\uAC00\uACE0 \uC788\uB2E4.)\r\n        \r\n       
    \uD558\uB1401 : \uC11C\uC7AC \uC55E\uB9CC \uC624\uBA74 \uC65C \uC774\uB807\uAC8C
    \uC228\uC774 \uC791\uC544\uC9C0\uB294\uC9C0 \uBAB0\uB77C.\r\n        \r\n       
    \uD558\uB1402 : \uADF8\uB7EC\uAC8C. \uB098 \uC544\uAE4C \uC7AC\uCC44\uAE30 \uB098\uC62C
    \uBED4\uD588\uB294\uB370 \uC0BC\uCF30\uC796\uC544.\r\n        \r\n        \uB124\uBAA8
    : \uC7AC\uCC44\uAE30\uB97C \uC5B4\uB5BB\uAC8C \uC0BC\uCF1C?\r\n        \r\n\r\n\uD558\uB1401
    : \uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.\r\n       
    \r\n        \uB124\uBAA8 : \uBC29\uAE08 \uC774\uC0C1\uD55C \uB9D0 \uD588\uC796\uC544.\r\n       
    \r\n        \uD558\uB1402 : \uADF8\uB0E5 \uC800\uD76C\uB07C\uB9AC \uD55C \uC598\uAE30\uC608\uC694.\r\n       
    \r\n        \uB124\uBAA8 : \uC65C \uC5EC\uAE30\uB9CC \uC624\uBA74 \uB2E4\uB4E4
    \uC870\uC6A9\uD574?\r\n        \r\n        \uD558\uB1401 : \uC74C\u2026 \uADF8\uB0E5
    \uBCF5\uB3C4\uB2C8\uAE4C\uC694.\r\n        \r\n        \uB124\uBAA8 : \uB2E4\uB978
    \uBCF5\uB3C4\uB294 \uC548 \uADF8\uB7F0\uB370.\r\n        \r\n        \uD558\uB1402
    : \uC5EC\uAE34 \uADF8\uB0E5\u2026 \uC880 \uC870\uC6A9\uD55C \uBCF5\uB3C4\uC608\uC694,
    \uC8FC\uC778\uB2D8.\r\n        \r\n        \uB124\uBAA8 : \uD750\uC751. \uC774\uC0C1\uD574."
