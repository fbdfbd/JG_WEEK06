  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: "event_week_001_house_talk_\uC0AC\uCD0C1_\uAD00\uB828_\uC18C\uBB38_blocked__step_event_week_001_house_talk_\uC0AC\uCD0C1_\uAD00\uB828_\uC18C\uBB38_blocked"
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE74\uC774\uC548 \uAD00\uB828 \uC18C\uBB38 \uD1B5\uC81C"
  _bodyText: "house_talk \uC0AC\uCD0C1_\uAD00\uB828_\uC18C\uBB38 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uBCC4\uAC70 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC29\uAE08 \uB204\uAD6C \uC628\uB2E4\uACE0 \uD588\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uADF8\uB0E5 \uC190\uB2D8 \uD55C \uBD84 \uC624\uC2E0\uB2E4\uB294 \uC598\uAE30\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB204\uAD6C \uC190\uB2D8?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uBC31\uC791\uB2D8 \uC190\uB2D8\uC774\uC2ED\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4\uB5A4 \uC0AC\uB78C\uC778\uB370?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uC5B4\uB978\uC774\uC5D0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uC544\uB294\uB370."
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uC740 \uB098\uC911\uC5D0 \uC544\uC2DC\uAC8C \uB420
      \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774. \uB9E8\uB0A0 \uB098\uC911\uC774\uB798."
  _nemoLine: "\uBCC4\uAC70 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
