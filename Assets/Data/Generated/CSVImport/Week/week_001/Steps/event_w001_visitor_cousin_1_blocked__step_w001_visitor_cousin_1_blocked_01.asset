  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w001_visitor_cousin_1_blocked__step_w001_visitor_cousin_1_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 1\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uC0AC\uC6A9\uC778\uB4E4\uC774 \uC751\uC811\uC2E4\uC744 \uBD84\uC8FC\uD788
    \uC815\uB9AC\uD558\uACE0 \uC788\uB2E4.)\r\n        \r\n                    \uB124\uBAA8
    : \uC5B4? \uC624\uB298 \uC190\uB2D8 \uC640\uC694?\r\n        \r\n                   
    \uD558\uB140 : \uC608, \uC8FC\uC778\uB2D8. \uBC31\uC791\uB2D8\uC758 \uC0AC\uCD0C
    \uC5B4\uB974\uC2E0\uAED8\uC11C \uC624\uC2ED\uB2C8\uB2E4.\r\n        \r\n                   
    \uB124\uBAA8 : \uC0AC\uCD0C\uC774\uBA74 \uAC00\uC871\uC774\uC9C0?\r\n       
    \r\n                    \uD558\uB140 : \uADF8\uB807\uC2B5\uB2C8\uB2E4.\r\n       
    \r\n                    \uC624\uB298 \uC624\uB294 \uC190\uB2D8\uC740 \uB298 \uC608\uC758
    \uBC14\uB974\uACE0 \uC0C1\uB0E5\uD558\uB2E4\uACE0 \uB4E4\uC5C8\uC9C0\uB9CC, \uC774\uC0C1\uD558\uAC8C
    \uC9D1\uC0AC\uC7A5 \uD45C\uC815\uC740 \uBCC4\uB85C \uC88B\uC9C0 \uC54A\uC558\uB358
    \uAC83 \uAC19\uAE30\uB3C4 \uD558\uB2E4.\r\n        \r\n\r\n(\uB124\uBAA8\uAC00
    \uC751\uC811\uC2E4 \uCABD\uC73C\uB85C \uAC00\uB824 \uD558\uC790 \uC9D1\uC0AC\uC7A5\uC774
    \uC55E\uC744 \uB9C9\uB294\uB2E4.)\r\n        \r\n                        \uC9D1\uC0AC\uC7A5
    : \uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC751\uC811\uC2E4\uC5D0 \uAC00\uC2DC\uBA74
    \uC548 \uB429\uB2C8\uB2E4.\r\n        \r\n                        \uB124\uBAA8
    : \uC65C\uC694?\r\n        \r\n                        \uC9D1\uC0AC\uC7A5 : \uC5B4\uB978\uB4E4\uB07C\uB9AC
    \uD560 \uC774\uC57C\uAE30\uAC00 \uC788\uC2B5\uB2C8\uB2E4.\r\n        \r\n                       
    \uB124\uBAA8 : \uB098\uB3C4 \uAC00\uC871\uC778\uB370?\r\n        \r\n                       
    \uC9D1\uC0AC\uC7A5 : \uC624\uB298\uC740 \uC548 \uB429\uB2C8\uB2E4.\r\n       
    \r\n                        \uB124\uBAA8 : \uC5D0\uC774\u2026\r\n        \r\n                       
    \uB124\uBAA8 : \uC7A0\uAE50\uB9CC \uBCF4\uBA74 \uC548 \uB3FC\uC694?\r\n       
    \r\n                        \uC9D1\uC0AC\uC7A5 : \uC548 \uB429\uB2C8\uB2E4.\r\n       
    \r\n                        \uB124\uBAA8 : \u2026\u2026\uC54C\uACA0\uC5B4\uC694.\r\n       
    \r\n                        (\uB124\uBAA8\uB294 \uC751\uC811\uC2E4 \uBB38 \uCABD\uC744
    \uD790\uB054 \uBCF4\uACE0 \uB3CC\uC544\uAC04\uB2E4.)"
