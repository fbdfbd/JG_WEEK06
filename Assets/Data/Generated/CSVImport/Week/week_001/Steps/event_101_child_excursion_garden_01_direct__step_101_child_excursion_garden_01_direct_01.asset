  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_101_child_excursion_garden_01_direct__step_101_child_excursion_garden_01_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 1\uCC28 - \uD5C8\uB77D"
  _bodyText: "\uC5F4\uB9B0 \uD6C4\uBB38\uACFC \uBA40\uCC0D\uC774 \uC120 \uACBD\uBE44\uB97C
    \uB4A4\uB85C\uD558\uACE0 \uB124\uBAA8\uAC00 \uCC98\uC74C\uC73C\uB85C \uD638\uC218
    \uCABD \uD48D\uACBD\uC744 \uBCF8\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC640, \uB098\uBE44\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4? \uC800\uAE30\uB85C \uAC14\uB124. \uC7A1\uACE0 \uC2F6\uC740\uB370\u2026"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uBE44 \uC5B4\uB514 \uAC14\uC9C0?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640\u2026 \uC5EC\uAE30 \uC9C4\uC9DC \uD06C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB3C\uC774 \uBC18\uC9DD\uBC18\uC9DD\uD574."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC774\uC81C \uB3CC\uC544\uAC00\uC2DC\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC8C\uC368\uC694?"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC624\uB798 \uACC4\uC2DC\uBA74 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uC54C\uACA0\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uC74C\uC5D0 \uB610 \uC624\uACE0 \uC2F6\uC740\uB370."
  _nemoLine: "\uC640, \uB098\uBE44\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
