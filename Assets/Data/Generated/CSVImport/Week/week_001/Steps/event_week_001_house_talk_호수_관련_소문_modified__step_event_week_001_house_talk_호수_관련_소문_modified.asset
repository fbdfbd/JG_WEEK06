  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: "event_week_001_house_talk_\uD638\uC218_\uAD00\uB828_\uC18C\uBB38_modified__step_event_week_001_house_talk_\uD638\uC218_\uAD00\uB828_\uC18C\uBB38_modified"
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 \uAD00\uB828 \uC18C\uBB38 \uC218\uC815"
  _bodyText: "house_talk \uD638\uC218_\uAD00\uB828_\uC18C\uBB38 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uD6C4\uBB38 \uCABD\uC5D4 \uACF0\uC774 \uB098\uC628\uB2E4\uB294
      \uB9D0\uC774 \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uACF0?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uADF8\uB798\uC11C \uB2E4\uB4E4 \uAC00\uAE4C\uC774 \uC548 \uAC00\uB294
      \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC \uD070 \uACF0?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC544\uC8FC \uAC00\uAE4C\uC774\uC11C \uBCF8 \uC0AC\uB78C\uC740 \uC5C6\uC9C0\uB9CC,
      \uB2E4\uB4E4 \uC870\uC2EC\uD558\uB798\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5C9\u2026"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uACF0\uC740 \uB354 \uBB34\uC11C\uC6B4\uB370."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uADF8\uB7EC\uB2C8\uAE4C \uD6C4\uBB38 \uCABD\uC740 \uC548 \uAC00\uC2DC\uB294
      \uAC8C \uC88B\uC544\uC694, \uC8FC\uC778\uB2D8."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uD6C4\uBB38 \uCABD\uC5D4 \uACF0\uC774 \uB098\uC628\uB2E4\uB294
    \uB9D0\uC774 \uC788\uC5B4\uC694."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
