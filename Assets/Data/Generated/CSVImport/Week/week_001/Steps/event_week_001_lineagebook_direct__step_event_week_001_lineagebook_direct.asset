  _titleOverride: "\uAC00\uACC4\uB3C4 \uAE30\uB85D\uC744 \uADF8\uB300\uB85C \uC77D\uC5B4
    \uC900\uB2E4"
  _bodyText: "\uAC00\uACC4\uB3C4 \uAD50\uC7AC \uAD50\uC7AC Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uAC00\uBB38\uC758 \uAE30\uB85D\uC774 \uC801\uD78C \uBB38\uC7A5\uC744
      \uC6D0\uBB38\uC5D0 \uAC00\uAE5D\uAC8C \uB610\uBC15\uB610\uBC15 \uC77D\uC5B4
      \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uB984\uC774 \uAE38\uB2E4. \uB2E4 \uAC00\uC871\uC774\uC5D0\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uD608\uC5F0\uACFC \uD638\uCE6D\uC744 \uB04A\uC5B4 \uC124\uBA85\uD558\uBA70
      \uAE30\uB85D\uC744 \uB530\uB77C\uAC00\uAC8C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5F7\uAC08\uB9AC\uC9C0\uB9CC \uC870\uAE08 \uC54C \uAC83 \uAC19\uC544."
  _nemoLine: "(\uAC00\uBB38\uC758 \uAE30\uB85D\uC774 \uC801\uD78C \uBB38\uC7A5\uC744
    \uC6D0\uBB38\uC5D0 \uAC00\uAE5D\uAC8C \uB610\uBC15\uB610\uBC15 \uC77D\uC5B4 \uC900\uB2E4.)"
