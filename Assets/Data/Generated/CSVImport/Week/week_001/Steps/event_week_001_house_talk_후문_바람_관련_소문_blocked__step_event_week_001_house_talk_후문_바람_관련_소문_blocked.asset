  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: "event_week_001_house_talk_\uD6C4\uBB38_\uBC14\uB78C_\uAD00\uB828_\uC18C\uBB38_blocked__step_event_week_001_house_talk_\uD6C4\uBB38_\uBC14\uB78C_\uAD00\uB828_\uC18C\uBB38_blocked"
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD6C4\uBB38 \uBC14\uB78C \uAD00\uB828 \uC18C\uBB38 \uD1B5\uC81C"
  _bodyText: "house_talk \uD6C4\uBB38_\uBC14\uB78C_\uAD00\uB828_\uC18C\uBB38 Blocked
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC29\uAE08 \uC6B0\uC0B0 \uB4A4\uC9D1\uD78C\uB314\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uADF8\uB0E5 \uC624\uB798\uB41C \uC6B0\uC0B0\uC774\uC5C8\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC14\uB78C \uB54C\uBB38 \uC544\uB2C8\uC57C?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC544\uB2C8\uC5D0\uC694. \uC800\uD76C\uAC00 \uC798\uBABB \uD3B8 \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uC6B0\uC0B0\uC774 \uBA4D\uCCAD\uD55C \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\u2026\uADF8\uB7F4 \uC218\uB3C4 \uC788\uACA0\uB124\uC694, \uC8FC\uC778\uB2D8."
  _nemoLine: "\uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
