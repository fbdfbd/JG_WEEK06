  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_excursion_basement_direct__step_event_week_001_excursion_basement_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 \uD5C8\uAC00"
  _bodyText: "excursion basement Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC9C0\uD558\uC2E4 \uBB38 \uC55E\uC5D0 \uC11C \uC788\uC790
      \uCC3D\uACE0\uC9C0\uAE30\uAC00 \uB2E4\uAC00\uC628\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC548\uCABD\uC740 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uC5EC\uAE30 \uC870\uAE08\uB9CC\uC740\uC694?"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC785\uAD6C \uCABD\uAE4C\uC9C0\uB9CC \uAC00\uB2A5\uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC\uC694?"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC608. \uC774 \uC0C1\uC790 \uB4A4\uC5D0 \uC228\uC73C\uC2DC\uBA74 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC640, \uC5EC\uAE30 \uC88B\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uC785\uAD6C \uCABD \uC0C1\uC790 \uB4A4\uC5D0 \uC3D9
      \uC228\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5E4\uD5E4, \uC5EC\uAE30\uBA74 \uBABB \uCC3E\uACA0\uB2E4."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC9C0\uD558\uC2E4 \uBB38 \uC55E\uC5D0 \uC11C \uC788\uC790
    \uCC3D\uACE0\uC9C0\uAE30\uAC00 \uB2E4\uAC00\uC628\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
