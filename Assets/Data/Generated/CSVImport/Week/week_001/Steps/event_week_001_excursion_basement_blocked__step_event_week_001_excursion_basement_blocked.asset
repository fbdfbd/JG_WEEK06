  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_excursion_basement_blocked__step_event_week_001_excursion_basement_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: basement Blocked
  _bodyText: "excursion basement Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC9C0\uD558\uC2E4\uB85C \uB4E4\uC5B4\uAC00\uB824\uB294
      \uC21C\uAC04 \uCC3D\uACE0\uC9C0\uAE30\uAC00 \uBB38 \uC55E\uC744 \uB9C9\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC5EC\uAE34 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694? \uC5EC\uAE30 \uB531 \uC88B\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC5EC\uAE34 \uBB3C\uAC74\uC774 \uB9CE\uC544\uC11C \uB2E4\uCE58\uC2E4
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC800 \uC870\uC2EC\uD560 \uAC74\uB370\uC694."
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC548 \uB429\uB2C8\uB2E4. \uB2E4\uB978 \uACF3\uC5D0 \uC228\uC73C\uC2DC\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774\u2026"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC54C\uACA0\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uC2DC\uBB34\uB8E9\uD55C \uCC44 \uB3CC\uC544\uAC04\uB2E4.)"
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC9C0\uD558\uC2E4\uB85C \uB4E4\uC5B4\uAC00\uB824\uB294
    \uC21C\uAC04 \uCC3D\uACE0\uC9C0\uAE30\uAC00 \uBB38 \uC55E\uC744 \uB9C9\uB294\uB2E4.)"
