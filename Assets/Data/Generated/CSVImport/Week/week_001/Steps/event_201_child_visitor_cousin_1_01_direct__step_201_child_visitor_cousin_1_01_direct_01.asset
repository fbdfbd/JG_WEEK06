  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_201_child_visitor_cousin_1_01_direct__step_201_child_visitor_cousin_1_01_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 \uCCAB \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "\uC9D1\uC0AC\uC7A5\uC774 \uC751\uC811\uC2E4\uB85C \uB370\uB824\uAC00\uACE0,
    \uC0AC\uCD0C1\uC740 \uC0AC\uD0D5 \uC0C1\uC790\uB97C \uB0B4\uBC00\uBA70 \uC0C1\uB0E5\uD558\uAC8C
    \uC778\uC0AC\uD55C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uC548\uB155? \uB124\uAC00 \uB124\uBAA8\uAD6C\uB098."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548\uB155\uD558\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uCC98\uC74C \uBD59\uC2B5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5E4\uD5E4."
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uC774\uB9AC \uC640 \uBCF4\uB834. \uC791\uC740 \uC120\uBB3C\uC744 \uC900\uBE44\uD588\uB2E8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC120\uBB3C?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640!"
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uB9C8\uC74C\uC5D0 \uB4DC\uB2C8?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB124! \uAC10\uC0AC\uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uC55E\uC73C\uB85C\uB3C4 \uC885\uC885 \uBCF4\uC790\uAFB8\uB098."
  _nemoLine: "\uC548\uB155? \uB124\uAC00 \uB124\uBAA8\uAD6C\uB098."
  _useCustomVisualState: 0
  _visualState: 0
