  m_Name: event_w001_house_lake_wolf_modified__step_w001_house_lake_wolf_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 \uAD00\uB828 \uC18C\uBB38 - \uC218\uC815"
  _bodyText: "(\uBCF5\uB3C4 \uAD6C\uC11D. \uD558\uB140 \uB458\uC774 \uC791\uC740
    \uBAA9\uC18C\uB9AC\uB85C \uC774\uC57C\uAE30\uD558\uACE0 \uC788\uB2E4.)\n       
    \n        \uD558\uB1401 : \uD6C4\uBB38 \uCABD \uBB38\uC81C\uB97C \uBE68\uB9AC
    \uD574\uACB0\uD558\uBA74 \uC88B\uACA0\uB294\uB370\u2026\n        \n        \uD558\uB1402
    : \uADF8\uB188\uC774 \uC6CC\uB099 \uB0A0\uC314\uC11C \uC7A1\uD788\uC9C8 \uC54A\uB098\uBD10.\n       
    \n        \uB124\uBAA8 : \uD6C4\uBB38\uC5D0 \uBB50 \uC788\uC5B4?\n        \n       
    \uD558\uB1401 : \u2026\u2026\n        \n\n\uD558\uB1401 : \uC8FC\uC778\uB2D8,
    \uD6C4\uBB38 \uCABD\uC5D4 \uACF0\uC774 \uB098\uC628\uB2E4\uB294 \uB9D0\uC774
    \uC788\uC5B4\uC694.\n        \n        \uB124\uBAA8 : \uACF0?\n        \n       
    \uD558\uB1402 : \uB124. \uADF8\uB798\uC11C \uB2E4\uB4E4 \uAC00\uAE4C\uC774 \uC548
    \uAC00\uB294 \uAC70\uC608\uC694.\n        \n        \uB124\uBAA8 : \uC9C4\uC9DC
    \uD070 \uACF0?\n        \n        \uD558\uB1401 : \uC544\uC8FC \uAC00\uAE4C\uC774\uC11C
    \uBCF8 \uC0AC\uB78C\uC740 \uC5C6\uC9C0\uB9CC, \uB2E4\uB4E4 \uC870\uC2EC\uD558\uB798\uC694.\n       
    \n        \uB124\uBAA8 : \uD5C9\u2026\n        \n        \uB124\uBAA8 : \uACF0\uC740
    \uB354 \uBB34\uC11C\uC6B4\uB370.\n        \n        \uD558\uB1402 : \uADF8\uB7EC\uB2C8\uAE4C
    \uD6C4\uBB38 \uCABD\uC740 \uC548 \uAC00\uC2DC\uB294 \uAC8C \uC88B\uC544\uC694,
    \uC8FC\uC778\uB2D8."
