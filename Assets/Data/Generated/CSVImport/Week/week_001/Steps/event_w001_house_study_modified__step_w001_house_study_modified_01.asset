  m_Name: event_w001_house_study_modified__step_w001_house_study_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC \uAD00\uB828 \uC18C\uBB38 - \uC218\uC815"
  _bodyText: "(\uC11C\uC7AC \uC55E \uBCF5\uB3C4. \uD558\uB140 \uB458\uC774 \uBC1C\uC18C\uB9AC\uB97C
    \uC8FD\uC774\uBA70 \uC9C0\uB098\uAC00\uACE0 \uC788\uB2E4.)\n        \n       
    \uD558\uB1401 : \uC11C\uC7AC \uC55E\uB9CC \uC624\uBA74 \uC65C \uC774\uB807\uAC8C
    \uC228\uC774 \uC791\uC544\uC9C0\uB294\uC9C0 \uBAB0\uB77C.\n        \n       
    \uD558\uB1402 : \uADF8\uB7EC\uAC8C. \uB098 \uC544\uAE4C \uC7AC\uCC44\uAE30 \uB098\uC62C
    \uBED4\uD588\uB294\uB370 \uC0BC\uCF30\uC796\uC544.\n        \n        \uB124\uBAA8
    : \uC7AC\uCC44\uAE30\uB97C \uC5B4\uB5BB\uAC8C \uC0BC\uCF1C?\n        \n\n\uD558\uB1401
    : \uC11C\uC7AC \uC55E \uBC14\uB2E5\uC740 \uC18C\uB9AC\uAC00 \uD06C\uAC8C \uC6B8\uB824\uC11C
    \uADF8\uB798\uC694, \uC8FC\uC778\uB2D8.\n        \n        \uB124\uBAA8 : \uBC14\uB2E5\uC774?\n       
    \n        \uD558\uB1402 : \uB124. \uC5EC\uAE30\uC11C \uC7AC\uCC44\uAE30\uD558\uBA74
    \uC548\uCABD\uAE4C\uC9C0 \uB2E4 \uB4E4\uB9B0\uB2F5\uB2C8\uB2E4.\n        \n       
    \uB124\uBAA8 : \uC9C4\uC9DC?\n        \n        \uD558\uB1401 : \uC608. \uBC1C\uC18C\uB9AC\uB3C4
    \uD06C\uAC8C \uB098\uACE0\uC694.\n        \n        \uB124\uBAA8 : \uADF8\uB798\uC11C
    \uB2E4\uB4E4 \uC870\uC6A9\uD55C \uAC70\uAD6C\uB098.\n        \n        \uD558\uB1402
    : \uB124. \uAD1C\uD788 \uC2DC\uB044\uB7FD\uAC8C \uD588\uB2E4\uAC00 \uBC31\uC791\uB2D8
    \uB180\uB77C\uC2DC\uB2C8\uAE4C\uC694.\n        \n        \uB124\uBAA8 : \uD750\uC751.\n       
    \n        \uB124\uBAA8 : \uC5EC\uAE30 \uBC14\uB2E5\uC740 \uC774\uC0C1\uD558\uB124."
