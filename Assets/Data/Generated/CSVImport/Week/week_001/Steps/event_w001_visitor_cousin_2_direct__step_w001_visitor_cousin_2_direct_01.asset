  m_Name: event_w001_visitor_cousin_2_direct__step_w001_visitor_cousin_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 1\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uC751\uC811\uC2E4 \uD55C\uCABD. \uC0AC\uCD0C1 \uC606\uC5D0 \uB610\uB798
    \uC544\uC774 \uD558\uB098\uAC00 \uAC00\uB9CC\uD788 \uC11C \uC788\uB2E4.)\n       
    \n                    \uB124\uBAA8 : \uC5B4? \uC800 \uC560\uB294 \uB204\uAD6C\uC57C?\n       
    \n                    \uD558\uB140 : \uC0AC\uCD0C \uC5B4\uB974\uC2E0\uACFC \uD568\uAED8
    \uC628 \uC8FC\uC778\uB2D8\uC774\uC2ED\uB2C8\uB2E4.\n        \n                   
    \uB124\uBAA8 : \uB098\uB791 \uBE44\uC2B7\uD55C\uB370.\n        \n                   
    \uC0AC\uCD0C2\uB294 \uB0AF\uC744 \uB9CE\uC774 \uAC00\uB9AC\uACE0, \uBA3C\uC800
    \uB9D0\uC744 \uAC78\uC9C0 \uC54A\uB294 \uC544\uC774\uB77C\uACE0 \uB4E4\uC740
    \uC801\uC774 \uC788\uB2E4.\n        \n\n(\uB124\uBAA8\uAC00 \uC0AC\uCD0C2 \uCABD\uC73C\uB85C
    \uC885\uC885 \uAC78\uC5B4\uAC04\uB2E4. \uC0AC\uCD0C2\uB294 \uC0AC\uCD0C1 \uB4A4\uC5D0
    \uBC18\uCBE4 \uC228\uB294\uB2E4.)\n        \n                        \uB124\uBAA8
    : \uC548\uB155.\n        \n                        \uC0AC\uCD0C2 : \u2026\u2026\uC548\uB155.\n       
    \n                        \uB124\uBAA8 : \uB108 \uC774\uB984 \uBB50\uC57C?\n       
    \n                        \uC0AC\uCD0C2 : \u2026\u2026\n        \n                       
    \uB124\uBAA8 : \uC65C \uB300\uB2F5 \uC548 \uD574?\n        \n                       
    \uC0AC\uCD0C2 : \uBBF8, \uBBF8\uC548.\n        \n                        \uC0AC\uCD0C2
    : \uB098\u2026 \u25CB\u25CB\uC774\uC57C.\n        \n                        \uB124\uBAA8
    : \uB09C \uB124\uBAA8\uC57C.\n        \n                        \uC0AC\uCD0C2
    : \uC751.\n        \n                        \uB124\uBAA8 : \uB108\uB3C4 \uC0AC\uD0D5
    \uC88B\uC544\uD574?\n        \n                        \uC0AC\uCD0C2 : \u2026\u2026\uC88B\uC544\uD574.\n       
    \n                        \uB124\uBAA8 : \uB098\uB3C4 \uC88B\uC544\uD574.\n       
    \n                        \uC0AC\uCD0C2 : \u2026\u2026\uC751.\n        \n                       
    (\uB458 \uC0AC\uC774\uC5D0 \uC7A0\uAE50 \uC5B4\uC0C9\uD55C \uCE68\uBB35\uC774
    \uD750\uB974\uC9C0\uB9CC, \uC0AC\uCD0C2\uB294 \uB3C4\uB9DD\uAC00\uC9C4 \uC54A\uB294\uB2E4.)\n       
    \n                        \uB124\uBAA8 : \uB2E4\uC74C\uC5D4 \uAC19\uC774 \uB180\uB798?\n       
    \n                        \uC0AC\uCD0C2 : \u2026\u2026\uC751. \uC544\uB9C8\uB3C4."
