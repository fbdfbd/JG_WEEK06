  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_external_w001_direct_2__step_event_week_001_external_w001_direct_2
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD3B8\uC9C0\uC9C0\uC5F0 \uC815\uBCF4 \uD5C8\uAC00"
  _bodyText: "external w001 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uBB50\uC57C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC6B0\uD3B8\uC774 \uB2A6\uC5B4\uC9C4\uB2E4\uB294 \uC548\uB0B4\uBB38\uC774\uC5D0\uC694,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C \uB2A6\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uBE44\uAC00 \uB9CE\uC774 \uC640\uC11C \uAE38\uC774 \uC9C8\uC5B4\uC84C\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB9C8\uCC28\uAC00 \uBABB \uC640?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uBC14\uD034\uAC00 \uBE60\uC9C0\uAE30\uB3C4 \uD558\uACE0, \uCC9C\uCC9C\uD788
      \uC640\uC57C \uD55C\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD3B8\uC9C0\uB3C4 \uC816\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8\uB798\uC11C \uC798 \uC2F8\uC11C \uC628\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBA3C \uB370\uC11C\uB3C4 \uC5EC\uAE30\uAE4C\uC9C0 \uC624\uB294\uAD6C\uB098."
  _nemoLine: "\uADF8\uAC74 \uBB50\uC57C?"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
