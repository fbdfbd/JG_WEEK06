  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: "event_week_001_house_talk_\uD6C4\uBB38_\uBC14\uB78C_\uAD00\uB828_\uC18C\uBB38_direct__step_event_week_001_house_talk_\uD6C4\uBB38_\uBC14\uB78C_\uAD00\uB828_\uC18C\uBB38_direct"
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD6C4\uBB38 \uBC14\uB78C \uAD00\uB828 \uC18C\uBB38 \uD5C8\uAC00"
  _bodyText: "house_talk \uD6C4\uBB38_\uBC14\uB78C_\uAD00\uB828_\uC18C\uBB38 Direct
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uB124, \uC8FC\uC778\uB2D8. \uD6C4\uBB38 \uCABD\uC740 \uBC14\uB78C\uC774
      \uC815\uB9D0 \uC149\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5C4\uCCAD \uC138?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uC6B0\uC0B0\uB3C4 \uD655 \uB4A4\uC9D1\uD788\uACE0, \uB9AC\uBCF8\uB3C4
      \uB2E4 \uB0A0\uC544\uAC00\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5C9. \uADF8\uB7FC \uBA38\uB9AC\uB3C4 \uB2E4 \uB0A0\uC544\uAC00?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uD6C4\uD6C4, \uC798 \uBB36\uC9C0 \uC54A\uC73C\uBA74 \uADF8\uB7F4\uC9C0\uB3C4
      \uBAA8\uB974\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uB098\uB3C4 \uBCF4\uACE0 \uC2F6\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uAC00\uAE4C\uC774 \uAC00\uBA74 \uC637\uC790\uB77D\uB3C4 \uC815\uC2E0\uC5C6\uC5B4\uC9C8
      \uAC70\uC608\uC694, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC880 \uC7AC\uBC0C\uACA0\uB2E4."
  _nemoLine: "\uB124, \uC8FC\uC778\uB2D8. \uD6C4\uBB38 \uCABD\uC740 \uBC14\uB78C\uC774
    \uC815\uB9D0 \uC149\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
