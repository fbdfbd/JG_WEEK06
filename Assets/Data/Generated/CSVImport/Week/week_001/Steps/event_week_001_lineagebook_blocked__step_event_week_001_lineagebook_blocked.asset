  _titleOverride: "\uAC00\uACC4\uB3C4 \uC7A5\uC744 \uB118\uAE34\uB2E4"
  _bodyText: "\uAC00\uACC4\uB3C4 \uAD50\uC7AC \uAD50\uC7AC Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uAC00\uACC4\uB3C4 \uAD50\uC7AC\uC758 \uD574\uB2F9 \uC7A5\uC744 \uB118\uAE30\uACE0,
      \uC624\uB298\uC740 \uB2E4\uB978 \uAE30\uB85D\uBD80\uD130 \uBCF4\uC5EC \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C \uC774\uAC74 \uC548 \uC77D\uC5B4\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uC9C0\uAE08\uC740 \uAD73\uC774 \uBD99\uC7A1\uC9C0 \uC54A\uACE0 \uB35C
      \uBB34\uAC70\uC6B4 \uBD80\uBD84\uC73C\uB85C \uB118\uC5B4\uAC04\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB098\uC911\uC5D0 \uB2E4\uC2DC \uBD10\uC694."
  _nemoLine: "(\uAC00\uACC4\uB3C4 \uAD50\uC7AC\uC758 \uD574\uB2F9 \uC7A5\uC744 \uB118\uAE30\uACE0,
    \uC624\uB298\uC740 \uB2E4\uB978 \uAE30\uB85D\uBD80\uD130 \uBCF4\uC5EC \uC900\uB2E4.)"
