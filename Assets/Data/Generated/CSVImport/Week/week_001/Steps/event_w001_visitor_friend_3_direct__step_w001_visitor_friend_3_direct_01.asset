  m_Name: event_w001_visitor_friend_3_direct__step_w001_visitor_friend_3_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 1\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uBCF5\uB3C4 \uB05D. \uB610\uB798 \uC544\uC774 \uD558\uB098\uAC00
    \uCC3D\uD2C0\uC5D0 \uC5BC\uAD74\uC744 \uBC14\uC9DD \uBD99\uC774\uACE0 \uBC16\uC744
    \uBCF4\uACE0 \uC788\uB2E4.)\r\n        \r\n                    \uB124\uBAA8 :
    \uC5B4? \uC548\uB155? \uB10C \uB204\uAD6C\uC57C?\r\n        \r\n                   
    \uCE5C\uAD6C3 : \uC800 \uAD6C\uB984 \uBD10. \uBE75 \uAC19\uC544.\r\n        \r\n                   
    \uB124\uBAA8 : \uBE75?\r\n        \r\n                    \uCE5C\uAD6C3 : \uC751.
    \uB72F\uC5B4 \uBA39\uACE0 \uC2F6\uC5B4.\r\n        \r\n                    \uB124\uBAA8
    :  \uB108\uB3C4? \uB098\uB3C4 \uADF8\uB7F0 \uC0DD\uAC01 \uB4E0\uC801 \uC788\uC5B4\r\n       
    \r\n                    \uC800 \uC544\uC774\uB294 \uCC98\uC74C \uBCF4\uB294 \uC0AC\uB78C\uD558\uACE0\uB3C4
    \uAE08\uBC29 \uB9D0\uC744 \uC11E\uACE0, \uAC00\uB054 \uC5C9\uB6B1\uD55C \uC18C\uB9AC\uB97C
    \uD55C\uB2E4\uACE0 \uB4E4\uC740 \uC801\uC774 \uC788\uB2E4.\r\n        \r\n\r\n(\uD558\uB140\uAC00
    \uD55C\uAC78\uC74C \uBB3C\uB7EC\uB09C\uB2E4.)\r\n        \r\n                       
    \uCE5C\uAD6C3 : \uC800\uAE30 \uB098\uBB34\uB294 \uBE0C\uB85C\uCF5C\uB9AC \uAC19\uC544.\r\n       
    \r\n                        \uB124\uBAA8 : \uC548 \uB2EE\uC558\uC5B4.\r\n       
    \r\n                        \uCE5C\uAD6C3 : \uB2EE\uC558\uC5B4.\r\n        \r\n                       
    \uB124\uBAA8 : \uC548 \uB2EE\uC558\uC5B4!\r\n        \r\n                       
    \uCE5C\uAD6C3 : \uADF8\uB7FC \uAC00\uAE4C\uC774 \uAC00\uC11C \uB2E4\uC2DC \uBCF4\uC790.\r\n       
    \r\n                        \uB124\uBAA8 : \u2026\u2026\uC751. \uADF8\uAC74 \uC880
    \uAD81\uAE08\uD55C\uB370.\r\n        \r\n                        (\uB458\uC740
    \uCC3D\uAC00\uC5D0 \uBD99\uC5B4\uC11C \uBC16\uC744 \uD55C\uCC38 \uB0B4\uB2E4\uBCF8\uB2E4.)\r\n       
    \r\n                        \uCE5C\uAD6C3 : \uC800 \uC0C8\uB294 \uCF69 \uAC19\uC544.
    \uC800 \uAC1C\uB294 \uBC30\uCD94 \uAC19\uC544. \uC800 \uB9C8\uCC28\uB294 \uD638\uBC15\uAC19\uC544.\r\n       
    \r\n                        \uB124\uBAA8 : \uB108 \uC9C4\uC9DC \uC774\uC0C1\uD55C\uB370
    \uC7AC\uBC0C\uB124.\r\n        \r\n                        ~~"
