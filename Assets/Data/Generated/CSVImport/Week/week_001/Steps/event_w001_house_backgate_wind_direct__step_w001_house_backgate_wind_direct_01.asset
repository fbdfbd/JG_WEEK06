  m_Name: event_w001_house_backgate_wind_direct__step_w001_house_backgate_wind_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD6C4\uBB38 \uBC14\uB78C \uAD00\uB828 \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uD604\uAD00 \uCABD \uBCF5\uB3C4. \uD558\uB140 \uB458\uC774 \uC816\uC740
    \uC6B0\uC0B0\uC744 \uD138\uBA70 \uD22C\uB35C\uAC70\uB9B0\uB2E4.)\n        \n       
    \uD558\uB1401 : \uD6C4\uBB38 \uCABD \uBC14\uB78C\uC740 \uC6B0\uC0B0\uC774\uB791
    \uC6D0\uC218\uC57C.\n        \n        \uD558\uB1402 : \uC5B4\uC81C\uB3C4 \uD558\uB098
    \uB4A4\uC9D1\uD614\uC796\uC544.\n        \n        \uB124\uBAA8 : \uC6B0\uC0B0\uC774
    \uB4A4\uC9D1\uD600?\n        \n\n\uD558\uB1401 : \uB124, \uC8FC\uC778\uB2D8.
    \uD6C4\uBB38 \uCABD\uC740 \uBC14\uB78C\uC774 \uC815\uB9D0 \uC149\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uC5C4\uCCAD \uC138?\n        \n        \uD558\uB1402
    : \uB124. \uC6B0\uC0B0\uB3C4 \uD655 \uB4A4\uC9D1\uD788\uACE0, \uB9AC\uBCF8\uB3C4
    \uB2E4 \uB0A0\uC544\uAC00\uC694.\n        \n        \uB124\uBAA8 : \uD5C9. \uADF8\uB7FC
    \uBA38\uB9AC\uB3C4 \uB2E4 \uB0A0\uC544\uAC00?\n        \n        \uD558\uB1401
    : \uD6C4\uD6C4, \uC798 \uBB36\uC9C0 \uC54A\uC73C\uBA74 \uADF8\uB7F4\uC9C0\uB3C4
    \uBAA8\uB974\uC9C0\uC694.\n        \n        \uB124\uBAA8 : \uC6B0\uC640. \uB098\uB3C4
    \uBCF4\uACE0 \uC2F6\uC740\uB370.\n        \n        \uD558\uB1402 : \uAC00\uAE4C\uC774
    \uAC00\uBA74 \uC637\uC790\uB77D\uB3C4 \uC815\uC2E0\uC5C6\uC5B4\uC9C8 \uAC70\uC608\uC694,
    \uC8FC\uC778\uB2D8.\n        \n        \uB124\uBAA8 : \uC880 \uC7AC\uBC0C\uACA0\uB2E4."
