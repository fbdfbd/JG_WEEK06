  _titleOverride: "\uAD00\uCC30 \uC218\uC5C5\uC744 \uD638\uAE30\uC2EC \uC704\uC8FC\uB85C
    \uD480\uC5B4 \uC900\uB2E4"
  _bodyText: "\uAF43\uACFC \uBC8C\uB808 \uAD00\uCC30 \uAD50\uC7AC Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC815\uB2F5\uC744 \uBC14\uB85C \uB9D0\uD558\uC9C0 \uC54A\uACE0, \uB124\uBAA8\uAC00
      \uBA3C\uC800 \uB9DE\uD600 \uBCF4\uAC8C \uD558\uBA70 \uAD00\uCC30\uC744 \uC720\uB3C4\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uC78E\uC774 \uD1B1\uB2C8 \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uD638\uAE30\uC2EC\uC774 \uB04A\uAE30\uC9C0 \uC54A\uAC8C \uC9C8\uBB38\uC744
      \uB358\uC9C0\uBA70 \uC218\uC5C5\uC744 \uC774\uC5B4 \uAC04\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610 \uB9DE\uD600 \uBCFC\uB798\uC694."
  _nemoLine: "(\uC815\uB2F5\uC744 \uBC14\uB85C \uB9D0\uD558\uC9C0 \uC54A\uACE0, \uB124\uBAA8\uAC00
    \uBA3C\uC800 \uB9DE\uD600 \uBCF4\uAC8C \uD558\uBA70 \uAD00\uCC30\uC744 \uC720\uB3C4\uD55C\uB2E4.)"
