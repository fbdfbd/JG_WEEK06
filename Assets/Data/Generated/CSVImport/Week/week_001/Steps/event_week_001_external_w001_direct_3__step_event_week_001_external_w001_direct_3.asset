  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_external_w001_direct_3__step_event_week_001_external_w001_direct_3
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC678\uBD80 \uC815\uBCF4 \uD5C8\uAC00"
  _bodyText: "external w001 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uBB50\uC57C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC655\uAD6D\uC5D0\uC11C \uC720\uBA85\uD55C \uBBF8\uC2A4\uD130 \uC774\uBB34\uC774\uB77C\uB294
      \uC0AC\uB78C\uC774, \uBD81\uCABD \uB9C8\uC218\uB4E4\uC758 \uC6B0\uB450\uBA38\uB9AC\uB97C
      \uD574\uCE58\uC6B0\uACE0 \uB3CC\uC544\uC654\uB2E4\uB294 \uC18C\uC2DD\uC774\uC5D0\uC694,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uB450\uBA38\uB9AC?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uBD81\uCABD\uC5D4 \uC0AC\uB098\uC6B4 \uB9C8\uC218\uB4E4\uC774
      \uB9CE\uC740\uB370, \uADF8\uC911 \uC81C\uC77C \uBB34\uC11C\uC6B4 \uB188\uC774\uC5C8\uB2E4\uACE0\uB4E4
      \uD574\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC? \uC6B0\uC640. \uBBF8\uC2A4\uD130 \uC774\uBB34\uC740 \uC5C4\uCCAD
      \uC13C\uAC00 \uBCF4\uB2E4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB2E4\uB4E4 \uADF8\uB807\uAC8C \uB9D0\uD558\uB354\uAD70\uC694, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uBCF4\uACE0 \uC2F6\uB2E4."
  _nemoLine: "\uADF8\uAC74 \uBB50\uC57C?"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
