  _titleOverride: "\uD638\uC218 \uAD00\uB828 \uC18C\uBB38 - \uCC28\uB2E8"
  _bodyText: "\uD6C4\uBB38 \uCABD \uB291\uB300 \uC18C\uBB38\uC744 \uB124\uBAA8\uC5D0\uAC8C
    \uC9C1\uC811 \uB4E4\uB824\uC8FC\uC9C0 \uC54A\uACE0 \uB118\uAE34\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uD6C4\uBB38 \uCABD \uBB38\uC81C\uB97C \uBE68\uB9AC \uD574\uACB0\uD558\uBA74
      \uC88B\uACA0\uB294\uB370\u2026"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8\uB188\uC774 \uC6CC\uB099 \uB0A0\uC314\uC11C \uC7A1\uD788\uC9C8
      \uC54A\uB098 \uBD10."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD6C4\uBB38\uC5D0 \uBB50 \uC788\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  _nemoLine: "\uD6C4\uBB38 \uCABD \uBB38\uC81C\uB97C \uBE68\uB9AC \uD574\uACB0\uD558\uBA74
    \uC88B\uACA0\uB294\uB370\u2026"
