  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_house_talk_cousin1_rumor_direct__step_event_week_001_house_talk_cousin1_rumor_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE74\uC774\uC548 \uAD00\uB828 \uC18C\uBB38 \uD5C8\uAC00"
  _bodyText: "house_talk \uC0AC\uCD0C1_\uAD00\uB828_\uC18C\uBB38 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uBC31\uC791\uB2D8 \uC0AC\uCD0C\uBD84\uC774 \uC624\uC2E0\uB300\uC694,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC0AC\uCD0C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uBC31\uC791\uB2D8 \uAC00\uC871\uC774\uC2E0 \uC148\uC774\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC00\uC871\uC778\uB370 \uC65C \uC774\uB807\uAC8C \uBC14\uBE60?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC190\uB2D8\uC73C\uB85C \uC624\uC2DC\uB294 \uAC70\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uAC00\uC871\uC774\uC5B4\uB3C4 \uC608\uB97C \uCC28\uB9B4 \uBD84\uC740
      \uCC28\uB824\uC57C \uD55C\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD750\uC751."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB098\uB3C4 \uC778\uC0AC\uD574\uC57C \uD574?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uB124. \uC608\uC058\uAC8C \uC778\uC0AC\uD558\uC2DC\uBA74 \uC88B\uC9C0\uC694,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548\uB155\uD558\uC138\uC694, \uD558\uBA74 \uB418\uC9C0?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uC544\uC8FC \uC798\uD558\uC168\uC5B4\uC694."
  _nemoLine: "\uBC31\uC791\uB2D8 \uC0AC\uCD0C\uBD84\uC774 \uC624\uC2E0\uB300\uC694,
    \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
