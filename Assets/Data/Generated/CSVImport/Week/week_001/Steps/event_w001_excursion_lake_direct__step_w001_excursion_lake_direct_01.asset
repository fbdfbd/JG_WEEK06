  m_Name: event_w001_excursion_lake_direct__step_w001_excursion_lake_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 1\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uCA0D\uD55C \uC810\uC2EC. \uC815\uC6D0\uC744 \uAC77\uB358 \uB124\uBAA8\uAC00
    \uB098\uBE44\uB97C \uBC1C\uACAC\uD55C\uB2E4.)\n        \n                   
    \uB124\uBAA8 : \uC640, \uB098\uBE44\uB2E4.\n        \n                    (\uB098\uBE44\uAC00
    \uD6C4\uBB38 \uB108\uBA38\uB85C \uB0A0\uC544\uAC04\uB2E4.)\n        \n                   
    \uB124\uBAA8 : \uC5B4? \uC800\uAE30\uB85C \uAC14\uB124.\n        \n                   
    \uB124\uBAA8 : \uC7A1\uACE0 \uC2F6\uC740\uB370\u2026\n        \n                   
    (\uC5B8\uC820\uAC00 \uB124\uBAA8\uB294 \uC8FC\uC704\uC5D0 \uB291\uB300\uAC00
    \uCD9C\uBAB0\uD55C\uB2E8 \uC598\uAE30\uB97C \uB4E4\uC740\uAC83 \uAC19\uB2E4)\n       
    \n\n(\uD6C4\uBB38\uC740 \uC5F4\uB824 \uC788\uACE0, \uBA40\uCC0D\uC774 \uACBD\uBE44\uAC00
    \uB300\uAE30 \uC911\uC774\uB2E4. \uB124\uBAA8\uB294 \uADF8\uAC78 \uBAA8\uB974\uACE0
    \uBC16\uC73C\uB85C \uB098\uAC04\uB2E4.)\n        \n                        \uB124\uBAA8
    : \uC6B0\uC640, \uC5F4\uB824 \uC788\uB124.\n        \n                       
    \uB124\uBAA8 : \uADF8\uB7FC \uB098\uAC00\uB3C4 \uB418\uB098?\n        \n                       
    (\uB124\uBAA8\uAC00 \uB098\uBE44\uB97C \uCAD3\uC544 \uD638\uC218\uAE4C\uC9C0
    \uAC04\uB2E4. \uACE7 \uAE38\uC744 \uC783\uACE0 \uC6B8\uC74C\uC744 \uD130\uD2B8\uB9B0\uB2E4.)\n       
    \n                        (\uC218\uD480\uC5D0\uC11C \uB291\uB300\uAC00 \uB098\uD0C0\uB098\uB824\uB294
    \uC21C\uAC04, \uB4A4\uB530\uB974\uB358 \uACBD\uBE44\uB300\uC7A5\uC774 \uD280\uC5B4\uB098\uC628\uB2E4.)\n       
    \n                        \uACBD\uBE44\uB300\uC7A5 : \uC8FC\uC778\uB2D8 \uB4A4\uB85C
    \uBB3C\uB7EC\uB098\uC2ED\uC2DC\uC624.\n        \n                        \uC288\uC288\uC289
    (\uB291\uB300\uAC00 \uC8FD\uC5C8\uB2E4.)\n        \n                        \uACBD\uBE44\uB300\uC7A5
    :  \uC8FC\uC778\uB2D8\uAED8\uC11C \uD6C4\uBB38 \uCABD\uC73C\uB85C \uAC00\uC2E4\uAC83
    \uAC19\uC544 \uC9C0\uD0A4\uACE0 \uC788\uC5C8\uC2B5\uB2C8\uB2E4. \uC774\uC81C
    \uB3CC\uC544\uAC00\uC2DC\uC8E0.\n        \n                        \uB124\uBAA8
    : \uD6CC\uCA4D\u2026\uB124"
