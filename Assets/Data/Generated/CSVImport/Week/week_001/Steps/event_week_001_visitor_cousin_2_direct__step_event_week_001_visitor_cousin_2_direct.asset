  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_visitor_cousin_2_direct__step_event_week_001_visitor_cousin_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9AC\uC548 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor cousin_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uB9AC\uC548 \uCABD\uC73C\uB85C \uC885\uC885 \uAC78\uC5B4\uAC04\uB2E4.
      \uB9AC\uC548\uC740 \uCE74\uC774\uC628 \uB4A4\uC5D0 \uBC18\uCBE4 \uC228\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\u2026\u2026\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB108 \uC774\uB984 \uBB50\uC57C?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\u2026\u2026"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C \uB300\uB2F5 \uC548 \uD574?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uBBF8, \uBBF8\uC548."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uB098\u2026 \u25CB\u25CB\uC774\uC57C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB09C \uB124\uBAA8\uC57C."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uC751."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB108\uB3C4 \uC0AC\uD0D5 \uC88B\uC544\uD574?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\u2026\u2026\uC88B\uC544\uD574."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uC88B\uC544\uD574."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\u2026\u2026\uC751."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB458 \uC0AC\uC774\uC5D0 \uC7A0\uAE50 \uC5B4\uC0C9\uD55C \uCE68\uBB35\uC774
      \uD750\uB974\uC9C0\uB9CC, \uB9AC\uC548\uC740 \uB3C4\uB9DD\uAC00\uC9C4 \uC54A\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uC74C\uC5D4 \uAC19\uC774 \uB180\uB798?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\u2026\u2026\uC751. \uC544\uB9C8\uB3C4."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uB9AC\uC548 \uCABD\uC73C\uB85C \uC885\uC885 \uAC78\uC5B4\uAC04\uB2E4.
    \uB9AC\uC548\uC740 \uCE74\uC774\uC628 \uB4A4\uC5D0 \uBC18\uCBE4 \uC228\uB294\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
