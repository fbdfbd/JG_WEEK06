  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: "event_week_001_house_talk_\uB0B4\uC11C\uC7AC_\uAD00\uB828_\uC18C\uBB38_modified__step_event_week_001_house_talk_\uB0B4\uC11C\uC7AC_\uAD00\uB828_\uC18C\uBB38_modified"
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC_\uAD00\uB828_\uC18C\uBB38 Modified"
  _bodyText: "house_talk \uB0B4\uC11C\uC7AC_\uAD00\uB828_\uC18C\uBB38 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC11C\uC7AC \uC55E \uBC14\uB2E5\uC740 \uC18C\uB9AC\uAC00 \uD06C\uAC8C
      \uC6B8\uB824\uC11C \uADF8\uB798\uC694, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC14\uB2E5\uC774?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uC5EC\uAE30\uC11C \uC7AC\uCC44\uAE30\uD558\uBA74 \uC548\uCABD\uAE4C\uC9C0
      \uB2E4 \uB4E4\uB9B0\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC608. \uBC1C\uC18C\uB9AC\uB3C4 \uD06C\uAC8C \uB098\uACE0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB798\uC11C \uB2E4\uB4E4 \uC870\uC6A9\uD55C \uAC70\uAD6C\uB098."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uAD1C\uD788 \uC2DC\uB044\uB7FD\uAC8C \uD588\uB2E4\uAC00 \uBC31\uC791\uB2D8
      \uB180\uB77C\uC2DC\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD750\uC751."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5EC\uAE30 \uBC14\uB2E5\uC740 \uC774\uC0C1\uD558\uB124."
  _nemoLine: "\uC11C\uC7AC \uC55E \uBC14\uB2E5\uC740 \uC18C\uB9AC\uAC00 \uD06C\uAC8C
    \uC6B8\uB824\uC11C \uADF8\uB798\uC694, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
