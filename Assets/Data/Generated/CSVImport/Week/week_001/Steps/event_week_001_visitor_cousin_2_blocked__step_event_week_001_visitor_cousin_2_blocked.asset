  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_visitor_cousin_2_blocked__step_event_week_001_visitor_cousin_2_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9AC\uC548 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor cousin_2 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uB2E4\uAC00\uAC00\uB824 \uD558\uC790 \uC9D1\uC0AC\uC7A5\uC774
      \uC5B4\uAE68\uB97C \uAC00\uBCCD\uAC8C \uB9C9\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC778\uC0AC\uB9CC \uD558\uC2DC\uB294
      \uAC8C \uC88B\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC190\uB2D8\uB3C4 \uC544\uC9C1 \uC5B4\uC0C9\uD574\uD558\uB294 \uB4EF\uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uAC19\uC774 \uB180\uBA74 \uC548 \uB3FC\uC694?"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC624\uB298\uC740 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774\u2026"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC0AC\uCD0C2\uB294 \uC791\uAC8C \uACE0\uAC1C\uB9CC \uB044\uB355\uC778\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\u2026\u2026\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uC544\uC26C\uC6B4 \uC5BC\uAD74\uB85C \uBB3C\uB7EC\uB09C\uB2E4.)"
  _nemoLine: "(\uB124\uBAA8\uAC00 \uB2E4\uAC00\uAC00\uB824 \uD558\uC790 \uC9D1\uC0AC\uC7A5\uC774
    \uC5B4\uAE68\uB97C \uAC00\uBCCD\uAC8C \uB9C9\uB294\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
