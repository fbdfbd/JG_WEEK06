  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w001_excursion_library_blocked__step_w001_excursion_library_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 1\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uB124\uBAA8\uAC00 \uC800\uD0DD \uB0B4\uBD80 \uB3C4\uC11C\uAD00 \uBB38\uC744
    \uBE7C\uAF3C \uC5F0\uB2E4.)\r\n        \r\n                    \uB124\uBAA8 :
    \uC6B0\uC640\u2026\r\n        \r\n                    \uB124\uBAA8 : \uCC45 \uC9C4\uC9DC
    \uB9CE\uB2E4.\r\n        \r\n                    (\uB192\uC740 \uCC45\uC7A5 \uC704\uC5D0
    \uAE08\uBC15\uC774 \uB4E4\uC5B4\uAC04 \uCEE4\uB2E4\uB780 \uCC45 \uD55C \uAD8C\uC774
    \uBC18\uC9DD\uC778\uB2E4.)\r\n        \r\n                    \uB124\uBAA8 :
    \uC5B4? \uC800\uAC70 \uBC18\uC9DD\uBC18\uC9DD\uD55C\uB2E4.\r\n        \r\n                   
    \uB124\uBAA8 : \uC800\uAC70 \uBCF4\uACE0 \uC2F6\uC740\uB370.\r\n        \r\n                   
    \uB192\uC740 \uCC45\uC740 \uD63C\uC790 \uAEBC\uB0B4\uBA74 \uC704\uD5D8\uD558\uACE0,
    \uB3C4\uC11C\uAD00 \uCC45\uC740 \uD568\uBD80\uB85C \uB9CC\uC9C0\uBA74 \uC548
    \uB41C\uB2E4\uACE0 \uB4E4\uC740 \uC801\uC774 \uC788\uB2E4.\r\n        \r\n\r\n(\uC11C\uACE0\uAD00\uB9AC\uC778\uC774
    \uB124\uBAA8\uB97C \uBCF4\uACE0 \uB2E4\uAC00\uC628\uB2E4.)\r\n        \r\n                       
    \uC11C\uACE0\uAD00\uB9AC\uC778 : \uC8FC\uC778\uB2D8, \uADF8 \uCC45\uC740 \uC548
    \uB429\uB2C8\uB2E4.\r\n        \r\n                        \uB124\uBAA8 : \uC65C\uC694?\r\n       
    \r\n                        \uC11C\uACE0\uAD00\uB9AC\uC778 : \uB192\uC740 \uACF3\uC5D0
    \uC788\uC5B4\uC11C \uC704\uD5D8\uD569\uB2C8\uB2E4.\r\n        \r\n                       
    \uB124\uBAA8 : \uC800 \uC870\uAE08\uB9CC \uBCFC \uAC74\uB370.\r\n        \r\n                       
    \uC11C\uACE0\uAD00\uB9AC\uC778 : \uC548 \uB429\uB2C8\uB2E4. \uC544\uC9C1 \uC8FC\uC778\uB2D8\uAED8\uB294
    \uC5B4\uB824\uC6B4 \uCC45\uC785\uB2C8\uB2E4.\r\n        \r\n                       
    \uB124\uBAA8 : \uC5D0\uC774\u2026\r\n        \r\n                        \uB124\uBAA8
    : \uADF8\uB9BC\uB3C4 \uC548 \uB3FC\uC694?\r\n        \r\n                       
    \uC11C\uACE0\uAD00\uB9AC\uC778 :  \uC774\uCABD \uCC45\uC740 \uBCF4\uC154\uB3C4
    \uB429\uB2C8\uB2E4.\r\n        \r\n                        \uB124\uBAA8 : \u2026\u2026\uC54C\uACA0\uC5B4\uC694.\r\n       
    \r\n                        (\uB124\uBAA8\uB294 \uC2DC\uBB34\uB8E9\uD574\uD558\uC9C0\uB9CC
    \uAD00\uB9AC\uC778\uC774 \uB0B4\uC5B4 \uC900 \uADF8\uB9BC\uCC45\uC744 \uBCF8\uB2E4.)"
