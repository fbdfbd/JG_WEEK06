--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_excursion_study_direct__step_event_week_001_excursion_study_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC11C\uC7AC \uD5C8\uAC00"
  _bodyText: "excursion study Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uBB38 \uC55E\uC5D0\uC11C \uC548\uC744 \uB4E4\uC5EC\uB2E4\uBCF4\uACE0
      \uC788\uC790 \uBE44\uC11C\uAC00 \uB2E4\uAC00\uC628\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC548\uC774 \uAD81\uAE08\uD558\uC2ED\uB2C8\uAE4C?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uC800 \uBC18\uC9DD\uC774\uB294 \uAC70 \uBCF4\uACE0 \uC2F6\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC548\uCABD\uAE4C\uC9C4 \uC548 \uB418\uC9C0\uB9CC, \uBB38 \uC55E\uC5D0\uC11C
      \uC7A0\uAE50 \uBCF4\uB294 \uAC74 \uAD1C\uCC2E\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC\uC694?"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC608. \uB300\uC2E0 \uC190\uB300\uC2DC\uBA74 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751! \uC548 \uB9CC\uC9C8\uB798\uC694!"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBE44\uC11C\uAC00 \uBB38\uC744 \uC870\uAE08 \uB354 \uC5F4\uC5B4 \uC900\uB2E4.
      \uB124\uBAA8\uB294 \uAE43\uD39C\uACFC \uC778\uC7A5, \uC885\uC774 \uC704 \uBD89\uC740
      \uBC00\uB78D\uC744 \uC2E0\uAE30\uD558\uAC8C \uBC14\uB77C\uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640\u2026 \uBA4B\uC788\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC31\uC791\uB2D8\uC740 \uB9E8\uB0A0 \uC774\uB7F0 \uAC70 \uC4F0\uB098?"
  _nemoLine: "(\uB124\uBAA8\uAC00 \uBB38 \uC55E\uC5D0\uC11C \uC548\uC744 \uB4E4\uC5EC\uB2E4\uBCF4\uACE0
    \uC788\uC790 \uBE44\uC11C\uAC00 \uB2E4\uAC00\uC628\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
