  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w001_visitor_friend_1_direct__step_w001_visitor_friend_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 1\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uC815\uC6D0 \uADFC\uCC98 \uC751\uC811\uC2E4 \uC55E. \uB610\uB798
    \uC544\uC774 \uD558\uB098\uAC00 \uD63C\uC790 \uBCF5\uB3C4 \uC7A5\uC2DD\uD488\uC744
    \uAD6C\uACBD\uD558\uBA70 \uC11C \uC788\uB2E4.)\r\n        \r\n                   
    \uB124\uBAA8 : \uC5B4?\r\n        \r\n                    \uB124\uBAA8 : \uC7E4\uB3C4
    \uC190\uB2D8\uC774\uC57C?\r\n        \r\n                    \uD558\uB140 : \uC608,
    \uC8FC\uC778\uB2D8. \uC624\uB298\uC740 \uB610\uB798 \uC190\uB2D8\uB3C4 \uD568\uAED8
    \uC654\uB2F5\uB2C8\uB2E4.\r\n        \r\n                    (\uADF8 \uC544\uC774\uAC00
    \uB124\uBAA8\uB97C \uBC1C\uACAC\uD558\uACE0 \uBA3C\uC800 \uB2E4\uAC00\uC628\uB2E4.)\r\n       
    \r\n                    \uCE5C\uAD6C1 : \uC548\uB155! \uB108 \uB124\uBAA8\uC9C0?\r\n       
    \r\n                    \uB124\uBAA8 : \uC5B4? \uC751.\r\n        \r\n                   
    \uCE5C\uAD6C1 : \uB09C \u25CB\u25CB\uC774\uC57C. \uC6B0\uB9AC \uAC19\uC774 \uB180\uB798?\r\n       
    \r\n                    \uC800 \uC544\uC774\uB294 \uB0AF\uC744 \uAC00\uB9AC\uC9C0
    \uC54A\uACE0 \uAE08\uBC29 \uCE5C\uD574\uC9C0\uB294 \uC131\uACA9\uC774\uB77C\uACE0
    \uB4E4\uC740 \uC801\uC774 \uC788\uB2E4.\r\n        \r\n\r\n(\uD558\uB140\uAC00
    \uD55C\uAC78\uC74C \uBB3C\uB7EC\uC120\uB2E4.)\r\n        \r\n                       
    \uD558\uB140 : \uB108\uBB34 \uBA40\uB9AC\uB9CC \uAC00\uC9C0 \uB9C8\uC138\uC694.\r\n       
    \r\n                        \uB124\uBAA8 : \uC9C4\uC9DC\uC694?\r\n        \r\n                       
    \uCE5C\uAD6C1 : \uC640! \uAC00\uC790!\r\n        \r\n                       
    (\uCE5C\uAD6C1\uC774 \uB124\uBAA8 \uC190\uBAA9\uC744 \uC7A1\uACE0 \uBCF5\uB3C4
    \uB05D\uC73C\uB85C \uB2EC\uB824\uAC04\uB2E4.)\r\n        \r\n                       
    \uB124\uBAA8 : \uC5B4\uC5B4? \uBE68\uB77C!\r\n        \r\n                       
    \uCE5C\uAD6C1 : \uB108 \uC220\uB798 \uD560\uB798?\r\n        \r\n                       
    \uB124\uBAA8 : \uC2EB\uC5B4! \uB098 \uC228\uC744\uB798!\r\n        \r\n                       
    \uCE5C\uAD6C1 : \uADF8\uB7FC \uB0B4\uAC00 \uCC3E\uB294\uB2E4!\r\n        \r\n                       
    \uB124\uBAA8 : \uD5E4\uD5E4, \uB098 \uC9C4\uC9DC \uC798 \uC228\uAC70\uB4E0!\r\n       
    \r\n                        (\uB458\uC740 \uBCF5\uB3C4\uC640 \uC815\uC6D0 \uC55E\uC744
    \uB6F0\uC5B4\uB2E4\uB2C8\uBA70 \uAE08\uC138 \uC2DC\uB04C\uBC85\uC801\uD574\uC9C4\uB2E4.)\r\n       
    \r\n                        \uCE5C\uAD6C1 : \uCC3E\uC558\uB2E4!\r\n        \r\n                       
    \uB124\uBAA8 : \uC5D0\uC5D0! \uBC8C\uC368?\r\n        \r\n                       
    \uCE5C\uAD6C1 : \uB108 \uBC1C \uBCF4\uC600\uC5B4!\r\n        \r\n                       
    \uB124\uBAA8 : \uC544 \uC9C4\uC9DC?\r\n        \r\n                        (\uB124\uBAA8\uB294
    \uAE08\uBC29 \uC6C3\uC73C\uBA70 \uB2E4\uC2DC \uB3C4\uB9DD\uAC04\uB2E4.)"
