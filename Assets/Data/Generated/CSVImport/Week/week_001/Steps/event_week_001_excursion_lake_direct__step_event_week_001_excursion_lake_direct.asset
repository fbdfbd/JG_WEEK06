  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_excursion_lake_direct__step_event_week_001_excursion_lake_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: lake Direct
  _bodyText: "excursion lake Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD6C4\uBB38\uC740 \uC5F4\uB824 \uC788\uACE0, \uBA40\uCC0D\uC774 \uACBD\uBE44\uAC00
      \uB300\uAE30 \uC911\uC774\uB2E4. \uB124\uBAA8\uB294 \uADF8\uAC78 \uBAA8\uB974\uACE0
      \uBC16\uC73C\uB85C \uB098\uAC04\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640, \uC5F4\uB824 \uC788\uB124."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB098\uAC00\uB3C4 \uB418\uB098?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uB098\uBE44\uB97C \uCAD3\uC544 \uD638\uC218\uAE4C\uC9C0
      \uAC04\uB2E4. \uACE7 \uAE38\uC744 \uC783\uACE0 \uC6B8\uC74C\uC744 \uD130\uD2B8\uB9B0\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC218\uD480\uC5D0\uC11C \uB291\uB300\uAC00 \uB098\uD0C0\uB098\uB824\uB294
      \uC21C\uAC04, \uB4A4\uB530\uB974\uB358 \uACBD\uBE44\uB300\uC7A5\uC774 \uD280\uC5B4\uB098\uC628\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC8FC\uC778\uB2D8 \uB4A4\uB85C \uBB3C\uB7EC\uB098\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uAED8\uC11C \uD6C4\uBB38 \uCABD\uC73C\uB85C \uAC00\uC2E4\uAC83
      \uAC19\uC544 \uC9C0\uD0A4\uACE0 \uC788\uC5C8\uC2B5\uB2C8\uB2E4. \uC774\uC81C
      \uB3CC\uC544\uAC00\uC2DC\uC8E0."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD6CC\uCA4D\u2026\uB124"
  _nemoLine: "(\uD6C4\uBB38\uC740 \uC5F4\uB824 \uC788\uACE0, \uBA40\uCC0D\uC774 \uACBD\uBE44\uAC00
    \uB300\uAE30 \uC911\uC774\uB2E4. \uB124\uBAA8\uB294 \uADF8\uAC78 \uBAA8\uB974\uACE0
    \uBC16\uC73C\uB85C \uB098\uAC04\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
