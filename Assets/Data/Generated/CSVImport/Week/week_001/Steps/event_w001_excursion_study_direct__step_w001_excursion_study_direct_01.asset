  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w001_excursion_study_direct__step_w001_excursion_study_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC 1\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uB124\uBAA8\uAC00 \uBCF5\uB3C4\uB97C \uAC77\uB2E4\uAC00 \uD50C\uB808\uC774\uC5B4\uC758
    \uC11C\uC7AC \uBB38 \uC55E\uC5D0 \uBA48\uCD98\uB2E4. \uBB38\uC740 \uC0B4\uC9DD
    \uC5F4\uB824 \uC788\uACE0, \uC548\uCABD \uCC45\uC0C1 \uC704\uC5D4 \uBC18\uC9DD\uC774\uB294
    \uAE43\uD39C\uACFC \uC778\uC7A5\uC774 \uBCF4\uC778\uB2E4.)\r\n        \r\n                   
    \uB124\uBAA8 : \uC5B4?\r\n        \r\n                    \uB124\uBAA8 : \uC800\uAE30
    \uBC18\uC9DD\uC774\uB294 \uAC70 \uC788\uB2E4.\r\n        \r\n                   
    \uB124\uBAA8 : \uB9CC\uC838 \uBCF4\uACE0 \uC2F6\uC740\uB370.\r\n        \r\n                   
    \uBC31\uC791\uB2D8\uC758 \uC11C\uC7AC\uB294 \uD568\uBD80\uB85C \uB4E4\uC5B4\uAC00\uBA74
    \uC548 \uB418\uACE0, \uCC45\uC0C1 \uC704 \uBB3C\uAC74\uC740 \uAC74\uB4DC\uB9AC\uBA74
    \uC548 \uB41C\uB2E4\uACE0 \uB4E4\uC740 \uC801\uC774 \uC788\uB2E4.\r\n       
    \r\n\r\n(\uB124\uBAA8\uAC00 \uBB38 \uC55E\uC5D0\uC11C \uC548\uC744 \uB4E4\uC5EC\uB2E4\uBCF4\uACE0
    \uC788\uC790 \uBE44\uC11C\uAC00 \uB2E4\uAC00\uC628\uB2E4.)\r\n        \r\n                       
    \uBE44\uC11C : \uC8FC\uC778\uB2D8, \uC548\uC774 \uAD81\uAE08\uD558\uC2ED\uB2C8\uAE4C?\r\n       
    \r\n                        \uB124\uBAA8 : \uC751. \uC800 \uBC18\uC9DD\uC774\uB294
    \uAC70 \uBCF4\uACE0 \uC2F6\uC5B4\uC694.\r\n        \r\n                       
    \uBE44\uC11C : \uC548\uCABD\uAE4C\uC9C4 \uC548 \uB418\uC9C0\uB9CC, \uBB38 \uC55E\uC5D0\uC11C
    \uC7A0\uAE50 \uBCF4\uB294 \uAC74 \uAD1C\uCC2E\uC2B5\uB2C8\uB2E4.\r\n        \r\n                       
    \uB124\uBAA8 : \uC9C4\uC9DC\uC694?\r\n        \r\n                        \uBE44\uC11C
    : \uC608. \uB300\uC2E0 \uC190\uB300\uC2DC\uBA74 \uC548 \uB429\uB2C8\uB2E4.\r\n       
    \r\n                        \uB124\uBAA8 : \uC751! \uC548 \uB9CC\uC9C8\uB798\uC694!\r\n       
    \r\n                        (\uBE44\uC11C\uAC00 \uBB38\uC744 \uC870\uAE08 \uB354
    \uC5F4\uC5B4 \uC900\uB2E4. \uB124\uBAA8\uB294 \uAE43\uD39C\uACFC \uC778\uC7A5,
    \uC885\uC774 \uC704 \uBD89\uC740 \uBC00\uB78D\uC744 \uC2E0\uAE30\uD558\uAC8C
    \uBC14\uB77C\uBCF8\uB2E4.)\r\n        \r\n                        \uB124\uBAA8
    : \uC6B0\uC640\u2026 \uBA4B\uC788\uB2E4.\r\n        \r\n                       
    \uB124\uBAA8 : \uBC31\uC791\uB2D8\uC740 \uB9E8\uB0A0 \uC774\uB7F0 \uAC70 \uC4F0\uB098?"
