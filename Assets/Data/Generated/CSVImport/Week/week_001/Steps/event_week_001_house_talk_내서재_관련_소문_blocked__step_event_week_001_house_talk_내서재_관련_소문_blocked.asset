  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: "event_week_001_house_talk_\uB0B4\uC11C\uC7AC_\uAD00\uB828_\uC18C\uBB38_blocked__step_event_week_001_house_talk_\uB0B4\uC11C\uC7AC_\uAD00\uB828_\uC18C\uBB38_blocked"
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC \uAD00\uB828 \uC18C\uBB38 \uD1B5\uC81C"
  _bodyText: "house_talk \uB0B4\uC11C\uC7AC_\uAD00\uB828_\uC18C\uBB38 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC29\uAE08 \uC774\uC0C1\uD55C \uB9D0 \uD588\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uADF8\uB0E5 \uC800\uD76C\uB07C\uB9AC \uD55C \uC598\uAE30\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C \uC5EC\uAE30\uB9CC \uC624\uBA74 \uB2E4\uB4E4 \uC870\uC6A9\uD574?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC74C\u2026 \uADF8\uB0E5 \uBCF5\uB3C4\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uB978 \uBCF5\uB3C4\uB294 \uC548 \uADF8\uB7F0\uB370."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uC5EC\uAE34 \uADF8\uB0E5\u2026 \uC880 \uC870\uC6A9\uD55C \uBCF5\uB3C4\uC608\uC694,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD750\uC751. \uC774\uC0C1\uD574."
  _nemoLine: "\uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
