  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w001_excursion_study_blocked__step_w001_excursion_study_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC 1\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uB124\uBAA8\uAC00 \uBCF5\uB3C4\uB97C \uAC77\uB2E4\uAC00 \uD50C\uB808\uC774\uC5B4\uC758
    \uC11C\uC7AC \uBB38 \uC55E\uC5D0 \uBA48\uCD98\uB2E4. \uBB38\uC740 \uC0B4\uC9DD
    \uC5F4\uB824 \uC788\uACE0, \uC548\uCABD \uCC45\uC0C1 \uC704\uC5D4 \uBC18\uC9DD\uC774\uB294
    \uAE43\uD39C\uACFC \uC778\uC7A5\uC774 \uBCF4\uC778\uB2E4.)\n        \n                   
    \uB124\uBAA8 : \uC5B4?\n        \n                    \uB124\uBAA8 : \uC800\uAE30
    \uBC18\uC9DD\uC774\uB294 \uAC70 \uC788\uB2E4.\n        \n                   
    \uB124\uBAA8 : \uB9CC\uC838 \uBCF4\uACE0 \uC2F6\uC740\uB370.\n        \n                   
    \uBC31\uC791\uB2D8\uC758 \uC11C\uC7AC\uB294 \uD568\uBD80\uB85C \uB4E4\uC5B4\uAC00\uBA74
    \uC548 \uB418\uACE0, \uCC45\uC0C1 \uC704 \uBB3C\uAC74\uC740 \uAC74\uB4DC\uB9AC\uBA74
    \uC548 \uB41C\uB2E4\uACE0 \uB4E4\uC740 \uC801\uC774 \uC788\uB2E4.\n        \n\n(\uB124\uBAA8\uAC00
    \uBB38\uD2C8\uC73C\uB85C \uB4E4\uC5B4\uAC00\uB824 \uD558\uC790 \uC9D1\uC0AC\uC7A5\uC774
    \uC870\uC6A9\uD788 \uB2E4\uAC00\uC628\uB2E4.)\n        \n                       
    \uC9D1\uC0AC\uC7A5 : \uC8FC\uC778\uB2D8, \uC774\uCABD\uC740 \uC548 \uB429\uB2C8\uB2E4.\n       
    \n                        \uB124\uBAA8 : \uC65C\uC694?\n        \n                       
    \uC9D1\uC0AC\uC7A5 : \uBC31\uC791\uB2D8\uC758 \uC911\uC694\uD55C \uBB3C\uAC74\uC774
    \uC788\uB294 \uACF3\uC785\uB2C8\uB2E4.\n        \n                        \uB124\uBAA8
    : \uC800 \uC870\uAE08\uB9CC \uBCFC \uAC74\uB370\uC694.\n        \n                       
    \uC9D1\uC0AC\uC7A5 : \uC548 \uB429\uB2C8\uB2E4. \uB2E4\uCE58\uC2DC\uAC70\uB098
    \uB9DD\uAC00\uB728\uB9AC\uC2DC\uBA74 \uACE4\uB780\uD569\uB2C8\uB2E4.\n       
    \n                        \uB124\uBAA8 : \uC5D0\uC774\u2026\n        \n                       
    \uB124\uBAA8 : \uC54C\uACA0\uC5B4\uC694.\n        \n                        (\uB124\uBAA8\uB294
    \uBB38 \uC55E\uC744 \uD55C \uBC88 \uB354 \uD790\uB057 \uBCF4\uACE0 \uB3CC\uC544\uC120\uB2E4.)"
