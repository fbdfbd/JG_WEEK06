  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w001_visitor_friend_2_blocked__step_w001_visitor_friend_2_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 1\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uC751\uC811\uC2E4 \uD55C\uCABD. \uB610\uB798 \uC544\uC774 \uD558\uB098\uAC00
    \uC637\uB9E4\uBB34\uC0C8\uB97C \uB9CC\uC9C0\uBA70 \uAC00\uB9CC\uD788 \uC11C \uC788\uB2E4.)\r\n       
    \r\n                    \uB124\uBAA8 : \uC5B4? \uC7E4\uB294 \uC65C \uC800\uB807\uAC8C
    \uAC00\uB9CC\uD788 \uC788\uC5B4?\r\n        \r\n                    \uD558\uB140
    : \uBC31\uC791\uB2D8\uC758 \uC190\uB2D8\uACFC \uAC19\uC774 \uC624\uC2E0 \uC190\uB2D8\uC774\uC2ED\uB2C8\uB2E4.\r\n       
    \r\n                    \uB124\uBAA8 : \uB098\uBCF4\uB2E4 \uC58C\uC804\uD55C\uB370.\r\n       
    \r\n                    \uC800 \uC544\uC774\uB294 \uC608\uC758\uB294 \uBC14\uB974\uC9C0\uB9CC,
    \uB0AF\uC120 \uC544\uC774\uC5D0\uAC8C \uBA3C\uC800 \uB2E4\uAC00\uAC00\uB294 \uC131\uACA9\uC740
    \uC544\uB2C8\uB77C\uACE0 \uB4E4\uC740 \uC801\uC774 \uC788\uB2E4.\r\n        \r\n\r\n(\uB124\uBAA8\uAC00
    \uB2E4\uAC00\uAC00\uB824 \uD558\uC790 \uD558\uB140\uAC00 \uC870\uC2EC\uC2A4\uB7FD\uAC8C
    \uB9C9\uB294\uB2E4.)\r\n        \r\n                        \uD558\uB140 : \uC8FC\uC778\uB2D8,
    \uC624\uB298\uC740 \uC778\uC0AC\uB9CC \uD558\uC154\uC57C \uD569\uB2C8\uB2E4.\r\n       
    \r\n                        \uB124\uBAA8 : \uC65C\uC694?\r\n        \r\n                       
    \uD558\uB140 : \uBC31\uC791\uB2D8\uAED8\uC11C \uC190\uB2D8\uAED8 \uC608\uB97C
    \uAC16\uCD94\uB77C \uD558\uC168\uC2B5\uB2C8\uB2E4.\r\n        \r\n                       
    \uB124\uBAA8 : \uB124\u2026  \uC548\uB155.\r\n        \r\n                       
    \uCE5C\uAD6C2 : \u2026\u2026\uC548\uB155.\r\n        \r\n                       
    \uB124\uBAA8 : \uB05D\uC774\uC57C?\r\n        \r\n                        \uD558\uB140
    : \uB124, \uC624\uB298\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uC785\uB2C8\uB2E4.\r\n       
    \r\n                        \uB124\uBAA8 : \uC54C\uACA0\uC5B4\uC694.\r\n       
    \r\n                        ~~"
