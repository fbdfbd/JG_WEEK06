  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_201_child_visitor_cousin_1_01_blocked__step_201_child_visitor_cousin_1_01_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 \uCCAB \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "\uC751\uC811\uC2E4\uB85C \uAC00\uB824\uB294 \uB124\uBAA8\uB97C \uC9D1\uC0AC\uC7A5\uC774
    \uB9C9\uC544 \uC138\uC6B0\uACE0, \uC624\uB298\uC740 \uC5B4\uB978\uB4E4 \uC774\uC57C\uAE30\uB9CC
    \uC788\uB2E4\uACE0 \uB9D0\uD55C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4? \uC624\uB298 \uC190\uB2D8 \uC640\uC694?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC608, \uC8FC\uC778\uB2D8. \uBC31\uC791\uB2D8\uC758 \uC0AC\uCD0C \uC5B4\uB974\uC2E0\uAED8\uC11C
      \uC624\uC2ED\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC0AC\uCD0C\uC774\uBA74 \uAC00\uC871\uC774\uC9C0?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8\uB807\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC751\uC811\uC2E4\uC5D0 \uAC00\uC2DC\uBA74
      \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC5B4\uB978\uB4E4\uB07C\uB9AC \uD560 \uC774\uC57C\uAE30\uAC00 \uC788\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uAC00\uC871\uC778\uB370?"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC624\uB298\uC740 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uC54C\uACA0\uC5B4\uC694."
  _nemoLine: "\uC5B4? \uC624\uB298 \uC190\uB2D8 \uC640\uC694?"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
