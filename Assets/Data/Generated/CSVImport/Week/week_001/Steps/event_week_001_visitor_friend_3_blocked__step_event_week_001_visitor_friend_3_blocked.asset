  _titleOverride: "\uC720\uD53C \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor friend_3 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uAC00\uAE4C\uC774 \uAC00\uB824 \uD558\uC790 \uD558\uB140\uAC00
      \uBD80\uB4DC\uB7FD\uAC8C \uB9C9\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC9E7\uAC8C \uC778\uC0AC\uB9CC
      \uD558\uC154\uC57C \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774\u2026"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uC548\uB155! \uB2E4\uC74C\uC5D4 \uAC19\uC774 \uBCF4\uC790!"
  _nemoLine: "(\uB124\uBAA8\uAC00 \uAC00\uAE4C\uC774 \uAC00\uB824 \uD558\uC790 \uD558\uB140\uAC00
    \uBD80\uB4DC\uB7FD\uAC8C \uB9C9\uB294\uB2E4.)"
