  m_Name: event_w001_house_cousin_1_direct__step_w001_house_cousin_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 \uAD00\uB828 \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "\uD558\uB1401 : \uC624\uB298 \uADF8\uBD84 \uC624\uC2E0\uB2E4\uBA70?\n       
    \n        \uD558\uB1402 : \uC751. \uAD1C\uD788 \uC2E4\uC218 \uC5C6\uAC8C \uD574\uC57C\uC9C0.\n       
    \n        \uB124\uBAA8 : \uB204\uAD6C \uC640?\n        \n\n\uD558\uB1401 : \uBC31\uC791\uB2D8
    \uC0AC\uCD0C\uBD84\uC774 \uC624\uC2E0\uB300\uC694, \uC8FC\uC778\uB2D8.\n       
    \n        \uB124\uBAA8 : \uC0AC\uCD0C?\n        \n        \uD558\uB1402 : \uB124.
    \uBC31\uC791\uB2D8 \uAC00\uC871\uC774\uC2E0 \uC148\uC774\uC9C0\uC694.\n       
    \n        \uB124\uBAA8 : \uAC00\uC871\uC778\uB370 \uC65C \uC774\uB807\uAC8C \uBC14\uBE60?\n       
    \n        \uD558\uB1401 : \uC190\uB2D8\uC73C\uB85C \uC624\uC2DC\uB294 \uAC70\uB2C8\uAE4C\uC694.\n       
    \n        \uD558\uB1402 : \uAC00\uC871\uC774\uC5B4\uB3C4 \uC608\uB97C \uCC28\uB9B4
    \uBD84\uC740 \uCC28\uB824\uC57C \uD55C\uB2F5\uB2C8\uB2E4.\n        \n       
    \uB124\uBAA8 : \uD750\uC751.\n        \n        \uB124\uBAA8 : \uADF8\uB7FC \uB098\uB3C4
    \uC778\uC0AC\uD574\uC57C \uD574?\n        \n        \uD558\uB1401 : \uB124. \uC608\uC058\uAC8C
    \uC778\uC0AC\uD558\uC2DC\uBA74 \uC88B\uC9C0\uC694, \uC8FC\uC778\uB2D8.\n       
    \n        \uB124\uBAA8 : \uC548\uB155\uD558\uC138\uC694, \uD558\uBA74 \uB418\uC9C0?\n       
    \n        \uD558\uB1402 : \uB124. \uC544\uC8FC \uC798\uD558\uC168\uC5B4\uC694."
