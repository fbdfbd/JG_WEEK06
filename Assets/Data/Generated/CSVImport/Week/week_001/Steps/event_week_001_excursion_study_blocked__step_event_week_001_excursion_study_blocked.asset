  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_excursion_study_blocked__step_event_week_001_excursion_study_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: study Blocked
  _bodyText: "excursion study Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uBB38\uD2C8\uC73C\uB85C \uB4E4\uC5B4\uAC00\uB824
      \uD558\uC790 \uC9D1\uC0AC\uC7A5\uC774 \uC870\uC6A9\uD788 \uB2E4\uAC00\uC628\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC774\uCABD\uC740 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uBC31\uC791\uB2D8\uC758 \uC911\uC694\uD55C \uBB3C\uAC74\uC774 \uC788\uB294
      \uACF3\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC800 \uC870\uAE08\uB9CC \uBCFC \uAC74\uB370\uC694."
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC548 \uB429\uB2C8\uB2E4. \uB2E4\uCE58\uC2DC\uAC70\uB098 \uB9DD\uAC00\uB728\uB9AC\uC2DC\uBA74
      \uACE4\uB780\uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774\u2026"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC54C\uACA0\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uBB38 \uC55E\uC744 \uD55C \uBC88 \uB354 \uD790\uB057
      \uBCF4\uACE0 \uB3CC\uC544\uC120\uB2E4.)"
  _nemoLine: "(\uB124\uBAA8\uAC00 \uBB38\uD2C8\uC73C\uB85C \uB4E4\uC5B4\uAC00\uB824
    \uD558\uC790 \uC9D1\uC0AC\uC7A5\uC774 \uC870\uC6A9\uD788 \uB2E4\uAC00\uC628\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
