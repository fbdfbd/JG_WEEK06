  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w001_visitor_cousin_1_direct__step_w001_visitor_cousin_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 1\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uC0AC\uC6A9\uC778\uB4E4\uC774 \uC751\uC811\uC2E4\uC744 \uBD84\uC8FC\uD788
    \uC815\uB9AC\uD558\uACE0 \uC788\uB2E4.)\n        \n                    \uB124\uBAA8
    : \uC5B4? \uC624\uB298 \uC190\uB2D8 \uC640\uC694?\n        \n                   
    \uD558\uB140 : \uC608, \uC8FC\uC778\uB2D8. \uBC31\uC791\uB2D8\uC758 \uC0AC\uCD0C
    \uC5B4\uB974\uC2E0\uAED8\uC11C \uC624\uC2ED\uB2C8\uB2E4.\n        \n                   
    \uB124\uBAA8 : \uC0AC\uCD0C\uC774\uBA74 \uAC00\uC871\uC774\uC9C0?\n        \n                   
    \uD558\uB140 : \uADF8\uB807\uC2B5\uB2C8\uB2E4.\n        \n                   
    \uC624\uB298 \uC624\uB294 \uC190\uB2D8\uC740 \uB298 \uC608\uC758 \uBC14\uB974\uACE0
    \uC0C1\uB0E5\uD558\uB2E4\uACE0 \uB4E4\uC5C8\uC9C0\uB9CC, \uC774\uC0C1\uD558\uAC8C
    \uC9D1\uC0AC\uC7A5 \uD45C\uC815\uC740 \uBCC4\uB85C \uC88B\uC9C0 \uC54A\uC558\uB358
    \uAC83 \uAC19\uAE30\uB3C4 \uD558\uB2E4.\n        \n\n(\uC9D1\uC0AC\uC7A5\uC774
    \uB124\uBAA8\uB97C \uC751\uC811\uC2E4\uB85C \uB370\uB824\uAC04\uB2E4. \uC0AC\uCD0C1\uC740
    \uB2E8\uC815\uD55C \uCC28\uB9BC\uC73C\uB85C \uC18C\uD30C\uC5D0 \uC549\uC544 \uC788\uB2E4.)\n       
    \n                        \uC0AC\uCD0C1 : \uC548\uB155? \uB124\uAC00 \uB124\uBAA8\uAD6C\uB098.\n       
    \n                        \uB124\uBAA8 : \uC548\uB155\uD558\uC138\uC694.\n       
    \n                        \uC0AC\uCD0C1 : \uCC98\uC74C \uBD59\uC2B5\uB2C8\uB2E4
    \uC8FC\uC778\uB2D8.\n        \n                        \uB124\uBAA8 : \uD5E4\uD5E4.\n       
    \n                        \uC0AC\uCD0C1 : \uC774\uB9AC \uC640 \uBCF4\uB834. \uC791\uC740
    \uC120\uBB3C\uC744 \uC900\uBE44\uD588\uB2E8\uB2E4.\n        \n                       
    \uB124\uBAA8 : \uC120\uBB3C?\n        \n                        (\uC0AC\uCD0C1\uC774
    \uC608\uC05C \uC0AC\uD0D5 \uC0C1\uC790\uB97C \uB0B4\uBBFC\uB2E4.)\n        \n                       
    \uB124\uBAA8 : \uC6B0\uC640!\n        \n                        \uC0AC\uCD0C1
    : \uB9C8\uC74C\uC5D0 \uB4DC\uB2C8?\n        \n                        \uB124\uBAA8
    : \uB124! \uAC10\uC0AC\uD569\uB2C8\uB2E4.\n        \n                       
    \uC0AC\uCD0C1 : \uC55E\uC73C\uB85C\uB3C4 \uC885\uC885 \uBCF4\uC790\uAFB8\uB098.\n       
    \n                        \uB124\uBAA8 : \uB124!\n        \n                       
    (\uC0AC\uCD0C1\uC740 \uBD80\uB4DC\uB7FD\uAC8C \uC6C3\uC9C0\uB9CC, \uC9D1\uC0AC\uC7A5\uC740
    \uC606\uC5D0\uC11C \uC870\uC6A9\uD788 \uC9C0\uCF1C\uBCF4\uACE0 \uC788\uB2E4.)"
