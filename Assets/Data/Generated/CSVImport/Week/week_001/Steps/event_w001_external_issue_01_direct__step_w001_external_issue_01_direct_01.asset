  m_Name: event_w001_external_issue_01_direct__step_w001_external_issue_01_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBB38\uC81C 1\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uD604\uAD00 \uADFC\uCC98\uC5D0\uC11C \uC6B0\uD3B8
    \uAFB8\uB7EC\uBBF8\uB97C \uC815\uB9AC\uD558\uACE0 \uC788\uB2E4.)\n        \n       
    (\uD558\uB140\uB294 \uC6B0\uD3B8\uC774 \uB2A6\uC5B4\uC9C4\uB2E4\uB294 \uC548\uB0B4\uBB38\uC744
    \uBC1C\uACAC\uD588\uB2E4.)\n        \n\n\uB124\uBAA8 : \uADF8\uAC74 \uBB50\uC57C?\n           
    \n            \uD558\uB140 : \uC6B0\uD3B8\uC774 \uB2A6\uC5B4\uC9C4\uB2E4\uB294
    \uC548\uB0B4\uBB38\uC774\uC5D0\uC694, \uC8FC\uC778\uB2D8.\n            \n           
    \uB124\uBAA8 : \uC65C \uB2A6\uC5B4?\n            \n            \uD558\uB140 :
    \uBE44\uAC00 \uB9CE\uC774 \uC640\uC11C \uAE38\uC774 \uC9C8\uC5B4\uC84C\uB300\uC694.\n           
    \n            \uB124\uBAA8 : \uADF8\uB7FC \uB9C8\uCC28\uAC00 \uBABB \uC640?\n           
    \n            \uD558\uB140 : \uB124. \uBC14\uD034\uAC00 \uBE60\uC9C0\uAE30\uB3C4
    \uD558\uACE0, \uCC9C\uCC9C\uD788 \uC640\uC57C \uD55C\uB300\uC694.\n           
    \n            \uB124\uBAA8 : \uD3B8\uC9C0\uB3C4 \uC816\uC5B4?\n            \n           
    \uD558\uB140 : \uADF8\uB798\uC11C \uC798 \uC2F8\uC11C \uC628\uB2F5\uB2C8\uB2E4.\n           
    \n            \uB124\uBAA8 : \uBA3C \uB370\uC11C\uB3C4 \uC5EC\uAE30\uAE4C\uC9C0
    \uC624\uB294\uAD6C\uB098."
