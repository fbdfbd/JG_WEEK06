  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w001_excursion_basement_direct__step_w001_excursion_basement_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 1\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uB124\uBAA8\uAC00 \uC0AC\uC6A9\uC778\uACFC \uC228\uBC14\uAF2D\uC9C8\uC744
    \uD558\uACE0 \uC788\uB2E4.)\r\n        \r\n                    \uB124\uBAA8 :
    \uAF2D\uAF2D \uC228\uC5B4\uB77C\u2026\r\n        \r\n                    \uB124\uBAA8
    : \uC5B4\uB514 \uC228\uC9C0?\r\n        \r\n                    (\uB124\uBAA8\uAC00
    \uBCF5\uB3C4\uB97C \uB450\uB9AC\uBC88\uAC70\uB9AC\uB2E4 \uBC18\uCBE4 \uC5F4\uB9B0
    \uC9C0\uD558\uC2E4 \uBB38\uC744 \uBC1C\uACAC\uD55C\uB2E4.)\r\n        \r\n                   
    \uB124\uBAA8 : \uC5B4? \uC5EC\uAE30 \uC228\uC73C\uBA74 \uBABB\uCC38\uACA0\uC9C0?\r\n       
    \r\n\r\n(\uB124\uBAA8\uAC00 \uC9C0\uD558\uC2E4 \uBB38 \uC55E\uC5D0 \uC11C \uC788\uC790
    \uCC3D\uACE0\uC9C0\uAE30\uAC00 \uB2E4\uAC00\uC628\uB2E4.)\r\n        \r\n                       
    \uCC3D\uACE0\uC9C0\uAE30 : \uC8FC\uC778\uB2D8, \uC548\uCABD\uC740 \uC548 \uB429\uB2C8\uB2E4.\r\n       
    \r\n                        \uB124\uBAA8 : \uADF8\uB7FC \uC5EC\uAE30 \uC870\uAE08\uB9CC\uC740\uC694?\r\n       
    \r\n                        \uCC3D\uACE0\uC9C0\uAE30 : \uC785\uAD6C \uCABD\uAE4C\uC9C0\uB9CC
    \uAC00\uB2A5\uD569\uB2C8\uB2E4.\r\n        \r\n                        \uB124\uBAA8
    : \uC9C4\uC9DC\uC694?\r\n        \r\n                        \uCC3D\uACE0\uC9C0\uAE30
    : \uC608. \uC774 \uC0C1\uC790 \uB4A4\uC5D0 \uC228\uC73C\uC2DC\uBA74 \uB429\uB2C8\uB2E4.\r\n       
    \r\n                        \uB124\uBAA8 : \uC640, \uC5EC\uAE30 \uC88B\uB2E4.\r\n       
    \r\n                        (\uB124\uBAA8\uB294 \uC785\uAD6C \uCABD \uC0C1\uC790
    \uB4A4\uC5D0 \uC3D9 \uC228\uB294\uB2E4.)\r\n        \r\n                       
    \uB124\uBAA8 : \uD5E4\uD5E4, \uC5EC\uAE30\uBA74 \uBABB \uCC3E\uACA0\uB2E4."
