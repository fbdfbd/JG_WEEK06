  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_101_child_excursion_garden_01_blocked__step_101_child_excursion_garden_01_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 1\uCC28 - \uD1B5\uC81C"
  _bodyText: "\uC815\uC6D0\uC5D0\uC11C \uB098\uBE44\uB97C \uCAD3\uB358 \uB124\uBAA8\uAC00
    \uD6C4\uBB38 \uB108\uBA38\uB85C \uAC00\uB824\uB294 \uC21C\uAC04 \uC815\uC6D0\uC0AC\uAC00
    \uAE38\uC744 \uB9C9\uB294\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC640, \uB098\uBE44\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4? \uC800\uAE30\uB85C \uAC14\uB124. \uC7A1\uACE0 \uC2F6\uC740\uB370\u2026"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC8FC\uC778\uB2D8~ \uADF8\uCABD\uC740 \uC548 \uB429\uB2C8\uB2E4~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uB4A4\uCABD\uC740 \uAE38\uC774 \uBBF8\uB044\uB7FD\uACE0, \uD63C\uC790
      \uAC00\uC2DC\uBA74 \uC704\uD5D8\uD569\uB2C8\uB2E4~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774\u2026 \uC870\uAE08\uB9CC\uC778\uB370."
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uB2E4\uC74C\uC5D0 \uC5B4\uB978\uC774 \uAC19\uC774 \uC788\uC744 \uB54C
      \uAC00 \uBCF4\uC2DC\uC9C0\uC694~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uC54C\uACA0\uC5B4\uC694."
  _nemoLine: "\uC640, \uB098\uBE44\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
