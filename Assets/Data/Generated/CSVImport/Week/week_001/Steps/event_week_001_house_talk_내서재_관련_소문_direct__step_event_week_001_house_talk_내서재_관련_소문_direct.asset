  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: "event_week_001_house_talk_\uB0B4\uC11C\uC7AC_\uAD00\uB828_\uC18C\uBB38_direct__step_event_week_001_house_talk_\uB0B4\uC11C\uC7AC_\uAD00\uB828_\uC18C\uBB38_direct"
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC_\uAD00\uB828_\uC18C\uBB38 Direct"
  _bodyText: "house_talk \uB0B4\uC11C\uC7AC_\uAD00\uB828_\uC18C\uBB38 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uBC31\uC791\uB2D8 \uC11C\uC7AC \uC55E\uC774\uB77C \uADF8\uB798\uC694,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uBC31\uC791\uB2D8\uAED8\uC11C \uC5EC\uAE30\uC11C \uC911\uC694\uD55C
      \uC77C\uC744 \uD558\uC2DC\uAC70\uB4E0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC911\uC694\uD55C \uC77C?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uB124. \uD3B8\uC9C0\uB3C4 \uC77D\uC73C\uC2DC\uACE0, \uC11C\uB958\uB3C4
      \uBCF4\uC2DC\uACE0, \uC0DD\uAC01\uB3C4 \uB9CE\uC774 \uD558\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB798\uC11C \uB2E4\uB4E4 \uC228 \uC791\uC544\uC838?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uBC29\uD574\uB418\uBA74 \uC548 \uB418\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD750\uC751."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB34\uC11C\uC6B4 \uB370\uB294 \uC544\uB2C8\uB124."
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uB124. \uC870\uC6A9\uD788 \uD574\uC57C \uD558\uB294 \uACF3\uC774\uC5D0\uC694,
      \uC8FC\uC778\uB2D8."
  _nemoLine: "\uBC31\uC791\uB2D8 \uC11C\uC7AC \uC55E\uC774\uB77C \uADF8\uB798\uC694,
    \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
