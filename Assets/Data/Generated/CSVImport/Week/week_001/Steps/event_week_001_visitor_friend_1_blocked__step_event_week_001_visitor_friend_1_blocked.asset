  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_visitor_friend_1_blocked__step_event_week_001_visitor_friend_1_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9C9\uC2A4 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor friend_1 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC2E0\uB09C \uC5BC\uAD74\uB85C \uB2E4\uAC00\uAC00\uB824
      \uD558\uC790 \uD558\uB140\uAC00 \uC870\uC2EC\uC2A4\uB7FD\uAC8C \uB9C9\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC624\uB798 \uB180\uBA74 \uC548
      \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC190\uB2D8\uB3C4 \uAE08\uBC29 \uB3CC\uC544\uAC00\uC2E4 \uD14C\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uC7A0\uAE50\uB9CC \uB180\uC544\uB3C4 \uC548 \uB3FC?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC624\uB298\uC740 \uC778\uC0AC\uB9CC \uD558\uC154\uC57C \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774\u2026"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC19\uC774 \uB180\uACE0 \uC2F6\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uAD1C\uCC2E\uC544. \uB2E4\uC74C\uC5D0 \uB610 \uBCF4\uC790!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uC751. \uB2E4\uC74C\uC5D0."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uCE5C\uAD6C1\uC740 \uC190\uC744 \uD754\uB4E4\uACE0, \uB124\uBAA8\uB3C4
      \uC870\uAE08 \uC2DC\uBB34\uB8E9\uD55C \uC5BC\uAD74\uB85C \uB530\uB77C \uD754\uB4E0\uB2E4.)"
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC2E0\uB09C \uC5BC\uAD74\uB85C \uB2E4\uAC00\uAC00\uB824
    \uD558\uC790 \uD558\uB140\uAC00 \uC870\uC2EC\uC2A4\uB7FD\uAC8C \uB9C9\uB294\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
