  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w001_visitor_friend_1_blocked__step_w001_visitor_friend_1_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 1\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uC815\uC6D0 \uADFC\uCC98 \uC751\uC811\uC2E4 \uC55E. \uB610\uB798
    \uC544\uC774 \uD558\uB098\uAC00 \uD63C\uC790 \uBCF5\uB3C4 \uC7A5\uC2DD\uD488\uC744
    \uAD6C\uACBD\uD558\uBA70 \uC11C \uC788\uB2E4.)\r\n        \r\n                   
    \uB124\uBAA8 : \uC5B4?\r\n        \r\n                    \uB124\uBAA8 : \uC7E4\uB3C4
    \uC190\uB2D8\uC774\uC57C?\r\n        \r\n                    \uD558\uB140 : \uC608,
    \uC8FC\uC778\uB2D8. \uC624\uB298\uC740 \uB610\uB798 \uC190\uB2D8\uB3C4 \uD568\uAED8
    \uC654\uB2F5\uB2C8\uB2E4.\r\n        \r\n                    (\uADF8 \uC544\uC774\uAC00
    \uB124\uBAA8\uB97C \uBC1C\uACAC\uD558\uACE0 \uBA3C\uC800 \uB2E4\uAC00\uC628\uB2E4.)\r\n       
    \r\n                    \uCE5C\uAD6C1 : \uC548\uB155! \uB108 \uB124\uBAA8\uC9C0?\r\n       
    \r\n                    \uB124\uBAA8 : \uC5B4? \uC751.\r\n        \r\n                   
    \uCE5C\uAD6C1 : \uB09C \u25CB\u25CB\uC774\uC57C. \uC6B0\uB9AC \uAC19\uC774 \uB180\uB798?\r\n       
    \r\n                    \uC800 \uC544\uC774\uB294 \uB0AF\uC744 \uAC00\uB9AC\uC9C0
    \uC54A\uACE0 \uAE08\uBC29 \uCE5C\uD574\uC9C0\uB294 \uC131\uACA9\uC774\uB77C\uACE0
    \uB4E4\uC740 \uC801\uC774 \uC788\uB2E4.\r\n        \r\n\r\n(\uB124\uBAA8\uAC00
    \uC2E0\uB09C \uC5BC\uAD74\uB85C \uB2E4\uAC00\uAC00\uB824 \uD558\uC790 \uD558\uB140\uAC00
    \uC870\uC2EC\uC2A4\uB7FD\uAC8C \uB9C9\uB294\uB2E4.)\r\n        \r\n                       
    \uD558\uB140 : \uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC624\uB798 \uB180\uBA74
    \uC548 \uB429\uB2C8\uB2E4.\r\n        \r\n                        \uB124\uBAA8
    : \uC65C\uC694?\r\n        \r\n                        \uD558\uB140 : \uC190\uB2D8\uB3C4
    \uAE08\uBC29 \uB3CC\uC544\uAC00\uC2E4 \uD14C\uB2C8\uAE4C\uC694.\r\n        \r\n                       
    \uCE5C\uAD6C1 : \uC7A0\uAE50\uB9CC \uB180\uC544\uB3C4 \uC548 \uB3FC?\r\n       
    \r\n                        \uD558\uB140 : \uC624\uB298\uC740 \uC778\uC0AC\uB9CC
    \uD558\uC154\uC57C \uD569\uB2C8\uB2E4.\r\n        \r\n                       
    \uB124\uBAA8 : \uC5D0\uC774\u2026\r\n        \r\n                        \uB124\uBAA8
    : \uAC19\uC774 \uB180\uACE0 \uC2F6\uC740\uB370.\r\n        \r\n                       
    \uCE5C\uAD6C1 : \uAD1C\uCC2E\uC544. \uB2E4\uC74C\uC5D0 \uB610 \uBCF4\uC790!\r\n       
    \r\n                        \uB124\uBAA8 : \u2026\u2026\uC751. \uB2E4\uC74C\uC5D0.\r\n       
    \r\n                        (\uCE5C\uAD6C1\uC740 \uC190\uC744 \uD754\uB4E4\uACE0,
    \uB124\uBAA8\uB3C4 \uC870\uAE08 \uC2DC\uBB34\uB8E9\uD55C \uC5BC\uAD74\uB85C \uB530\uB77C
    \uD754\uB4E0\uB2E4.)"
