  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 1\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uBCF5\uB3C4 \uB05D. \uB610\uB798 \uC544\uC774 \uD558\uB098\uAC00
    \uCC3D\uD2C0\uC5D0 \uC5BC\uAD74\uC744 \uBC14\uC9DD \uBD99\uC774\uACE0 \uBC16\uC744
    \uBCF4\uACE0 \uC788\uB2E4.)\r\n        \r\n                    \uB124\uBAA8 :
    \uC5B4? \uC548\uB155? \uB10C \uB204\uAD6C\uC57C?\r\n        \r\n                   
    \uCE5C\uAD6C3 : \uC800 \uAD6C\uB984 \uBD10. \uBE75 \uAC19\uC544.\r\n        \r\n                   
    \uB124\uBAA8 : \uBE75?\r\n        \r\n                    \uCE5C\uAD6C3 : \uC751.
    \uB72F\uC5B4 \uBA39\uACE0 \uC2F6\uC5B4.\r\n        \r\n                    \uB124\uBAA8
    :  \uB108\uB3C4? \uB098\uB3C4 \uADF8\uB7F0 \uC0DD\uAC01 \uB4E0\uC801 \uC788\uC5B4\r\n       
    \r\n                    \uC800 \uC544\uC774\uB294 \uCC98\uC74C \uBCF4\uB294 \uC0AC\uB78C\uD558\uACE0\uB3C4
    \uAE08\uBC29 \uB9D0\uC744 \uC11E\uACE0, \uAC00\uB054 \uC5C9\uB6B1\uD55C \uC18C\uB9AC\uB97C
    \uD55C\uB2E4\uACE0 \uB4E4\uC740 \uC801\uC774 \uC788\uB2E4.\r\n        \r\n\r\n(\uB124\uBAA8\uAC00
    \uAC00\uAE4C\uC774 \uAC00\uB824 \uD558\uC790 \uD558\uB140\uAC00 \uBD80\uB4DC\uB7FD\uAC8C
    \uB9C9\uB294\uB2E4.)\r\n        \r\n                        \uD558\uB140 : \uC8FC\uC778\uB2D8,
    \uC624\uB298\uC740 \uC9E7\uAC8C \uC778\uC0AC\uB9CC \uD558\uC154\uC57C \uD569\uB2C8\uB2E4.\r\n       
    \r\n                        \uB124\uBAA8 : \uC65C\uC694?\r\n        \r\n                       
    \uD558\uB140 : \uC8FC\uC778\uB2D8.\r\n        \r\n                        \uB124\uBAA8
    : \uC5D0\uC774\u2026\r\n        \r\n                        \uB124\uBAA8 : \uC548\uB155.\r\n       
    \r\n                        \uCE5C\uAD6C3 : \uC548\uB155! \uB2E4\uC74C\uC5D4
    \uAC19\uC774 \uBCF4\uC790!\r\n        \r\n                        ~~"
