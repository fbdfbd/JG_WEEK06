  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_visitor_cousin_1_blocked__step_event_week_001_visitor_cousin_1_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: cousin_1 Blocked
  _bodyText: "visitor cousin_1 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC751\uC811\uC2E4 \uCABD\uC73C\uB85C \uAC00\uB824
      \uD558\uC790 \uC9D1\uC0AC\uC7A5\uC774 \uC55E\uC744 \uB9C9\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC751\uC811\uC2E4\uC5D0 \uAC00\uC2DC\uBA74
      \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC5B4\uB978\uB4E4\uB07C\uB9AC \uD560 \uC774\uC57C\uAE30\uAC00 \uC788\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uAC00\uC871\uC778\uB370?"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC624\uB298\uC740 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774\u2026"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC7A0\uAE50\uB9CC \uBCF4\uBA74 \uC548 \uB3FC\uC694?"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uC54C\uACA0\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uC751\uC811\uC2E4 \uBB38 \uCABD\uC744 \uD790\uB054
      \uBCF4\uACE0 \uB3CC\uC544\uAC04\uB2E4.)"
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC751\uC811\uC2E4 \uCABD\uC73C\uB85C \uAC00\uB824
    \uD558\uC790 \uC9D1\uC0AC\uC7A5\uC774 \uC55E\uC744 \uB9C9\uB294\uB2E4.)"
