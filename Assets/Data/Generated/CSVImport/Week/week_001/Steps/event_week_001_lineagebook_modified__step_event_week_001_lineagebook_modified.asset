  m_Name: event_week_001_lineagebook_modified__step_event_week_001_lineagebook_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uAC00\uACC4\uB3C4 \uAE30\uB85D\uC5D0 \uB9E5\uB77D\uC744 \uBD99\uC5EC
    \uC124\uBA85\uD55C\uB2E4"
  _bodyText: "\uAC00\uACC4\uB3C4 \uAD50\uC7AC \uAD50\uC7AC Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB531\uB531\uD55C \uAE30\uB85D\uB9CC \uC77D\uC9C0 \uC54A\uACE0, \uC778\uBB3C
      \uC0AC\uC774 \uAD00\uACC4\uB97C \uC26C\uC6B4 \uB9D0\uB85C \uB367\uBD99\uC5EC
      \uC124\uBA85\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uB807\uAC8C \uB4E4\uC73C\uB2C8\uAE4C \uC880 \uC54C\uC544\uB4E3\uACA0\uC5B4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uB0AF\uC120 \uC774\uB984\uC774 \uACB9\uCE58\uC9C0 \uC54A\uAC8C \uC21C\uC11C\uB97C
      \uC815\uB9AC\uD574 \uBCF4\uC5EC \uC900\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uC74C\uC5D4 \uC800\uCABD \uAC00\uC9C0\uB3C4 \uC54C\uB824 \uC918\uC694."
  _nemoLine: "(\uB531\uB531\uD55C \uAE30\uB85D\uB9CC \uC77D\uC9C0 \uC54A\uACE0, \uC778\uBB3C
    \uC0AC\uC774 \uAD00\uACC4\uB97C \uC26C\uC6B4 \uB9D0\uB85C \uB367\uBD99\uC5EC
    \uC124\uBA85\uD55C\uB2E4.)"
