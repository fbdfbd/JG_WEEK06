  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_external_w001_direct__step_event_week_001_external_w001_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCD95\uC81C \uC815\uBCF4 \uD5C8\uAC00"
  _bodyText: "external w001 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC70 \uBB50\uC57C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB9C8\uC744 \uC911\uC559\uC5D0\uC11C \uCD95\uC81C\uAC00 \uC5F4\uB9B0\uB2E4\uB294
      \uAE00\uC774\uC5D0\uC694, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uCD95\uC81C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uCC9C\uB3C4 \uAC78\uACE0, \uAC04\uC2DD\uB3C4 \uD314\uACE0, \uB178\uB798\uB3C4
      \uD55C\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uB9DB\uC788\uB294 \uAC83\uB3C4 \uB9CE\uC544?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uB2EC\uCF64\uD55C \uAC83\uB3C4 \uB9CE\uB2E4\uACE0 \uB4E4\uC5C8\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uAC00 \uBCF4\uACE0 \uC2F6\uB2E4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC815\uB9D0 \uC88B\uC544\uD558\uC2E4 \uAC83 \uAC19\uB124\uC694, \uC8FC\uC778\uB2D8."
  _nemoLine: "\uADF8\uAC70 \uBB50\uC57C?"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
