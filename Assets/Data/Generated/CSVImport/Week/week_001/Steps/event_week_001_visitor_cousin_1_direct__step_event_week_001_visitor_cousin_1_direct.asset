MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_visitor_cousin_1_direct__step_event_week_001_visitor_cousin_1_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: cousin_1 Direct
  _bodyText: "visitor cousin_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC9D1\uC0AC\uC7A5\uC774 \uB124\uBAA8\uB97C \uC751\uC811\uC2E4\uB85C
      \uB370\uB824\uAC04\uB2E4. \uC0AC\uCD0C1\uC740 \uB2E8\uC815\uD55C \uCC28\uB9BC\uC73C\uB85C
      \uC18C\uD30C\uC5D0 \uC549\uC544 \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uC548\uB155? \uB124\uAC00 \uB124\uBAA8\uAD6C\uB098."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548\uB155\uD558\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uCC98\uC74C \uBD59\uC2B5\uB2C8\uB2E4 \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5E4\uD5E4."
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uC774\uB9AC \uC640 \uBCF4\uB834. \uC791\uC740 \uC120\uBB3C\uC744 \uC900\uBE44\uD588\uB2E8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC120\uBB3C?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC0AC\uCD0C1\uC774 \uC608\uC05C \uC0AC\uD0D5 \uC0C1\uC790\uB97C \uB0B4\uBBFC\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640!"
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uB9C8\uC74C\uC5D0 \uB4DC\uB2C8?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB124! \uAC10\uC0AC\uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uC55E\uC73C\uB85C\uB3C4 \uC885\uC885 \uBCF4\uC790\uAFB8\uB098."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB124!"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC0AC\uCD0C1\uC740 \uBD80\uB4DC\uB7FD\uAC8C \uC6C3\uC9C0\uB9CC, \uC9D1\uC0AC\uC7A5\uC740
      \uC606\uC5D0\uC11C \uC870\uC6A9\uD788 \uC9C0\uCF1C\uBCF4\uACE0 \uC788\uB2E4.)"
  _nemoLine: "(\uC9D1\uC0AC\uC7A5\uC774 \uB124\uBAA8\uB97C \uC751\uC811\uC2E4\uB85C
    \uB370\uB824\uAC04\uB2E4. \uC0AC\uCD0C1\uC740 \uB2E8\uC815\uD55C \uCC28\uB9BC\uC73C\uB85C
    \uC18C\uD30C\uC5D0 \uC549\uC544 \uC788\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
