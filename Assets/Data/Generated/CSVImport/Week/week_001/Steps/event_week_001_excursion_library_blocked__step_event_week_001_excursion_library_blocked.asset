  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_excursion_library_blocked__step_event_week_001_excursion_library_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: library Blocked
  _bodyText: "excursion library Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC11C\uACE0\uAD00\uB9AC\uC778\uC774 \uB124\uBAA8\uB97C \uBCF4\uACE0
      \uB2E4\uAC00\uC628\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uADF8 \uCC45\uC740 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uB192\uC740 \uACF3\uC5D0 \uC788\uC5B4\uC11C \uC704\uD5D8\uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC800 \uC870\uAE08\uB9CC \uBCFC \uAC74\uB370."
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uC548 \uB429\uB2C8\uB2E4. \uC544\uC9C1 \uC8FC\uC778\uB2D8\uAED8\uB294
      \uC5B4\uB824\uC6B4 \uCC45\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774\u2026"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB9BC\uB3C4 \uC548 \uB3FC\uC694?"
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uC774\uCABD \uCC45\uC740 \uBCF4\uC154\uB3C4 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uC54C\uACA0\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uC2DC\uBB34\uB8E9\uD574\uD558\uC9C0\uB9CC \uAD00\uB9AC\uC778\uC774
      \uB0B4\uC5B4 \uC900 \uADF8\uB9BC\uCC45\uC744 \uBCF8\uB2E4.)"
  _nemoLine: "(\uC11C\uACE0\uAD00\uB9AC\uC778\uC774 \uB124\uBAA8\uB97C \uBCF4\uACE0
    \uB2E4\uAC00\uC628\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
