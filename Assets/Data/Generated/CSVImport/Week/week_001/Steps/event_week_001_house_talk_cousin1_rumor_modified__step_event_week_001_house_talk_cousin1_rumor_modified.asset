  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_001_house_talk_cousin1_rumor_modified__step_event_week_001_house_talk_cousin1_rumor_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE74\uC774\uC548 \uAD00\uB828 \uC18C\uBB38 \uC218\uC815"
  _bodyText: "house_talk \uC0AC\uCD0C1_\uAD00\uB828_\uC18C\uBB38 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uBC31\uC791\uB2D8\uC774 \uC624\uB798\uC804\uBD80\uD130 \uC544\uC2DC\uB358
      \uBD84\uC774 \uC624\uC2E0\uB300\uC694, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uCE5C\uAD6C\uC57C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uBE44\uC2B7\uD574\uC694. \uC544\uC8FC \uAC00\uAE4C\uC6B4 \uBD84\uC774\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC00\uC871\uC740 \uC544\uB2C8\uC57C?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC74C\u2026 \uBC31\uC791\uB2D8\uACFC \uC624\uB798 \uC54C\uACE0 \uC9C0\uB0B8
      \uBD84\uC774\uB77C\uACE0 \uC0DD\uAC01\uD558\uC2DC\uBA74 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD750\uC751."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uADF8\uB0E5 \uCE5C\uD55C \uC190\uB2D8\uC774\uB124."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uADF8\uB807\uAC8C \uC0DD\uAC01\uD558\uC154\uB3C4 \uB429\uB2C8\uB2E4,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC54C\uACA0\uC5B4."
  _nemoLine: "\uBC31\uC791\uB2D8\uC774 \uC624\uB798\uC804\uBD80\uD130 \uC544\uC2DC\uB358
    \uBD84\uC774 \uC624\uC2E0\uB300\uC694, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
