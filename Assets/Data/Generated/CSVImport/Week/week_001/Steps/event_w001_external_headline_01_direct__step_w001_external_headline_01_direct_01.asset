  m_Name: event_w001_external_headline_01_direct__step_w001_external_headline_01_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB274\uC2A4 1\uCC28 - \uD5C8\uB77D"
  _bodyText: "\uD558\uB140\uAC00 \uBC14\uAE65 \uC18C\uC2DD\uC774 \uC801\uD78C \uC804\uB2E8\uC744
    \uB4E4\uACE0 \uC788\uB2E4.)\r\n        \r\n                    (\uC804\uB2E8\uC5D0\uB294
    \uC655\uAD6D\uC758 \uC720\uBA85\uD55C \uBBF8\uC2A4\uD130 \uC784\uC774 \uBD81\uCABD
    \uB9C8\uC218\uB4E4\uC758 \uC6B0\uB450\uBA38\uB9AC\uB97C \uD574\uCE58\uC6B0\uACE0
    \uB3CC\uC544\uC654\uB2E4\uB294 \uAE00\uC774 \uC801\uD600 \uC788\uB2E4.)\r\n       
    \r\n\r\n\uB124\uBAA8 : \uADF8\uAC74 \uBB50\uC57C?\r\n        \r\n                       
    \uD558\uB140 : \uC655\uAD6D\uC5D0\uC11C \uC720\uBA85\uD55C \uBBF8\uC2A4\uD130
    \uC784\uC774\uB77C\uB294 \uC0AC\uB78C\uC774, \uBD81\uCABD \uB9C8\uC218\uB4E4\uC758
    \uC6B0\uB450\uBA38\uB9AC\uB97C \uD574\uCE58\uC6B0\uACE0 \uB3CC\uC544\uC654\uB2E4\uB294
    \uC18C\uC2DD\uC774\uC5D0\uC694, \uC8FC\uC778\uB2D8.\r\n        \r\n                       
    \uB124\uBAA8 : \uC6B0\uB450\uBA38\uB9AC?\r\n        \r\n                       
    \uD558\uB140 : \uB124. \uBD81\uCABD\uC5D4 \uC0AC\uB098\uC6B4 \uB9C8\uC218\uB4E4\uC774
    \uB9CE\uC740\uB370, \uADF8\uC911 \uC81C\uC77C \uBB34\uC11C\uC6B4 \uB188\uC774\uC5C8\uB2E4\uACE0\uB4E4
    \uD574\uC694.\r\n        \r\n                        \uB124\uBAA8 : \uC9C4\uC9DC?
    \uC6B0\uC640. \uBBF8\uC2A4\uD130 \uC784\uC740 \uC5C4\uCCAD \uC13C\uAC00 \uBCF4\uB2E4.\r\n       
    \r\n                        \uD558\uB140 : \uB2E4\uB4E4 \uADF8\uB807\uAC8C \uB9D0\uD558\uB354\uAD70\uC694,
    \uC8FC\uC778\uB2D8.\r\n        \r\n                        \uB124\uBAA8 : \uB098\uB3C4
    \uBCF4\uACE0 \uC2F6\uB2E4."
