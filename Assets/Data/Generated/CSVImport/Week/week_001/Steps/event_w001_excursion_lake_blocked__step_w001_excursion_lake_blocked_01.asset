  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 1\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uCA0D\uD55C \uC810\uC2EC. \uC815\uC6D0\uC744 \uAC77\uB358 \uB124\uBAA8\uAC00
    \uB098\uBE44\uB97C \uBC1C\uACAC\uD55C\uB2E4.)\r\n        \r\n                   
    \uB124\uBAA8 : \uC640, \uB098\uBE44\uB2E4.\r\n        \r\n                   
    (\uB098\uBE44\uAC00 \uD6C4\uBB38 \uB108\uBA38\uB85C \uB0A0\uC544\uAC04\uB2E4.)\r\n       
    \r\n                    \uB124\uBAA8 : \uC5B4? \uC800\uAE30\uB85C \uAC14\uB124.\r\n       
    \r\n                    \uB124\uBAA8 : \uC7A1\uACE0 \uC2F6\uC740\uB370\u2026\r\n       
    \r\n                    (\uC5B8\uC820\uAC00 \uB124\uBAA8\uB294 \uC8FC\uC704\uC5D0
    \uB291\uB300\uAC00 \uCD9C\uBAB0\uD55C\uB2E8 \uC598\uAE30\uB97C \uB4E4\uC740\uAC83
    \uAC19\uB2E4)\r\n        \r\n\r\n(\uD6C4\uBB38\uC73C\uB85C \uAC00\uB824\uB294
    \uC21C\uAC04, \uC815\uB9AC\uB97C \uD558\uB358 \uC815\uC6D0\uC0AC\uAC00 \uC55E\uC744
    \uB9C9\uB294\uB2E4.)\r\n        \r\n                        \uC815\uC6D0\uC0AC
    : \uC8FC\uC778\uB2D8~ \uADF8\uCABD\uC740 \uC548 \uB429\uB2C8\uB2E4~\r\n       
    \r\n                        \uB124\uBAA8 : \uC65C\uC694?\r\n        \r\n                       
    \uC815\uC6D0\uC0AC : \uC694\uC998 \uADF8\uCABD\uC5D0 \uBB34\uC11C\uC6B4 \uC9D0\uC2B9\uC774
    \uB098\uC628\uB2F5\uB2C8\uB2E4~\r\n        \r\n                        \uB124\uBAA8
    : \uD5C9. \uC9C4\uC9DC\uC694?\r\n        \r\n                        \uC815\uC6D0\uC0AC
    : \uC608~ \uB2E4\uCE58\uC2DC\uBA74 \uD070\uC77C \uB098\uC9C0\uC694~\r\n       
    \r\n                        \uB124\uBAA8 : \u2026\u2026\uADF8\uB7FC \uC548 \uAC08\uB798\uC694.\r\n       
    \r\n                        \uC2A4\uD0EF\uBCC0\uD654 : \uC2E0\uB8B0+"
