  _titleOverride: "\uB3D9\uD654\uB97C \uC7AC\uBBF8\uC788\uAC8C \uD480\uC5B4 \uC77D\uD78C\uB2E4"
  _bodyText: "\uB3D9\uD654\uC640 \uAE00\uC790 \uAD50\uC7AC Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB4F1\uC7A5\uC778\uBB3C \uBAA9\uC18C\uB9AC\uB97C \uD749\uB0B4 \uB0B4\uBA70
      \uB3D9\uD654\uB97C \uB354 \uC27D\uAC8C \uC77D\uAC8C \uB9CC\uB4E0\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774 \uC0AC\uB78C \uBAA9\uC18C\uB9AC \uC774\uC0C1\uD574."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uC6C3\uC74C\uC774 \uB04A\uAE30\uC9C0 \uC54A\uAC8C \uC774\uC57C\uAE30\uB97C
      \uC11E\uC5B4 \uAE00\uC790\uB97C \uC775\uD788\uAC8C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB2E4\uC74C \uC7A5\uB3C4 \uBE68\uB9AC \uC77D\uACE0 \uC2F6\uC5B4."
  _nemoLine: "(\uB4F1\uC7A5\uC778\uBB3C \uBAA9\uC18C\uB9AC\uB97C \uD749\uB0B4 \uB0B4\uBA70
    \uB3D9\uD654\uB97C \uB354 \uC27D\uAC8C \uC77D\uAC8C \uB9CC\uB4E0\uB2E4.)"
