  _titleOverride: "\uC218\uC0C1\uD55C \uC9C8\uBB38"
  _bodyText: "\uB124\uBAA8\uAC00 \uD3B8\uC9C0 \uC774\uC57C\uAE30\uB97C \uB2E4\uC2DC
    \uBB3B\uB294\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8 \uD3B8\uC9C0 \uB9D0\uC774\uC57C. \uC65C \uC870\uAE08 \uC774\uC0C1\uD588\uC5B4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC624\uB298\uC740 \uC804\uBD80 \uB9D0\uC500\uB4DC\uB9AC\uAE30 \uC5B4\uB824\uC6E0\uC2B5\uB2C8\uB2E4."
  _nemoLine: "\uADF8 \uD3B8\uC9C0 \uB9D0\uC774\uC57C. \uC65C \uC870\uAE08 \uC774\uC0C1\uD588\uC5B4."
