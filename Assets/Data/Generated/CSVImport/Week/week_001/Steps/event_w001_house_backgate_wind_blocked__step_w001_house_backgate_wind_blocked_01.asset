  m_Name: event_w001_house_backgate_wind_blocked__step_w001_house_backgate_wind_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD6C4\uBB38 \uBC14\uB78C \uAD00\uB828 \uC18C\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uD604\uAD00 \uCABD \uBCF5\uB3C4. \uD558\uB140 \uB458\uC774 \uC816\uC740
    \uC6B0\uC0B0\uC744 \uD138\uBA70 \uD22C\uB35C\uAC70\uB9B0\uB2E4.)\n        \n       
    \uD558\uB1401 : \uD6C4\uBB38 \uCABD \uBC14\uB78C\uC740 \uC6B0\uC0B0\uC774\uB791
    \uC6D0\uC218\uC57C.\n        \n        \uD558\uB1402 : \uC5B4\uC81C\uB3C4 \uD558\uB098
    \uB4A4\uC9D1\uD614\uC796\uC544.\n        \n        \uB124\uBAA8 : \uC6B0\uC0B0\uC774
    \uB4A4\uC9D1\uD600?\n        \n\n\uD558\uB1401 : \uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4,
    \uC8FC\uC778\uB2D8.\n        \n        \uB124\uBAA8 : \uBC29\uAE08 \uC6B0\uC0B0
    \uB4A4\uC9D1\uD78C\uB314\uC796\uC544.\n        \n        \uD558\uB1402 : \uADF8\uB0E5
    \uC624\uB798\uB41C \uC6B0\uC0B0\uC774\uC5C8\uC5B4\uC694.\n        \n        \uB124\uBAA8
    : \uBC14\uB78C \uB54C\uBB38 \uC544\uB2C8\uC57C?\n        \n        \uD558\uB1401
    : \uC544\uB2C8\uC5D0\uC694. \uC800\uD76C\uAC00 \uC798\uBABB \uD3B8 \uAC70\uC608\uC694.\n       
    \n        \uB124\uBAA8 : \uADF8\uB7FC \uC6B0\uC0B0\uC774 \uBA4D\uCCAD\uD55C \uAC70\uB124.\n       
    \n        \uD558\uB1402 : \u2026\uADF8\uB7F4 \uC218\uB3C4 \uC788\uACA0\uB124\uC694,
    \uC8FC\uC778\uB2D8."
