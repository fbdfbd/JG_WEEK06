  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w004_visitor_cousin_2_blocked__step_w004_visitor_cousin_2_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 4\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uBC31\uC791\uC758 \uC11C\uC7AC, \uC0AC\uCD0C 2\uAC00 \uBB38\uC55E\uC5D0\uC11C
    \uCB48\uBF1B\uAC70\uB9AC\uBA70 \uB4E4\uC5B4\uC624\uC9C0 \uBABB\uD558\uACE0 \uC788\uB2E4.
    \uB124\uBAA8\uAC00 \uBC1C\uACAC\uD558\uACE0 \uADF8\uB97C \uC548\uC73C\uB85C \uB04C\uC5B4\uB2F9\uAE34\uB2E4.)\n       
    \n        \uB124\uBAA8 : \uC57C, \uC0AC\uCD0C 2! \uC65C \uAC70\uAE30 \uC11C \uC788\uC5B4?
    \uADF8\uB0E5 \uB4E4\uC5B4\uC640. \uBC31\uC791\uB2D8 \uC9C0\uAE08 \uC548 \uACC4\uC154.\n       
    \uC0AC\uCD0C 2 : (\uC8FC\uBCC0\uC744 \uB450\uB9AC\uBC88\uAC70\uB9AC\uBA70) \uADF8\uCE58\uB9CC...
    \uC5EC\uAE30\uAC00 \uBC31\uC791\uB2D8\uC758 \uC11C\uC7AC\uC796\uC544. \uB108\uBB34
    \uC5C4\uC219\uD574\uC11C \uC228\uC18C\uB9AC\uB3C4 \uD06C\uAC8C \uB0B4\uBA74 \uC548
    \uB420 \uAC83 \uAC19\uC544.\n        \uB124\uBAA8 : \uC5D0\uC774, \uB098\uB791
    \uC788\uC73C\uBA74 \uAD1C\uCC2E\uC544. \uC790, \uC5EC\uAE30 \uC549\uC544\uBD10.\n       
    \n\n(\uB450 \uC18C\uB144\uC774 \uC18C\uD30C\uC5D0 \uC549\uC73C\uB824 \uD558\uC790,
    \uC11C\uC7AC \uAD6C\uC11D\uC758 \uC9D1\uC0AC\uAC00 \uD5DB\uAE30\uCE68\uC744 \uD558\uBA70
    \uB2E4\uAC00\uC628\uB2E4.)\n        \uC9D1\uC0AC : \uB3C4\uB828\uB2D8, \uC8FC\uC778\uB2D8\uAED8\uC11C
    \uC11C\uC7AC\uC5D0\uC11C\uC758 \uC0AC\uC801\uC778 \uCE5C\uBAA9\uC740 \uAE08\uD558\uC168\uC2B5\uB2C8\uB2E4.
    \uC6A9\uAC74\uC774 \uC788\uB2E4\uBA74 \uAC70\uC2E4\uB85C \uC774\uB3D9\uD558\uC2ED\uC2DC\uC624.\n       
    \uC0AC\uCD0C 2 : (\uAE5C\uC9DD \uB180\uB77C \uC77C\uC5B4\uB098\uBA70) \uD788\uC775!
    \uAC70 \uBD10, \uB124\uBAA8\uC57C... \uB0B4\uAC00 \uC548 \uB41C\uB2E4\uACE0 \uD588\uC796\uC544.\n       
    \uB124\uBAA8 : (\uC9D1\uC0AC\uB97C \uC9F8\uB824\uBCF4\uBA70) \uC0BC\uCD0C(\uC0AC\uCD0C
    1)\uC740 \uC5EC\uAE30\uC11C \uCC28\uB3C4 \uB9C8\uC2DC\uACE0 \uAC00\uB294\uB370
    \uC65C \uC0AC\uCD0C 2\uB294 \uC548 \uB3FC\uC694? \uB108\uBB34\uD558\uB124 \uC9C4\uC9DC.\n       
    \uC0AC\uCD0C 2 : \uC544\uB0D0, \uB124\uBAA8\uC57C... \uB098 \uADF8\uB0E5 \uAC08\uAC8C.
    \uBC31\uC791\uB2D8 \uBB34\uC11C\uC6CC..."
