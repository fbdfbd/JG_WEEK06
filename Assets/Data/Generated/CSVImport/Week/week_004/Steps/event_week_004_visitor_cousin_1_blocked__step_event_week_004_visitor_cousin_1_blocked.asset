  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_visitor_cousin_1_blocked__step_event_week_004_visitor_cousin_1_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE74\uC774\uC548 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor cousin_1 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC190\uC744 \uBED7\uC790, \uC9D1\uC0AC\uAC00 \uC11C\uC7AC
      \uBB38\uC744 \uB450\uB4DC\uB9B0\uB2E4. \uB124\uBAA8\uB294 \uC6C0\uCC14\uD558\uBA70
      \uC190\uC744 \uAC70\uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uB098\uC911\uC5D0\uC694. \uBC31\uC791\uB2D8\uC774 \uD5C8\uB77D\uD558\uC9C0
      \uC54A\uC740 \uC678\uBD80 \uBB3C\uAC74\uC740 \uC11C\uC7AC\uC5D0 \uB4E4\uC774\uC9C0
      \uB9D0\uB77C\uACE0 \uD558\uC168\uAC70\uB4E0\uC694."
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "(\uCE6B, \uD600\uB97C \uCC28\uBA70) \uBC31\uC791\uB2D8\uC740 \uB108\uBB34
      \uC608\uBBFC\uD574."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uBA48\uCE6B\uD558\uBA70) \uADF8\uAC8C \uBB34\uC2A8 \uC18C\uB9AC\uC5D0\uC694?"
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uC544\uB0D0, \uC544\uB0D0. \uC78A\uC5B4\uBC84\uB824."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC190\uC744 \uBED7\uC790, \uC9D1\uC0AC\uAC00 \uC11C\uC7AC
    \uBB38\uC744 \uB450\uB4DC\uB9B0\uB2E4. \uB124\uBAA8\uB294 \uC6C0\uCC14\uD558\uBA70
    \uC190\uC744 \uAC70\uB454\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
