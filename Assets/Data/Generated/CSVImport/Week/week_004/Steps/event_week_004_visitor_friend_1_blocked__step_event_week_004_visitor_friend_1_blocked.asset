  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_visitor_friend_1_blocked__step_event_week_004_visitor_friend_1_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9C9\uC2A4 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor friend_1 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB9C9\uC2A4\uAC00 \uC7A5\uC2DD\uC6A9 \uAC80\uC5D0 \uC190\uC744 \uB300\uB824\uB294
      \uC21C\uAC04, \uBB38\uAC00\uC5D0 \uC11C \uC788\uB358 \uACBD\uBE44\uB300\uC7A5\uC774
      \uCE7C\uC9D1\uC744 \uD22D \uCE58\uBA70 \uC704\uD611\uC801\uC778 \uC18C\uB9AC\uB97C
      \uB0B8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB3C4\uB828\uB2D8, \uC11C\uC7AC \uB0B4\uC758 \uBB34\uAD6C\uB294 \uC7A5\uC2DD\uC6A9\uC774
      \uC544\uB2D9\uB2C8\uB2E4. \uC678\uBD80\uC778\uC758 \uC190\uAE38\uC740 \uD5C8\uC6A9\uB418\uC9C0
      \uC54A\uC73C\uB2C8 \uC989\uC2DC \uBB3C\uB7EC\uB098\uAC8C \uD558\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uB9C9\uC2A4\uAC00 \uD314\uC744 \uC7A1\uC544\uB04C\uBA70) \uAC70 \uBD10,
      \uB0B4\uAC00 \uC548 \uB41C\uB2E4\uACE0 \uD588\uC9C0! \uC544\uC800\uC528, \uC8C4\uC1A1\uD574\uC694.
      \uC598 \uAE08\uBC29 \uBCF4\uB0BC\uAC8C\uC694."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "(\uC785\uC220\uC744 \uC090\uC8FD\uC774\uBA70) \uCCC7, \uBC31\uC791\uB2D8\uC740
      \uB108\uBB34 \uAE50\uAE50\uD558\uC2DC\uB124. \uAD6C\uACBD\uB3C4 \uBABB \uD558\uAC8C
      \uD558\uACE0... \uB124\uBAA8, \uB108 \uC9C4\uC9DC \uC2EC\uC2EC\uD558\uACA0\uB2E4."
  _nemoLine: "(\uB9C9\uC2A4\uAC00 \uC7A5\uC2DD\uC6A9 \uAC80\uC5D0 \uC190\uC744 \uB300\uB824\uB294
    \uC21C\uAC04, \uBB38\uAC00\uC5D0 \uC11C \uC788\uB358 \uACBD\uBE44\uB300\uC7A5\uC774
    \uCE7C\uC9D1\uC744 \uD22D \uCE58\uBA70 \uC704\uD611\uC801\uC778 \uC18C\uB9AC\uB97C
    \uB0B8\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
