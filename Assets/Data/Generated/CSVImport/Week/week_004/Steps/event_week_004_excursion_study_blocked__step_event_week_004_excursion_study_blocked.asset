  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_excursion_study_blocked__step_event_week_004_excursion_study_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC11C\uC7AC \uD1B5\uC81C"
  _bodyText: "excursion study Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC0AC\uD0D5\uC744 \uC9D1\uC73C\uB824\uB294 \uC21C\uAC04,
      \uC11C\uC7AC \uBB38\uBC16\uC5D0\uC11C \uB300\uAE30\uD558\uB358 \uC9D1\uC0AC\uAC00
      \uD5DB\uAE30\uCE68\uC744 \uD558\uBA70 \uB4E4\uC5B4\uC628\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uB3C4\uB828\uB2D8, \uC8FC\uC778\uB2D8\uAED8\uC11C \uADF8 \uC11C\uB78D\uC758
      \uAC1C\uC218\uB294 \uC81C\uAC00 \uCCB4\uD06C\uD558\uB3C4\uB85D \uBA85\uD558\uC168\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544... \uAE5C\uC9DD\uC774\uC57C! \uADF8\uB0E5 \uAD6C\uACBD\uB9CC \uD55C
      \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC624\uB298 \uC774\uBBF8 \uC2DD\uC0AC \uD6C4\uC5D0 \uB450 \uAC1C\uB97C
      \uB4DC\uC2E0 \uAC83\uC73C\uB85C \uC555\uB2C8\uB2E4. \uC11C\uB78D\uC744 \uB2EB\uC544\uC8FC\uC2DC\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC785\uC220\uC744 \uB0B4\uBC00\uBA70) \uCE58\uC0AC\uD574. \uC774\uB807\uAC8C
      \uC228\uACA8\uB458 \uAC70\uBA74 \uC544\uC608 \uBCF4\uC5EC\uC8FC\uC9C8 \uB9D0\uB4E0\uAC00."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC0AC\uD0D5\uC744 \uC9D1\uC73C\uB824\uB294 \uC21C\uAC04,
    \uC11C\uC7AC \uBB38\uBC16\uC5D0\uC11C \uB300\uAE30\uD558\uB358 \uC9D1\uC0AC\uAC00
    \uD5DB\uAE30\uCE68\uC744 \uD558\uBA70 \uB4E4\uC5B4\uC628\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
