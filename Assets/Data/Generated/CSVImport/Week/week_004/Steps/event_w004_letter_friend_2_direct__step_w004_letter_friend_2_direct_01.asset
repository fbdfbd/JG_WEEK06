  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 \uD3B8\uC9C0 4\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uC544\uC8FC \uC815\uAC08\uD558\uAC8C \uBC00\uBD09\uB41C
    \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C \uADC0\uD241\uC774\uC5D0\uB294
    '\uB2F5\uC7A5 \uD544\uD788 \uBC14\uB78C'\uC774\uB77C\uACE0 \uC791\uAC8C \uC801\uD600
    \uC788\uB2E4.)\r\n    \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C
    \uC628 \uD3B8\uC9C0\uB124\uC694. \uC885\uC774\uC5D0\uC11C \uC740\uC740\uD55C
    \uC885\uC774 \uB0C4\uC0C8\uAC00 \uB0A9\uB2C8\uB2E4.\r\n        \r\n\r\n(\uD558\uB140\uAC00
    \uBD09\uD22C\uB97C \uB4E4\uACE0 \uB124\uBAA8\uC5D0\uAC8C \uB2E4\uAC00\uAC04\uB2E4.)\r\n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8, \uD3B8\uC9C0\uAC00 \uC654\uC2B5\uB2C8\uB2E4.
    \uADF8 \uAF3C\uAF3C\uD55C \uCE5C\uAD6C\uBD84\uC5D0\uAC8C\uC11C \uC628 \uBAA8\uC591\uC774\uC5D0\uC694.\r\n       
    \uB124\uBAA8 : \uAC54\uAC00 \uB610?\r\n        (\uD558\uB140\uAC00 \uBD09\uD22C\uB97C
    \uC5F4\uC5B4 \uD3B8\uC9C0\uB97C \uC77D\uC5B4 \uC900\uB2E4.)\r\n        \uB124\uBAA8\uC5D0\uAC8C.
    \uC9C0\uB09C\uBC88\uC5D0 \uC77D\uB358 \uCC45 14\uD398\uC774\uC9C0 \uC544\uB798\uCABD\uC5D0
    \uC791\uC740 \uD45C\uC2DC\uB97C \uD574\uB480\uC5B4. \uACBD\uBE44\uB300\uC7A5
    \uC544\uC800\uC528\uAC00 \uBCF4\uBA74 \uB099\uC11C\uB77C\uACE0 \uD654\uB0BC \uD14C\uB2C8\uAE4C
    \uB108\uB9CC \uBAB0\uB798 \uD655\uC778\uD574. \uAC70\uAE30 '\uC548\uB155'\uC774\uB77C\uACE0
    \uC544\uC8FC \uC791\uAC8C \uC801\uC5C8\uC5B4. \uB2F5\uC7A5\uC73C\uB85C \uB108\uB3C4
    \uC778\uC0AC\uD574 \uC918.\r\n        \uB124\uBAA8 : \uCC45\uC5D0\uB2E4 \uC778\uC0AC\uB97C
    \uC228\uACBC\uB300!\r\n        \uD558\uB140 : \uC8FC\uC778\uB2D8\uB9CC \uC54C\uC544\uBCFC
    \uC218 \uC788\uB294 \uBE44\uBC00 \uC778\uC0AC\uB97C \uB0A8\uACBC\uB098 \uBD05\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : 14\uD398\uC774\uC9C0... 14\uD398\uC774\uC9C0... \uC774\uB530\uAC00
    \uC544\uC800\uC528 \uC5C6\uC744 \uB54C \uAF2D \uCC3E\uC544\uBD10\uC57C\uC9C0!"
