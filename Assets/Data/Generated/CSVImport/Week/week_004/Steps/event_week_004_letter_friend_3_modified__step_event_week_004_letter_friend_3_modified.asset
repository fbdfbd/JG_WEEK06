  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_letter_friend_3_modified__step_event_week_004_letter_friend_3_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC720\uD53C \uC218\uC815"
  _bodyText: "letter friend_3 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC9C0\uB09C\uBC88\uC5D0
      \uC11C\uC7AC\uC5D0\uC11C \uC788\uC5C8\uB358 \uC77C\uC744 \uC544\uC8FC \uB9C8\uBC95
      \uAC19\uC740 \uC77C\uB85C \uAE30\uC5B5\uD558\uACE0 \uC788\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9C8\uBC95? \uBB34\uC2A8 \uB9C8\uBC95?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC789\uD06C \uBCD1 \uD558\uB098\uB97C \uB9CC\uC9C0\uB294 \uC21C\uAC04\uC5D0\uB3C4
      \uC2E0\uBE44\uD55C \uC77C\uC774 \uC77C\uC5B4\uB098\uB294 \uAC83 \uAC19\uC558\uB300\uC694.
      \uC8FC\uC778\uB2D8\uACFC \uD568\uAED8 \uC788\uC73C\uBA74 \uBAA8\uB4E0 \uAC8C
      \uD2B9\uBCC4\uD574 \uBCF4\uC778\uB2E4\uACE0 \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC789\uD06C \uBCD1\uC774 \uD2B9\uBCC4\uD574 \uBCF4\uC778\uB2E4\uACE0?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC8FC\uC778\uB2D8\uACFC \uB178\uB294 \uAC8C \uADF8\uB9CC\uD07C
      \uC990\uAC70\uC6E0\uB098 \uBD05\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC54\uB294 \uC9C4\uC9DC \uD2B9\uC774\uD574. \uADF8\uB798\uB3C4 \uB2E4\uC74C\uC5D4
      \uBB34\uC2A8 \uC18C\uB9B4 \uD560\uC9C0 \uAD81\uAE08\uD574."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC9C0\uB09C\uBC88\uC5D0
    \uC11C\uC7AC\uC5D0\uC11C \uC788\uC5C8\uB358 \uC77C\uC744 \uC544\uC8FC \uB9C8\uBC95
    \uAC19\uC740 \uC77C\uB85C \uAE30\uC5B5\uD558\uACE0 \uC788\uB124\uC694."
  _useCustomVisualState: 0
  _visualState: 0
