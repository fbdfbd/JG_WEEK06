  m_Name: event_w004_letter_friend_2_modified__step_w004_letter_friend_2_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 \uD3B8\uC9C0 4\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uC544\uC8FC \uC815\uAC08\uD558\uAC8C \uBC00\uBD09\uB41C
    \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C \uADC0\uD241\uC774\uC5D0\uB294
    '\uB2F5\uC7A5 \uD544\uD788 \uBC14\uB78C'\uC774\uB77C\uACE0 \uC791\uAC8C \uC801\uD600
    \uC788\uB2E4.)\n    \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C
    \uC628 \uD3B8\uC9C0\uB124\uC694. \uC885\uC774\uC5D0\uC11C \uC740\uC740\uD55C
    \uC885\uC774 \uB0C4\uC0C8\uAC00 \uB0A9\uB2C8\uB2E4.\n        \n\n(\uD558\uB140\uAC00
    \uD3B8\uC9C0\uB97C \uC77D\uACE0 \uB124\uBAA8 \uC55E\uC5D0 \uC549\uC544 \uB098\uAE0B\uD558\uAC8C
    \uC804\uD574 \uC900\uB2E4.)\n        \uD558\uB140 : \uC8FC\uC778\uB2D8, \uC800\uBC88\uC5D0
    \uB9CC\uB09C \uB610\uB798 \uC190\uB2D8\uC774 \uC11C\uC7AC\uC5D0 \uC791\uC740
    \uC120\uBB3C\uC744 \uC228\uACA8\uB450\uC5C8\uB2E4\uACE0 \uD569\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uC120\uBB3C? \uBA39\uB294 \uAC70\uC57C?\n        \uD558\uB140
    : \uBA39\uB294 \uAC74 \uC544\uB2C8\uC9C0\uB9CC, \uC8FC\uC778\uB2D8\uB9CC \uCC3E\uC744
    \uC218 \uC788\uB294 '\uBE44\uBC00 \uC778\uC0AC'\uB77C\uACE0 \uD558\uB124\uC694.
    \uCC45\uC7A5 \uC5B4\uB518\uAC00\uC5D0 \uC228\uACA8\uB450\uC5C8\uB300\uC694.\n       
    \uB124\uBAA8 : \uC6B0\uC640, \uBCF4\uBB3C \uCC3E\uAE30 \uAC19\uC544.\n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8\uC774 \uCC3E\uC544\uC8FC\uAE38 \uC544\uC8FC
    \uB9CE\uC774 \uAE30\uB2E4\uB9AC\uACE0 \uC788\uB294 \uBAA8\uC591\uC785\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uADF8\uB7FC \uB0B4\uAC00 \uBE68\uB9AC \uCC3E\uC544\uC11C \uB098\uB3C4
    \uC548\uB155 \uD574\uC918\uC57C\uACA0\uB2E4!"
