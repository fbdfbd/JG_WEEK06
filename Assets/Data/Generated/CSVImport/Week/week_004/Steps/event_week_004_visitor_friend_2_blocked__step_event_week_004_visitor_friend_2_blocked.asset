  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_visitor_friend_2_blocked__step_event_week_004_visitor_friend_2_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC00\uB9AC\uC544 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor friend_2 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB450 \uC18C\uB144\uC774 \uC18C\uACE4\uAC70\uB9AC\uC790, \uBB38\uAC00\uC5D0
      \uC11C \uC788\uB358 \uACBD\uBE44\uB300\uC7A5\uC774 \uD5DB\uAE30\uCE68\uC744
      \uD558\uBA70 \uB2E4\uAC00\uC628\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB3C4\uB828\uB2D8, \uC8FC\uC778\uB2D8\uAED8\uC11C \uC11C\uC7AC \uB0B4\uC5D0\uC11C\uC758
      \uBD88\uD544\uC694\uD55C \uB300\uD654\uB294 \uC0BC\uAC00\uB77C \uD558\uC168\uC2B5\uB2C8\uB2E4.
      \uB3C5\uC11C\uC5D0\uB9CC \uC9D1\uC911\uD558\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uBAA9\uC18C\uB9AC\uB97C \uB0AE\uCD94\uBA70) \uC544\uC800\uC528, \uCE5C\uAD6C\uB791
      \uC544\uC8FC \uC791\uAC8C \uC774\uC57C\uAE30\uD558\uB294 \uAC83\uB3C4 \uC548
      \uB3FC\uC694?"
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "(\uAE5C\uC9DD \uB180\uB77C \uCC45\uC73C\uB85C \uC5BC\uAD74\uC744 \uAC00\uB9AC\uBA70)
      \uBBF8\uC548\uD574, \uB124\uBAA8\uC57C... \uB0B4\uAC00 \uB9D0\uC744 \uAC78\uC5B4\uC11C...
      \uC774\uC81C \uC870\uC6A9\uD788 \uD560\uAC8C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uBC00\uB9AC\uC544\uC758 \uB208\uCE58\uB97C \uBCF4\uBA70) \uC544\uB0D0,
      \uB124 \uC798\uBABB \uC544\uB0D0. \uBC31\uC791\uB2D8\uC774 \uC880 \uC5C4\uACA9\uD558\uC154\uC11C
      \uADF8\uB798."
  _nemoLine: "(\uB450 \uC18C\uB144\uC774 \uC18C\uACE4\uAC70\uB9AC\uC790, \uBB38\uAC00\uC5D0
    \uC11C \uC788\uB358 \uACBD\uBE44\uB300\uC7A5\uC774 \uD5DB\uAE30\uCE68\uC744 \uD558\uBA70
    \uB2E4\uAC00\uC628\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
