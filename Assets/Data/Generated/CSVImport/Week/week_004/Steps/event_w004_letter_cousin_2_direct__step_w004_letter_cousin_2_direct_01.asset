  m_Name: event_w004_letter_cousin_2_direct__step_w004_letter_cousin_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 \uD3B8\uC9C0 4\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uC544\uC8FC \uC791\uACE0 \uD5A5\uAE0B\uD55C \uAF43\uD5A5\uAE30\uAC00
    \uB098\uB294 \uBD09\uD22C\uB97C \uBC1B\uC544 \uB4E0\uB2E4. \uAE00\uC528\uAC00
    \uC870\uAE08 \uB354 \uB2E8\uC815\uD574\uC84C\uC9C0\uB9CC, \uC5EC\uC804\uD788
    \uC870\uC2EC\uC2A4\uB7EC\uC6B4 \uD544\uCCB4\uB2E4.)\n    \uD558\uB140 : \uC0AC\uCD0C
    \uC8FC\uC778\uB2D8 \uCABD\uC5D0\uC11C \uC628 \uD3B8\uC9C0\uB124\uC694. \uBD09\uD22C
    \uC0AC\uC774\uC5D0 \uC791\uC740 \uB9D0\uB9B0 \uAF43\uC78E\uC774 \uB07C\uC5B4
    \uC788\uC2B5\uB2C8\uB2E4.\n        \n\n(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C
    \uB4E4\uACE0 \uB124\uBAA8\uC5D0\uAC8C \uB2E4\uAC00\uAC04\uB2E4.)\n        \uD558\uB140
    : \uC8FC\uC778\uB2D8, \uD3B8\uC9C0\uAC00 \uC654\uC2B5\uB2C8\uB2E4. \uC800\uBC88\uC5D0
    \uB9CC\uB09C \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uC774 \uBCF4\uB0B4\uC2E0 \uAC83
    \uAC19\uC544\uC694.\n        \uB124\uBAA8 : \uC0AC\uCD0C 2\uAC00? \uC77D\uC5B4
    \uC918!\n        (\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uC5F4\uC5B4 \uD3B8\uC9C0\uB97C
    \uC77D\uC5B4 \uC900\uB2E4.)\n        \uB124\uBAA8 \uC548\uB155. \uC800\uBC88\uC5D0
    \uACBD\uBE44\uB300\uC7A5 \uC544\uC800\uC528\uAC00 \uC6B0\uB9AC \uCABD\uC9C0 \uBE8F\uC5B4\uAC14\uC744
    \uB54C \uB108\uBB34 \uBB34\uC11C\uC6E0\uC5B4. \uC0AC\uC2E4 \uB098 \uC870\uAE08
    \uC6B8 \uBED4\uD588\uB294\uB370... \uB124\uAC00 \uB0B4 \uD3B8 \uB4E4\uC5B4\uC918\uC11C
    \uACE0\uB9C8\uC6CC. \uB098... \uB124\uAC00 \uC870\uAE08 \uB354 \uC88B\uC544\uC84C\uC5B4.
    \uB2E4\uC74C\uC5D4 \uC544\uC800\uC528 \uC548 \uACC4\uC2DC\uB294 \uACF3\uC5D0\uC11C
    \uB354 \uB9CE\uC774 \uC598\uAE30\uD558\uC790.\n        \uB124\uBAA8 : \uC6B8
    \uBED4\uD588\uB300? \uBC14\uBCF4 \uAC19\uC544.\n        \uD558\uB140 : \uADF8\uB798\uB3C4
    \uC8FC\uC778\uB2D8\uC774 \uC9C0\uCF1C\uC8FC\uC2E0 \uAC8C \uC544\uC8FC \uB4E0\uB4E0\uD588\uB098
    \uBD05\uB2C8\uB2E4.\n        \uB124\uBAA8 : \uB0B4\uAC00 \uC880 \uC6A9\uAC10\uD558\uAE34
    \uD588\uC9C0. \uAC54\uB294 \uB0B4\uAC00 \uC5C6\uC73C\uBA74 \uC548 \uB418\uACA0\uB2E4."
