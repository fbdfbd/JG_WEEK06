  m_Name: event_w004_visitor_cousin_1_direct__step_w004_visitor_cousin_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 4\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uBC31\uC791\uC774 \uC790\uB9AC\uB97C \uBE44\uC6B4 \uC11C\uC7AC. \uC0AC\uCD0C
    1\uC774 \uC18C\uD30C\uC5D0 \uB298\uC5B4\uC838 \uC788\uB2E4\uAC00 \uB124\uBAA8\uAC00
    \uB4E4\uC5B4\uC624\uC790 \uC8FC\uBA38\uB2C8\uC5D0\uC11C \uD654\uB824\uD558\uAC8C
    \uD3EC\uC7A5\uB41C \uC0C1\uC790\uB97C \uAEBC\uB0B8\uB2E4.)\r\n        \r\n       
    \uC0AC\uCD0C 1 : \uC57C, \uB124\uBAA8! \uB108\uD76C \uBC31\uC791\uB2D8\uC740
    \uC5EC\uC804\uD558\uC2DC\uB0D0? \uC544\uC8FC \uC800\uD0DD\uC744 \uAC10\uC625\uC73C\uB85C
    \uB9CC\uB4E4\uC5B4 \uB1A8\uB124. \uC790, \uC774\uAC74 \uC624\uB2E4 \uC8FC\uC6B4
    \uAC70\uB2E4.\r\n        \uB124\uBAA8 : \uC6B0\uC640, \uC774\uAC8C \uBB50\uC608\uC694?
    \uC5C4\uCCAD \uBC18\uC9DD\uAC70\uB824\uC694.\r\n        \uC0AC\uCD0C 1 : \uBCC4\uAC70
    \uC544\uB0D0. \uADF8\uB0E5 \uC608\uC804\uC5D0 \uC7A5\uC2DD\uD488\uC774\uC9C0.\r\n       
    \r\n\r\n(\uB124\uBAA8\uAC00 \uC0C1\uC790\uB97C \uC5F4\uC790 \uC815\uAD50\uD55C
    \uCE7C \uBAA8\uC591\uC758 \uC7A5\uC2DD\uD488\uC774 \uB098\uC628\uB2E4.)\r\n       
    \uB124\uBAA8 : \uC6B0\uC640... \uC9C4\uC9DC \uC608\uBED0\uC694. \uCE7C \uBAA8\uC591\uC774\uB124\uC694?\r\n       
    \uC0AC\uCD0C 1 : \uB0B4\uAC00 \uD0C0\uAD6D\uC5D0 \uC7A0\uC2DC \uAC14\uB294\uB370
    \uAC70\uAE30 \uC9C0\uB3C4\uC790\uAC00 \uCC28\uACE0 \uC788\uB294 \uAC80\uC774
    \uC815\uB9D0 \uD654\uB824\uD588\uAC70\uB4E0\r\n        \uB124\uBAA8 : (\uC7A5\uC2DD\uD488\uC744
    \uB9CC\uC9C0\uBA70) \uADF8\uB798\uC11C \uBE44\uC2B7\uD55C\uAC78 \uC0AC\uC624\uC2E0
    \uAC70\uAD70\uC694\r\n        \uC0AC\uCD0C 1 : \uD5C8\uD5C8, \uBC31\uC791\uB2D8\uD55C\uD150
    \uBE44\uBC00\uC774\uB2E4!"
