  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w004_excursion_lake_blocked__step_w004_excursion_lake_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 4\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uD574\uAC00 \uAC70\uC758 \uC9C4 \uC800\uB141. \uD638\uC22B\uAC00
    \uB09C\uAC04\uC744 \uB530\uB77C \uC791\uC740 \uC720\uB9AC\uB4F1\uC774 \uD558\uB098\uC529
    \uCF1C\uC9C0\uAE30 \uC2DC\uC791\uD55C\uB2E4. \uBD88\uAF43\uCC98\uB7FC \uD754\uB4E4\uB9AC\uC9C0\uB3C4
    \uC54A\uACE0, \uB2EC\uBE5B\uCC98\uB7FC \uC740\uC740\uD558\uAC8C \uBB3C \uC704\uC5D0
    \uAE38\uC744 \uB9CC\uB4E0\uB2E4.)\n        \n        \uB124\uBAA8 : \uC5B4? \uC800\uAC70
    \uC6D0\uB798 \uC788\uC5C8\uB098.\n        \n        (\uB124\uBAA8\uAC00 \uB09C\uAC04
    \uCABD\uC73C\uB85C \uB2E4\uAC00\uAC00\uC790, \uBC1C\uBC11\uC758 \uB4F1\uBD88\uC774
    \uD55C \uBC15\uC790 \uB2A6\uAC8C \uB354 \uBC1D\uC544\uC9C4\uB2E4. \uBB3C\uACB0\uC774
    \uC6C0\uC9C1\uC77C \uB54C\uB9C8\uB2E4 \uBE5B\uC774 \uB530\uB77C \uD754\uB4E4\uB824,
    \uB9C8\uCE58 \uB09C\uAC04 \uC544\uB798\uC5D0 \uC740\uAC00\uB8E8\uB97C \uBFCC\uB9B0
    \uAC83 \uAC19\uB2E4.)\n        \n        \uB124\uBAA8 : ...\uC608\uC058\uB2E4.\n       
    \n        \uB124\uBAA8 : \uBB3C\uC774 \uBE5B \uBA39\uB294 \uAC83 \uAC19\uC544.\n       
    \n\n(\uACBD\uBE44\uB300\uC7A5\uC774 \uB09C\uAC04 \uC55E\uC5D0\uC11C \uD55C \uAC78\uC74C
    \uBA3C\uC800 \uBA48\uCDB0 \uC120\uB2E4.)\n        \n        \uACBD\uBE44\uB300\uC7A5
    : \uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC5EC\uAE30\uC11C \uBCF4\uC154\uC57C
    \uD569\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : \uC65C\uC694?\n       
    \n        \uACBD\uBE44\uB300\uC7A5 : \uD574\uAC00 \uC84C\uC2B5\uB2C8\uB2E4. \uBB3C\uAC00
    \uCABD\uC740 \uB354 \uC5B4\uB450\uC6CC\uC9C0\uACE0\uC694.\n        \n       
    \uB124\uBAA8 : \uADFC\uB370 \uC800 \uB4F1\uBD88 \uC788\uC796\uC544.\n       
    \n        \uACBD\uBE44\uB300\uC7A5 : \uADF8\uB798\uC11C \uB354\uB354\uC6B1 \uB09C\uAC04
    \uC548\uCABD\uAE4C\uC9C0\uB9CC\uC785\uB2C8\uB2E4.\n        \n        \uB124\uBAA8
    : \uB2E4 \uD574 \uB193\uACE0 \uBABB \uAC00\uAC8C \uD558\uBA74 \uC880 \uC5B5\uC6B8\uD55C\uB370.\n       
    \n        \uACBD\uBE44\uB300\uC7A5 : \uBCF4\uB294 \uAC83\uB9CC\uC73C\uB85C\uB3C4
    \uCDA9\uBD84\uD788 \uC608\uC058\uC9C0 \uC54A\uC2B5\uB2C8\uAE4C.\n        \n       
    \uB124\uBAA8 : ...\uADF8\uB798\uB3C4 \uB204\uAC00 \uC774\uB7F0 \uAC78 \uD574
    \uB1A8\uB294\uC9C4 \uAD81\uAE08\uD558\uB124."
