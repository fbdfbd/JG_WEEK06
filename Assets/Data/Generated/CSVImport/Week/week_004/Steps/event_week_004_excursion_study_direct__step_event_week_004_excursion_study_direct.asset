  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_excursion_study_direct__step_event_week_004_excursion_study_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC11C\uC7AC \uD5C8\uAC00"
  _bodyText: "excursion study Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC0AC\uD0D5 \uD558\uB098\uB97C \uAEBC\uB0B4 \uC785\uC5D0
      \uB123\uC790, \uC11C\uB78D \uC548\uCABD\uC5D0 \uB124\uBAA8\uC758 \uC774\uB984\uC774
      \uC0C8\uACA8\uC9C4 \uC791\uC740 \uC740\uC0C9 \uC9D1\uAC8C\uAC00 \uB193\uC5EC
      \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB0B4 \uC804\uC6A9 \uC9D1\uAC8C\uAE4C\uC9C0 \uAC16\uB2E4 \uB193\uC73C\uC168\uB124."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uACB0\uAD6D \uC5EC\uAE30\uC11C \uBA39\uC73C\uB77C\uB294 \uAC70\uC796\uC544.
      \uC790\uAE30 \uAC10\uC2DC \uC544\uB798\uC5D0 \uB450\uACE0."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uBC31\uC791\uC758 \uC758\uC790\uC5D0 \uAE4A\uC219\uC774
      \uC549\uC544 \uC0AC\uD0D5\uC744 \uAD74\uB9AC\uBA70 \uC11C\uC7AC\uB97C \uB458\uB7EC\uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50, \uC758\uC790\uB294 \uD3B8\uD558\uB2C8\uAE4C \uBD10\uC904\uAC8C\uC694."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC0AC\uD0D5 \uD558\uB098\uB97C \uAEBC\uB0B4 \uC785\uC5D0
    \uB123\uC790, \uC11C\uB78D \uC548\uCABD\uC5D0 \uB124\uBAA8\uC758 \uC774\uB984\uC774
    \uC0C8\uACA8\uC9C4 \uC791\uC740 \uC740\uC0C9 \uC9D1\uAC8C\uAC00 \uB193\uC5EC
    \uC788\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
