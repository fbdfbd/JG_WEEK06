  m_Name: event_w004_house_main_direct__step_w004_house_main_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "4\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uB2A6\uC740 \uC624\uD6C4 \uBCF5\uB3C4. \uD558\uB140 \uB458\uC774
    \uBCBD\uC5D0 \uAC78\uB9B0 \uCEE4\uB2E4\uB780 \uCD08\uC0C1\uD654\uB97C \uD790\uB057\uAC70\uB9AC\uBA70
    \uBE60\uB974\uAC8C \uAC77\uACE0 \uC788\uB2E4.)\r\n    \uD558\uB1401 : \uC800\uBC88\uC5D0
    \uB2E6\uC744 \uB54C \uBD84\uBA85 \uC67C\uCABD\uC744 \uBCF4\uACE0 \uC788\uC5C8\uB294\uB370...\r\n   
    \uD558\uB1402 : \uB9D0\uB3C4 \uB9C8. \uB098\uB3C4 \uC544\uAE4C \uC815\uBA74\uC778
    \uC904 \uC54C\uACE0 \uAE5C\uC9DD \uB180\uB790\uB2E4\uB2C8\uAE4C.\r\n    \uB124\uBAA8
    : \uADF8\uB9BC\uC774 \uC6C0\uC9C1\uC5EC?\r\n    \r\n\r\n\uD558\uB1401 : \uC774
    \uCD08\uC0C1\uD654\uB294 \uAC00\uBB38\uC758 \uC870\uC0C1\uB2D8\uC774\uB77C, \uAC00\uB054
    \uD6C4\uC190\uB4E4\uC744 \uC9C0\uCF1C\uBCF4\uC2E0\uB2E4\uB294 \uC18C\uBB38\uC774
    \uC788\uC5B4\uC694.\r\n    \uB124\uBAA8 : \uC9C4\uC9DC? \uB098\uB97C \uBCF4\uACE0
    \uACC4\uC2E0 \uAC70\uC57C?\r\n    \uD558\uB1402 : \uB124. \uB098\uC05C \uC9D3\uC744
    \uD558\uB294 \uC0AC\uB78C\uC774 \uC5C6\uB294\uC9C0 \uAC10\uC2DC\uD558\uC2E0\uB300\uC694.\r\n   
    \uB124\uBAA8 : \uD5C9... \uADF8\uB7FC \uB0B4\uAC00 \uACFC\uC790 \uBAB0\uB798
    \uBA39\uB294 \uAC83\uB3C4 \uC544\uC2DC\uACA0\uB124?\r\n    \uD558\uB1401 : \uC544\uB9C8
    \uADF8\uB7F4\uC9C0\uB3C4 \uBAA8\uB974\uC9C0\uC694. \uADF8\uB798\uC11C \uB2E4\uB4E4
    \uC774 \uBCF5\uB3C4\uC5D0\uC120 \uC870\uC2EC\uD55C\uB2F5\uB2C8\uB2E4.\r\n   
    \uB124\uBAA8 : \uBB34\uC11C\uC6B4\uB370... \uADF8\uB798\uB3C4 \uB098\uB97C \uC9C0\uCF1C\uC8FC\uC2DC\uB294
    \uAC70\uB2C8\uAE4C \uC870\uAE08 \uB4E0\uB4E0\uD574."
