  m_Name: event_w004_letter_friend_3_direct__step_w004_letter_friend_3_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 4\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uC54C\uB85D\uB2EC\uB85D\uD55C \uBD09\uD22C\uB97C
    \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C \uAC89\uBA74\uC5D0\uB294 \uC5F0\uD544\uB85C
    \uADF8\uB9B0 \uD5D8\uC545\uD558\uAC8C \uC0DD\uAE34 \uAD34\uBB3C \uADF8\uB9BC\uC774
    \uADF8\uB824\uC838 \uC788\uB2E4.)\n    \uD558\uB140 : \uB610\uB798 \uC190\uB2D8
    \uCABD\uC5D0\uC11C \uC628 \uD3B8\uC9C0\uB124\uC694. \uADF8\uB9BC\uC774 \uC544\uC8FC
    \uB3C5\uD2B9\uD569\uB2C8\uB2E4.\n        \n\n(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C
    \uB4E4\uACE0 \uB124\uBAA8\uC5D0\uAC8C \uB2E4\uAC00\uAC04\uB2E4.)\n        \uD558\uB140
    : \uC8FC\uC778\uB2D8, \uC0C1\uC0C1\uB825\uC774 \uD48D\uBD80\uD55C \uCE5C\uAD6C\uBD84\uC774
    \uC774\uBC88\uC5D4 \uADF8\uB9BC \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC5B4\uC694.\n       
    \uB124\uBAA8 : \uC774\uBC88\uC5D4 \uB610 \uBB50\uC57C?\n        (\uD558\uB140\uAC00
    \uBD09\uD22C\uB97C \uC5F4\uC5B4 \uD3B8\uC9C0\uB97C \uC77D\uC5B4 \uC900\uB2E4.)\n       
    \uB124\uBAA8 \uC548\uB155! \uB098 \uC5B4\uC81C \uAFC8\uC5D0\uC11C \uACBD\uBE44\uB300\uC7A5
    \uC544\uC800\uC528 \uB2EE\uC740 \uAD34\uBB3C\uC744 \uBD24\uC5B4! \uAC11\uC637\uC744
    \uC785\uC5C8\uB294\uB370 \uBA38\uB9AC\uAC00 \uC138 \uAC1C\uB098 \uB2EC\uB838\uB354\uB77C\uAD6C.
    \uB2E4\uC74C \uD3B8\uC9C0\uC5D4 \uADF8 \uAD34\uBB3C\uC744 \uBB34\uCC0C\uB974\uB294
    \uB124 \uBAA8\uC2B5\uC744 \uADF8\uB824\uC904\uAC8C. \uB108\uB294 \uC6A9\uAC10\uD55C
    \uAE30\uC0AC\uAC00 \uB418\uB294 \uAC70\uC57C!\n        \uB124\uBAA8 : \uBA38\uB9AC
    \uC138 \uAC1C \uB2EC\uB9B0 \uACBD\uBE44\uB300\uC7A5 \uC544\uC800\uC528?\n       
    \uD558\uB140 : \uC815\uB9D0 \uC5C9\uB6B1\uD55C \uC0C1\uC0C1\uC744 \uD558\uB294
    \uCE5C\uAD6C\uB124\uC694.\n        \uB124\uBAA8 : \uC544\uC800\uC528\uAC00 \uC54C\uBA74
    \uC9C4\uC9DC \uD654\uB0B4\uACA0\uB2E4. \uADFC\uB370 \uB0B4\uAC00 \uBB34\uCC0C\uB974\uB294
    \uAC74 \uC880 \uBA4B\uC788\uC744 \uAC83 \uAC19\uC544!"
