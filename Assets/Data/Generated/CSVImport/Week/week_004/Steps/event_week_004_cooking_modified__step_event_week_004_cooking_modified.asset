  _titleOverride: "\uC694\uB9AC \uC218\uC5C5\uC744 \uB9DB\uC788\uB294 \uC774\uC57C\uAE30\uB85C
    \uD47C\uB2E4"
  _bodyText: "\uC694\uB9AC \uC218\uC5C5\uC744 \uB9DB\uC788\uB294 \uC774\uC57C\uAE30\uB85C
    \uD47C\uB2E4 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB0C4\uC0C8\uC640 \uB9DB\uC744 \uC0C1\uC0C1\uD558\uAC8C \uD558\uBA70
      \uC7AC\uB8CC \uC124\uBA85\uC744 \uB354 \uC27D\uAC8C \uD480\uC5B4 \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774 \uC7AC\uB8CC\uB294 \uBB34\uC2A8 \uB0C4\uC0C8\uC77C\uAE4C."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uB9DB\uC744 \uB5A0\uC62C\uB9AC\uAC8C \uD558\uBA70 \uAD50\uC7AC\uB97C
      \uC9C0\uB8E8\uD558\uC9C0 \uC54A\uAC8C \uB530\uB77C\uAC00\uAC8C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uB807\uAC8C \uBC30\uC6B0\uBA74 \uBC30\uACE0\uD504\uC9C0\uB9CC
      \uC7AC\uBC0C\uC5B4."
  _nemoLine: "(\uB0C4\uC0C8\uC640 \uB9DB\uC744 \uC0C1\uC0C1\uD558\uAC8C \uD558\uBA70
    \uC7AC\uB8CC \uC124\uBA85\uC744 \uB354 \uC27D\uAC8C \uD480\uC5B4 \uC900\uB2E4.)"
