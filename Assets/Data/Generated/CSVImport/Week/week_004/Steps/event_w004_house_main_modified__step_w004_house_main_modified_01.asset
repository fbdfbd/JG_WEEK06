  m_Name: event_w004_house_main_modified__step_w004_house_main_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "4\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uB2A6\uC740 \uC624\uD6C4 \uBCF5\uB3C4. \uD558\uB140 \uB458\uC774
    \uBCBD\uC5D0 \uAC78\uB9B0 \uCEE4\uB2E4\uB780 \uCD08\uC0C1\uD654\uB97C \uD790\uB057\uAC70\uB9AC\uBA70
    \uBE60\uB974\uAC8C \uAC77\uACE0 \uC788\uB2E4.)\n    \uD558\uB1401 : \uC800\uBC88\uC5D0
    \uB2E6\uC744 \uB54C \uBD84\uBA85 \uC67C\uCABD\uC744 \uBCF4\uACE0 \uC788\uC5C8\uB294\uB370...\n   
    \uD558\uB1402 : \uB9D0\uB3C4 \uB9C8. \uB098\uB3C4 \uC544\uAE4C \uC815\uBA74\uC778
    \uC904 \uC54C\uACE0 \uAE5C\uC9DD \uB180\uB790\uB2E4\uB2C8\uAE4C.\n    \uB124\uBAA8
    : \uADF8\uB9BC\uC774 \uC6C0\uC9C1\uC5EC?\n    \n\n\uD558\uB1401 : \uC774 \uADF8\uB9BC\uC740
    \uBCF4\uB294 \uBC29\uD5A5\uC5D0 \uB530\uB77C \uB208\uB3D9\uC790\uAC00 \uB530\uB77C\uC624\uB294
    \uAC83\uCC98\uB7FC \uADF8\uB824\uC9C4 \uC544\uC8FC \uC2E0\uAE30\uD55C \uC791\uD488\uC774\uC5D0\uC694.\n   
    \uB124\uBAA8 : \uB208\uC774 \uB530\uB77C\uC640?\n    \uD558\uB1402 : \uB124.
    \uD654\uAC00\uB2D8\uC774 \uC77C\uBD80\uB7EC \uADF8\uB807\uAC8C \uB9CC\uB4DC\uC2E0
    \uAC70\uB798\uC694. \uC5B4\uB514\uC11C\uB4E0 \uC8FC\uC778\uB2D8\uACFC \uC778\uC0AC\uB97C
    \uB098\uB204\uACE0 \uC2F6\uC5B4\uC11C\uC694.\n    \uB124\uBAA8 : \uC6B0\uC640,
    \uC9C4\uC9DC\uB124! \uB0B4\uAC00 \uC774\uCABD\uC73C\uB85C \uAC00\uB3C4 \uB098\uB97C
    \uBD10!\n    \uD558\uB1401 : \uB124. \uC544\uC8FC \uB2E4\uC815\uD55C \uADF8\uB9BC\uC774\uC9C0\uC694?\n   
    \uB124\uBAA8 : \uC751! \uC774\uC81C \uC774 \uBCF5\uB3C4 \uC9C0\uB0A0 \uB550 \uB098\uB3C4
    \uC778\uC0AC\uD574 \uC904\uB798."
