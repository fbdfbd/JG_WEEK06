  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w004_external_main_direct__step_w004_external_main_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "4\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uB4B7\uB9C8\uB2F9 \uB2F4\uC7A5 \uB108\uBA38, \uB554\uAC10\uC744 \uC2E4\uC5B4
    \uB098\uB974\uB294 \uB9C8\uBD80\uAC00 \uC815\uC6D0\uC0AC\uC5D0\uAC8C \uB2F4\uBC30\uB97C
    \uBE4C\uB9AC\uBA70 \uC218\uAD70\uAC70\uB9B0\uB2E4.)\n    \uB9C8\uBD80 : \uC800\uAE30
    \uBD81\uCABD \uC232 \uAE4A\uC740 \uACF3\uC5D0 \uC0AC\uB78C\uC774 \uC0B4\uACE0
    \uC788\uB2E4\uB294 \uAC70 \uC54C\uC544? \uBC24\uB9C8\uB2E4 \uC774\uC0C1\uD55C
    \uBD88\uBE5B\uC774 \uBC88\uCA4D\uC778\uB2E4\uB2C8\uAE4C.\n    \uC815\uC6D0\uC0AC
    : \uC5D0\uC774, \uAC70\uAE34 \uC9D0\uC2B9\uB4E4\uB9CC \uC0AC\uB294 \uACF3\uC774\uC796\uC544.
    \uB204\uAC00 \uADF8\uB7F0 \uB370\uC11C \uC0B4\uC544?\n    \uB124\uBAA8 : \uC232\uC5D0
    \uB204\uAC00 \uC0B4\uC544?\n    \n\n\uB9C8\uBD80 : \uC18C\uBB38\uC5D0 \uC758\uD558\uBA74
    \uC544\uC8FC \uC61B\uB0A0\uC5D0 \uAD81\uC804\uC5D0\uC11C \uCAD3\uACA8\uB09C \uB9C8\uBC95\uC0AC\uB77C\uB294
    \uB9D0\uC774 \uC788\uC5B4\uC694.\n    \uB124\uBAA8 : \uB9C8\uBC95\uC0AC? \uC9C4\uC9DC\uB85C
    \uC9C0\uD321\uC774 \uD754\uB4E4\uBA74 \uB9C8\uBC95\uC774 \uB098\uC640?\n    \uC815\uC6D0\uC0AC
    : \uC870\uC2EC\uD558\uC138\uC694, \uC8FC\uC778\uB2D8. \uB9C8\uBC95\uC0AC\uB791
    \uB208\uC774 \uB9C8\uC8FC\uCE58\uBA74 \uB3CC\uC774 \uB418\uC5B4\uBC84\uB9B0\uB2E4\uB294
    \uC18C\uBB38\uB3C4 \uC788\uC73C\uB2C8\uAE4C\uC694.\n    \uB124\uBAA8 : \uD5C9...
    \uADF8\uB7FC \uC232 \uADFC\uCC98\uC5D4 \uC808\uB300 \uAC00\uBA74 \uC548 \uB418\uACA0\uB2E4.
    \uADFC\uB370 \uC870\uAE08 \uAD81\uAE08\uD558\uAE34 \uD574."
