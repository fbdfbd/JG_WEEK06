  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w004_excursion_library_blocked__step_w004_excursion_library_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 4\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uB124\uBAA8\uAC00 \uB192\uC740 \uC120\uBC18\uC5D0 \uAF42\uD78C \uB0A1\uC740
    \uC5ED\uC0AC\uC11C\uB97C \uBCF4\uBA70 \uAE4C\uCE58\uBC1C\uC744 \uB4E4\uACE0 \uC788\uB2E4.
    \uC190\uC774 \uB2FF\uC744\uB77D \uB9D0\uB77D \uD558\uB294 \uC21C\uAC04, \uB4A4\uC5D0\uC11C
    \uB204\uAD70\uAC00 \uB300\uC2E0 \uCC45\uC744 \uAEBC\uB0B4 \uB124\uBAA8\uC758
    \uBA38\uB9AC \uC704\uB85C \uC4F1 \uB0B4\uBBFC\uB2E4.)\r\n        \r\n       
    \uB124\uBAA8 : \uC557, \uAC10\uC0AC\uD569\uB2C8...\r\n        (\uB4A4\uB97C \uB3CC\uC544\uBCF4\uC790
    \uC544\uBB34\uB3C4 \uC5C6\uB2E4. \uBC31\uC791\uC758 \uC804\uC6A9 \uC9D1\uC0AC\uB9CC\uC774
    \uC870\uC6A9\uD788 \uACE0\uAC1C\uB97C \uC219\uC774\uACE0 \uC11C \uC788\uB2E4.)\r\n       
    \r\n        \uB124\uBAA8 : ...\uBC31\uC791\uB2D8\uC778 \uC904 \uC54C\uC558\uB124.\r\n       
    \uC9D1\uC0AC : \uC8FC\uC778\uB2D8\uAED8\uC11C \uB3C4\uB828\uB2D8\uC774 \uC774
    \uC2DC\uAC04\uC5D0 \uC774 \uCC45\uC744 \uCC3E\uC73C\uC2E4 \uAC70\uB77C\uBA70
    \uBBF8\uB9AC \uB300\uAE30\uD558\uB77C \uBA85\uD558\uC168\uC2B5\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uBBF8\uB9AC? \uB0B4\uAC00 \uBB58 \uC77D\uC744\uC9C0
    \uB2E4 \uC548\uB2E4\uB294 \uB4EF\uC774?\r\n        \uC9D1\uC0AC : \uB3C4\uB828\uB2D8\uC758
    \uB3C5\uC11C \uAE30\uB85D\uC744 \uB9E4\uC77C \uBC24 \uAC80\uD1A0\uD558\uC2DC\uB2C8\uAE4C\uC694.\r\n       
    \r\n\r\n(\uC9D1\uC0AC\uAC00 \uCC45\uC744 \uAC74\uB124\uC8FC\uC9C0 \uC54A\uACE0
    \uB3C5\uC11C\uB300\uB85C \uAC00\uC838\uAC00 \uD3BC\uCCD0 \uB193\uB294\uB2E4.)\r\n       
    \uC9D1\uC0AC : \uC8FC\uC778\uB2D8\uAED8\uC11C \uC774 \uCC45\uC740 \uBB34\uAC70\uC6B0\uB2C8
    \uBC18\uB4DC\uC2DC \uB3C5\uC11C\uB300 \uC704\uC5D0\uC11C\uB9CC \uBCF4\uB77C\uACE0
    \uD558\uC168\uC2B5\uB2C8\uB2E4. \uC774\uB3D9\uC740 \uAE08\uC9C0\uC785\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : ...\uB0B4 \uD314 \uADFC\uC721\uAE4C\uC9C0 \uAC71\uC815\uD574 \uC8FC\uB294
    \uAC70\uC57C, \uC544\uB2C8\uBA74 \uB0B4\uAC00 \uCC45 \uB4E4\uACE0 \uB3C4\uB9DD\uAC08\uAE4C
    \uBD10 \uADF8\uB7EC\uB294 \uAC70\uC57C?\r\n        \uC9D1\uC0AC : \uB458 \uB2E4\uC77C\uC9C0\uB3C4
    \uBAA8\uB974\uACA0\uC2B5\uB2C8\uB2E4.\r\n        \uB124\uBAA8 : (\uC785\uC220\uC744
    \uC090\uC8FD\uC774\uBA70) \uCC38\uB098. \uCC45\uC7A5 \uC704\uCE58\uAE4C\uC9C0
    \uB2E4 \uC678\uC6B0\uACE0 \uACC4\uC2DC\uB2E4\uB2C8, \uBB34\uC11C\uC6CC\uC11C
    \uCC45 \uBCF4\uACA0\uB098."
