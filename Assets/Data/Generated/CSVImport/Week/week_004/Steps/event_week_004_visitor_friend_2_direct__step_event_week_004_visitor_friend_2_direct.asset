  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_visitor_friend_2_direct__step_event_week_004_visitor_friend_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC00\uB9AC\uC544 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor friend_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uBC31\uC791\uC758 \uCC45\uC0C1 \uC704\uC5D0 \uB193\uC778
      \uC791\uC740 \uBAA8\uB798\uC2DC\uACC4\uB97C \uAC00\uC838\uC640 \uD0C1\uC790\uC5D0
      \uB193\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC70 \uB2E4 \uB5A8\uC5B4\uC9C8 \uB54C\uAE4C\uC9C0\uB9CC \uC26C\uC790.
      \uC774\uAC74 \uBC31\uC791\uB2D8\uC774 \uB098\uD55C\uD14C \uC8FC\uC2E0 '\uD734\uC2DD
      \uC2DC\uAC04' \uC804\uC6A9 \uC2DC\uACC4\uC57C."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uC6B0\uC640, \uBAA8\uB798\uAC00 \uBC18\uC9DD\uAC70\uB824. \uB124\uBAA8\uC57C,
      \uB108\uB294 \uCC38 \uC88B\uC740 \uBCF4\uD638\uC790\uB97C \uB450\uC5C8\uAD6C\uB098.
      \uC774\uB807\uAC8C \uC608\uC05C \uAC78\uB85C \uC26C\uB294 \uC2DC\uAC04\uB3C4
      \uCC59\uACA8\uC8FC\uC2DC\uACE0."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uBBF8\uC18C \uC9C0\uC73C\uBA70) \uADF8\uCE58? \uB098\uC911\uC5D0 \uBAA8\uB798
      \uB2E4 \uB5A8\uC5B4\uC9C0\uBA74 \uC800\uAE30 \uC788\uB294 \uB9DB\uC788\uB294
      \uCC28\uB3C4 \uAC19\uC774 \uB9C8\uC2DC\uC790."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uBC31\uC791\uC758 \uCC45\uC0C1 \uC704\uC5D0 \uB193\uC778
    \uC791\uC740 \uBAA8\uB798\uC2DC\uACC4\uB97C \uAC00\uC838\uC640 \uD0C1\uC790\uC5D0
    \uB193\uB294\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
