  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w004_visitor_friend_2_blocked__step_w004_visitor_friend_2_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 4\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uC11C\uC7AC \uC18C\uD30C\uC5D0 \uB124\uBAA8\uC640 \uCE5C\uAD6C 2\uAC00
    \uB098\uB780\uD788 \uC549\uC544 \uAC01\uC790 \uCC45\uC744 \uC77D\uACE0 \uC788\uB2E4.
    \uB108\uBB34 \uC870\uC6A9\uD574\uC11C \uC2DC\uACC4\uCD94 \uC18C\uB9AC\uB9CC \uB4E4\uB9AC\uB294
    \uAC00\uC6B4\uB370, \uCE5C\uAD6C 2\uAC00 \uC870\uC2EC\uC2A4\uB7FD\uAC8C \uC785\uC744
    \uC5F0\uB2E4.)\n        \n        \uCE5C\uAD6C 2 : \uB124\uBAA8\uC57C, \uC5EC\uAE30\uB294
    \uC815\uB9D0... \uC138\uC0C1\uC5D0\uC11C \uC81C\uC77C \uC870\uC6A9\uD55C \uACF3
    \uAC19\uC544. \uCC45\uC7A5\uC774 \uB118\uC5B4\uAC00\uB294 \uC18C\uB9AC\uB3C4
    \uD06C\uAC8C \uB4E4\uB824.\n        \uB124\uBAA8 : \uC751, \uBC31\uC791\uB2D8\uC774
    \uACF5\uBD80\uD560 \uB550 \uC9D1\uC911\uD574\uC57C \uD55C\uB2E4\uACE0 \uD558\uC168\uAC70\uB4E0.
    \uB108\uB791 \uC774\uB807\uAC8C \uBCF4\uB2C8\uAE4C \uD558\uB098\uB3C4 \uC548
    \uC2EC\uC2EC\uD558\uACE0 \uC88B\uB2E4.\n        \uCE5C\uAD6C 2 : \uB098\uB3C4...
    \uC6B0\uB9AC \uC9D1\uBCF4\uB2E4 \uC5EC\uAE30\uAC00 \uB354 \uC9D1\uC911\uC774
    \uC798 \uB418\uB294 \uAC83 \uAC19\uC544.\n        \n\n(\uB450 \uC18C\uB144\uC774
    \uC18C\uACE4\uAC70\uB9AC\uC790, \uBB38\uAC00\uC5D0 \uC11C \uC788\uB358 \uACBD\uBE44\uB300\uC7A5\uC774
    \uD5DB\uAE30\uCE68\uC744 \uD558\uBA70 \uB2E4\uAC00\uC628\uB2E4.)\n        \uACBD\uBE44\uB300\uC7A5
    : \uB3C4\uB828\uB2D8, \uC8FC\uC778\uB2D8\uAED8\uC11C \uC11C\uC7AC \uB0B4\uC5D0\uC11C\uC758
    \uBD88\uD544\uC694\uD55C \uB300\uD654\uB294 \uC0BC\uAC00\uB77C \uD558\uC168\uC2B5\uB2C8\uB2E4.
    \uB3C5\uC11C\uC5D0\uB9CC \uC9D1\uC911\uD558\uC2ED\uC2DC\uC624.\n        \uB124\uBAA8
    : (\uBAA9\uC18C\uB9AC\uB97C \uB0AE\uCD94\uBA70) \uC544\uC800\uC528, \uCE5C\uAD6C\uB791
    \uC544\uC8FC \uC791\uAC8C \uC774\uC57C\uAE30\uD558\uB294 \uAC83\uB3C4 \uC548
    \uB3FC\uC694?\n        \uCE5C\uAD6C 2 : (\uAE5C\uC9DD \uB180\uB77C \uCC45\uC73C\uB85C
    \uC5BC\uAD74\uC744 \uAC00\uB9AC\uBA70) \uBBF8\uC548\uD574, \uB124\uBAA8\uC57C...
    \uB0B4\uAC00 \uB9D0\uC744 \uAC78\uC5B4\uC11C... \uC774\uC81C \uC870\uC6A9\uD788
    \uD560\uAC8C.\n        \uB124\uBAA8 : (\uCE5C\uAD6C 2\uC758 \uB208\uCE58\uB97C
    \uBCF4\uBA70) \uC544\uB0D0, \uB124 \uC798\uBABB \uC544\uB0D0. \uBC31\uC791\uB2D8\uC774
    \uC880 \uC5C4\uACA9\uD558\uC154\uC11C \uADF8\uB798."
