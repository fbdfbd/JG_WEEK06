  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w004_excursion_basement_blocked__step_w004_excursion_basement_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 4\uCC28 \uBC29\uBB38 - \uD1B5"
  _bodyText: "(\uBE44 \uC624\uB294 \uB0A0 \uC624\uD6C4. \uC9C0\uD558\uC2E4 \uC785\uAD6C
    \uADFC\uCC98 \uBCBD\uC5D0 \uD587\uBE5B \uB300\uC2E0 \uC791\uC740 \uC870\uBA85\uC11D
    \uBD88\uBE5B\uC774 \uB9FA\uD600 \uC788\uB2E4. \uB124\uBAA8\uB294 \uADF8 \uBE5B
    \uC544\uB798, \uBCBD \uD55C\uCABD\uC5D0 \uC5B4\uC124\uD508 \uC120\uACFC \uB3D9\uADF8\uB77C\uBBF8\uAC00
    \uADF8\uB824\uC9C4 \uAC78 \uBC1C\uACAC\uD55C\uB2E4.)\n        \n        \uB124\uBAA8
    : \uC5B4?\n        \n        \uB124\uBAA8 : \uC774\uAC70 \uB099\uC11C\uC796\uC544.\n       
    \n        (\uAC00\uAE4C\uC774 \uBCF4\uB2C8 \uB099\uC11C \uC704\uC5D4 \uC587\uACE0
    \uD22C\uBA85\uD55C \uB9C9 \uAC19\uC740 \uAC8C \uC50C\uC6CC\uC838 \uC788\uB2E4.
    \uC190\uB05D\uC73C\uB85C \uAC74\uB4DC\uB9AC\uBA74 \uCC28\uAC11\uACE0 \uB9E4\uB048\uD558\uB2E4.)\n       
    \n        \uB124\uBAA8 : \uBB50\uC57C. \uB099\uC11C \uC704\uC5D0 \uC720\uB9AC
    \uBC1C\uB77C \uB1A8\uB124.\n        \n\n\uCC3D\uACE0\uC9C0\uAE30 : \uC8FC\uC778\uB2D8,
    \uC624\uB798\uB41C \uBCBD\uBA74\uC774\uB77C \uC190\uB300\uBA74 \uB36E\uAC1C\uAC00
    \uBC97\uACA8\uC9C8 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n        \n        \uB124\uBAA8
    : \uADFC\uB370 \uC65C \uC548 \uC9C0\uC6E0\uC5B4?\n        \n        \uCC3D\uACE0\uC9C0\uAE30
    : ...\uC9C0\uC6B0\uC9C0 \uB9D0\uB77C \uD558\uC2E0 \uBD84\uC774 \uACC4\uC168\uC2B5\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uB354 \uAD81\uAE08\uD558\uAC8C \uB9D0\uD558\uB124."
