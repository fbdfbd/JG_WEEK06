  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_house_talk_w004_modified__step_event_week_004_house_talk_w004_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC2E0\uBE44\uD55C \uCD08\uC0C1\uD654 \uC18C\uBB38 \uC218\uC815"
  _bodyText: "house_talk w004 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC774 \uADF8\uB9BC\uC740 \uBCF4\uB294 \uBC29\uD5A5\uC5D0 \uB530\uB77C
      \uB208\uB3D9\uC790\uAC00 \uB530\uB77C\uC624\uB294 \uAC83\uCC98\uB7FC \uADF8\uB824\uC9C4
      \uC544\uC8FC \uC2E0\uAE30\uD55C \uC791\uD488\uC774\uC5D0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB208\uC774 \uB530\uB77C\uC640?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uD654\uAC00\uB2D8\uC774 \uC77C\uBD80\uB7EC \uADF8\uB807\uAC8C
      \uB9CC\uB4DC\uC2E0 \uAC70\uB798\uC694. \uC5B4\uB514\uC11C\uB4E0 \uC8FC\uC778\uB2D8\uACFC
      \uC778\uC0AC\uB97C \uB098\uB204\uACE0 \uC2F6\uC5B4\uC11C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640, \uC9C4\uC9DC\uB124! \uB0B4\uAC00 \uC774\uCABD\uC73C\uB85C
      \uAC00\uB3C4 \uB098\uB97C \uBD10!"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uB124. \uC544\uC8FC \uB2E4\uC815\uD55C \uADF8\uB9BC\uC774\uC9C0\uC694?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751! \uC774\uC81C \uC774 \uBCF5\uB3C4 \uC9C0\uB0A0 \uB550 \uB098\uB3C4
      \uC778\uC0AC\uD574 \uC904\uB798."
  _nemoLine: "\uC774 \uADF8\uB9BC\uC740 \uBCF4\uB294 \uBC29\uD5A5\uC5D0 \uB530\uB77C
    \uB208\uB3D9\uC790\uAC00 \uB530\uB77C\uC624\uB294 \uAC83\uCC98\uB7FC \uADF8\uB824\uC9C4
    \uC544\uC8FC \uC2E0\uAE30\uD55C \uC791\uD488\uC774\uC5D0\uC694."
  _useCustomVisualState: 0
  _visualState: 0
