  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_external_w004_direct__step_event_week_004_external_w004_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC740\uB454\uC790 \uB9C8\uBC95\uC0AC \uC18C\uBB38 \uD5C8\uAC00"
  _bodyText: "external w004 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: bb92d18cb19ba9944ac71077eb8aa4c5, type: 2}
    _text: "\uC18C\uBB38\uC5D0 \uC758\uD558\uBA74 \uC544\uC8FC \uC61B\uB0A0\uC5D0
      \uAD81\uC804\uC5D0\uC11C \uCAD3\uACA8\uB09C \uB9C8\uBC95\uC0AC\uB77C\uB294
      \uB9D0\uC774 \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9C8\uBC95\uC0AC? \uC9C4\uC9DC\uB85C \uC9C0\uD321\uC774 \uD754\uB4E4\uBA74
      \uB9C8\uBC95\uC774 \uB098\uC640?"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC870\uC2EC\uD558\uC138\uC694, \uC8FC\uC778\uB2D8. \uB9C8\uBC95\uC0AC\uB791
      \uB208\uC774 \uB9C8\uC8FC\uCE58\uBA74 \uB3CC\uC774 \uB418\uC5B4\uBC84\uB9B0\uB2E4\uB294
      \uC18C\uBB38\uB3C4 \uC788\uC73C\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5C9... \uADF8\uB7FC \uC232 \uADFC\uCC98\uC5D4 \uC808\uB300 \uAC00\uBA74
      \uC548 \uB418\uACA0\uB2E4. \uADFC\uB370 \uC870\uAE08 \uAD81\uAE08\uD558\uAE34
      \uD574."
  _nemoLine: "\uC18C\uBB38\uC5D0 \uC758\uD558\uBA74 \uC544\uC8FC \uC61B\uB0A0\uC5D0
    \uAD81\uC804\uC5D0\uC11C \uCAD3\uACA8\uB09C \uB9C8\uBC95\uC0AC\uB77C\uB294 \uB9D0\uC774
    \uC788\uC5B4\uC694."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
