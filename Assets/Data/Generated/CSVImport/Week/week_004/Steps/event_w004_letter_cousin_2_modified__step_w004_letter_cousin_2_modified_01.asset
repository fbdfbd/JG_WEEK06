  m_Name: event_w004_letter_cousin_2_modified__step_w004_letter_cousin_2_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 \uD3B8\uC9C0 4\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uC544\uC8FC \uC791\uACE0 \uD5A5\uAE0B\uD55C \uAF43\uD5A5\uAE30\uAC00
    \uB098\uB294 \uBD09\uD22C\uB97C \uBC1B\uC544 \uB4E0\uB2E4. \uAE00\uC528\uAC00
    \uC870\uAE08 \uB354 \uB2E8\uC815\uD574\uC84C\uC9C0\uB9CC, \uC5EC\uC804\uD788
    \uC870\uC2EC\uC2A4\uB7EC\uC6B4 \uD544\uCCB4\uB2E4.)\r\n    \uD558\uB140 : \uC0AC\uCD0C
    \uC8FC\uC778\uB2D8 \uCABD\uC5D0\uC11C \uC628 \uD3B8\uC9C0\uB124\uC694. \uBD09\uD22C
    \uC0AC\uC774\uC5D0 \uC791\uC740 \uB9D0\uB9B0 \uAF43\uC78E\uC774 \uB07C\uC5B4
    \uC788\uC2B5\uB2C8\uB2E4.\r\n        \r\n\r\n(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C
    \uC77D\uACE0 \uB124\uBAA8\uC758 \uB208\uB192\uC774\uC5D0 \uB9DE\uCDB0 \uC549\uC544
    \uB0B4\uC6A9\uC744 \uC804\uD55C\uB2E4.)\r\n        \uD558\uB140 : \uC8FC\uC778\uB2D8,
    \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uC774 \uD3B8\uC9C0\uB97C
    \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\r\n        \uB124\uBAA8 : \uBB50\uB77C\uACE0
    \uD588\uC5B4?\r\n        \uD558\uB140 : \uC800\uBC88\uC5D0 \uC8FC\uC778\uB2D8\uC774
    \uACBD\uBE44\uB300\uC7A5\uB2D8 \uC55E\uC5D0\uC11C\uB3C4 \uB2F9\uB2F9\uD558\uAC8C
    \uBCF8\uC778\uC744 \uAC10\uC2F8\uC8FC\uC5C8\uB358 \uAC8C \uC815\uB9D0 \uBA4B\uC788\uC5C8\uB300\uC694.\r\n       
    \uB124\uBAA8 : \uC9C4\uC9DC? \uB0B4\uAC00?\r\n        \uD558\uB140 : \uB124.
    \uADF8\uB798\uC11C \uC8FC\uC778\uB2D8\uC744 \uC804\uBCF4\uB2E4 \uD6E8\uC52C \uB354
    \uBBFF\uACE0 \uC88B\uC544\uD558\uAC8C \uB418\uC5C8\uB2E4\uACE0 \uD569\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : \uC624... \uAC54\uB294 \uCC38 \uB9C8\uC74C\uC774 \uC5EC\uB824.
    \uB0B4\uAC00 \uC798\uD574\uC918\uC57C\uACA0\uC5B4."
