  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_visitor_friend_3_direct__step_event_week_004_visitor_friend_3_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC720\uD53C \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor friend_3 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uCE5C\uAD6C 3\uC5D0\uAC8C \uC606\uC5D0 \uC788\uB294
      \uB0A1\uC740 \uC9C0\uAD6C\uBCF8\uC744 \uB300\uC2E0 \uBCF4\uC5EC\uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB300\uC2E0 \uC774\uAC70 \uBD10\uBD10. \uC774\uAC74 \uBC31\uC791\uB2D8\uC774
      \uB098 \uACF5\uBD80\uD560 \uB54C \uBCF4\uB77C\uACE0 \uD5C8\uB77D\uD574\uC8FC\uC2E0
      \uAC70\uC57C. \uB3CC\uB9AC\uBA74 \uC18C\uB9AC\uB3C4 \uB09C\uB2E4?"
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uC624, \uB300\uBC15! \uC9C4\uC9DC\uB124? \uC57C, \uB124\uBAA8. \uB108\uB294
      \uC5EC\uAE30 \uAC00\uB9CC\uD788 \uC549\uC544\uC11C \uC804 \uC138\uACC4\uB97C
      \uB2E4 \uAD6C\uACBD\uD558\uB294\uAD6C\uB098. \uBC31\uC791\uB2D8\uB3C4 \uC54C\uACE0
      \uBCF4\uBA74 \uAF64 \uB0AD\uB9CC\uC801\uC778 \uBD84 \uC544\uB0D0?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uBBF8\uC18C \uC9C0\uC73C\uBA70) \uADF8\uB7F4\uC9C0\uB3C4 \uBAB0\uB77C.
      \uB098\uC911\uC5D0 \uB108\uB791 \uAC19\uC774 \uC800\uAE30 \uB05D\uAE4C\uC9C0
      \uAC00\uBCF4\uB294 \uAC8C \uB0B4 \uAFC8\uC774\uC57C."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uCE5C\uAD6C 3\uC5D0\uAC8C \uC606\uC5D0 \uC788\uB294
    \uB0A1\uC740 \uC9C0\uAD6C\uBCF8\uC744 \uB300\uC2E0 \uBCF4\uC5EC\uC900\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
