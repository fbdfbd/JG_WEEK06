MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_excursion_basement_direct__step_event_week_004_excursion_basement_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: basement Direct
  _bodyText: "excursion basement Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uB36E\uAC1C \uC704 \uBA3C\uC9C0\uB9CC
      \uBD80\uB4DC\uB7FD\uAC8C \uB2E6\uC544 \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC5EC\uC12F \uC0B4 \uB54C \uC8FC\uC778\uB2D8\uC774 \uADF8\uB9AC\uC2E0
      \uAC81\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB0B4\uAC00?"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC608. \uC9C0\uC6B0\uB824 \uD588\uB354\uB2C8 \uBC31\uC791\uB2D8\uAED8\uC11C
      \uADF8\uB300\uB85C \uB450\uB77C\uACE0 \uD558\uC168\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uC9C4\uC9DC?"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC608. \uADF8\uB798\uC11C \uD22C\uBA85 \uB36E\uAC1C\uAE4C\uC9C0 \uC50C\uC6E0\uC9C0\uC694.
      \uBC88\uC9C0\uAC70\uB098 \uAE01\uD788\uC9C0 \uC54A\uAC8C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC7A0\uAE50\uB9CC."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB099\uC11C\uC5D0 \uBCF4\uD638\uB9C9\uC744 \uC50C\uC6E0\uB2E4\uACE0?"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uB124."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uC880 \uC6C3\uAE34\uB370."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uB36E\uAC1C \uB108\uBA38 \uC090\uB6A4\uBE7C\uB6A4\uD55C
      \uB3D9\uADF8\uB77C\uBBF8\uB97C \uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBABB \uADF8\uB838\uB124."
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uADF8\uB798\uB3C4 \uBC31\uC791\uB2D8 \uB208\uC5D4 \uC9C0\uC6B8 \uAC8C
      \uC544\uB2C8\uC5C8\uB358 \uBAA8\uC591\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uADF8\uAC74 \uC880 \uC774\uC0C1\uD558\uAC8C \uC88B\uB2E4."
  _nemoLine: "(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uB36E\uAC1C \uC704 \uBA3C\uC9C0\uB9CC
    \uBD80\uB4DC\uB7FD\uAC8C \uB2E6\uC544 \uC900\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
