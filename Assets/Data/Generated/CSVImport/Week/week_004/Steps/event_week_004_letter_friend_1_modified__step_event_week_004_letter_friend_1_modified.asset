MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_letter_friend_1_modified__step_event_week_004_letter_friend_1_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9C9\uC2A4 \uD3B8\uC9C0 \uC218\uC815"
  _bodyText: "letter friend_1 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798
      \uC190\uB2D8\uC774 \uB2E4\uC2DC \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uB77C\uACE0 \uD588\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uACBD\uBE44\uB300\uC7A5\uB2D8\uC774 \uC870\uAE08 \uBB34\uC11C\uC6E0\uC9C0\uB9CC,
      \uADF8\uB798\uB3C4 \uC8FC\uC778\uB2D8\uC774\uB791 \uAF2D \uB2E4\uC2DC \uB180\uACE0
      \uC2F6\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uADF8\uB798\uC11C \uB2E4\uC74C\uC5D0 \uB9CC\uB098\uBA74 \uB458\uB9CC\uC758
      \uC2E0\uD638\uB97C \uB9CC\uB4E4\uC5B4\uC11C \uC7AC\uBC0C\uAC8C \uB180\uC790\uACE0
      \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC2E0\uD638? \uC5B4\uB5BB\uAC8C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB208\uC9D3\uC744 \uD558\uAC70\uB098, \uC18C\uB9AC\uB97C \uB0B4\uAC70\uB098...
      \uC6B0\uB9AC\uB07C\uB9AC\uB9CC \uC544\uB294 \uADDC\uCE59\uC744 \uB9CC\uB4E4\uC790\uACE0
      \uD558\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624. \uADF8\uB7FC \uB098\uB3C4 \uC5F0\uC2B5\uD574 \uAC00\uC57C\uACA0\uB2E4."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798
    \uC190\uB2D8\uC774 \uB2E4\uC2DC \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
