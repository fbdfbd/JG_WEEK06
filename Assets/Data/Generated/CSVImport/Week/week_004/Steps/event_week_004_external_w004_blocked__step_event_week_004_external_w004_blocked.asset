  _titleOverride: w004 Blocked
  _bodyText: "external w004 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: bb92d18cb19ba9944ac71077eb8aa4c5, type: 2}
    _text: "(\uB124\uBAA8\uB97C \uBCF4\uACE0 \uAE5C\uC9DD \uB180\uB77C \uBAA8\uC790\uB97C
      \uBC97\uC73C\uBA70) \uC544, \uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4,
      \uC5B4\uB9B0 \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uADF8\uB0E5 \uB5A0\uB3CC\uC774 \uAC1C\uB4E4\uC774 \uB208\uC744 \uBD80\uB77C\uB9AC\uB294
      \uAC78 \uC798\uBABB \uBD24\uB098 \uBD05\uB2C8\uB2E4. \uB3C4\uB828\uB2D8\uC740
      \uC2E0\uACBD \uC4F0\uC9C0 \uB9C8\uC2DC\uACE0 \uC548\uC73C\uB85C \uB4E4\uC5B4\uAC00\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC29\uAE08 \uBD88\uBE5B\uC774 \uBC88\uCA4D\uC600\uB2E4\uACE0 \uD588\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: bb92d18cb19ba9944ac71077eb8aa4c5, type: 2}
    _text: "\uD558\uD558, \uC81C\uAC00 \uB178\uC548\uC774\uB77C \uBC88\uAC2F\uBD88\uC744
      \uC798\uBABB \uBCF8 \uBAA8\uC591\uC785\uB2C8\uB2E4\uC694."
  _nemoLine: "(\uB124\uBAA8\uB97C \uBCF4\uACE0 \uAE5C\uC9DD \uB180\uB77C \uBAA8\uC790\uB97C
    \uBC97\uC73C\uBA70) \uC544, \uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4,
    \uC5B4\uB9B0 \uC8FC\uC778\uB2D8."
