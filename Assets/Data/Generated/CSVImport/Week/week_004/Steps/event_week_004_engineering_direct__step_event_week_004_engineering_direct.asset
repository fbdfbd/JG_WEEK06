  _titleOverride: "\uB3C4\uB974\uB798\uC640 \uAD6C\uC870\uC758 \uAE30\uBCF8\uC744
    \uAC00\uB974\uCE5C\uB2E4"
  _bodyText: "\uB3C4\uB974\uB798\uC640 \uAD6C\uC870\uC758 \uAE30\uBCF8\uC744 \uAC00\uB974\uCE5C\uB2E4
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD1B1\uB2C8\uC640 \uB3C4\uB974\uB798 \uADF8\uB9BC\uC744 \uC9DA\uC73C\uBA70
      \uAD6C\uC870\uAC00 \uC5B4\uB5BB\uAC8C \uC6C0\uC9C1\uC774\uB294\uC9C0 \uC124\uBA85\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774 \uD1B1\uB2C8\uAC00 \uB3CC\uBA74 \uC606\uC5D0 \uC788\uB294 \uAC83\uB3C4
      \uAC19\uC774 \uB3C4\uB294 \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uAC01 \uBD80\uD488\uC758 \uC5ED\uD560\uC744 \uD558\uB098\uC529 \uC5F0\uACB0\uD574
      \uC774\uD574\uC2DC\uD0A4\uB824 \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uC81C \uC65C \uAC19\uC774 \uB3C4\uB294\uC9C0 \uC870\uAE08 \uC54C\uACA0\uC5B4."
  _nemoLine: "(\uD1B1\uB2C8\uC640 \uB3C4\uB974\uB798 \uADF8\uB9BC\uC744 \uC9DA\uC73C\uBA70
    \uAD6C\uC870\uAC00 \uC5B4\uB5BB\uAC8C \uC6C0\uC9C1\uC774\uB294\uC9C0 \uC124\uBA85\uD55C\uB2E4.)"
