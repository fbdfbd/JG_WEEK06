  m_Name: event_w004_house_main_blocked__step_w004_house_main_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "4\uC8FC\uCC28 - \uD1B5\uC81C"
  _bodyText: "(\uB2A6\uC740 \uC624\uD6C4 \uBCF5\uB3C4. \uD558\uB140 \uB458\uC774
    \uBCBD\uC5D0 \uAC78\uB9B0 \uCEE4\uB2E4\uB780 \uCD08\uC0C1\uD654\uB97C \uD790\uB057\uAC70\uB9AC\uBA70
    \uBE60\uB974\uAC8C \uAC77\uACE0 \uC788\uB2E4.)\n    \uD558\uB1401 : \uC800\uBC88\uC5D0
    \uB2E6\uC744 \uB54C \uBD84\uBA85 \uC67C\uCABD\uC744 \uBCF4\uACE0 \uC788\uC5C8\uB294\uB370...\n   
    \uD558\uB1402 : \uB9D0\uB3C4 \uB9C8. \uB098\uB3C4 \uC544\uAE4C \uC815\uBA74\uC778
    \uC904 \uC54C\uACE0 \uAE5C\uC9DD \uB180\uB790\uB2E4\uB2C8\uAE4C.\n    \uB124\uBAA8
    : \uADF8\uB9BC\uC774 \uC6C0\uC9C1\uC5EC?\n    \n\n\uD558\uB1401 : \uC544\uBB34\uAC83\uB3C4
    \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.\n    \uD558\uB1402 : \uADF8\uB0E5
    \uC870\uBA85 \uB54C\uBB38\uC5D0 \uADF8\uB807\uAC8C \uBCF4\uC778 \uAC70\uC608\uC694.\n   
    \uB124\uBAA8 : \uBC29\uAE08 \uB208\uB3D9\uC790\uAC00 \uBCC0\uD588\uB2E4\uBA70.\n   
    \uD558\uB1401 : \uC800\uD76C\uAC00 \uB208\uC774 \uD53C\uB85C\uD574\uC11C \uC798\uBABB
    \uBCF8 \uBAA8\uC591\uC785\uB2C8\uB2E4. \uC8FC\uC778\uB2D8\uC740 \uC2E0\uACBD
    \uC4F0\uC9C0 \uB9C8\uC138\uC694.\n    \uB124\uBAA8 : \uC5D0\uC774, \uB610 \uB098\uB9CC
    \uBE7C\uACE0 \uC598\uAE30\uD574."
