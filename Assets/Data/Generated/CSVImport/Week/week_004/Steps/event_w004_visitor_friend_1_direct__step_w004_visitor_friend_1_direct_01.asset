  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w004_visitor_friend_1_direct__step_w004_visitor_friend_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 4\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uBC31\uC791\uC774 \uC5C6\uB294 \uC0AC\uC774, \uB124\uBAA8\uAC00 \uCE5C\uAD6C
    1\uC744 \uB370\uB9AC\uACE0 \uC11C\uC7AC\uB85C \uBAB0\uB798 \uB4E4\uC5B4\uC628\uB2E4.
    \uCE5C\uAD6C 1\uC740 \uC11C\uC7AC\uC758 \uC6C5\uC7A5\uD568\uC5D0 \uAC10\uD0C4\uD558\uBA70
    \uC774\uACF3\uC800\uACF3\uC744 \uB4E4\uC464\uC2E0\uB2E4.)\n        \n       
    \uCE5C\uAD6C 1 : \uC640, \uB124\uBAA8! \uB108\uB124 \uC544\uC800\uC528 \uC11C\uC7AC
    \uC9C4\uC9DC \uB05D\uB0B4\uC900\uB2E4! \uC800 \uCE7C \uBB50\uC57C? \uC9C4\uC9DC
    \uBCA0\uC5EC?\n        \uB124\uBAA8 : \uC57C, \uC870\uC6A9\uD788 \uD574! \uACBD\uBE44\uB300\uC7A5
    \uC544\uC800\uC528\uD55C\uD14C \uB4E4\uD0A4\uBA74 \uC6B0\uB9AC \uBC14\uB85C \uCAD3\uACA8\uB09C\uB2E8
    \uB9D0\uC774\uC57C.\n        \uCE5C\uAD6C 1 : \uC5D0\uC774, \uD55C \uBC88\uB9CC
    \uB9CC\uC838\uBCF4\uC790. \uC0BC\uCD0C\uC774 \uADF8\uB7EC\uB294\uB370 \uC774
    \uC11C\uC7AC\uC5D0 \uC5C4\uCCAD\uB09C \uBCF4\uBB3C\uC774 \uC228\uACA8\uC838 \uC788\uB300!\n       
    \n\n(\uB124\uBAA8\uAC00 \uCE5C\uAD6C 1\uC5D0\uAC8C \uBC31\uC791\uC758 \uCC45\uC0C1
    \uC704\uC5D0 \uB193\uC778 \uD654\uB824\uD55C \uB3CB\uBCF4\uAE30\uB97C \uAC74\uB124\uC900\uB2E4.)\n       
    \uB124\uBAA8 : \uCE7C\uC740 \uC548 \uB3FC\uB3C4 \uC774\uAC74 \uBD10\uB3C4 \uB3FC.
    \uC774\uAC78\uB85C \uBCF4\uBA74 \uAE00\uC790\uAC00 \uC774\uB9CC\uD07C \uCEE4\uC9C4\uB2E4?\n       
    \uCE5C\uAD6C 1 : \uC624! \uC9C4\uC9DC\uB124? \uC57C, \uC774\uAC78\uB85C \uC800\uAE30
    \uBA40\uB9AC \uC788\uB294 \uAC1C\uBBF8\uB3C4 \uBCF4\uC774\uACA0\uB2E4! \uB108\uD76C
    \uC544\uC800\uC528, \uBB34\uC11C\uC6B4 \uC904\uB9CC \uC54C\uC558\uB294\uB370
    \uC774\uB7F0 \uC7AC\uBC0C\uB294 \uAC83\uB3C4 \uAC00\uC9C0\uACE0 \uACC4\uC2DC\uB124.\n       
    \uB124\uBAA8 : (\uBFCC\uB4EF\uD574\uD558\uBA70) \uADF8\uCE58? \uB098\uC911\uC5D0
    \uBC31\uC791\uB2D8 \uAE30\uBD84 \uC88B\uC73C\uC2E4 \uB54C \uC800\uAE30 \uC788\uB294
    \uBCF4\uBB3C\uD568\uB3C4 \uBCF4\uC5EC\uB2EC\uB77C\uACE0 \uD574\uBCFC\uAC8C."
