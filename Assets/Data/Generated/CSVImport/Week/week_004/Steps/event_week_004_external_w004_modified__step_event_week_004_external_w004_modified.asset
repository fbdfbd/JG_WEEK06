  _titleOverride: w004 Modified
  _bodyText: "external w004 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: bb92d18cb19ba9944ac71077eb8aa4c5, type: 2}
    _text: "\uC0AC\uC2E4\uC740 \uC544\uC8FC \uADC0\uD55C \uC57D\uCD08\uB97C \uCE90\uB294
      \uC57D\uCD08\uAFBC\uB4E4\uC774 \uBC24\uC5D0 \uB4F1\uBD88\uC744 \uCF1C\uACE0
      \uC791\uC5C5\uC744 \uD558\uB294 \uAC70\uB798\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC57D\uCD08\uAFBC\uB4E4\uC774 \uBC24\uC5D0 \uC77C\uC744 \uD574?"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uBC24\uC5D0\uB9CC \uD53C\uB294 \uAF43\uC774 \uC788\uAC70\uB4E0\uC694.
      \uC544\uC8FC \uD5A5\uAE30\uB86D\uACE0 \uBAB8\uC5D0 \uC88B\uC740 \uAF43\uC774\uB77C\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640, \uADF8\uB7FC \uBB34\uC11C\uC6B4 \uAC8C \uC544\uB2C8\uB124?
      \uB098\uC911\uC5D0 \uADF8 \uAF43 \uD5A5\uAE30 \uB098\uB3C4 \uB9E1\uC544\uBCF4\uACE0
      \uC2F6\uC5B4."
  _nemoLine: "\uC0AC\uC2E4\uC740 \uC544\uC8FC \uADC0\uD55C \uC57D\uCD08\uB97C \uCE90\uB294
    \uC57D\uCD08\uAFBC\uB4E4\uC774 \uBC24\uC5D0 \uB4F1\uBD88\uC744 \uCF1C\uACE0 \uC791\uC5C5\uC744
    \uD558\uB294 \uAC70\uB798\uC694."
