  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_house_talk_w004_direct__step_event_week_004_house_talk_w004_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: w004 Direct
  _bodyText: "house_talk w004 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC774 \uCD08\uC0C1\uD654\uB294 \uAC00\uBB38\uC758 \uC870\uC0C1\uB2D8\uC774\uB77C,
      \uAC00\uB054 \uD6C4\uC190\uB4E4\uC744 \uC9C0\uCF1C\uBCF4\uC2E0\uB2E4\uB294
      \uC18C\uBB38\uC774 \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC? \uB098\uB97C \uBCF4\uACE0 \uACC4\uC2E0 \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uB098\uC05C \uC9D3\uC744 \uD558\uB294 \uC0AC\uB78C\uC774 \uC5C6\uB294\uC9C0
      \uAC10\uC2DC\uD558\uC2E0\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5C9... \uADF8\uB7FC \uB0B4\uAC00 \uACFC\uC790 \uBAB0\uB798 \uBA39\uB294
      \uAC83\uB3C4 \uC544\uC2DC\uACA0\uB124?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC544\uB9C8 \uADF8\uB7F4\uC9C0\uB3C4 \uBAA8\uB974\uC9C0\uC694. \uADF8\uB798\uC11C
      \uB2E4\uB4E4 \uC774 \uBCF5\uB3C4\uC5D0\uC120 \uC870\uC2EC\uD55C\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB34\uC11C\uC6B4\uB370... \uADF8\uB798\uB3C4 \uB098\uB97C \uC9C0\uCF1C\uC8FC\uC2DC\uB294
      \uAC70\uB2C8\uAE4C \uC870\uAE08 \uB4E0\uB4E0\uD574."
  _nemoLine: "\uC774 \uCD08\uC0C1\uD654\uB294 \uAC00\uBB38\uC758 \uC870\uC0C1\uB2D8\uC774\uB77C,
    \uAC00\uB054 \uD6C4\uC190\uB4E4\uC744 \uC9C0\uCF1C\uBCF4\uC2E0\uB2E4\uB294 \uC18C\uBB38\uC774
    \uC788\uC5B4\uC694."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
