MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_excursion_lake_blocked__step_event_week_004_excursion_lake_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: lake Blocked
  _bodyText: "excursion lake Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uB09C\uAC04 \uC55E\uC5D0\uC11C \uD55C
      \uAC78\uC74C \uBA3C\uC800 \uBA48\uCDB0 \uC120\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC5EC\uAE30\uC11C \uBCF4\uC154\uC57C
      \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uD574\uAC00 \uC84C\uC2B5\uB2C8\uB2E4. \uBB3C\uAC00 \uCABD\uC740 \uB354
      \uC5B4\uB450\uC6CC\uC9C0\uACE0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADFC\uB370 \uC800 \uB4F1\uBD88 \uC788\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uADF8\uB798\uC11C \uB354\uB354\uC6B1 \uB09C\uAC04 \uC548\uCABD\uAE4C\uC9C0\uB9CC\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4 \uD574 \uB193\uACE0 \uBABB \uAC00\uAC8C \uD558\uBA74 \uC880 \uC5B5\uC6B8\uD55C\uB370."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uBCF4\uB294 \uAC83\uB9CC\uC73C\uB85C\uB3C4 \uCDA9\uBD84\uD788 \uC608\uC058\uC9C0
      \uC54A\uC2B5\uB2C8\uAE4C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uADF8\uB798\uB3C4 \uB204\uAC00 \uC774\uB7F0 \uAC78 \uD574 \uB1A8\uB294\uC9C4
      \uAD81\uAE08\uD558\uB124."
  _nemoLine: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uB09C\uAC04 \uC55E\uC5D0\uC11C \uD55C
    \uAC78\uC74C \uBA3C\uC800 \uBA48\uCDB0 \uC120\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
