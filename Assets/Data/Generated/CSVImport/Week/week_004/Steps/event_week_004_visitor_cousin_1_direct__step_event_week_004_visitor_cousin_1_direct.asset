  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_visitor_cousin_1_direct__step_event_week_004_visitor_cousin_1_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE74\uC774\uC548 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor cousin_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC0C1\uC790\uB97C \uC5F4\uC790 \uC815\uAD50\uD55C
      \uCE7C \uBAA8\uC591\uC758 \uC7A5\uC2DD\uD488\uC774 \uB098\uC628\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640... \uC9C4\uC9DC \uC608\uBED0\uC694. \uCE7C \uBAA8\uC591\uC774\uB124\uC694?"
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uB0B4\uAC00 \uD0C0\uAD6D\uC5D0 \uC7A0\uC2DC \uAC14\uB294\uB370 \uAC70\uAE30
      \uC9C0\uB3C4\uC790\uAC00 \uCC28\uACE0 \uC788\uB294 \uAC80\uC774 \uC815\uB9D0
      \uD654\uB824\uD588\uAC70\uB4E0"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC7A5\uC2DD\uD488\uC744 \uB9CC\uC9C0\uBA70) \uADF8\uB798\uC11C \uBE44\uC2B7\uD55C\uAC78
      \uC0AC\uC624\uC2E0 \uAC70\uAD70\uC694"
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uD5C8\uD5C8, \uBC31\uC791\uB2D8\uD55C\uD150 \uBE44\uBC00\uC774\uB2E4!"
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC0C1\uC790\uB97C \uC5F4\uC790 \uC815\uAD50\uD55C
    \uCE7C \uBAA8\uC591\uC758 \uC7A5\uC2DD\uD488\uC774 \uB098\uC628\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
