  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w004_visitor_cousin_2_direct__step_w004_visitor_cousin_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 4\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uBC31\uC791\uC758 \uC11C\uC7AC, \uC0AC\uCD0C 2\uAC00 \uBB38\uC55E\uC5D0\uC11C
    \uCB48\uBF1B\uAC70\uB9AC\uBA70 \uB4E4\uC5B4\uC624\uC9C0 \uBABB\uD558\uACE0 \uC788\uB2E4.
    \uB124\uBAA8\uAC00 \uBC1C\uACAC\uD558\uACE0 \uADF8\uB97C \uC548\uC73C\uB85C \uB04C\uC5B4\uB2F9\uAE34\uB2E4.)\r\n       
    \r\n        \uB124\uBAA8 : \uC57C, \uC0AC\uCD0C 2! \uC65C \uAC70\uAE30 \uC11C
    \uC788\uC5B4? \uADF8\uB0E5 \uB4E4\uC5B4\uC640. \uBC31\uC791\uB2D8 \uC9C0\uAE08
    \uC548 \uACC4\uC154.\r\n        \uC0AC\uCD0C 2 : (\uC8FC\uBCC0\uC744 \uB450\uB9AC\uBC88\uAC70\uB9AC\uBA70)
    \uADF8\uCE58\uB9CC... \uC5EC\uAE30\uAC00 \uBC31\uC791\uB2D8\uC758 \uC11C\uC7AC\uC796\uC544.
    \uB108\uBB34 \uC5C4\uC219\uD574\uC11C \uC228\uC18C\uB9AC\uB3C4 \uD06C\uAC8C \uB0B4\uBA74
    \uC548 \uB420 \uAC83 \uAC19\uC544.\r\n        \uB124\uBAA8 : \uC5D0\uC774, \uB098\uB791
    \uC788\uC73C\uBA74 \uAD1C\uCC2E\uC544. \uC790, \uC5EC\uAE30 \uC549\uC544\uBD10.\r\n       
    \r\n\r\n(\uB124\uBAA8\uAC00 \uBC31\uC791\uC758 \uCC45\uC0C1 \uC606 \uC791\uC740
    \uAC04\uC2DD \uD568\uC5D0\uC11C \uC0AC\uD0D5 \uD558\uB098\uB97C \uAEBC\uB0B4
    \uC0AC\uCD0C 2\uC5D0\uAC8C \uAC74\uB128\uB2E4.)\r\n        \uB124\uBAA8 : \uC774\uAC70
    \uBA39\uC5B4\uBD10. \uBC31\uC791\uB2D8\uC774 \uB098 \uC8FC\uB824\uACE0 \uC228\uACA8\uB450\uC2E0
    \uAC74\uB370, \uB108\uB2C8\uAE4C \uD2B9\uBCC4\uD788 \uC8FC\uB294 \uAC70\uC57C.\r\n       
    \uC0AC\uCD0C 2 : (\uC870\uC2EC\uC2A4\uB7FD\uAC8C \uC0AC\uD0D5\uC744 \uBC1B\uC73C\uBA70)
    \uACE0\uB9C8\uC6CC, \uB124\uBAA8\uC57C... \uB108\uB294 \uCC38 \uB300\uB2E8\uD558\uB2E4.
    \uC774\uB7F0 \uBB34\uC11C\uC6B4 \uACF3\uC5D0\uC11C \uB9E4\uC77C \uACF5\uBD80\uB3C4
    \uD558\uACE0.\r\n        \uB124\uBAA8 : \uBB34\uC12D\uAE34 \uBB50\uAC00. \uB098\uC911\uC5D4
    \uB0B4\uAC00 \uB108 \uC5EC\uAE30 \uCD08\uB300\uD574\uC11C \uD558\uB8E8 \uC885\uC77C
    \uB180\uAC8C \uD574\uC904\uAC8C. \uBC31\uC791\uB2D8\uD55C\uD14C \uC798 \uB9D0\uD574\uBCFC\uAC8C!"
