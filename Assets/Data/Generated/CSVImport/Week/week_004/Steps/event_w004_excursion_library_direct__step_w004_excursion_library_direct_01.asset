  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w004_excursion_library_direct__step_w004_excursion_library_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 4\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uB124\uBAA8\uAC00 \uB192\uC740 \uC120\uBC18\uC5D0 \uAF42\uD78C \uB0A1\uC740
    \uC5ED\uC0AC\uC11C\uB97C \uBCF4\uBA70 \uAE4C\uCE58\uBC1C\uC744 \uB4E4\uACE0 \uC788\uB2E4.
    \uC190\uC774 \uB2FF\uC744\uB77D \uB9D0\uB77D \uD558\uB294 \uC21C\uAC04, \uB4A4\uC5D0\uC11C
    \uB204\uAD70\uAC00 \uB300\uC2E0 \uCC45\uC744 \uAEBC\uB0B4 \uB124\uBAA8\uC758
    \uBA38\uB9AC \uC704\uB85C \uC4F1 \uB0B4\uBBFC\uB2E4.)\n        \n        \uB124\uBAA8
    : \uC557, \uAC10\uC0AC\uD569\uB2C8...\n        (\uB4A4\uB97C \uB3CC\uC544\uBCF4\uC790
    \uC544\uBB34\uB3C4 \uC5C6\uB2E4. \uBC31\uC791\uC758 \uC804\uC6A9 \uC9D1\uC0AC\uB9CC\uC774
    \uC870\uC6A9\uD788 \uACE0\uAC1C\uB97C \uC219\uC774\uACE0 \uC11C \uC788\uB2E4.)\n       
    \n        \uB124\uBAA8 : ...\uBC31\uC791\uB2D8\uC778 \uC904 \uC54C\uC558\uB124.\n       
    \uC9D1\uC0AC : \uC8FC\uC778\uB2D8\uAED8\uC11C \uB3C4\uB828\uB2D8\uC774 \uC774
    \uC2DC\uAC04\uC5D0 \uC774 \uCC45\uC744 \uCC3E\uC73C\uC2E4 \uAC70\uB77C\uBA70
    \uBBF8\uB9AC \uB300\uAE30\uD558\uB77C \uBA85\uD558\uC168\uC2B5\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uBBF8\uB9AC? \uB0B4\uAC00 \uBB58 \uC77D\uC744\uC9C0
    \uB2E4 \uC548\uB2E4\uB294 \uB4EF\uC774?\n        \uC9D1\uC0AC : \uB3C4\uB828\uB2D8\uC758
    \uB3C5\uC11C \uAE30\uB85D\uC744 \uB9E4\uC77C \uBC24 \uAC80\uD1A0\uD558\uC2DC\uB2C8\uAE4C\uC694.\n       
    \n\n(\uC9D1\uC0AC\uAC00 \uCC45\uC744 \uAC74\uB124\uC8FC\uBA70 \uB124\uBAA8\uC758
    \uB208\uB192\uC774\uC5D0 \uB9DE\uB294 \uB0AE\uC740 \uD14C\uC774\uBE14\uB85C \uC548\uB0B4\uD55C\uB2E4.)\n       
    \uC9D1\uC0AC : \uB3C4\uB828\uB2D8\uC758 \uD0A4\uAC00 \uCEE4\uC9C4 \uAC83\uC744
    \uACE0\uB824\uD574, \uC774 \uAD6C\uC5ED\uC758 \uC120\uBC18 \uB192\uC774\uB97C
    \uC804\uBD80 \uB0AE\uCD94\uB77C\uB294 \uC9C0\uC2DC\uAC00 \uC788\uC5C8\uC2B5\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : ...\uC5B4\uCA50\uC9C0, \uC694\uC998 \uAE4C\uCE58\uBC1C \uC548
    \uB4E4\uC5B4\uB3C4 \uB41C\uB2E4 \uD588\uC5B4.\n        \uC9D1\uC0AC : \uBD88\uD3B8\uD568
    \uC5C6\uC774 \uC77D\uC73C\uC2DC\uB294 \uAC8C \uC8FC\uC778\uB2D8\uC758 \uB73B\uC785\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : (\uCC45\uC744 \uD488\uC5D0 \uC548\uC73C\uBA70) \uBB50, \uB098\uC058\uC9C4
    \uC54A\uB124. \uB0B4\uAC00 \uC790\uB77C\uB294 \uAC78 \uC9C0\uCF1C\uBCF4\uACE0
    \uC788\uB2E4\uB294 \uB73B \uAC19\uAE30\uB3C4 \uD558\uACE0."
