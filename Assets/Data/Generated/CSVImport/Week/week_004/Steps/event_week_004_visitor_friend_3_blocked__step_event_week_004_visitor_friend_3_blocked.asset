  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_visitor_friend_3_blocked__step_event_week_004_visitor_friend_3_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC720\uD53C \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor friend_3 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC720\uD53C\uAC00 \uB3CB\uBCF4\uAE30\uB97C \uB4E4\uC5B4 \uC62C\uB9AC\uB824
      \uD558\uC790, \uACBD\uBE44\uB300\uC7A5\uC774 \uCE7C\uC9D1\uC73C\uB85C \uCC45\uC0C1
      \uC704\uB97C \uAC00\uB85C\uB9C9\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB3C4\uB828\uB2D8, \uC8FC\uC778\uB2D8\uC758 \uC9D1\uBB34 \uB3C4\uAD6C\uB294
      \uC7A5\uB09C\uAC10\uC774 \uC544\uB2D9\uB2C8\uB2E4. \uC190\uB2D8\uC744 \uC989\uC2DC
      \uC548\uC804 \uAC70\uB9AC \uBC16\uC73C\uB85C \uBB3C\uB7EC\uB098\uAC8C \uD558\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC720\uD53C\uC758 \uC18C\uB9E4\uB97C \uB2F9\uAE30\uBA70) \uAC70 \uBD10,
      \uB0B4\uAC00 \uACBD\uACE0\uD588\uC9C0! \uC544\uC800\uC528, \uC8C4\uC1A1\uD574\uC694.
      \uC598\uAC00 \uD638\uAE30\uC2EC\uC774 \uC880 \uB9CE\uC544\uC11C \uADF8\uB798\uC694."
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "(\uC785\uC220\uC744 \uC090\uC8FD\uC774\uBA70) \uCE58, \uB9CC\uC838\uBCF4\uC9C0\uB3C4
      \uBABB\uD558\uAC8C \uD558\uB124. \uB124\uBAA8, \uB10C \uC774\uB7F0 \uB370\uC11C
      \uC5B4\uB5BB\uAC8C \uC0B4\uC544? \uAF2D \uBC15\uBB3C\uAD00\uC5D0 \uAC07\uD78C
      \uC778\uD615 \uAC19\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC501\uC4F8\uD558\uAC8C \uC6C3\uC73C\uBA70) ...\uB098\uB97C \uBCF4\uD638\uD558\uB824\uACE0
      \uADF8\uB7EC\uC2DC\uB294 \uAC70\uB77C\uB2C8\uAE4C."
  _nemoLine: "(\uC720\uD53C\uAC00 \uB3CB\uBCF4\uAE30\uB97C \uB4E4\uC5B4 \uC62C\uB9AC\uB824
    \uD558\uC790, \uACBD\uBE44\uB300\uC7A5\uC774 \uCE7C\uC9D1\uC73C\uB85C \uCC45\uC0C1
    \uC704\uB97C \uAC00\uB85C\uB9C9\uB294\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
