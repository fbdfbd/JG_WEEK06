  _titleOverride: "\uC9C0\uD558\uC2E4 \uD1B5\uC81C"
  _bodyText: "excursion basement Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB798\uB41C \uBCBD\uBA74\uC774\uB77C \uC190\uB300\uBA74
      \uB36E\uAC1C\uAC00 \uBC97\uACA8\uC9C8 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADFC\uB370 \uC65C \uC548 \uC9C0\uC6E0\uC5B4?"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "...\uC9C0\uC6B0\uC9C0 \uB9D0\uB77C \uD558\uC2E0 \uBD84\uC774 \uACC4\uC168\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB354 \uAD81\uAE08\uD558\uAC8C \uB9D0\uD558\uB124."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC624\uB798\uB41C \uBCBD\uBA74\uC774\uB77C \uC190\uB300\uBA74
    \uB36E\uAC1C\uAC00 \uBC97\uACA8\uC9C8 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
