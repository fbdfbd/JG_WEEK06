  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w004_excursion_basement_direct__step_w004_excursion_basement_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 4\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uBE44 \uC624\uB294 \uB0A0 \uC624\uD6C4. \uC9C0\uD558\uC2E4 \uC785\uAD6C
    \uADFC\uCC98 \uBCBD\uC5D0 \uD587\uBE5B \uB300\uC2E0 \uC791\uC740 \uC870\uBA85\uC11D
    \uBD88\uBE5B\uC774 \uB9FA\uD600 \uC788\uB2E4. \uB124\uBAA8\uB294 \uADF8 \uBE5B
    \uC544\uB798, \uBCBD \uD55C\uCABD\uC5D0 \uC5B4\uC124\uD508 \uC120\uACFC \uB3D9\uADF8\uB77C\uBBF8\uAC00
    \uADF8\uB824\uC9C4 \uAC78 \uBC1C\uACAC\uD55C\uB2E4.)\n        \n        \uB124\uBAA8
    : \uC5B4?\n        \n        \uB124\uBAA8 : \uC774\uAC70 \uB099\uC11C\uC796\uC544.\n       
    \n        (\uAC00\uAE4C\uC774 \uBCF4\uB2C8 \uB099\uC11C \uC704\uC5D4 \uC587\uACE0
    \uD22C\uBA85\uD55C \uB9C9 \uAC19\uC740 \uAC8C \uC50C\uC6CC\uC838 \uC788\uB2E4.
    \uC190\uB05D\uC73C\uB85C \uAC74\uB4DC\uB9AC\uBA74 \uCC28\uAC11\uACE0 \uB9E4\uB048\uD558\uB2E4.)\n       
    \n        \uB124\uBAA8 : \uBB50\uC57C. \uB099\uC11C \uC704\uC5D0 \uC720\uB9AC
    \uBC1C\uB77C \uB1A8\uB124.\n        \n\n(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uB36E\uAC1C
    \uC704 \uBA3C\uC9C0\uB9CC \uBD80\uB4DC\uB7FD\uAC8C \uB2E6\uC544 \uC900\uB2E4.)\n       
    \n        \uCC3D\uACE0\uC9C0\uAE30 : \uC5EC\uC12F \uC0B4 \uB54C \uC8FC\uC778\uB2D8\uC774
    \uADF8\uB9AC\uC2E0 \uAC81\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : \uB0B4\uAC00?\n       
    \n        \uCC3D\uACE0\uC9C0\uAE30 : \uC608. \uC9C0\uC6B0\uB824 \uD588\uB354\uB2C8
    \uBC31\uC791\uB2D8\uAED8\uC11C \uADF8\uB300\uB85C \uB450\uB77C\uACE0 \uD558\uC168\uB2F5\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : ...\uC9C4\uC9DC?\n        \n        \uCC3D\uACE0\uC9C0\uAE30
    : \uC608. \uADF8\uB798\uC11C \uD22C\uBA85 \uB36E\uAC1C\uAE4C\uC9C0 \uC50C\uC6E0\uC9C0\uC694.
    \uBC88\uC9C0\uAC70\uB098 \uAE01\uD788\uC9C0 \uC54A\uAC8C\uC694.\n        \n       
    \uB124\uBAA8 : \uC7A0\uAE50\uB9CC.\n        \n        \uB124\uBAA8 : \uB099\uC11C\uC5D0
    \uBCF4\uD638\uB9C9\uC744 \uC50C\uC6E0\uB2E4\uACE0?\n        \n        \uCC3D\uACE0\uC9C0\uAE30
    : \uB124.\n        \n        \uB124\uBAA8 : \uC774\uAC74 \uC880 \uC6C3\uAE34\uB370.\n       
    \n        (\uB124\uBAA8\uAC00 \uB36E\uAC1C \uB108\uBA38 \uC090\uB6A4\uBE7C\uB6A4\uD55C
    \uB3D9\uADF8\uB77C\uBBF8\uB97C \uBCF8\uB2E4.)\n        \n        \uB124\uBAA8
    : \uBABB \uADF8\uB838\uB124.\n        \n        \uCC3D\uACE0\uC9C0\uAE30 : \uADF8\uB798\uB3C4
    \uBC31\uC791\uB2D8 \uB208\uC5D4 \uC9C0\uC6B8 \uAC8C \uC544\uB2C8\uC5C8\uB358
    \uBAA8\uC591\uC785\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : ...\uADF8\uAC74
    \uC880 \uC774\uC0C1\uD558\uAC8C \uC88B\uB2E4."
  _dialogueLines: []
