  m_Name: event_w004_letter_friend_1_modified__step_w004_letter_friend_1_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 4\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD604\uAD00 \uCABD\uC5D0\uC11C \uD558\uB140\uAC00 \uD759\uC774 \uC0B4\uC9DD
    \uBB3B\uC740 \uBD09\uD22C\uB97C \uBC1B\uC544 \uB4E0\uB2E4. \uBD09\uD22C \uC785\uAD6C\uC5D0\uB294
    \uB098\uBB47\uC78E \uD558\uB098\uAC00 \uB07C\uC6CC\uC838 \uC788\uB2E4.)\r\n   
    \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C \uC628 \uD3B8\uC9C0\uB124\uC694.
    \uC774\uBC88\uC5D4 \uBC16\uC5D0\uC11C \uD55C\uCC38 \uB180\uB2E4 \uBCF4\uB0C8\uB098
    \uBD05\uB2C8\uB2E4.\r\n        \r\n\r\n(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C
    \uC77D\uACE0, \uB098\uBB47\uC78E\uC744 \uB124\uBAA8\uC758 \uC190\uC5D0 \uC950\uC5EC\uC8FC\uBA70
    \uC549\uB294\uB2E4.)\r\n        \uD558\uB140 : \uC8FC\uC778\uB2D8, \uC800\uBC88\uC5D0
    \uB9CC\uB09C \uB610\uB798 \uC190\uB2D8\uC774 \uC544\uC8FC \uD2B9\uBCC4\uD55C
    \uC81C\uC548\uC744 \uD588\uC2B5\uB2C8\uB2E4.\r\n        \uB124\uBAA8 : \uBB50\uB77C\uACE0
    \uD588\uC5B4?\r\n        \uD558\uB140 : \uB2E4\uC74C\uC5D0 \uB9CC\uB098\uBA74
    \uB458\uB9CC\uC758 \uBE44\uBC00 \uC7A5\uC18C\uC5D0\uC11C \uC18C\uC911\uD55C \uBB3C\uAC74\uC744
    \uC11C\uB85C \uB098\uB204\uC790\uACE0 \uD558\uB124\uC694.\r\n        \uB124\uBAA8
    : \uBE44\uBC00 \uC120\uBB3C?\r\n        \uD558\uB140 : \uB124. \uC544\uBB34\uB3C4
    \uBAA8\uB974\uB294 \uACF3\uC5D0 \uC228\uACA8\uB450\uACE0 \uC6B0\uB9AC\uB07C\uB9AC\uB9CC
    \uD655\uC778\uD558\uC790\uACE0 \uD569\uB2C8\uB2E4.\r\n        \uB124\uBAA8 :
    \uC6B0\uC640. \uADF8\uB7FC \uB098\uB3C4 \uBB50 \uC900\uBE44\uD574\uC57C\uACA0\uB2E4.
    \uAC54\uB294 \uC9C4\uC9DC \uBAA8\uD5D8\uAC00 \uAC19\uC544."
