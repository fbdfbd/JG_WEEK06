  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w004_letter_friend_1_direct__step_w004_letter_friend_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 4\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD604\uAD00 \uCABD\uC5D0\uC11C \uD558\uB140\uAC00 \uD759\uC774 \uC0B4\uC9DD
    \uBB3B\uC740 \uBD09\uD22C\uB97C \uBC1B\uC544 \uB4E0\uB2E4. \uBD09\uD22C \uC785\uAD6C\uC5D0\uB294
    \uB098\uBB47\uC78E \uD558\uB098\uAC00 \uB07C\uC6CC\uC838 \uC788\uB2E4.)\n   
    \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C \uC628 \uD3B8\uC9C0\uB124\uC694.
    \uC774\uBC88\uC5D4 \uBC16\uC5D0\uC11C \uD55C\uCC38 \uB180\uB2E4 \uBCF4\uB0C8\uB098
    \uBD05\uB2C8\uB2E4.\n        \n\n(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uB4E4\uACE0
    \uB124\uBAA8\uC5D0\uAC8C \uB2E4\uAC00\uAC04\uB2E4.)\n        \uD558\uB140 : \uC8FC\uC778\uB2D8,
    \uD3B8\uC9C0\uAC00 \uC654\uC2B5\uB2C8\uB2E4. \uC774\uBC88\uC5D4 \uB098\uBB47\uC78E
    \uC120\uBB3C\uB3C4 \uAC19\uC774 \uC654\uB124\uC694.\n        \uB124\uBAA8 : \uB098\uD55C\uD14C?
    \uBE68\uB9AC \uC77D\uC5B4 \uC918.\n        (\uD558\uB140\uAC00 \uBD09\uD22C\uB97C
    \uC5F4\uC5B4 \uD3B8\uC9C0\uB97C \uC77D\uC5B4 \uC900\uB2E4.)\n        \uB124\uBAA8
    \uC548\uB155. \uC800\uBC88\uC5D0 \uB9D0\uD55C \uBE44\uBC00 \uC7A5\uC18C\uC5D0
    \uAC14\uB294\uB370, \uAC70\uAE30 \uC5C4\uCCAD \uD070 \uB098\uBB34 \uAD6C\uBA4D\uC774
    \uC788\uC5B4! \uAC70\uAE30\uB2E4 \uC6B0\uB9AC\uB9CC \uC544\uB294 \uBCF4\uBB3C\uC744
    \uC228\uACA8\uB450\uBA74 \uC544\uBB34\uB3C4 \uBAA8\uB97C \uAC70\uC57C. \uB2E4\uC74C\uC5D0
    \uC62C \uB54C \uB108\uB3C4 \uC228\uAE38 \uAC70 \uD558\uB098 \uAC00\uC838\uC640.\n       
    \uB124\uBAA8 : \uBCF4\uBB3C \uCC3E\uAE30 \uAC19\uC544!\n        \uD558\uB140
    : \uC8FC\uC778\uB2D8\uC740 \uBB34\uC5C7\uC744 \uC228\uAE30\uACE0 \uC2F6\uC73C\uC2ED\uB2C8\uAE4C?\n       
    \uB124\uBAA8 : \uC74C... \uBC31\uC791\uB2D8\uC774 \uBC84\uB9AC\uB77C\uACE0 \uD55C
    \uACE0\uC7A5 \uB09C \uC7A5\uB09C\uAC10! \uAC70\uAE30 \uC228\uAE30\uBA74 \uC808\uB300
    \uC548 \uBE8F\uAE30\uACA0\uC9C0?"
