  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w004_excursion_lake_direct__step_w004_excursion_lake_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 4\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uD574\uAC00 \uAC70\uC758 \uC9C4 \uC800\uB141. \uD638\uC22B\uAC00
    \uB09C\uAC04\uC744 \uB530\uB77C \uC791\uC740 \uC720\uB9AC\uB4F1\uC774 \uD558\uB098\uC529
    \uCF1C\uC9C0\uAE30 \uC2DC\uC791\uD55C\uB2E4. \uBD88\uAF43\uCC98\uB7FC \uD754\uB4E4\uB9AC\uC9C0\uB3C4
    \uC54A\uACE0, \uB2EC\uBE5B\uCC98\uB7FC \uC740\uC740\uD558\uAC8C \uBB3C \uC704\uC5D0
    \uAE38\uC744 \uB9CC\uB4E0\uB2E4.)\r\n        \r\n        \uB124\uBAA8 : \uC5B4?
    \uC800\uAC70 \uC6D0\uB798 \uC788\uC5C8\uB098.\r\n        \r\n        (\uB124\uBAA8\uAC00
    \uB09C\uAC04 \uCABD\uC73C\uB85C \uB2E4\uAC00\uAC00\uC790, \uBC1C\uBC11\uC758
    \uB4F1\uBD88\uC774 \uD55C \uBC15\uC790 \uB2A6\uAC8C \uB354 \uBC1D\uC544\uC9C4\uB2E4.
    \uBB3C\uACB0\uC774 \uC6C0\uC9C1\uC77C \uB54C\uB9C8\uB2E4 \uBE5B\uC774 \uB530\uB77C
    \uD754\uB4E4\uB824, \uB9C8\uCE58 \uB09C\uAC04 \uC544\uB798\uC5D0 \uC740\uAC00\uB8E8\uB97C
    \uBFCC\uB9B0 \uAC83 \uAC19\uB2E4.)\r\n        \r\n        \uB124\uBAA8 : ...\uC608\uC058\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uBB3C\uC774 \uBE5B \uBA39\uB294 \uAC83 \uAC19\uC544.\r\n       
    \r\n\r\n(\uACBD\uBE44\uB300\uC7A5\uC774 \uB09C\uAC04 \uC548\uCABD \uC881\uC740
    \uAE38\uAE4C\uC9C0\uB9CC \uBE44\uCF1C \uC120\uB2E4.)\r\n        \r\n        \uACBD\uBE44\uB300\uC7A5
    : \uB09C\uAC04 \uC548\uCABD\uC73C\uB85C\uB9CC \uAC78\uC73C\uC2ED\uC2DC\uC624,
    \uC8FC\uC778\uB2D8.\r\n        \r\n        \uB124\uBAA8 : \uC54C\uACA0\uC5B4.\r\n       
    \r\n        (\uB124\uBAA8\uAC00 \uCC9C\uCC9C\uD788 \uB09C\uAC04\uC744 \uB530\uB77C
    \uAC77\uB294\uB2E4. \uAC78\uC74C\uC744 \uC62E\uAE38 \uB54C\uB9C8\uB2E4 \uAC00\uAE4C\uC6B4
    \uB4F1\uBD88\uC774 \uC740\uC740\uD558\uAC8C \uBC1D\uC544\uC9C0\uACE0, \uBA40\uC5B4\uC9C4
    \uB4F1\uBD88\uC740 \uB2E4\uC2DC \uC7A6\uC544\uB4E0\uB2E4.)\r\n        \r\n       
    \uB124\uBAA8 : ...\uC7A0\uAE50.  \uC774\uAC70 \uB0B4\uAC00 \uC6C0\uC9C1\uC774\uBA74
    \uB530\uB77C \uCF1C\uC838?\r\n        \r\n        \uACBD\uBE44\uB300\uC7A5 :
    \uC57D\uD55C \uAC10\uC751 \uB9C8\uBC95\uC774 \uAC78\uB824 \uC788\uC2B5\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uC0DD\uD65C \uB9C8\uBC95\uC73C\uB85C?\r\n       
    \r\n        \uACBD\uBE44\uB300\uC7A5 : \uC608. \uBC24\uB208\uC774 \uC5B4\uB450\uC6B4
    \uBD84\uAED8 \uB9DE\uCD98 \uAC70\uC9C0\uC694.\r\n        \r\n        \uB124\uBAA8
    : \uB204\uAD6C\uD55C\uD14C?\r\n        \r\n        \uACBD\uBE44\uB300\uC7A5 :
    \u2026\uC8FC\uC778\uB2D8\uAED8\uC694.\r\n        \r\n        \uB124\uBAA8 : \uADF8\uB7FC
    \uC774\uAC70, \uC6D0\uB798\uBD80\uD130 \uB0B4\uAC00 \uBCF4\uB77C\uACE0 \uCF1C\uC9C0\uB294
    \uAC70\uB124.\r\n        \r\n        (\uB124\uBAA8\uAC00 \uB09C\uAC04 \uC704\uC5D0
    \uC190\uC744 \uC5B9\uB294\uB2E4.)\r\n        \r\n        \uB124\uBAA8 : \uC774\uAC74
    \uC880\u2026 \uB108\uBB34 \uC815\uC131\uC778\uB370."
