  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w004_visitor_friend_3_blocked__step_w004_visitor_friend_3_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 4\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uBC31\uC791\uC774 \uC5C6\uB294 \uC11C\uC7AC. \uCE5C\uAD6C 3\uC740
    \uBC31\uC791\uC758 \uCC45\uC0C1 \uADFC\uCC98\uB97C \uC11C\uC131\uC774\uBA70 \uC2E0\uAE30\uD55C
    \uB3C4\uAD6C\uB4E4\uC744 \uAD00\uCC30\uD558\uACE0 \uC788\uB2E4. \uACBD\uBE44\uB300\uC7A5\uC758
    \uB0A0\uCE74\uB85C\uC6B4 \uC2DC\uC120\uC774 \uAF42\uD788\uC9C0\uB9CC, \uCE5C\uAD6C
    3\uC740 \uC544\uB791\uACF3\uD558\uC9C0 \uC54A\uB294\uB2E4.)\n        \n       
    \uCE5C\uAD6C 3 : \uC57C, \uB124\uBAA8. \uC774 \uB3CB\uBCF4\uAE30\uB294 \uC65C
    \uC774\uB807\uAC8C \uCEE4? \uC774\uAC78\uB85C \uBCF4\uBA74 \uBC31\uC791\uB2D8
    \uC5BC\uAD74\uB3C4 \uC774\uB9CC\uD07C \uD06C\uAC8C \uBCF4\uC5EC?\n        \uB124\uBAA8
    : \uC57C, \uCE5C\uAD6C 3! \uC870\uC2EC\uD574. \uADF8\uAC70 \uBC31\uC791\uB2D8\uC774
    \uC544\uB07C\uC2DC\uB294 \uAC70\uC57C. \uACBD\uBE44\uB300\uC7A5 \uC544\uC800\uC528
    \uD45C\uC815 \uC880 \uBD10.\n        \uCE5C\uAD6C 3 : (\uACBD\uBE44\uB300\uC7A5\uC744
    \uC2A5 \uBCF4\uACE0\uB294) \uC544\uC800\uC528, \uC800 \uC548 \uD6D4\uCCD0\uAC00\uC694.
    \uADF8\uB0E5 \uAD81\uAE08\uD574\uC11C \uADF8\uB798\uC694.\n        \n\n(\uCE5C\uAD6C
    3\uC774 \uB3CB\uBCF4\uAE30\uB97C \uB4E4\uC5B4 \uC62C\uB9AC\uB824 \uD558\uC790,
    \uACBD\uBE44\uB300\uC7A5\uC774 \uCE7C\uC9D1\uC73C\uB85C \uCC45\uC0C1 \uC704\uB97C
    \uAC00\uB85C\uB9C9\uB294\uB2E4.)\n        \uACBD\uBE44\uB300\uC7A5 : \uB3C4\uB828\uB2D8,
    \uC8FC\uC778\uB2D8\uC758 \uC9D1\uBB34 \uB3C4\uAD6C\uB294 \uC7A5\uB09C\uAC10\uC774
    \uC544\uB2D9\uB2C8\uB2E4. \uC190\uB2D8\uC744 \uC989\uC2DC \uC548\uC804 \uAC70\uB9AC
    \uBC16\uC73C\uB85C \uBB3C\uB7EC\uB098\uAC8C \uD558\uC2ED\uC2DC\uC624.\n       
    \uB124\uBAA8 : (\uCE5C\uAD6C 3\uC758 \uC18C\uB9E4\uB97C \uB2F9\uAE30\uBA70) \uAC70
    \uBD10, \uB0B4\uAC00 \uACBD\uACE0\uD588\uC9C0! \uC544\uC800\uC528, \uC8C4\uC1A1\uD574\uC694.
    \uC598\uAC00 \uD638\uAE30\uC2EC\uC774 \uC880 \uB9CE\uC544\uC11C \uADF8\uB798\uC694.\n       
    \uCE5C\uAD6C 3 : (\uC785\uC220\uC744 \uC090\uC8FD\uC774\uBA70) \uCE58, \uB9CC\uC838\uBCF4\uC9C0\uB3C4
    \uBABB\uD558\uAC8C \uD558\uB124. \uB124\uBAA8, \uB10C \uC774\uB7F0 \uB370\uC11C
    \uC5B4\uB5BB\uAC8C \uC0B4\uC544? \uAF2D \uBC15\uBB3C\uAD00\uC5D0 \uAC07\uD78C
    \uC778\uD615 \uAC19\uB2E4.\n        \uB124\uBAA8 : (\uC501\uC4F8\uD558\uAC8C
    \uC6C3\uC73C\uBA70) ...\uB098\uB97C \uBCF4\uD638\uD558\uB824\uACE0 \uADF8\uB7EC\uC2DC\uB294
    \uAC70\uB77C\uB2C8\uAE4C."
  _dialogueLines: []
