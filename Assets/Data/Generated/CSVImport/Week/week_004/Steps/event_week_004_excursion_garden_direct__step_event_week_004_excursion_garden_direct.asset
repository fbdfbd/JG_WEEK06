MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_excursion_garden_direct__step_event_week_004_excursion_garden_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: garden Direct
  _bodyText: "excursion garden Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC815\uC6D0\uC0AC\uAC00 \uB124\uBAA8\uB97C \uD654\uB2E8\uC5D0\uC11C
      \uC870\uAE08 \uB5A8\uC5B4\uC9C4 \uB3CC\uC758\uC790 \uCABD\uC73C\uB85C \uC548\uB0B4\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC774\uCABD\uC774\uBA74 \uAD1C\uCC2E\uC2B5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.
      \uBC14\uB78C\uB3C4 \uB4F1\uC9C0\uACE0 \uC788\uACE0\uC694~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5EC\uAE30\uC11C\uB3C4 \uBCF4\uC5EC."
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uD574\uAC00 \uB2E4 \uC9C0\uBA74 \uB354 \uD65C\uC9DD \uD544 \uAC81\uB2C8\uB2E4.
      \uC628\uC5F4\uC11D \uB355\uC5D0 \uC624\uB298\uC740 \uC870\uAE08 \uBE68\uB9AC
      \uC5F4\uB838\uC9C0\uC694~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC0DD\uD65C \uB9C8\uBC95\uC774\uB124."
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC544\uC8FC \uC870\uAE08\uC694~ \uAF43\uC774 \uB180\uB77C\uC9C0 \uC54A\uC744
      \uB9CC\uD07C\uB9CC\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC8C \uB354 \uC2E0\uAE30\uD55C\uB370."
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uC740 \uAF43\uBCF4\uB2E4 \uB3CC\uC774 \uB354 \uAD81\uAE08\uD558\uC2E0
      \uBAA8\uC591\uC785\uB2C8\uB2E4~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB458 \uB2E4 \uAD81\uAE08\uD574."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADFC\uB370 \uC774\uB7F0 \uAC74 \uBC24\uC5D0\uB9CC \uBCFC \uC218 \uC788\uC73C\uB2C8\uAE4C
      \uB354 \uAD1C\uCC2E\uB2E4."
  _nemoLine: "(\uC815\uC6D0\uC0AC\uAC00 \uB124\uBAA8\uB97C \uD654\uB2E8\uC5D0\uC11C
    \uC870\uAE08 \uB5A8\uC5B4\uC9C4 \uB3CC\uC758\uC790 \uCABD\uC73C\uB85C \uC548\uB0B4\uD55C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
