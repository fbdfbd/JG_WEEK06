  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_excursion_library_direct__step_event_week_004_excursion_library_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 \uD5C8\uAC00"
  _bodyText: "excursion library Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC9D1\uC0AC\uAC00 \uCC45\uC744 \uAC74\uB124\uC8FC\uBA70 \uB124\uBAA8\uC758
      \uB208\uB192\uC774\uC5D0 \uB9DE\uB294 \uB0AE\uC740 \uD14C\uC774\uBE14\uB85C
      \uC548\uB0B4\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uB3C4\uB828\uB2D8\uC758 \uD0A4\uAC00 \uCEE4\uC9C4 \uAC83\uC744 \uACE0\uB824\uD574,
      \uC774 \uAD6C\uC5ED\uC758 \uC120\uBC18 \uB192\uC774\uB97C \uC804\uBD80 \uB0AE\uCD94\uB77C\uB294
      \uC9C0\uC2DC\uAC00 \uC788\uC5C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uC5B4\uCA50\uC9C0, \uC694\uC998 \uAE4C\uCE58\uBC1C \uC548 \uB4E4\uC5B4\uB3C4
      \uB41C\uB2E4 \uD588\uC5B4."
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uBD88\uD3B8\uD568 \uC5C6\uC774 \uC77D\uC73C\uC2DC\uB294 \uAC8C \uC8FC\uC778\uB2D8\uC758
      \uB73B\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uCC45\uC744 \uD488\uC5D0 \uC548\uC73C\uBA70) \uBB50, \uB098\uC058\uC9C4
      \uC54A\uB124. \uB0B4\uAC00 \uC790\uB77C\uB294 \uAC78 \uC9C0\uCF1C\uBCF4\uACE0
      \uC788\uB2E4\uB294 \uB73B \uAC19\uAE30\uB3C4 \uD558\uACE0."
  _nemoLine: "(\uC9D1\uC0AC\uAC00 \uCC45\uC744 \uAC74\uB124\uC8FC\uBA70 \uB124\uBAA8\uC758
    \uB208\uB192\uC774\uC5D0 \uB9DE\uB294 \uB0AE\uC740 \uD14C\uC774\uBE14\uB85C \uC548\uB0B4\uD55C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
