  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_letter_cousin_2_modified__step_event_week_004_letter_cousin_2_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9AC\uC548 \uD3B8\uC9C0 \uC218\uC815"
  _bodyText: "letter cousin_2 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uC774 \uC5EC\uD589\uC9C0\uC5D0\uC11C
      \uC8FC\uC778\uB2D8 \uC0DD\uAC01\uC774 \uB098\uC11C \uC791\uC740 \uC120\uBB3C\uC744
      \uC900\uBE44\uD588\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC120\uBB3C? \uB098 \uC8FC\uB824\uACE0?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC138\uC0C1\uC5D0\uC11C \uC81C\uC77C \uC608\uC05C \uC870\uAC1C\uAECD\uB370\uAE30\uB97C
      \uCC3E\uC558\uB300\uC694. \uB2E4\uC74C\uC5D0 \uB9CC\uB098\uBA74 \uB204\uAD6C\uB3C4
      \uBAA8\uB974\uAC8C \uC8FC\uC778\uB2D8\uAED8\uB9CC \uC804\uD574\uC8FC\uACE0
      \uC2F6\uC5B4 \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640... \uAC54\uB294 \uC5EC\uD589 \uAC00\uC11C\uB3C4 \uB0B4 \uC0DD\uAC01\uC744
      \uD588\uB124."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uACFC \uB458\uB9CC\uC758 \uBE44\uBC00\uC744 \uB9CC\uB4E4\uACE0
      \uC2F6\uC740\uAC00 \uBD05\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uB098\uB3C4 \uAC54 \uB9CC\uB098\uBA74 \uC904 \uAC70 \uCC3E\uC544\uBD10\uC57C\uC9C0."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uC774 \uC5EC\uD589\uC9C0\uC5D0\uC11C
    \uC8FC\uC778\uB2D8 \uC0DD\uAC01\uC774 \uB098\uC11C \uC791\uC740 \uC120\uBB3C\uC744
    \uC900\uBE44\uD588\uB300\uC694."
  _useCustomVisualState: 0
  _visualState: 0
