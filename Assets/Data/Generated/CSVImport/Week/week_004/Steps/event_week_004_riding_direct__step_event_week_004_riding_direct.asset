  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_riding_direct__step_event_week_004_riding_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uAE30\uB9C8 \uC608\uC808\uACFC \uAE30\uBCF8\uC744 \uAC00\uB974\uCE5C\uB2E4"
  _bodyText: "\uAE30\uB9C8 \uC608\uC808\uACFC \uAE30\uBCF8\uC744 \uAC00\uB974\uCE5C\uB2E4
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACE0\uC090 \uC7A1\uB294 \uBC95\uACFC \uC549\uB294 \uC790\uC138\uB97C
      \uADF8\uB9BC\uC73C\uB85C \uC9DA\uC73C\uBA70 \uAE30\uBCF8\uC744 \uC775\uD788\uAC8C
      \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC190\uBD80\uD130 \uC798\uBABB \uC7A1\uC73C\uBA74 \uB9D0\uC774 \uC2EB\uC5B4\uD558\uACA0\uC9C0?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uBAB8\uC758 \uADE0\uD615\uACFC \uC608\uC808\uC744 \uD568\uAED8 \uC54C\uB824
      \uC8FC\uBA70 \uCC28\uBD84\uD788 \uC9C4\uB3C4\uB97C \uB098\uAC04\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uC74C\uC5D4 \uC790\uC138\uBD80\uD130 \uB354 \uB611\uBC14\uB85C
      \uD574 \uBCFC\uB798\uC694."
  _nemoLine: "(\uACE0\uC090 \uC7A1\uB294 \uBC95\uACFC \uC549\uB294 \uC790\uC138\uB97C
    \uADF8\uB9BC\uC73C\uB85C \uC9DA\uC73C\uBA70 \uAE30\uBCF8\uC744 \uC775\uD788\uAC8C
    \uD55C\uB2E4.)"
