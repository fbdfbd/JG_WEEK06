--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_004_excursion_lake_direct__step_event_week_004_excursion_lake_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: lake Direct
  _bodyText: "excursion lake Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uB09C\uAC04 \uC548\uCABD \uC881\uC740
      \uAE38\uAE4C\uC9C0\uB9CC \uBE44\uCF1C \uC120\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB09C\uAC04 \uC548\uCABD\uC73C\uB85C\uB9CC \uAC78\uC73C\uC2ED\uC2DC\uC624,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC54C\uACA0\uC5B4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uCC9C\uCC9C\uD788 \uB09C\uAC04\uC744 \uB530\uB77C
      \uAC77\uB294\uB2E4. \uAC78\uC74C\uC744 \uC62E\uAE38 \uB54C\uB9C8\uB2E4 \uAC00\uAE4C\uC6B4
      \uB4F1\uBD88\uC774 \uC740\uC740\uD558\uAC8C \uBC1D\uC544\uC9C0\uACE0, \uBA40\uC5B4\uC9C4
      \uB4F1\uBD88\uC740 \uB2E4\uC2DC \uC7A6\uC544\uB4E0\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uC7A0\uAE50. \uC774\uAC70 \uB0B4\uAC00 \uC6C0\uC9C1\uC774\uBA74 \uB530\uB77C
      \uCF1C\uC838?"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC57D\uD55C \uAC10\uC751 \uB9C8\uBC95\uC774 \uAC78\uB824 \uC788\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC0DD\uD65C \uB9C8\uBC95\uC73C\uB85C?"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC608. \uBC24\uB208\uC774 \uC5B4\uB450\uC6B4 \uBD84\uAED8 \uB9DE\uCD98
      \uAC70\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB204\uAD6C\uD55C\uD14C?"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\u2026\uC8FC\uC778\uB2D8\uAED8\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uC774\uAC70, \uC6D0\uB798\uBD80\uD130 \uB0B4\uAC00 \uBCF4\uB77C\uACE0
      \uCF1C\uC9C0\uB294 \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uB09C\uAC04 \uC704\uC5D0 \uC190\uC744 \uC5B9\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uC880\u2026 \uB108\uBB34 \uC815\uC131\uC778\uB370."
  _nemoLine: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uB09C\uAC04 \uC548\uCABD \uC881\uC740
    \uAE38\uAE4C\uC9C0\uB9CC \uBE44\uCF1C \uC120\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
