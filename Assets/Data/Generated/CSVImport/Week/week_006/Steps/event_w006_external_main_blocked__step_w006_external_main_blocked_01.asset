  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_external_main_blocked__step_w006_external_main_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "6\uCC28 - \uD1B5\uC81C"
  _bodyText: "(\uC751\uC811\uC2E4 \uBC16, \uBA40\uB9AC\uC11C \uC628 \uC190\uB2D8\uC758
    \uB9C8\uBD80\uAC00 \uC800\uD0DD \uB9C8\uBD80\uB4E4\uACFC \uB458\uB7EC\uC549\uC544
    \uC774\uC57C\uAE30\uD55C\uB2E4.)\r\n    \uB9C8\uBD801 : \uC774\uBC88\uC5D0 \uC190\uB2D8
    \uBAA8\uC2DC\uACE0 \uC624\uBA74\uC11C \uB4E4\uC5C8\uB294\uB370, \uBC14\uB2E4
    \uAC74\uB108\uC5D4 \uAE38\uBC14\uB2E5\uC774 \uC804\uBD80 \uAE08\uC73C\uB85C \uAE54\uB9B0
    \uB3C4\uC2DC\uAC00 \uC788\uB2E4\uBA70?\r\n    \uB9C8\uBD802 : \uAC70\uAE30 \uC0AC\uB78C\uB4E4\uC740
    \uAD6C\uB984 \uC704\uB97C \uAC78\uC5B4 \uB2E4\uB2CC\uB2E4\uB294 \uB9D0\uB3C4
    \uC548 \uB418\uB294 \uC18C\uB9AC\uB3C4 \uB4E4\uC5C8\uB124.\r\n    \uB124\uBAA8
    : \uAE38\uC774 \uB2E4 \uAE08\uC774\uC57C? \uAD6C\uB984\uC744 \uAC78\uC5B4?\r\n   
    \r\n\r\n\uB9C8\uBD801 : (\uB4B7\uBA38\uB9AC\uB97C \uAE01\uC801\uC774\uBA70) \uC5D0\uC774,
    \uB3C4\uB828\uB2D8. \uC800\uD76C \uAC19\uC740 \uC77C\uAFBC\uB4E4\uC774 \uC9C0\uC5B4\uB0B8
    \uB18D\uB2F4\uC785\uB2C8\uB2E4.\r\n    \uB124\uBAA8 : \uC9C4\uC9DC \uC788\uB294
    \uACF3 \uC544\uB2C8\uC57C? \uB098\uB3C4 \uAC00\uBCF4\uACE0 \uC2F6\uC740\uB370.\r\n   
    \uB9C8\uBD802 : \uC138\uC0C1\uC5D0 \uADF8\uB7F0 \uB370\uAC00 \uC5B4\uB514 \uC788\uACA0\uC2B5\uB2C8\uAE4C.
    \uADF8\uB0E5 \uAFC8\uC18D \uC774\uC57C\uAE30\uC9C0\uC694. \uC5B4\uC11C \uB4E4\uC5B4\uAC00
    \uC26C\uC138\uC694.\r\n    \uB124\uBAA8 : \uD765, \uB2E4\uB4E4 \uC548 \uAC00\uBCF8
    \uAC70\uBA74\uC11C \uC5C6\uB2E4\uACE0\uB9CC \uD574."
