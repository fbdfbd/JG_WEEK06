  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_excursion_basement_direct__step_event_week_006_excursion_basement_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 \uD5C8\uAC00"
  _bodyText: "excursion basement Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uBCD1\uC744 \uAC74\uB4DC\uB9AC\uC9C4
      \uC54A\uACE0, \uD45C\uB9CC \uB124\uBAA8 \uCABD\uC73C\uB85C \uB3CC\uB824 \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC624\uB798 \uB450\uB294 \uAC83\uB3C4 \uC88B\uC9C0\uB9CC, \uAC00\uC7A5
      \uC88B\uC740 \uB54C\uB97C \uB193\uCE58\uBA74 \uC544\uAE5D\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB798\uC11C \u2018\uC5BC\uB9C8 \uC548 \uB0A8\uC558\uB2E4\u2019\uACE0
      \uC801\uC740 \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC608."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC640\uC778\uB3C4 \uB54C\uAC00 \uC788\uB124."
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC0AC\uB78C \uC190\uC744 \uAE30\uB2E4\uB9AC\uB2E4 \uB108\uBB34 \uB2A6\uC73C\uBA74,
      \uC624\uD788\uB824 \uB9DB\uC774 \uC8FD\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uBCD1\uB4E4\uC744 \uCC9C\uCC9C\uD788 \uD6D1\uC5B4\uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uACE7 \uC788\uC73C\uBA74 \uB9C8\uC2E4 \uB0A0\uC774 \uC624\uACA0\uC9C0?"
  _nemoLine: "(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uBCD1\uC744 \uAC74\uB4DC\uB9AC\uC9C4
    \uC54A\uACE0, \uD45C\uB9CC \uB124\uBAA8 \uCABD\uC73C\uB85C \uB3CC\uB824 \uC900\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
