  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_house_main_blocked__step_w006_house_main_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "6\uC8FC\uCC28 - \uD1B5\uC81C"
  _bodyText: "(\uC8FC\uBC29 \uADFC\uCC98 \uBCF5\uB3C4. \uD558\uB140 \uB458\uC774
    \uC55E\uCE58\uB9C8\uB97C \uD138\uBA70 \uC5B4\uB9AC\uB465\uC808\uD55C \uD45C\uC815\uC744
    \uC9D3\uACE0 \uC788\uB2E4.)\n    \uD558\uB1401 : \uBD84\uBA85\uD788 \uC2DD\uD0C1
    \uC704\uC5D0 \uB480\uB294\uB370, \uAE5C\uBE61\uD558\uB294 \uC0AC\uC774\uC5D0
    \uC5C6\uC5B4\uC84C\uC5B4.\n    \uD558\uB1402 : \uC124\uD0D5 \uB3C4\uB451\uC5D0
    \uC774\uC5B4\uC11C \uC774\uBC88\uC5D4 \uC2A4\uD47C\uC774\uC57C? \uAE4C\uB9C8\uADC0\uAC00
    \uAC00\uC838\uAC14\uB098?\n    \uB124\uBAA8 : \uC774\uBC88\uC5D4 \uB610 \uBB50\uAC00
    \uC5C6\uC5B4\uC84C\uC5B4?\n    \n\n\uD558\uB1401 : \uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4,
    \uC8FC\uC778\uB2D8. \uC800\uD76C\uAC00 \uC22B\uC790\uB97C \uC798\uBABB \uC14C\uB098
    \uBD10\uC694.\n    \uB124\uBAA8 : \uC740\uC2A4\uD47C \uC5C6\uC5B4\uC84C\uB2E4\uBA70!\n   
    \uD558\uB1402 : \uB2E4\uC2DC \uCC3E\uC544\uBCF4\uB2C8 \uC2F1\uD06C\uB300 \uBC11\uC5D0
    \uC788\uC5C8\uC5B4\uC694. \uC800\uD76C\uAC00 \uB364\uBC99\uAC70\uB824\uC11C \uADF8\uB807\uC2B5\uB2C8\uB2E4.\n   
    \uB124\uBAA8 : \uAC70\uC9D3\uB9D0. \uC544\uAE4C\uB294 \uC5C6\uB2E4\uACE0 \uD588\uC73C\uBA74\uC11C."
