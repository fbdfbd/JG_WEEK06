  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_excursion_library_direct__step_w006_excursion_library_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 6\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uB2A6\uC740 \uBC24, \uB124\uBAA8\uAC00 \uB3C4\uC11C\uAD00 \uAD6C\uC11D
    \uC18C\uD30C\uC5D0\uC11C \uCC45\uC744 \uC5BC\uAD74\uC5D0 \uB36E\uC740 \uCC44
    \uC7A0\uB4E4\uC5B4 \uC788\uB2E4. \uAE68\uC5B4\uBCF4\uB2C8 \uC5B4\uAE68\uC5D0
    \uBB35\uC9C1\uD558\uACE0 \uB530\uB73B\uD55C \uC678\uD22C\uAC00 \uB36E\uC5EC \uC788\uACE0,
    \uD0C1\uC790 \uC704 \uCD1B\uBD88\uC740 \uAC70\uC758 \uB2E4 \uD0C0\uB4E4\uC5B4
    \uAC00\uACE0 \uC788\uB2E4.)\n        \n        \uB124\uBAA8 : ...\uC74C.\n       
    (\uC678\uD22C\uC5D0\uC11C \uC775\uC219\uD55C \uD5A5\uC218 \uB0C4\uC0C8\uAC00
    \uB09C\uB2E4. \uBC31\uC791\uC774 \uC9D1\uBB34\uC2E4\uC5D0\uC11C \uC785\uB358
    \uCF54\uD2B8\uB2E4.)\n        \n        \uB124\uBAA8 : \uC5B8\uC81C \uC654\uB2E4
    \uAC00\uC2E0 \uAC70\uC9C0?\n        (\uD0C1\uC790 \uC704\uB97C \uBCF4\uB2C8,
    \uC2DD\uC5B4\uBC84\uB9B0 \uCF54\uCF54\uC544 \uD55C \uC794\uACFC \"\uBC24\uC774
    \uAE4A\uC5C8\uB2E4. \uBC29\uC73C\uB85C \uB3CC\uC544\uAC00\uB77C\"\uACE0 \uC801\uD78C
    \uCABD\uC9C0\uAC00 \uB193\uC5EC \uC788\uB2E4.)\n        \n\n(\uB124\uBAA8\uAC00
    \uCF54\uD2B8\uB97C \uB354 \uAE4A\uAC8C \uB20C\uB7EC\uC4F0\uBA70 \uCABD\uC9C0\uB97C
    \uB9CC\uC9C0\uC791\uAC70\uB9B0\uB2E4.)\n        \uB124\uBAA8 : \uCF54\uCF54\uC544...
    \uC544\uC9C1 \uC870\uAE08 \uB530\uB73B\uD558\uB124.\n        (\uCABD\uC9C0 \uB4B7\uBA74\uC744
    \uBCF4\uB2C8 '\uB0B4\uC77C\uC740 \uC11C\uC7AC\uB85C \uC640\uB77C. \uAD81\uAE08\uD574\uD558\uB358
    \uB2E4\uC74C \uAD8C\uC744 \uCC3E\uC544\uB450\uC5C8\uB2E4'\uB77C\uACE0 \uC801\uD600
    \uC788\uB2E4.)\n        \uB124\uBAA8 : (\uD53C\uC2DD \uC6C3\uC73C\uBA70) \uBB50\uC57C,
    \uACF5\uBD80 \uB354 \uD558\uB77C\uB294 \uC18C\uB9AC\uC796\uC544.\n        \uB124\uBAA8
    : \uADF8\uB798\uB3C4 \uBB50... \uD63C\uC790 \uB450\uB294 \uAC83\uBCF4\uB2E8 \uB0AB\uB098.
    \uCF54\uD2B8 \uB530\uB73B\uD558\uB124."
