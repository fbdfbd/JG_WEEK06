  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_letter_friend_1_modified__step_event_week_006_letter_friend_1_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9C9\uC2A4 \uD3B8\uC9C0 \uC218\uC815"
  _bodyText: "letter friend_1 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uCE5C\uAD6C\uBD84\uC774
      \uC55E\uC73C\uB85C\uC758 \uC57D\uC18D\uC744 \uC801\uC5B4 \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB34\uC2A8 \uC57D\uC18D?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC2DC\uAC04\uC774 \uC544\uC8FC \uB9CE\uC774 \uD758\uB7EC\uC11C \uC8FC\uC778\uB2D8\uC774
      \uC5B4\uB978\uC774 \uB418\uC5B4\uB3C4, \uC601\uC6D0\uD788 \uAC00\uC7A5 \uCE5C\uD55C
      \uCE5C\uAD6C\uB85C \uB0A8\uACE0 \uC2F6\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uADF8\uB54C\uAC00 \uB418\uBA74 \uC544\uBB34 \uAC71\uC815 \uC5C6\uC774
      \uD558\uB8E8 \uC885\uC77C \uAC19\uC774 \uB180\uC790\uACE0 \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uADF8\uB7FC \uB098\uB3C4 \uAC54\uB791 \uACC4\uC18D \uB180
      \uC218 \uC788\uB294 \uAC70\uB124?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB9CE\uC774 \uAE30\uC058\uC2E0\uAC00 \uBD05\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uAC54\uB294 \uC9C4\uC9DC \uC88B\uC740 \uCE5C\uAD6C\uC57C."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uCE5C\uAD6C\uBD84\uC774
    \uC55E\uC73C\uB85C\uC758 \uC57D\uC18D\uC744 \uC801\uC5B4 \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
