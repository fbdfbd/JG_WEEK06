  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_visitor_friend_3_direct__step_event_week_006_visitor_friend_3_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC720\uD53C \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor friend_3 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uBD10 \uBD10, \uB0B4\uAC00 \uC9C1\uC811 \uB9CC\uB4E0 \uC791\uC740 \uC5F0\uC774\uC57C.
      \uCC3D\uAC00\uC5D0\uC11C\uB77C\uB3C4 \uC0B4\uC9DD \uB744\uC6CC \uBCF4\uBA74
      \uC548 \uB3FC?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640, \uAF2C\uB9AC\uB3C4 \uB2EC\uB838\uC5B4. \uC9C4\uC9DC \uC0C8
      \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB450 \uC544\uC774\uB294 \uCC3D\uBB38 \uD2C8\uC73C\uB85C \uB4E4\uC5B4\uC624\uB294
      \uBC14\uB78C\uC5D0 \uB9DE\uCDB0 \uC5F0\uC744 \uC870\uC2EC\uC2A4\uB7FD\uAC8C
      \uD754\uB4E4\uC5B4 \uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uBC16\uC73C\uB85C \uBABB \uB098\uAC00\uB3C4 \uAD1C\uCC2E\uC544. \uC774\uB807\uAC8C\uB9CC
      \uD574\uB3C4 \uD558\uB298\uC774 \uC6B0\uB9AC \uCABD\uC73C\uB85C \uC624\uB294
      \uAC83 \uAC19\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uB2E4\uC74C\uC5D4 \uC9C4\uC9DC \uB9C8\uB2F9\uC5D0\uC11C \uAC19\uC774
      \uB0A0\uB9AC\uACE0 \uC2F6\uB2E4."
  _nemoLine: "\uBD10 \uBD10, \uB0B4\uAC00 \uC9C1\uC811 \uB9CC\uB4E0 \uC791\uC740
    \uC5F0\uC774\uC57C. \uCC3D\uAC00\uC5D0\uC11C\uB77C\uB3C4 \uC0B4\uC9DD \uB744\uC6CC
    \uBCF4\uBA74 \uC548 \uB3FC?"
  _useCustomVisualState: 0
  _visualState: 0
