  _titleOverride: "\uC694\uB9AC \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4"
  _bodyText: "\uC694\uB9AC \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC694\uB9AC \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
      \uC7AC\uB8CC \uC774\uB984\uB9CC \uBCF4\uACE0 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624\uB298\uC740 \uBB58 \uC548 \uB9CC\uB4E4\uC5B4\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uBC30\uC6B0\uB294 \uBD84\uB7C9\uC744 \uC904\uC774\uACE0 \uB2E4\uC74C\uC5D0
      \uB2E4\uC2DC \uBCF4\uAE30\uB85C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB2E4\uC74C\uC5D4 \uB9DB\uC788\uB294 \uAC83\uB3C4 \uAC19\uC774
      \uBD10\uC694."
  _nemoLine: "(\uC694\uB9AC \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
    \uC7AC\uB8CC \uC774\uB984\uB9CC \uBCF4\uACE0 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4.)"
