  _titleOverride: cousin_2 Direct
  _bodyText: "visitor cousin_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC0AC\uCD0C 2\uAC00 \uADF8\uB9B0 \uAF43 \uC606\uC5D0
      \uC790\uC2E0\uC758 \uC774\uB984\uC744 \uC11C\uD234\uAC8C \uC801\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBD10, '\uB124\uBAA8\uB791 \uC0AC\uCD0C 2'. \uC774\uB807\uAC8C \uC801\uC5B4\uB450\uBA74
      \uC6B0\uB9AC \uB098\uC911\uC5D0\uB3C4 \uACC4\uC18D \uCE5C\uAD6C\uC778 \uAC70\uB2E4?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "(\uC5BC\uAD74\uC744 \uBD89\uD788\uBA70 \uACE0\uAC1C\uB97C \uB044\uB355\uC778\uB2E4)
      \uC751... \uB124\uBAA8\uC57C, \uB108\uB791 \uAC19\uC774 \uC788\uC73C\uBA74
      \uC774 \uBB34\uC11C\uC6B4 \uC11C\uC7AC\uB3C4 \uC660\uC9C0 \uB530\uB73B\uD558\uAC8C
      \uB290\uAEF4\uC838."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC0AC\uCD0C 2\uC758 \uC5B4\uAE68\uB97C \uD22D \uCE58\uBA70) \uADF8\uCE58?
      \uBC31\uC791\uB2D8\uB3C4 \uB098\uC911\uC5D0 \uC6B0\uB9AC\uAC00 \uCE5C\uD558\uAC8C
      \uC9C0\uB0B4\uB294 \uAC70 \uBCF4\uC2DC\uBA74 \uC88B\uC544\uD558\uC2E4 \uAC70\uC57C.
      \uB0B4\uAC00 \uB9DB\uC788\uB294 \uAC70 \uB354 \uAC00\uC838\uC62C\uAC8C, \uAE30\uB2E4\uB824!"
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC0AC\uCD0C 2\uAC00 \uADF8\uB9B0 \uAF43 \uC606\uC5D0
    \uC790\uC2E0\uC758 \uC774\uB984\uC744 \uC11C\uD234\uAC8C \uC801\uB294\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
