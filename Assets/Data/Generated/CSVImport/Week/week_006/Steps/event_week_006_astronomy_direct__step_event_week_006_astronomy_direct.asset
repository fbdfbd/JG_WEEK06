--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_astronomy_direct__step_event_week_006_astronomy_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBCC4\uB85C \uAE38\uACFC \uC2DC\uAC04\uC744 \uC77D\uB294\uB2E4"
  _bodyText: "\uBCC4\uC790\uB9AC\uC640 \uD56D\uD574 6\uC8FC\uCC28 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBC24. \uBCC4\uC790\uB9AC\uD310 \uC606\uC5D0 \uAC04\uB2E8\uD55C \uC9C0\uB3C4\uC640
      \uBAA8\uD615 \uBC30\uAC00 \uB193\uC5EC \uC788\uB2E4. \uCC3D\uBC16 \uD558\uB298\uACFC
      \uCC45\uC0C1 \uC704 \uC9C0\uB3C4\uB97C \uBC88\uAC08\uC544 \uBCF4\uBA70 \uC704\uCE58\uB97C
      \uB9DE\uCDB0 \uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uBCC4\uC744 \uBCF4\uB294 \uAC83\uC5D0\uC11C
      \uB05D\uB0B4\uC9C0 \uC54A\uACE0, \uBCC4\uB85C \uAE38\uC744 \uC9DA\uC5B4 \uBCFC
      \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uC81C \uC9C4\uC9DC \uD56D\uD574\uC220 \uAC19\uB124."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBD81\uCABD\uC774 \uC5EC\uAE30\uBA74, \uC774\uCABD\uC774 \uD56D\uAD6C
      \uCABD\uC774\uC9C0?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uADF8\uB9AC\uACE0 \uC800 \uBCC4\uC774 \uC800\uB9CC\uD07C \uAE30\uC6B8\uBA74
      \uC9C0\uAE08 \uC2DC\uAC04\uC774 \uAF64 \uB2A6\uC5C8\uB2E4\uB294 \uB73B\uC774\uAE30\uB3C4
      \uD574\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD558\uB298\uC774 \uAE38\uC774\uB791 \uC2DC\uAC04 \uB458 \uB2E4 \uC54C\uB824\uC8FC\uB294
      \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB9DE\uC544\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC0DD\uAC01\uBCF4\uB2E4 \uC2E4\uC6A9\uC801\uC774\uB77C \uC880 \uB180\uB790\uC5B4."
  _nemoLine: "(\uBC24. \uBCC4\uC790\uB9AC\uD310 \uC606\uC5D0 \uAC04\uB2E8\uD55C \uC9C0\uB3C4\uC640
    \uBAA8\uD615 \uBC30\uAC00 \uB193\uC5EC \uC788\uB2E4. \uCC3D\uBC16 \uD558\uB298\uACFC
    \uCC45\uC0C1 \uC704 \uC9C0\uB3C4\uB97C \uBC88\uAC08\uC544 \uBCF4\uBA70 \uC704\uCE58\uB97C
    \uB9DE\uCDB0 \uBCF8\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
