  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_letter_cousin_2_direct__step_w006_letter_cousin_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 \uD3B8\uC9C0 6\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uC791\uC740 \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4.
    \uBD09\uD22C\uB294 \uC544\uC8FC \uAE68\uB057\uD558\uACE0, \uC885\uC774 \uC811\uD78C
    \uBAA8\uC591\uB3C4 \uBB34\uCC99 \uC815\uC131\uC2A4\uB7FD\uB2E4.)\r\n    \uD558\uB140
    : \uC774\uBC88\uC5D4 \uC544\uC8FC \uC9C4\uC2EC \uC5B4\uB9B0 \uC778\uC0AC\uAC00
    \uB2F4\uAE34 \uD3B8\uC9C0\uC778 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.\r\n        \r\n\r\n\uD558\uB140
    : \uC8FC\uC778\uB2D8, \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uC774 \uC6A9\uAE30\uB97C
    \uB0B4\uC11C \uB9C8\uC9C0\uB9C9 \uD3B8\uC9C0\uB97C \uBCF4\uB0B4\uC168\uC5B4\uC694.\r\n       
    \uB124\uBAA8 : \uB9C8\uC9C0\uB9C9? \uC65C? \uC774\uC81C \uC548 \uC628\uB300?\r\n       
    (\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)\r\n        \uB124\uBAA8
    \uC548\uB155. \uB098\uB294 \uC18C\uC2EC\uD558\uACE0 \uAC81\uB3C4 \uB9CE\uC9C0\uB9CC,
    \uB108\uB791 \uCE5C\uAD6C\uAC00 \uB41C \uAC74 \uB0B4 \uC778\uC0DD\uC5D0\uC11C
    \uC81C\uC77C \uC6A9\uAE30 \uC788\uB294 \uC77C\uC774\uC5C8\uC5B4. \uC6B0\uB9AC
    \uC5B4\uB978\uC774 \uB418\uC5B4\uB3C4 \uACC4\uC18D \uCE5C\uAD6C \uD574\uC904
    \uAC70\uC9C0? \uB300\uB2F5\uC740 \uC548 \uD574\uB3C4 \uB3FC. \uADF8\uB0E5 \uC77D\uC5B4\uC8FC\uAE30\uB9CC
    \uD574\uB3C4 \uB098\uB294 \uAE30\uBED0.\r\n        \uB124\uBAA8 : \uC81C\uC77C
    \uC6A9\uAE30 \uC788\uB294 \uC77C\uC774\uC5C8\uB300...\r\n        \uD558\uB140
    : \uC8FC\uC778\uB2D8\uC774 \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uAED8 \uC544\uC8FC
    \uD070 \uD798\uC774 \uB418\uC5C8\uB098 \uBD05\uB2C8\uB2E4.\r\n        \uB124\uBAA8
    : \uB300\uB2F5 \uC548 \uD574\uB3C4 \uB41C\uB2E4\uB2C8, \uBC14\uBCF4\uC57C. \uB2F9\uC5F0\uD788
    \uCE5C\uAD6C \uD574\uC904 \uAC74\uB370."
