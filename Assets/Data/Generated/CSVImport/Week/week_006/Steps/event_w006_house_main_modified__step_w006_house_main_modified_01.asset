  m_Name: event_w006_house_main_modified__step_w006_house_main_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "6\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uC8FC\uBC29 \uADFC\uCC98 \uBCF5\uB3C4. \uD558\uB140 \uB458\uC774
    \uC55E\uCE58\uB9C8\uB97C \uD138\uBA70 \uC5B4\uB9AC\uB465\uC808\uD55C \uD45C\uC815\uC744
    \uC9D3\uACE0 \uC788\uB2E4.)\n    \uD558\uB1401 : \uBD84\uBA85\uD788 \uC2DD\uD0C1
    \uC704\uC5D0 \uB480\uB294\uB370, \uAE5C\uBE61\uD558\uB294 \uC0AC\uC774\uC5D0
    \uC5C6\uC5B4\uC84C\uC5B4.\n    \uD558\uB1402 : \uC124\uD0D5 \uB3C4\uB451\uC5D0
    \uC774\uC5B4\uC11C \uC774\uBC88\uC5D4 \uC2A4\uD47C\uC774\uC57C? \uAE4C\uB9C8\uADC0\uAC00
    \uAC00\uC838\uAC14\uB098?\n    \uB124\uBAA8 : \uC774\uBC88\uC5D4 \uB610 \uBB50\uAC00
    \uC5C6\uC5B4\uC84C\uC5B4?\n    \n\n\uD558\uB1401 : \uC740\uC2A4\uD47C\uC744 \uB2E6\uC73C\uB824\uACE0
    \uC7A0\uAE50 \uBAA8\uC544\uB450\uC5C8\uB294\uB370, \uD558\uB140 \uD55C \uBA85\uC774
    \uC2E4\uC218\uB85C \uB2E4\uB978 \uC0C1\uC790\uC5D0 \uB123\uC5C8\uB098 \uBD10\uC694.\n   
    \uB124\uBAA8 : \uC2E4\uC218\uD55C \uAC70\uC57C?\n    \uD558\uB1402 : \uB124.
    \uAC00\uB054 \uB108\uBB34 \uBC14\uC058\uBA74 \uC190\uC774 \uAF2C\uC774\uAE30\uB3C4
    \uD558\uAC70\uB4E0\uC694. \uAE08\uBC29 \uCC3E\uC744 \uC218 \uC788\uC744 \uAC70\uC608\uC694.\n   
    \uB124\uBAA8 : \uC544, \uADF8\uB807\uAD6C\uB098. \uB3C4\uB451\uB9DE\uC740 \uC904
    \uC54C\uC558\uC796\uC544.\n    \uD558\uB1401 : \uC8FC\uC778\uB2D8\uC740 \uADF8\uB7F0
    \uAC71\uC815 \uC548 \uD558\uC154\uB3C4 \uB3FC\uC694. \uC800\uD0DD \uBB3C\uAC74\uB4E4\uC740
    \uB2E4 \uC81C\uC790\uB9AC\uB97C \uCC3E\uC544\uAC00\uB2C8\uAE4C\uC694.\n    \uB124\uBAA8
    : \uB2E4\uD589\uC774\uB2E4. \uADF8\uB7FC \uC774\uB530\uAC00 \uB9DB\uC788\uB294
    \uAC70 \uBA39\uC744 \uB54C \uC4F8 \uC218 \uC788\uACA0\uB124?"
