%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_cooking_direct__step_event_week_006_cooking_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBAAB\uACFC \uC21C\uC11C\uB97C \uC9C1\uC811 \uB098\uB208\uB2E4"
  _bodyText: "\uC694\uB9AC\uC640 \uBC30\uC2DD\uC758 \uC6D0\uB9AC 6\uC8FC\uCC28 Direct
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC8FC\uBC29. \uC791\uAC8C \uAD6C\uC6B4 \uBE75\uACFC \uACFC\uC77C \uC870\uAC01\uC774
      \uB193\uC5EC \uC788\uACE0, \uC624\uB298\uC740 \uC9C1\uC811 \uB9CC\uB4DC\uB294
      \uAC83 \uB2E4\uC74C\uC73C\uB85C \uB098\uB204\uB294 \uC21C\uC11C\uB97C \uBC30\uC6B4\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uB9CC\uB4DC\uB294 \uAC83\uB9CC\uC774
      \uC544\uB2C8\uB77C, \uC5B4\uB5BB\uAC8C \uB098\uB20C\uC9C0\uB3C4 \uAC19\uC774
      \uBCFC \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBA39\uAE30 \uC804\uC5D0 \uB098\uB204\uB294 \uAC83\uBD80\uD130?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uBC30\uC2DD\uB3C4 \uC77C\uC758 \uC77C\uBD80\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uBC31\uC791\uB2D8 \uAC70, \uC774\uAC74 \uD558\uB140 \uB204\uB098\uB4E4
      \uAC70, \uC774\uAC74 \uB0B4 \uAC70."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC798 \uB098\uB204\uC168\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9CC\uB4E4 \uB54C\uBCF4\uB2E4 \uB098\uB204\uB294 \uAC8C \uB354 \uAE34\uC7A5\uB418\uB124."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB204\uAC00 \uBA3C\uC800 \uBC1B\uACE0, \uB204\uAC00 \uB9C8\uC9C0\uB9C9\uC5D0
      \uBC1B\uB294\uC9C0\uB3C4 \uB2E4 \uAE30\uC5B5\uC5D0 \uB0A8\uC73C\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uBC30\uC2DD\uB3C4 \uC608\uBC95\uC774\uB124."
  _nemoLine: "(\uC8FC\uBC29. \uC791\uAC8C \uAD6C\uC6B4 \uBE75\uACFC \uACFC\uC77C
    \uC870\uAC01\uC774 \uB193\uC5EC \uC788\uACE0, \uC624\uB298\uC740 \uC9C1\uC811
    \uB9CC\uB4DC\uB294 \uAC83 \uB2E4\uC74C\uC73C\uB85C \uB098\uB204\uB294 \uC21C\uC11C\uB97C
    \uBC30\uC6B4\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
