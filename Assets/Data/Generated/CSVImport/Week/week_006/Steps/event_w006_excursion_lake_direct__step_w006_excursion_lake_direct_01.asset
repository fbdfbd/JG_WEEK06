  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_excursion_lake_direct__step_w006_excursion_lake_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 6\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uD587\uBE5B\uC774 \uC798 \uB4DC\uB294 \uC624\uD6C4. \uD638\uC22B\uAC00
    \uAC00\uAE4C\uC6B4 \uBB3C\uC740 \uC720\uB09C\uD788 \uB9D1\uC544\uC11C, \uBC14\uB2E5\uC758
    \uC794\uB3CC\uAE4C\uC9C0 \uB610\uB837\uD558\uAC8C \uBCF4\uC778\uB2E4. \uC595\uC740
    \uCABD\uC5D4 \uC791\uC740 \uC57D\uCD08 \uC8FC\uBA38\uB2C8 \uBA87 \uAC1C\uAC00
    \uB3CC\uC5D0 \uBB36\uC5EC \uC0B4\uC9DD \uD754\uB4E4\uB9AC\uACE0 \uC788\uB2E4.)\r\n       
    \r\n        \uB124\uBAA8 : \uBB3C\uC774 \uC624\uB298 \uC5C4\uCCAD \uB9D1\uB124.\r\n       
    \r\n        (\uB124\uBAA8\uAC00 \uB09C\uAC04\uC5D0 \uAE30\uB300 \uC544\uB798\uB97C
    \uB0B4\uB824\uB2E4\uBCF8\uB2E4. \uBC14\uB78C\uC774 \uBD88\uC790 \uBB3C\uAC00\uC5D0\uC11C
    \uD480 \uB0C4\uC0C8\uCC98\uB7FC \uC2DC\uC6D0\uD55C \uD5A5\uC774 \uC0B4\uC9DD
    \uC62C\uB77C\uC628\uB2E4.)\r\n        \r\n        \uB124\uBAA8 : ...\uB0C4\uC0C8\uB3C4
    \uB098. \uBB3C\uC778\uB370 \uC57D\uAC04 \uCC28 \uAC19\uC544.\r\n        \r\n       
    (\uB124\uBAA8\uAC00 \uC190\uB05D\uC73C\uB85C \uBB3C\uC744 \uAC74\uB4DC\uB9AC\uB824
    \uD55C\uB2E4.)\r\n        \r\n\r\n(\uACBD\uBE44\uB300\uC7A5\uC774 \uAE34 \uC190\uC7A1\uC774
    \uAD6D\uC790\uB85C \uB9D1\uC740 \uBB3C\uC744 \uC870\uAE08 \uB5A0, \uC595\uC740
    \uB3CC\uADF8\uB987\uC5D0 \uB2F4\uC544 \uB124\uBAA8 \uC55E\uC5D0 \uB0B4\uBBFC\uB2E4.)\r\n       
    \r\n        \uACBD\uBE44\uB300\uC7A5 : \uC9C1\uC811 \uBB3C\uAC00\uB85C \uAC00\uB294
    \uAC74 \uC548 \uB418\uC9C0\uB9CC, \uC774 \uC815\uB3C4\uB294 \uAD1C\uCC2E\uC2B5\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : ...\uC624. \uC9C4\uC9DC \uCC28\uAC11\uB2E4.\r\n       
    \r\n        (\uB124\uBAA8\uAC00 \uC190\uB05D\uB9CC \uC0B4\uC9DD \uC801\uC2E0\uB2E4.
    \uBB3C\uC740 \uB9D1\uACE0 \uCC28\uAC00\uC6B4\uB370, \uB530\uAC11\uAC70\uB098
    \uAC70\uCE5C \uB290\uB08C\uC740 \uC5C6\uB2E4.)\r\n        \r\n        \uB124\uBAA8
    : \uBD80\uB4DC\uB7FD\uB124.\r\n        \r\n        \uACBD\uBE44\uB300\uC7A5 :
    \uB9E4\uC77C \uC544\uCE68 \uC57D\uCD08\uB85C \uD55C \uBC88\uC529 \uC190\uC744
    \uBD05\uB2C8\uB2E4.\r\n        \r\n        \uB124\uBAA8 : \uB9E4\uC77C?\r\n       
    \r\n        (\uB124\uBAA8\uAC00 \uC816\uC740 \uC190\uB05D\uC744 \uD587\uBE5B\uC5D0
    \uB4E4\uC5B4 \uC62C\uB9B0\uB2E4. \uBB3C\uBC29\uC6B8\uC774 \uBC18\uC9DD\uC778\uB2E4.)\r\n       
    \r\n        \uB124\uBAA8 : \uC0DD\uAC01\uBCF4\uB2E4 \uC5C4\uCCAD \uAD00\uB9AC\uBC1B\uB294
    \uD638\uC218\uC600\uB124.\r\n        \r\n        \uACBD\uBE44\uB300\uC7A5 : \uC8FC\uC778\uB2D8\uAED8
    \uB2FF\uB294 \uAC74 \uB300\uAC1C \uADF8\uB807\uC2B5\uB2C8\uB2E4.\r\n        \r\n       
    \uB124\uBAA8 : \uC5EC\uB984\uC5D4 \uC774\uCABD\uC774 \uC81C\uC77C \uB0AB\uACA0\uB124."
  _dialogueLines: []
