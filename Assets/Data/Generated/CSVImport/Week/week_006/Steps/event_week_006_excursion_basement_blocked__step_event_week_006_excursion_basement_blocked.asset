--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_excursion_basement_blocked__step_event_week_006_excursion_basement_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 \uD1B5\uC81C"
  _bodyText: "excursion basement Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uBC14\uB85C \uBA54\uBAA8\uD45C\uB97C
      \uB4A4\uC9D1\uC5B4 \uB193\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC774\uAC74 \uBCF4\uC2DC\uBA74 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uBC31\uC791\uB2D8 \uBCF4\uAD00\uD488\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uC544\uB294\uB370, \uBC29\uAE08 \uBB50\uB77C\uACE0 \uC801\uD600
      \uC788\uC5C8\uC5B4."
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC640\uC778 \uAD00\uB9AC\uC6A9 \uBA54\uBAA8\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5BC\uB9C8 \uC548 \uB0A8\uC558\uB2E4\uACE0 \uD588\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uB9C8\uC2E4 \uB54C\uAC00 \uB2E4\uAC00\uC654\uB2E4\uB294 \uB73B\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624. \uADF8\uB7FC \uC774\uC81C \uACE7 \uC5C6\uC5B4\uC9C0\uB294 \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC608. \uADF8\uB7F0 \uC148\uC774\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uC0C1\uD558\uB2E4. \uB2E4\uB4E4 \uC624\uB798 \uB450\uB824\uACE0
      \uC544\uB07C\uB294 \uC904 \uC54C\uC558\uB294\uB370."
  _nemoLine: "(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uBC14\uB85C \uBA54\uBAA8\uD45C\uB97C
    \uB4A4\uC9D1\uC5B4 \uB193\uB294\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
