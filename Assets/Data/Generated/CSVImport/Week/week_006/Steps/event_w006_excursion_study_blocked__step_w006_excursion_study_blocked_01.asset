  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_excursion_study_blocked__step_w006_excursion_study_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC 6\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uBC24\uB2A6\uC740 \uC2DC\uAC04, \uB124\uBAA8\uAC00 \uBC31\uC791\uC5D0\uAC8C
    \uBB3C\uC5B4\uBCFC \uAC83\uC774 \uC788\uC5B4 \uC11C\uC7AC \uBB38\uC744 \uC0B4\uC9DD
    \uBC00\uACE0 \uB4E4\uC5B4\uC628\uB2E4. \uBC31\uC791\uC740 \uC790\uB9AC\uC5D0
    \uC5C6\uC9C0\uB9CC, \uCEE4\uB2E4\uB780 \uAC00\uC8FD \uC758\uC790\uC5D0\uB294
    \uBC29\uAE08 \uC804\uAE4C\uC9C0 \uB204\uAD70\uAC00 \uC549\uC544 \uC788\uC5C8\uB358
    \uB4EF\uD55C \uC628\uAE30\uAC00 \uB0A8\uC544 \uC788\uB2E4.)\n        \n       
    \uB124\uBAA8 : \uC544\uC800\uC528? ...\uC548 \uACC4\uC2DC\uB124.\n        (\uCC45\uC0C1
    \uC704\uC5D0\uB294 \uB124\uBAA8\uAC00 \uC5B4\uC81C \uC783\uC5B4\uBC84\uB838\uB358
    \uC7A5\uAC11 \uD55C \uC9DD\uC774 \uAC00\uC9C0\uB7F0\uD788 \uB193\uC5EC \uC788\uACE0,
    \uADF8 \uC606\uC5D4 \uB530\uB73B\uD55C \uAE40\uC774 \uC62C\uB77C\uC624\uB294
    \uC6B0\uC720 \uD55C \uC794\uC774 \uB193\uC5EC \uC788\uB2E4.)\n        \n       
    \uB124\uBAA8 : \uAF2D \uB0B4\uAC00 \uC62C \uC904 \uC54C\uC558\uB358 \uAC83\uCC98\uB7FC...\n       
    \n\n(\uAC11\uC790\uAE30 \uC11C\uC7AC\uC758 \uB9C8\uBC95 \uC870\uBA85\uC774 \uBC1D\uC544\uC9C0\uBA70
    \uBC31\uC791\uC758 \uBAA9\uC18C\uB9AC\uAC00 \uB9C8\uBC95\uAD6C\uC5D0\uC11C \uD758\uB7EC\uB098\uC628\uB2E4.)\n       
    \uBC31\uC791(\uC74C\uC131) : \uB124\uBAA8, \uD5C8\uB77D \uC5C6\uC774 \uC11C\uC7AC\uC5D0
    \uB4E4\uC5B4\uC628 \uAC74 \uC774\uBC88\uC774 \uB9C8\uC9C0\uB9C9\uC774\uB2E4.
    \uC6B0\uC720\uB9CC \uB9C8\uC2DC\uACE0 \uC989\uC2DC \uBC29\uC73C\uB85C \uB3CC\uC544\uAC00\uB3C4\uB85D.\n       
    \uB124\uBAA8 : (\uAE5C\uC9DD \uB180\uB77C \uC5B4\uAE68\uB97C \uB4E4\uC369\uC774\uBA70)
    \uBCF4\uACE0 \uACC4\uC168\uB358 \uAC70\uC608\uC694?\n        \uBC31\uC791(\uC74C\uC131)
    : \uB124 \uB3D9\uC120\uC740 \uD56D\uC0C1 \uD30C\uC545\uD558\uACE0 \uC788\uB2E4.
    \uB2A6\uC5C8\uC73C\uB2C8 \uC794\uB9D0 \uB9D0\uACE0 \uC790\uAC70\uB77C.\n       
    \uB124\uBAA8 : ...\uC9C4\uC9DC \uC228 \uB9C9\uD600. \uC6B0\uC720\uC5D0 \uC218\uBA74\uC81C\uB77C\uB3C4
    \uD0C4 \uAC70 \uC544\uB2C8\uC57C?"
