  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_house_talk_w006_modified__step_event_week_006_house_talk_w006_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: w006 Modified
  _bodyText: "house_talk w006 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC740\uC2A4\uD47C\uC744 \uB2E6\uC73C\uB824\uACE0 \uC7A0\uAE50 \uBAA8\uC544\uB450\uC5C8\uB294\uB370,
      \uD558\uB140 \uD55C \uBA85\uC774 \uC2E4\uC218\uB85C \uB2E4\uB978 \uC0C1\uC790\uC5D0
      \uB123\uC5C8\uB098 \uBD10\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC2E4\uC218\uD55C \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uAC00\uB054 \uB108\uBB34 \uBC14\uC058\uBA74 \uC190\uC774 \uAF2C\uC774\uAE30\uB3C4
      \uD558\uAC70\uB4E0\uC694. \uAE08\uBC29 \uCC3E\uC744 \uC218 \uC788\uC744 \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544, \uADF8\uB807\uAD6C\uB098. \uB3C4\uB451\uB9DE\uC740 \uC904 \uC54C\uC558\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uC740 \uADF8\uB7F0 \uAC71\uC815 \uC548 \uD558\uC154\uB3C4
      \uB3FC\uC694. \uC800\uD0DD \uBB3C\uAC74\uB4E4\uC740 \uB2E4 \uC81C\uC790\uB9AC\uB97C
      \uCC3E\uC544\uAC00\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uD589\uC774\uB2E4. \uADF8\uB7FC \uC774\uB530\uAC00 \uB9DB\uC788\uB294
      \uAC70 \uBA39\uC744 \uB54C \uC4F8 \uC218 \uC788\uACA0\uB124?"
  _nemoLine: "\uC740\uC2A4\uD47C\uC744 \uB2E6\uC73C\uB824\uACE0 \uC7A0\uAE50 \uBAA8\uC544\uB450\uC5C8\uB294\uB370,
    \uD558\uB140 \uD55C \uBA85\uC774 \uC2E4\uC218\uB85C \uB2E4\uB978 \uC0C1\uC790\uC5D0
    \uB123\uC5C8\uB098 \uBD10\uC694."
  _useCustomVisualState: 0
  _visualState: 0
