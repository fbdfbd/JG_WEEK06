--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_astronomy_modified__step_event_week_006_astronomy_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC24\uAE38\uC744 \uC783\uC9C0 \uC54A\uB294 \uBC95\uBD80\uD130
    \uC775\uD78C\uB2E4"
  _bodyText: "\uBCC4\uC790\uB9AC\uC640 \uD56D\uD574 6\uC8FC\uCC28 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBC24. \uBCC4\uC790\uB9AC\uD310 \uC606\uC5D0 \uAC04\uB2E8\uD55C \uC9C0\uB3C4\uC640
      \uBAA8\uD615 \uBC30\uAC00 \uB193\uC5EC \uC788\uB2E4. \uCC3D\uBC16 \uD558\uB298\uACFC
      \uCC45\uC0C1 \uC704 \uC9C0\uB3C4\uB97C \uBC88\uAC08\uC544 \uBCF4\uBA70 \uC704\uCE58\uB97C
      \uB9DE\uCDB0 \uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uBCC4\uC744 \uBCF4\uB294 \uAC83\uC5D0\uC11C
      \uB05D\uB0B4\uC9C0 \uC54A\uACE0, \uBCC4\uB85C \uAE38\uC744 \uC9DA\uC5B4 \uBCFC
      \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uC81C \uC9C4\uC9DC \uD56D\uD574\uC220 \uAC19\uB124."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uC9C0\uB3C4 \uC704\uC5D0 \uC791\uC740 \uB098\uBB34
      \uB9D0\uC744 \uC6C0\uC9C1\uC774\uBA70 \uC124\uBA85\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uBC14\uB2E4\uB97C \uAC74\uB10C\uB2E4\uACE0 \uC0DD\uAC01\uD558\uC9C0
      \uB9D0\uACE0, \uBC24\uAE38\uC744 \uC783\uC9C0 \uC54A\uB294 \uBC95\uBD80\uD130
      \uC775\uD78C\uB2E4\uACE0 \uC0DD\uAC01\uD574 \uBCF4\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uD6E8\uC52C \uC54C\uACA0\uB2E4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC800\uD0DD \uBC16\uC5D0\uC11C\uB3C4 \uD558\uB298\uC740 \uB298
      \uBCF4\uC774\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uC774\uAC74 \uC5EC\uD589 \uC218\uC5C5\uC774\uB77C\uAE30\uBCF4\uB2E4
      \uB3CC\uC544\uC624\uB294 \uC218\uC5C5\uC774\uB124."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8\uB807\uAC8C \uC0DD\uAC01\uD558\uC154\uB3C4 \uC88B\uC2B5\uB2C8\uB2E4."
  _nemoLine: "(\uBC24. \uBCC4\uC790\uB9AC\uD310 \uC606\uC5D0 \uAC04\uB2E8\uD55C \uC9C0\uB3C4\uC640
    \uBAA8\uD615 \uBC30\uAC00 \uB193\uC5EC \uC788\uB2E4. \uCC3D\uBC16 \uD558\uB298\uACFC
    \uCC45\uC0C1 \uC704 \uC9C0\uB3C4\uB97C \uBC88\uAC08\uC544 \uBCF4\uBA70 \uC704\uCE58\uB97C
    \uB9DE\uCDB0 \uBCF8\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
