  _titleOverride: "\uCC9C\uBB38 \uC218\uC5C5\uC744 \uC774\uC57C\uAE30\uCC98\uB7FC
    \uD47C\uB2E4"
  _bodyText: "\uCC9C\uBB38 \uC218\uC5C5\uC744 \uC774\uC57C\uAE30\uCC98\uB7FC \uD47C\uB2E4
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBC24\uD558\uB298 \uC774\uC57C\uAE30\uB97C \uACC1\uB4E4\uC5EC \uBCC4\uC790\uB9AC
      \uC774\uB984\uC744 \uBD80\uB2F4 \uC5C6\uC774 \uC775\uD788\uAC8C \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774 \uBCC4\uC740 \uC774\uB984\uB3C4 \uBA4B\uC788\uB124."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uC815\uB2F5\uBCF4\uB2E4 \uD765\uBBF8\uB97C \uBA3C\uC800 \uBD99\uC774\uBA70
      \uCC9C\uBB38 \uAD50\uC7AC\uC5D0 \uC775\uC219\uD574\uC9C0\uAC8C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uB807\uAC8C \uBC30\uC6B0\uBA74 \uB354 \uC624\uB798 \uAE30\uC5B5\uB0A0
      \uAC83 \uAC19\uC544."
  _nemoLine: "(\uBC24\uD558\uB298 \uC774\uC57C\uAE30\uB97C \uACC1\uB4E4\uC5EC \uBCC4\uC790\uB9AC
    \uC774\uB984\uC744 \uBD80\uB2F4 \uC5C6\uC774 \uC775\uD788\uAC8C \uD55C\uB2E4.)"
