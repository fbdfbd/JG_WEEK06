  m_Name: event_w006_visitor_cousin_2_blocked__step_w006_visitor_cousin_2_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 6\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uB124\uBAA8\uAC00 \uBC31\uC791\uC758 \uD654\uB824\uD55C \uAE43\uD39C\uC744
    \uC0AC\uCD0C 2\uC5D0\uAC8C \uC950\uC5EC\uC900\uB2E4. \uC0AC\uCD0C 2\uB294 \uB5A8\uB9AC\uB294
    \uC190\uC73C\uB85C \uC885\uC774 \uADC0\uD241\uC774\uC5D0 \uC791\uC740 \uAF43
    \uADF8\uB9BC\uC744 \uADF8\uB9B0\uB2E4.)\r\n        \r\n        \uC0AC\uCD0C 2
    : \uB124\uBAA8\uC57C, \uC774\uAC70 \uC9C4\uC9DC \uBD80\uB4DC\uB7FD\uAC8C \uC368\uC9C4\uB2E4...
    \uADFC\uB370 \uC774\uAC70 \uB0B4\uAC00 \uC368\uB3C4 \uB418\uB294 \uAC70\uC57C?
    \uBC31\uC791\uB2D8\uC774 \uBCF4\uC2DC\uBA74...\r\n        \uB124\uBAA8 : \uAD1C\uCC2E\uC544,
    \uB0B4\uAC00 \uADF8\uB9B0 \uAC70\uB77C\uACE0 \uD558\uBA74 \uB3FC. \uB108 \uADF8\uB9BC
    \uC9C4\uC9DC \uC798 \uADF8\uB9B0\uB2E4! \uC5EC\uAE30 \uB098\uBE44\uB3C4 \uADF8\uB824\uC918.\r\n       
    \r\n\r\n(\uACBD\uBE44\uB300\uC7A5\uC774 \uB2E4\uAC00\uC640 \uB450 \uC18C\uB144\uC774
    \uC4F0\uACE0 \uC788\uB358 \uC885\uC774\uB97C \uC218\uAC70\uD574\uAC04\uB2E4.)\r\n       
    \uACBD\uBE44\uB300\uC7A5 : \uB3C4\uB828\uB2D8, \uC8FC\uC778\uB2D8\uC758 \uC9D1\uBB34
    \uC6A9\uC9C0\uB294 \uACF5\uC801 \uAE30\uB85D\uC744 \uC704\uD55C \uAC83\uC785\uB2C8\uB2E4.
    \uB099\uC11C\uAC00 \uB41C \uC885\uC774\uB294 \uD3D0\uAE30\uD558\uB3C4\uB85D \uD558\uACA0\uC2B5\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : \uC544\uC800\uC528! \uADF8\uAC70 \uC0AC\uCD0C 2\uAC00 \uCC98\uC74C\uC73C\uB85C
    \uADF8\uB9B0 \uAC70\uB780 \uB9D0\uC774\uC5D0\uC694!\r\n        \uC0AC\uCD0C 2
    : (\uACE0\uAC1C\uB97C \uD479 \uC219\uC774\uBA70) \uBBF8\uC548\uD574, \uB124\uBAA8\uC57C...
    \uB0B4\uAC00 \uAD1C\uD55C \uC9D3\uC744 \uD574\uC11C... \uBC31\uC791\uB2D8\uD55C\uD14C
    \uD63C\uB098\uBA74 \uC5B4\uB5A1\uD574... \uBBF8\uC548\uD574\u2026"
