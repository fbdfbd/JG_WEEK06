  _titleOverride: study Blocked
  _bodyText: "excursion study Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uAC11\uC790\uAE30 \uC11C\uC7AC\uC758 \uB9C8\uBC95 \uC870\uBA85\uC774
      \uBC1D\uC544\uC9C0\uBA70 \uBC31\uC791\uC758 \uBAA9\uC18C\uB9AC\uAC00 \uB9C8\uBC95\uAD6C\uC5D0\uC11C
      \uD758\uB7EC\uB098\uC628\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uAE5C\uC9DD \uB180\uB77C \uC5B4\uAE68\uB97C \uB4E4\uC369\uC774\uBA70)
      \uBCF4\uACE0 \uACC4\uC168\uB358 \uAC70\uC608\uC694?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uC9C4\uC9DC \uC228 \uB9C9\uD600. \uC6B0\uC720\uC5D0 \uC218\uBA74\uC81C\uB77C\uB3C4
      \uD0C4 \uAC70 \uC544\uB2C8\uC57C?"
  _nemoLine: "(\uAC11\uC790\uAE30 \uC11C\uC7AC\uC758 \uB9C8\uBC95 \uC870\uBA85\uC774
    \uBC1D\uC544\uC9C0\uBA70 \uBC31\uC791\uC758 \uBAA9\uC18C\uB9AC\uAC00 \uB9C8\uBC95\uAD6C\uC5D0\uC11C
