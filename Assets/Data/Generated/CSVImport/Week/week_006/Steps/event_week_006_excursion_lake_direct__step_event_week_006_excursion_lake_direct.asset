--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_excursion_lake_direct__step_event_week_006_excursion_lake_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 \uD5C8\uAC00"
  _bodyText: "excursion lake Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uAE34 \uC190\uC7A1\uC774 \uAD6D\uC790\uB85C
      \uB9D1\uC740 \uBB3C\uC744 \uC870\uAE08 \uB5A0, \uC595\uC740 \uB3CC\uADF8\uB987\uC5D0
      \uB2F4\uC544 \uB124\uBAA8 \uC55E\uC5D0 \uB0B4\uBBFC\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC9C1\uC811 \uBB3C\uAC00\uB85C \uAC00\uB294 \uAC74 \uC548 \uB418\uC9C0\uB9CC,
      \uC774 \uC815\uB3C4\uB294 \uAD1C\uCC2E\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uC624. \uC9C4\uC9DC \uCC28\uAC11\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC190\uB05D\uB9CC \uC0B4\uC9DD \uC801\uC2E0\uB2E4.
      \uBB3C\uC740 \uB9D1\uACE0 \uCC28\uAC00\uC6B4\uB370, \uB530\uAC11\uAC70\uB098
      \uAC70\uCE5C \uB290\uB08C\uC740 \uC5C6\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBD80\uB4DC\uB7FD\uB124."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB9E4\uC77C \uC544\uCE68 \uC57D\uCD08\uB85C \uD55C \uBC88\uC529 \uC190\uC744
      \uBD05\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9E4\uC77C?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC816\uC740 \uC190\uB05D\uC744 \uD587\uBE5B\uC5D0
      \uB4E4\uC5B4 \uC62C\uB9B0\uB2E4. \uBB3C\uBC29\uC6B8\uC774 \uBC18\uC9DD\uC778\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC0DD\uAC01\uBCF4\uB2E4 \uC5C4\uCCAD \uAD00\uB9AC\uBC1B\uB294 \uD638\uC218\uC600\uB124."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uAED8 \uB2FF\uB294 \uAC74 \uB300\uAC1C \uADF8\uB807\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5EC\uB984\uC5D4 \uC774\uCABD\uC774 \uC81C\uC77C \uB0AB\uACA0\uB124."
  _nemoLine: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uAE34 \uC190\uC7A1\uC774 \uAD6D\uC790\uB85C
    \uB9D1\uC740 \uBB3C\uC744 \uC870\uAE08 \uB5A0, \uC595\uC740 \uB3CC\uADF8\uB987\uC5D0
    \uB2F4\uC544 \uB124\uBAA8 \uC55E\uC5D0 \uB0B4\uBBFC\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
