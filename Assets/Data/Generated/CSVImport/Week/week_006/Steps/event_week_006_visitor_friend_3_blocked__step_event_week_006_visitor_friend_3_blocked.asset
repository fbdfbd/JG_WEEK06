  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_visitor_friend_3_blocked__step_event_week_006_visitor_friend_3_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC720\uD53C \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor friend_3 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC720\uD53C\uAC00 \uCC3D\uAC00\uC5D0 \uC791\uACE0 \uC54C\uB85D\uB2EC\uB85D\uD55C
      \uC5F0\uC744 \uD3BC\uCE58\uC790 \uD558\uB140\uAC00 \uC7AC\uBE68\uB9AC \uC811\uC5B4
      \uC0C1\uC790 \uC704\uC5D0 \uC62C\uB824\uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uBC14\uB78C\uC774 \uC138\uB2C8
      \uC7A5\uB09C\uC740 \uB2E4\uC74C\uC73C\uB85C \uBBF8\uB8E8\uB294 \uAC8C \uC88B\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544... \uC870\uAE08\uB9CC \uBCF4\uACE0 \uC2F6\uC5C8\uB294\uB370."
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uAD1C\uCC2E\uC544, \uB124\uBAA8. \uB2E4\uC74C\uC5D4 \uB354 \uD070 \uAC78
      \uAC00\uC838\uC62C\uAC8C. \uC624\uB298\uC740 \uCC3D\uBB38\uC5D0\uC11C \uBC14\uB78C\uB9CC
      \uAC19\uC774 \uBCF4\uC790."
  _nemoLine: "(\uC720\uD53C\uAC00 \uCC3D\uAC00\uC5D0 \uC791\uACE0 \uC54C\uB85D\uB2EC\uB85D\uD55C
    \uC5F0\uC744 \uD3BC\uCE58\uC790 \uD558\uB140\uAC00 \uC7AC\uBE68\uB9AC \uC811\uC5B4
    \uC0C1\uC790 \uC704\uC5D0 \uC62C\uB824\uB454\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
