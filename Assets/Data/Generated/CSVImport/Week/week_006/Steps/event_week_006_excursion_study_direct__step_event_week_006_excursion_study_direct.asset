  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_excursion_study_direct__step_event_week_006_excursion_study_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: study Direct
  _bodyText: "excursion study Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC758\uC790\uC5D0 \uC549\uC544 \uC6B0\uC720\uB97C
      \uD55C \uBAA8\uAE08 \uB9C8\uC2E0\uB2E4. \uC6B0\uC720 \uCEF5 \uBC11\uC5D0 \uC791\uC740
      \uC5F4\uC1E0 \uD558\uB098\uAC00 \uB193\uC5EC \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74... \uC11C\uC7AC \uC81C\uC77C \uB192\uC740 \uACF3\uC5D0 \uC788\uB294
      \uAC04\uC2DD\uC7A5 \uC5F4\uC1E0\uC778\uB370?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uCABD\uC9C0\uC5D0\uB294 '\uC7A0\uC774 \uC548 \uC624\uBA74 \uD558\uB098\uB9CC
      \uAEBC\uB0B4 \uBA39\uC5B4\uB77C. \uB2E8, \uC774 \uBC29 \uC548\uC5D0\uC11C\uB9CC\uC774\uB2E4.'\uB77C\uACE0
      \uC801\uD600 \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD750\uC74C... \uACB0\uAD6D \uC5EC\uAE30\uC11C \uB098\uAC00\uC9C0 \uB9D0\uB77C\uB294
      \uC18C\uB9AC\uB124."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB798\uB3C4 \uBB50, \uC758\uC790\uAC00 \uB530\uB73B\uD574\uC11C
      \uC870\uAE08\uB9CC \uB354 \uC788\uB2E4 \uAC08\uAE4C..."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC758\uC790\uC5D0 \uC549\uC544 \uC6B0\uC720\uB97C
    \uD55C \uBAA8\uAE08 \uB9C8\uC2E0\uB2E4. \uC6B0\uC720 \uCEF5 \uBC11\uC5D0 \uC791\uC740
    \uC5F4\uC1E0 \uD558\uB098\uAC00 \uB193\uC5EC \uC788\uB2E4.)"
