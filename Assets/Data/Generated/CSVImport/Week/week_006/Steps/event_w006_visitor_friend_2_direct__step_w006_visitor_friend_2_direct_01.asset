  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_visitor_friend_2_direct__step_w006_visitor_friend_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 6\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uCE5C\uAD6C 2\uAC00 \uBC31\uC791\uC758 \uACE0\uAE09 \uAE43\uD39C\uC744
    \uC2E0\uAE30\uD55C \uB4EF \uBC14\uB77C\uBCF8\uB2E4. \uB124\uBAA8\uB294 \uCE5C\uAD6C
    2\uC5D0\uAC8C \uAE43\uD39C\uC744 \uC950\uC5EC\uC8FC\uBA70 \uD55C \uBC88 \uC368\uBCF4\uB77C\uACE0
    \uAD8C\uD55C\uB2E4.)\n        \n        \uB124\uBAA8 : \uC774\uAC70 \uC9C4\uC9DC
    \uBD80\uB4DC\uB7EC\uC6CC. \uB124\uAC00 \uC88B\uC544\uD558\uB294 \uC2DC \uD55C
    \uAD6C\uC808 \uC801\uC5B4\uBD10.\n        \uCE5C\uAD6C 2 : (\uC870\uC2EC\uC2A4\uB7FD\uAC8C
    \uAE43\uD39C\uC744 \uC7A1\uC73C\uBA70) \uC815\uB9D0? \uC774\uB807\uAC8C \uADC0\uD55C
    \uAC78 \uB0B4\uAC00 \uC368\uB3C4 \uB420\uAE4C? \uBC31\uC791\uB2D8\uC774 \uC18C\uC911\uD788
    \uC5EC\uAE30\uC2DC\uB294 \uAC70\uC796\uC544.\n        \uB124\uBAA8 : \uAD1C\uCC2E\uC544,
    \uB0B4\uAC00 \uBE4C\uB824\uC8FC\uB294 \uAC70\uC57C. \uB108 \uAE00\uC528 \uC608\uC058\uB2C8\uAE4C
    \uBC31\uC791\uB2D8\uB3C4 \uBCF4\uC2DC\uBA74 \uCE6D\uCC2C\uD558\uC2E4\uAC78?\n       
    \n\n(\uCE5C\uAD6C 2\uAC00 \uC885\uC774 \uADC0\uD241\uC774\uC5D0 \uC815\uAC08\uD55C
    \uAE00\uC528\uB85C '\uC6B0\uC815'\uC774\uB77C\uB294 \uB2E8\uC5B4\uB97C \uC801\uB294\uB2E4.)\n       
    \uB124\uBAA8 : \uC640, \uC9C4\uC9DC \uC798 \uC4F4\uB2E4! \uBC31\uC791\uB2D8 \uAE00\uC528\uCC98\uB7FC
    \uBA4B\uC838.\n        \uCE5C\uAD6C 2 : (\uC218\uC90D\uAC8C \uC6C3\uC73C\uBA70)
    \uACE0\uB9C8\uC6CC, \uB124\uBAA8\uC57C. \uC774 \uD39C\uC73C\uB85C \uC4F0\uB2C8\uAE4C
    \uC660\uC9C0 \uB098\uB3C4 \uBA4B\uC9C4 \uC0AC\uB78C\uC774 \uB41C \uAC83 \uAC19\uC544.
    \uBC31\uC791\uB2D8 \uC11C\uC7AC\uB294 \uCC38 \uB9C8\uBC95 \uAC19\uC740 \uACF3\uC774\uB124.\n       
    \uB124\uBAA8 : (\uCE5C\uAD6C 2\uC758 \uC5B4\uAE68\uB97C \uAC10\uC2F8\uBA70) \uADF8\uCE58?
    \uB098\uC911\uC5D0 \uB108 \uC62C \uB54C\uB9C8\uB2E4 \uC774 \uD39C \uC4F0\uAC8C
    \uD574\uC904\uAC8C. \uBC31\uC791\uB2D8\uD55C\uD14C \uC6B0\uB9AC \uB458\uB9CC\uC758
    '\uAE30\uB85D\uC7A5' \uD558\uB098 \uB9CC\uB4E4\uC5B4\uB2EC\uB77C\uACE0 \uC870\uB97C
    \uAC70\uC57C!"
