  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_external_w006_direct__step_event_week_006_external_w006_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC2E0\uBE44\uD55C \uB300\uB959 \uC18C\uBB38 \uD5C8\uAC00"
  _bodyText: "external w006 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: bb92d18cb19ba9944ac71077eb8aa4c5, type: 2}
    _text: "\uC544\uC8FC \uBA3C \uB0A8\uCABD\uC73C\uB85C \uBC30\uB97C \uD0C0\uACE0
      \uD55C \uB2EC\uC744 \uAC00\uBA74 \uB098\uC624\uB294 \uC2E0\uBE44\uD55C \uB300\uB959\uC774
      \uC788\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD55C \uB2EC\uC774\uB098? \uADF8\uB7FC \uAC70\uAE30 \uAC00\uBA74 \uC9C4\uC9DC
      \uD558\uB298\uC744 \uB0A0 \uC218 \uC788\uC5B4?"
  - _speaker: {fileID: 11400000, guid: bb92d18cb19ba9944ac71077eb8aa4c5, type: 2}
    _text: "\uAC70\uAE30\uC120 \uCF54\uB07C\uB9AC\uB77C\uB294 \uAC70\uB300\uD55C
      \uC9D0\uC2B9\uC744 \uD0C0\uACE0 \uB2E4\uB2C8\uACE0, \uC0AC\uD0D5\uC774 \uC5F4\uB9AC\uB294
      \uB098\uBB34\uB3C4 \uC788\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640! \uB098 \uB098\uC911\uC5D0 \uC5B4\uB978 \uB418\uBA74 \uAF2D
      \uBC30 \uD0C0\uACE0 \uAC70\uAE30 \uAC08\uB798. \uC0AC\uD0D5 \uB098\uBB34 \uC9C4\uC9DC
      \uAD81\uAE08\uD574!"
  _nemoLine: "\uC544\uC8FC \uBA3C \uB0A8\uCABD\uC73C\uB85C \uBC30\uB97C \uD0C0\uACE0
    \uD55C \uB2EC\uC744 \uAC00\uBA74 \uB098\uC624\uB294 \uC2E0\uBE44\uD55C \uB300\uB959\uC774
    \uC788\uB300\uC694."
