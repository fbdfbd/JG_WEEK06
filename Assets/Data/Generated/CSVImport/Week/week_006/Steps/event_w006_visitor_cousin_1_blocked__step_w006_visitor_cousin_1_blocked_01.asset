  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_visitor_cousin_1_blocked__step_w006_visitor_cousin_1_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 6\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uC0AC\uCD0C 1\uC774 \uC5EC\uD589\uAE38\uC5D0 \uC37C\uB358 \uB0A1\uC740
    \uBAA8\uC790\uB97C \uBC31\uC791\uC758 \uCC45\uC0C1 \uC704\uC5D0 \uD22D \uB358\uC838\uB193\uB294\uB2E4.
    \uBC31\uC791\uC758 \uC815\uAC08\uD55C \uCC45\uC0C1\uC5D0 \uC5B4\uC6B8\uB9AC\uC9C0
    \uC54A\uB294 \uD759\uBA3C\uC9C0 \uBB3B\uC740 \uBAA8\uC790\uB2E4.)\r\n       
    \r\n        \uC0AC\uCD0C 1 : \uB124\uBAA8\uC57C, \uC0BC\uCD0C \uC774\uBC88\uC5D0
    \uBD81\uBD80 \uACE0\uC6D0 \uB2E4\uB140\uC654\uB294\uB370 \uB9D0\uC774\uC57C.
    \uC774 \uBAA8\uC790\uC5D0 \uAC70\uAE30 \uB0C4\uC0C8\uAC00 \uBC30\uC5B4 \uC788\uC744
    \uAC70\uB2E4. \uD55C\uBC88 \uB9E1\uC544\uBCFC\uB798?\r\n        \uB124\uBAA8
    : (\uBAA8\uC790\uB97C \uC870\uC2EC\uC2A4\uB808 \uB4E4\uC5B4 \uCF54\uB97C \uAC16\uB2E4
    \uB304\uB2E4) \uC74C... \uB9E4\uC6B4 \uB0C4\uC0C8\uAC00 \uB098\uC694! \uC774\uAC8C
    \uACE0\uC6D0\uC758 \uB0C4\uC0C8\uC608\uC694?\r\n        \uC0AC\uCD0C 1 : \uADF8\uAC74
    \uB0B4\uAC00 \uC5B4\uC81C \uBA39\uC740 \uD5A5\uC2E0\uB8CC \uB0C4\uC0C8\uACE0!
    \uD558\uD558\uD558!\r\n        \r\n\r\n(\uC9D1\uC0AC\uAC00 \uC740\uC7C1\uBC18\uC744
    \uB4E4\uACE0 \uC640 \uBAA8\uC790\uB97C \uC9D1\uAC8C\uB85C \uC9D1\uC5B4 \uC62C\uB9B0\uB2E4.)\r\n       
    \uC9D1\uC0AC : \uC678\uBD80\uC778\uC758 \uC18C\uC9C0\uD488\uC740 \uC11C\uC7AC\uC758
    \uCCAD\uACB0\uC744 \uD574\uCE69\uB2C8\uB2E4. \uC8FC\uC778\uB2D8\uAED8\uC11C \uBCF4\uC2DC\uAE30
    \uC804\uC5D0 \uCE58\uC6B0\uACA0\uC2B5\uB2C8\uB2E4.\r\n        \uB124\uBAA8 :
    (\uBAA8\uC790\uB97C \uBE8F\uAE30\uBA70) \uC544... \uC7A0\uAE50\uB9CC\uC694, \uC544\uC9C1
    \uC81C\uB300\uB85C \uBABB \uB9E1\uC544\uBD24\uB294\uB370!\r\n        \uC0AC\uCD0C
    1 : \uC815\uB9D0 \uC5EC\uC804\uD558\uC2DC\uAD6C\uB9CC. \uD759\uB0C4\uC0C8 \uC880
    \uB9E1\uB294\uB2E4\uACE0 \uC601\uC9C0\uAC00 \uB9DD\uD558\uB294 \uAC83\uB3C4 \uC544\uB2CC\uB370
    \uB9D0\uC774\uC57C.\r\n        \uB124\uBAA8 : (\uBB34\uC548\uD55C \uB4EF \uC190\uC744
    \uBE44\uBE44\uBA70) \uBC31\uC791\uB2D8\uC774 \uC800\uB97C \uC704\uD574 \uC644\uBCBD\uD55C
    \uD658\uACBD\uB9CC \uB9CC\uB4E4\uC5B4\uC8FC\uC2DC\uB824\uB294 \uAC70\uB2C8\uAE4C...
    \uC774\uD574\uD574\uC57C\uC8E0. \uBBF8\uC548\uD574\uC694."
