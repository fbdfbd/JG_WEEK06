  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_external_w006_blocked__step_event_week_006_external_w006_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC2E0\uBE44\uD55C \uB300\uB959 \uC18C\uBB38 \uD1B5\uC81C"
  _bodyText: "external w006 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: bb92d18cb19ba9944ac71077eb8aa4c5, type: 2}
    _text: "(\uB4B7\uBA38\uB9AC\uB97C \uAE01\uC801\uC774\uBA70) \uC5D0\uC774, \uB3C4\uB828\uB2D8.
      \uC800\uD76C \uAC19\uC740 \uC77C\uAFBC\uB4E4\uC774 \uC9C0\uC5B4\uB0B8 \uB18D\uB2F4\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC \uC788\uB294 \uACF3 \uC544\uB2C8\uC57C? \uB098\uB3C4 \uAC00\uBCF4\uACE0
      \uC2F6\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: bb92d18cb19ba9944ac71077eb8aa4c5, type: 2}
    _text: "\uC138\uC0C1\uC5D0 \uADF8\uB7F0 \uB370\uAC00 \uC5B4\uB514 \uC788\uACA0\uC2B5\uB2C8\uAE4C.
      \uADF8\uB0E5 \uAFC8\uC18D \uC774\uC57C\uAE30\uC9C0\uC694. \uC5B4\uC11C \uB4E4\uC5B4\uAC00
      \uC26C\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD765, \uB2E4\uB4E4 \uC548 \uAC00\uBCF8 \uAC70\uBA74\uC11C \uC5C6\uB2E4\uACE0\uB9CC
      \uD574."
  _nemoLine: "(\uB4B7\uBA38\uB9AC\uB97C \uAE01\uC801\uC774\uBA70) \uC5D0\uC774, \uB3C4\uB828\uB2D8.
    \uC800\uD76C \uAC19\uC740 \uC77C\uAFBC\uB4E4\uC774 \uC9C0\uC5B4\uB0B8 \uB18D\uB2F4\uC785\uB2C8\uB2E4."
