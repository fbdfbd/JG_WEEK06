  _titleOverride: "\uC720\uD53C \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "letter friend_3 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uB294 \uD654\uB824\uD55C \uB099\uC11C\uB97C \uBCF4\uACE0\uB294
      \"\uB3C4\uBB34\uC9C0 \uC54C\uC544\uBCFC \uC218\uAC00 \uC5C6\uB124\"\uB77C\uBA70
      \uD3B8\uC9C0\uD568 \uBC11\uBC14\uB2E5\uC5D0 \uB123\uC5B4 \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uCC3D\uBC16 \uAD6C\uB984\uC744 \uBCF4\uBA70 \uADF8\uB0E5
      \uD558\uC580 \uB369\uC5B4\uB9AC\uB124, \uD558\uACE0 \uC7AC\uBBF8\uC5C6\uAC8C
      \uB3CC\uC544\uC120\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\u2026\u2026\uACF5\uBD80\uC5D0 \uC9D1\uC911\uD574\uC57C \uD560 \uC2DC\uAE30\uC5D0
      \uC774\uB7F0 \uC7A5\uB09C\uC740 \uBC29\uD574\uB9CC \uB420 \uBFD0\uC774\uC57C."
  _nemoLine: "(\uD558\uB140\uB294 \uD654\uB824\uD55C \uB099\uC11C\uB97C \uBCF4\uACE0\uB294
    \"\uB3C4\uBB34\uC9C0 \uC54C\uC544\uBCFC \uC218\uAC00 \uC5C6\uB124\"\uB77C\uBA70
    \uD3B8\uC9C0\uD568 \uBC11\uBC14\uB2E5\uC5D0 \uB123\uC5B4 \uB454\uB2E4.)"
