  m_Name: event_week_006_excursion_library_blocked__step_event_week_006_excursion_library_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: library Blocked
  _bodyText: "excursion library Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC9D1\uC0AC\uAC00 \uB098\uD0C0\uB098 \uC678\uD22C\uB97C \uD68C\uC218\uD558\uBA70
      \uB124\uBAA8\uB97C \uC7AC\uCD09\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uD1B5\uAE08 \uC2DC\uAC04\uC774 30\uBD84 \uC9C0\uB0AC\uC2B5\uB2C8\uB2E4.
      \uC8FC\uC778\uB2D8\uAED8\uC11C \uB9E4\uC6B0 \uC5C4\uC911\uD788 \uBCF4\uACE0
      \uACC4\uC2ED\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uCF54\uD2B8\uB97C \uBE8F\uAE30\uB4EF \uB0B4\uC8FC\uBA70) \uADF8\uB0E5
      \uAE68\uC6CC\uC11C \uBCF4\uB0B4\uC9C0, \uC65C \uCF54\uD2B8\uB9CC \uB36E\uC5B4\uC8FC\uACE0
      \uAC00\uC2E0\uB300."
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC7A0\uB4E0 \uBAA8\uC2B5\uC744 \uBC29\uD574\uD558\uC9C0 \uB9D0\uB77C\uB294
      \uBC30\uB824\uC168\uC2B5\uB2C8\uB2E4. \uB2E4\uB9CC \uB0B4\uC77C\uBD80\uD130
      \uC57C\uAC04 \uB3C4\uC11C\uAD00 \uCD9C\uC785\uC740 \uAE08\uC9C0\uB420 \uC608\uC815\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uD55C\uC228\uC744 \uC26C\uBA70) \uC5ED\uC2DC... \uB2E4\uC815\uD55C
      \uCC99\uD558\uBA74\uC11C \uACB0\uAD6D\uC740 \uAE08\uC9C0\uB124."
  _nemoLine: "(\uC9D1\uC0AC\uAC00 \uB098\uD0C0\uB098 \uC678\uD22C\uB97C \uD68C\uC218\uD558\uBA70
    \uB124\uBAA8\uB97C \uC7AC\uCD09\uD55C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
