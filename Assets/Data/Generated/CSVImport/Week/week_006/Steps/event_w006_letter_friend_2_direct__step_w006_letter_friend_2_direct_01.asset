  m_Name: event_w006_letter_friend_2_direct__step_w006_letter_friend_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 \uD3B8\uC9C0 6\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uB2E8\uC815\uD55C \uBD09\uD22C\uB97C \uB4E4\uACE0
    \uC628\uB2E4. \uBD09\uD22C \uAC89\uBA74\uC5D0\uB294 '\uB124\uBAA8\uB9CC \uC77D\uC744
    \uAC83'\uC774\uB77C\uACE0 \uD07C\uC9C1\uD558\uAC8C \uC801\uD600 \uC788\uB2E4.)\n   
    \uD558\uB140 : \uC774\uBC88 \uD3B8\uC9C0\uB294 \uC720\uB3C5 \uC2E0\uACBD\uC744
    \uB9CE\uC774 \uC4F4 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.\n        \n\n\uD558\uB140
    : \uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uBBF8\uB798\uC758 \uC57D\uC18D\uC744
    \uC801\uC5B4\uC11C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\n        \uB124\uBAA8 : \uBBF8\uB798?
    \uC5B4\uB978 \uB41C \uB2E4\uC74C \uC598\uAE30\uC57C?\n        (\uD558\uB140\uAC00
    \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)\n        \uB124\uBAA8\uC5D0\uAC8C. \uB098\uC911\uC5D4
    \uB0B4\uAC00 \uC544\uC8FC \uD06C\uACE0 \uC870\uC6A9\uD55C \uC11C\uC7AC\uB97C
    \uB9CC\uB4E4 \uAC70\uC57C. \uACBD\uBE44\uB300\uC7A5 \uC544\uC800\uC528\uB3C4,
    \uBC31\uC791\uB2D8\uB3C4 \uC5C6\uB294 \uACF3\uC5D0\uC11C \uC6B0\uB9AC \uB458\uC774
    \uD558\uB8E8 \uC885\uC77C \uCC45 \uC77D\uC790. \uB9AC\uBCF8\uC740 \uB0B4\uAC00
    \uB9E4\uC77C \uC608\uC058\uAC8C \uBB36\uC5B4\uC904\uAC8C. \uADF8\uB7EC\uB2C8\uAE4C
    \uADF8\uB54C\uAE4C\uC9C0 \uB098 \uC78A\uC9C0 \uB9C8.\n        \uB124\uBAA8 :
    \uAC54\uAC00 \uB9AC\uBCF8 \uBB36\uC5B4\uC900\uB300?\n        \uD558\uB140 : \uB124.
    \uB204\uAD6C\uC758 \uBC29\uD574\uB3C4 \uBC1B\uC9C0 \uC54A\uB294 \uB458\uB9CC\uC758
    \uACF5\uAC04\uC744 \uB9CC\uB4E4\uACE0 \uC2F6\uC740\uAC00 \uBD05\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uC640... \uADF8\uB7FC \uB098 \uC774\uC81C \uB9AC\uBCF8 \uC5F0\uC2B5
    \uC548 \uD574\uB3C4 \uB418\uACA0\uB2E4! \uAC54\uAC00 \uD574\uC904 \uAC70\uB2C8\uAE4C!\n       
    \uD558\uB140 : \uC544\uC8FC \uB4E0\uB4E0\uD55C \uCE5C\uAD6C\uB97C \uB450\uC168\uB124\uC694,
    \uC8FC\uC778\uB2D8."
