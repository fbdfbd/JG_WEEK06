  _titleOverride: w006 Blocked
  _bodyText: "house_talk w006 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.
      \uC800\uD76C\uAC00 \uC22B\uC790\uB97C \uC798\uBABB \uC14C\uB098 \uBD10\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC740\uC2A4\uD47C \uC5C6\uC5B4\uC84C\uB2E4\uBA70!"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB2E4\uC2DC \uCC3E\uC544\uBCF4\uB2C8 \uC2F1\uD06C\uB300 \uBC11\uC5D0
      \uC788\uC5C8\uC5B4\uC694. \uC800\uD76C\uAC00 \uB364\uBC99\uAC70\uB824\uC11C
      \uADF8\uB807\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC70\uC9D3\uB9D0. \uC544\uAE4C\uB294 \uC5C6\uB2E4\uACE0 \uD588\uC73C\uBA74\uC11C."
  _nemoLine: "\uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.
    \uC800\uD76C\uAC00 \uC22B\uC790\uB97C \uC798\uBABB \uC14C\uB098 \uBD10\uC694."
