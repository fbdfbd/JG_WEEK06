  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_visitor_cousin_1_direct__step_w006_visitor_cousin_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 6\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uC0AC\uCD0C 1\uC774 \uC5EC\uD589\uAE38\uC5D0 \uC37C\uB358 \uB0A1\uC740
    \uBAA8\uC790\uB97C \uBC31\uC791\uC758 \uCC45\uC0C1 \uC704\uC5D0 \uD22D \uB358\uC838\uB193\uB294\uB2E4.
    \uBC31\uC791\uC758 \uC815\uAC08\uD55C \uCC45\uC0C1\uC5D0 \uC5B4\uC6B8\uB9AC\uC9C0
    \uC54A\uB294 \uD759\uBA3C\uC9C0 \uBB3B\uC740 \uBAA8\uC790\uB2E4.)\n        \n       
    \uC0AC\uCD0C 1 : \uB124\uBAA8\uC57C, \uC0BC\uCD0C \uC774\uBC88\uC5D0 \uBD81\uBD80
    \uACE0\uC6D0 \uB2E4\uB140\uC654\uB294\uB370 \uB9D0\uC774\uC57C. \uC774 \uBAA8\uC790\uC5D0
    \uAC70\uAE30 \uB0C4\uC0C8\uAC00 \uBC30\uC5B4 \uC788\uC744 \uAC70\uB2E4. \uD55C\uBC88
    \uB9E1\uC544\uBCFC\uB798?\n        \uB124\uBAA8 : (\uBAA8\uC790\uB97C \uC870\uC2EC\uC2A4\uB808
    \uB4E4\uC5B4 \uCF54\uB97C \uAC16\uB2E4 \uB304\uB2E4) \uC74C... \uB9E4\uC6B4 \uB0C4\uC0C8\uAC00
    \uB098\uC694! \uC774\uAC8C \uACE0\uC6D0\uC758 \uB0C4\uC0C8\uC608\uC694?\n       
    \uC0AC\uCD0C 1 : \uADF8\uAC74 \uB0B4\uAC00 \uC5B4\uC81C \uBA39\uC740 \uD5A5\uC2E0\uB8CC
    \uB0C4\uC0C8\uACE0! \uD558\uD558\uD558!\n        \n\n(\uB124\uBAA8\uAC00 \uC0BC\uCD0C\uC758
    \uBAA8\uC790\uB97C \uC790\uAE30 \uBA38\uB9AC\uC5D0 \uD479 \uB20C\uB7EC\uC4F4\uB2E4.
    \uBAA8\uC790\uAC00 \uB108\uBB34 \uCEE4\uC11C \uB208\uC774 \uAC00\uB824\uC9C4\uB2E4.)\n       
    \uB124\uBAA8 : \uC6B0\uC640, \uC55E\uC774 \uD558\uB098\uB3C4 \uC548 \uBCF4\uC5EC\uC694!
    \uC0BC\uCD0C\uC740 \uC774\uB7F0 \uAC78 \uC4F0\uACE0 \uC138\uC0C1\uC744 \uB2E4
    \uB3CC\uC544\uB2E4\uB2CC \uAC70\uC608\uC694?\n        \uC0AC\uCD0C 1 : \uADF8\uB7FC!
    \uB208\uC744 \uAC00\uB824\uC57C \uB9C8\uC74C\uC758 \uB208\uC774 \uB5A0\uC9C0\uB294
    \uBC95\uC774\uAC70\uB4E0. \uC5B4\uB5A0\uB0D0, \uBC31\uC791\uB2D8 \uC11C\uC7AC\uAC00
    \uC544\uB2C8\uB77C \uB113\uC740 \uBC8C\uD310\uC5D0 \uC11C \uC788\uB294 \uAE30\uBD84\uC774
    \uB4E4\uC9C0 \uC54A\uC544?\n        \uB124\uBAA8 : (\uBAA8\uC790 \uC18D\uC5D0\uC11C
    \uC6C5\uC5BC\uAC70\uB9AC\uBA70) \uB124... \uC2E0\uAE30\uD574\uC694. \uBC31\uC791\uB2D8
    \uD5A5\uC218 \uB0C4\uC0C8 \uB9D0\uACE0 \uC774\uB7F0 \uD22C\uBC15\uD55C \uB0C4\uC0C8\uB3C4
    \uCC38 \uC88B\uB124\uC694. \uC81C \uC138\uACC4\uAC00 \uB113\uC5B4\uC9C0\uB294
    \uAE30\uBD84\uC774\uC5D0\uC694."
