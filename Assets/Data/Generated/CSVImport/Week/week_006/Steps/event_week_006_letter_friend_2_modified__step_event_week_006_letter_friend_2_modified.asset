--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_letter_friend_2_modified__step_event_week_006_letter_friend_2_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC00\uB9AC\uC544 \uD3B8\uC9C0 \uC218\uC815"
  _bodyText: "letter friend_2 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uCE5C\uAD6C\uBD84\uC774
      \uC55E\uC73C\uB85C\uC758 \uAFC8\uC744 \uC801\uC5B4 \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB34\uC2A8 \uAFC8\uC778\uB370?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB098\uC911\uC5D0 \uC5B4\uB978\uC774 \uB418\uBA74 \uC8FC\uC778\uB2D8\uC744
      \uC544\uC8FC \uD3B8\uC548\uD558\uACE0 \uBA4B\uC9C4 \uACF3\uC73C\uB85C \uCD08\uB300\uD558\uACE0
      \uC2F6\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBA4B\uC9C4 \uACF3?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uAC70\uAE30\uC120 \uC8FC\uC778\uB2D8\uC774 \uD558\uACE0 \uC2F6\uC740
      \uAC78 \uB9C8\uC74C\uAECF \uD560 \uC218 \uC788\uAC8C \uB3C4\uC640\uC8FC\uACA0\uB2E4\uACE0
      \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uAC54\uB294 \uACF5\uBD80\uB3C4 \uC798\uD558\uB2C8\uAE4C
      \uC9C4\uC9DC \uD560 \uC218 \uC788\uC744 \uAC70\uC57C."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uC744 \uD5A5\uD55C \uB9C8\uC74C\uC774 \uC544\uC8FC
      \uC9C4\uC2EC\uC778 \uAC83 \uAC19\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uAC54\uAC00 \uB9CC\uB4E0 \uC11C\uC7AC\uB294 \uC138\uC0C1\uC5D0\uC11C
      \uC81C\uC77C \uC88B\uC744 \uAC83 \uAC19\uC544."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uCE5C\uAD6C\uBD84\uC774
    \uC55E\uC73C\uB85C\uC758 \uAFC8\uC744 \uC801\uC5B4 \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
