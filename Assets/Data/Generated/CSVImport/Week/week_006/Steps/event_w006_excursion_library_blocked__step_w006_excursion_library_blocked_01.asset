  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_excursion_library_blocked__step_w006_excursion_library_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 6\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uB2A6\uC740 \uBC24, \uB124\uBAA8\uAC00 \uB3C4\uC11C\uAD00 \uAD6C\uC11D
    \uC18C\uD30C\uC5D0\uC11C \uCC45\uC744 \uC5BC\uAD74\uC5D0 \uB36E\uC740 \uCC44
    \uC7A0\uB4E4\uC5B4 \uC788\uB2E4. \uAE68\uC5B4\uBCF4\uB2C8 \uC5B4\uAE68\uC5D0
    \uBB35\uC9C1\uD558\uACE0 \uB530\uB73B\uD55C \uC678\uD22C\uAC00 \uB36E\uC5EC \uC788\uACE0,
    \uD0C1\uC790 \uC704 \uCD1B\uBD88\uC740 \uAC70\uC758 \uB2E4 \uD0C0\uB4E4\uC5B4
    \uAC00\uACE0 \uC788\uB2E4.)\r\n        \r\n        \uB124\uBAA8 : ...\uC74C.\r\n       
    (\uC678\uD22C\uC5D0\uC11C \uC775\uC219\uD55C \uD5A5\uC218 \uB0C4\uC0C8\uAC00
    \uB09C\uB2E4. \uBC31\uC791\uC774 \uC9D1\uBB34\uC2E4\uC5D0\uC11C \uC785\uB358
    \uCF54\uD2B8\uB2E4.)\r\n        \r\n        \uB124\uBAA8 : \uC5B8\uC81C \uC654\uB2E4
    \uAC00\uC2E0 \uAC70\uC9C0?\r\n        (\uD0C1\uC790 \uC704\uB97C \uBCF4\uB2C8,
    \uC2DD\uC5B4\uBC84\uB9B0 \uCF54\uCF54\uC544 \uD55C \uC794\uACFC \"\uBC24\uC774
    \uAE4A\uC5C8\uB2E4. \uBC29\uC73C\uB85C \uB3CC\uC544\uAC00\uB77C\"\uACE0 \uC801\uD78C
    \uCABD\uC9C0\uAC00 \uB193\uC5EC \uC788\uB2E4.)\r\n        \r\n\r\n(\uC9D1\uC0AC\uAC00
    \uB098\uD0C0\uB098 \uC678\uD22C\uB97C \uD68C\uC218\uD558\uBA70 \uB124\uBAA8\uB97C
    \uC7AC\uCD09\uD55C\uB2E4.)\r\n        \uC9D1\uC0AC : \uD1B5\uAE08 \uC2DC\uAC04\uC774
    30\uBD84 \uC9C0\uB0AC\uC2B5\uB2C8\uB2E4. \uC8FC\uC778\uB2D8\uAED8\uC11C \uB9E4\uC6B0
    \uC5C4\uC911\uD788 \uBCF4\uACE0 \uACC4\uC2ED\uB2C8\uB2E4.\r\n        \uB124\uBAA8
    : (\uCF54\uD2B8\uB97C \uBE8F\uAE30\uB4EF \uB0B4\uC8FC\uBA70) \uADF8\uB0E5 \uAE68\uC6CC\uC11C
    \uBCF4\uB0B4\uC9C0, \uC65C \uCF54\uD2B8\uB9CC \uB36E\uC5B4\uC8FC\uACE0 \uAC00\uC2E0\uB300.\r\n       
    \uC9D1\uC0AC : \uC7A0\uB4E0 \uBAA8\uC2B5\uC744 \uBC29\uD574\uD558\uC9C0 \uB9D0\uB77C\uB294
    \uBC30\uB824\uC168\uC2B5\uB2C8\uB2E4. \uB2E4\uB9CC \uB0B4\uC77C\uBD80\uD130 \uC57C\uAC04
    \uB3C4\uC11C\uAD00 \uCD9C\uC785\uC740 \uAE08\uC9C0\uB420 \uC608\uC815\uC785\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : (\uD55C\uC228\uC744 \uC26C\uBA70) \uC5ED\uC2DC... \uB2E4\uC815\uD55C
    \uCC99\uD558\uBA74\uC11C \uACB0\uAD6D\uC740 \uAE08\uC9C0\uB124."
