  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_visitor_friend_2_blocked__step_event_week_006_visitor_friend_2_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC00\uB9AC\uC544 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor friend_2 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBC00\uB9AC\uC544\uAC00 \uD55C \uAE00\uC790 \uC801\uC73C\uB824\uB294\uB370,
      \uACBD\uBE44\uB300\uC7A5\uC774 \uB2E4\uAC00\uC640 \uC885\uC774\uB97C \uAC00\uB85C\uB9C9\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB3C4\uB828\uB2D8, \uC8FC\uC778\uB2D8\uC758 \uC9D1\uBB34 \uC6A9\uC9C0\uB294
      \uC678\uBD80\uC778\uC758 \uB099\uC11C\uB97C \uC704\uD574 \uC900\uBE44\uB41C
      \uAC83\uC774 \uC544\uB2D9\uB2C8\uB2E4. \uD39C\uC744 \uB0B4\uB824\uB193\uAC8C
      \uD558\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC6B8\uCEE5\uD558\uBA70) \uC544\uC800\uC528! \uCE5C\uAD6C\uAC00 \uC2DC
      \uD55C \uC904 \uC4F0\uB294 \uAC8C \uBB50\uAC00 \uADF8\uB807\uAC8C \uD070\uC77C\uC774\uB77C\uACE0
      \uADF8\uB7EC\uC138\uC694!"
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "(\uD669\uAE09\uD788 \uD39C\uC744 \uB0B4\uB824\uB193\uC73C\uBA70) \uBBF8\uC548\uD574,
      \uB124\uBAA8\uC57C... \uB0B4\uAC00 \uC8FC\uC81C\uB118\uC5C8\uC5B4. \uB098 \uADF8\uB0E5
      \uAC08\uAC8C. \uBC31\uC791\uB2D8\uC774 \uC624\uC2DC\uBA74 \uB098 \uB54C\uBB38\uC5D0
      \uB124\uAC00 \uD63C\uB0A0\uAE4C \uBD10 \uAC81\uB098."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC0AC\uACFC\uD558\uB294 \uCE5C\uAD6C\uB97C \uBCF4\uBA70) \uC544\uB0D0,
      \uB124 \uC798\uBABB \uC544\uB0D0... \uC5EC\uAE30 \uBD84\uC704\uAE30\uAC00 \uC774\uB798\uC11C
      \uADF8\uB798. \uBBF8\uC548\uD574."
  _nemoLine: "(\uBC00\uB9AC\uC544\uAC00 \uD55C \uAE00\uC790 \uC801\uC73C\uB824\uB294\uB370,
    \uACBD\uBE44\uB300\uC7A5\uC774 \uB2E4\uAC00\uC640 \uC885\uC774\uB97C \uAC00\uB85C\uB9C9\uB294\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
