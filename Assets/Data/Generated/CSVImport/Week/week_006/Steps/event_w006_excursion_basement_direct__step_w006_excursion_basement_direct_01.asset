  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_excursion_basement_direct__step_w006_excursion_basement_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 6\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uC800\uB141 \uBB34\uB835. \uC9C0\uD558\uC2E4 \uC548\uCABD \uC120\uBC18\uC5D4
    \uC640\uC778\uBCD1\uB4E4\uC774 \uAC00\uC9C0\uB7F0\uD788 \uB204\uC6CC \uC788\uB2E4.
    \uBCD1\uBAA9\uB9C8\uB2E4 \uC5F0\uB3C4\uD45C\uC640 \uC791\uC740 \uBA54\uBAA8\uAC00
    \uB2EC\uB824 \uC788\uB2E4. \uB124\uBAA8\uB294 \uADF8\uC911 \uAC00\uC7A5 \uC55E\uC904\uC5D0
    \uB193\uC778 \uBCD1 \uD558\uB098\uB97C \uC720\uC2EC\uD788 \uBCF8\uB2E4.)\r\n       
    \r\n        \uB124\uBAA8 : \uC774\uAC74 \uC65C \uB2E4 \uB215\uD600 \uB194?\r\n       
    \r\n        \uB124\uBAA8 : \uC138\uC6CC \uB450\uBA74 \uB354 \uBCF4\uAE30 \uD3B8\uD560
    \uD150\uB370.\r\n        \r\n        (\uBCD1 \uC606 \uC791\uC740 \uD45C\uC5D4
    \uC789\uD06C\uB85C \uC9E7\uC740 \uBB38\uC7A5\uC774 \uC801\uD600 \uC788\uB2E4.
    \u2018\uAC1C\uBD09 \uC801\uAE30 \uC784\uBC15\u2019 \uAC19\uC740 \uB531\uB531\uD55C
    \uAE00 \uC606\uC5D0, \uB204\uAD70\uAC00 \uB354 \uC791\uAC8C \uB367\uC4F4 \uBA54\uBAA8\uAC00
    \uBCF4\uC778\uB2E4.)\r\n        \r\n        \uB124\uBAA8 : ...\uC5BC\uB9C8 \uC548
    \uB0A8\uC558\uB2E4?\r\n        \r\n\r\n(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uBCD1\uC744
    \uAC74\uB4DC\uB9AC\uC9C4 \uC54A\uACE0, \uD45C\uB9CC \uB124\uBAA8 \uCABD\uC73C\uB85C
    \uB3CC\uB824 \uC900\uB2E4.)\r\n        \r\n        \uCC3D\uACE0\uC9C0\uAE30 :
    \uC624\uB798 \uB450\uB294 \uAC83\uB3C4 \uC88B\uC9C0\uB9CC, \uAC00\uC7A5 \uC88B\uC740
    \uB54C\uB97C \uB193\uCE58\uBA74 \uC544\uAE5D\uB2F5\uB2C8\uB2E4.\r\n        \r\n       
    \uB124\uBAA8 : \uADF8\uB798\uC11C \u2018\uC5BC\uB9C8 \uC548 \uB0A8\uC558\uB2E4\u2019\uACE0
    \uC801\uC740 \uAC70\uC57C?\r\n        \r\n        \uCC3D\uACE0\uC9C0\uAE30 :
    \uC608.\r\n        \r\n        \uB124\uBAA8 : \uC640\uC778\uB3C4 \uB54C\uAC00
    \uC788\uB124.\r\n        \r\n        \uCC3D\uACE0\uC9C0\uAE30 : \uC0AC\uB78C
    \uC190\uC744 \uAE30\uB2E4\uB9AC\uB2E4 \uB108\uBB34 \uB2A6\uC73C\uBA74, \uC624\uD788\uB824
    \uB9DB\uC774 \uC8FD\uC2B5\uB2C8\uB2E4.\r\n        \r\n        (\uB124\uBAA8\uB294
    \uBCD1\uB4E4\uC744 \uCC9C\uCC9C\uD788 \uD6D1\uC5B4\uBCF8\uB2E4.)\r\n        \r\n       
    \uB124\uBAA8 : \uB098\uB3C4 \uACE7 \uC788\uC73C\uBA74 \uB9C8\uC2E4 \uB0A0\uC774
    \uC624\uACA0\uC9C0?"
