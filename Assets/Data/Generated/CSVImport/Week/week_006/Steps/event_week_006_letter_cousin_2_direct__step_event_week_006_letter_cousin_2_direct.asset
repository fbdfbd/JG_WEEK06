  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_letter_cousin_2_direct__step_event_week_006_letter_cousin_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9AC\uC548 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "letter cousin_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uC774 \uC6A9\uAE30\uB97C
      \uB0B4\uC11C \uB9C8\uC9C0\uB9C9 \uD3B8\uC9C0\uB97C \uBCF4\uB0B4\uC168\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9C8\uC9C0\uB9C9? \uC65C? \uC774\uC81C \uC548 \uC628\uB300?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC81C\uC77C \uC6A9\uAE30 \uC788\uB294 \uC77C\uC774\uC5C8\uB300..."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uC774 \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uAED8 \uC544\uC8FC
      \uD070 \uD798\uC774 \uB418\uC5C8\uB098 \uBD05\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB300\uB2F5 \uC548 \uD574\uB3C4 \uB41C\uB2E4\uB2C8, \uBC14\uBCF4\uC57C.
      \uB2F9\uC5F0\uD788 \uCE5C\uAD6C \uD574\uC904 \uAC74\uB370."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uC774 \uC6A9\uAE30\uB97C
    \uB0B4\uC11C \uB9C8\uC9C0\uB9C9 \uD3B8\uC9C0\uB97C \uBCF4\uB0B4\uC168\uC5B4\uC694."
  _useCustomVisualState: 0
  _visualState: 0
