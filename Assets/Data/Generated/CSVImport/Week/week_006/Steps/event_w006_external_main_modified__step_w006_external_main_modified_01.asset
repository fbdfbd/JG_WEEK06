  m_Name: event_w006_external_main_modified__step_w006_external_main_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "6\uCC28 - \uC218\uC815"
  _bodyText: "(\uC751\uC811\uC2E4 \uBC16, \uBA40\uB9AC\uC11C \uC628 \uC190\uB2D8\uC758
    \uB9C8\uBD80\uAC00 \uC800\uD0DD \uB9C8\uBD80\uB4E4\uACFC \uB458\uB7EC\uC549\uC544
    \uC774\uC57C\uAE30\uD55C\uB2E4.)\r\n    \uB9C8\uBD801 : \uC774\uBC88\uC5D0 \uC190\uB2D8
    \uBAA8\uC2DC\uACE0 \uC624\uBA74\uC11C \uB4E4\uC5C8\uB294\uB370, \uBC14\uB2E4
    \uAC74\uB108\uC5D4 \uAE38\uBC14\uB2E5\uC774 \uC804\uBD80 \uAE08\uC73C\uB85C \uAE54\uB9B0
    \uB3C4\uC2DC\uAC00 \uC788\uB2E4\uBA70?\r\n    \uB9C8\uBD802 : \uAC70\uAE30 \uC0AC\uB78C\uB4E4\uC740
    \uAD6C\uB984 \uC704\uB97C \uAC78\uC5B4 \uB2E4\uB2CC\uB2E4\uB294 \uB9D0\uB3C4
    \uC548 \uB418\uB294 \uC18C\uB9AC\uB3C4 \uB4E4\uC5C8\uB124.\r\n    \uB124\uBAA8
    : \uAE38\uC774 \uB2E4 \uAE08\uC774\uC57C? \uAD6C\uB984\uC744 \uAC78\uC5B4?\r\n   
    \r\n\r\n\uB9C8\uBD801 : \uC0AC\uC2E4 \uD669\uAE08 \uB3C4\uC2DC\uB294 \uC544\uB2C8\uACE0,
    \uD587\uBE5B\uC774 \uB108\uBB34 \uC608\uC058\uAC8C \uBE44\uCCD0\uC11C \uB3C4\uC2DC
    \uC804\uCCB4\uAC00 \uAE08\uC0C9\uC73C\uB85C \uBCF4\uC774\uB294 \uACF3\uC774\uB798\uC694.\r\n   
    \uB124\uBAA8 : \uC544, \uD587\uBE5B \uB54C\uBB38\uC5D0 \uADF8\uB7F0 \uAC70\uC57C?\r\n   
    \uB9C8\uBD802 : \uB124. \uAC70\uAE30 \uC0AC\uB78C\uB4E4\uC740 \uB9C8\uC74C\uC774
    \uD558\uB3C4 \uB113\uC5B4\uC11C \uAD6C\uB984 \uC704\uB97C \uAC77\uB294 \uAC83\uCC98\uB7FC
    \uAE30\uBD84\uC774 \uC88B\uB2E4\uACE0\uB4E4 \uD558\uC8E0.\r\n    \uB124\uBAA8
    : \uADF8\uB807\uAD6C\uB098... \uC6B0\uB9AC \uC800\uD0DD\uB3C4 \uD587\uBE5B \uBE44\uCE58\uBA74
    \uD669\uAE08 \uC800\uD0DD \uB418\uB294\uB370! \uADF8\uB7FC \uC5EC\uAE30\uB3C4
    \uD669\uAE08 \uB3C4\uC2DC\uB124?"
