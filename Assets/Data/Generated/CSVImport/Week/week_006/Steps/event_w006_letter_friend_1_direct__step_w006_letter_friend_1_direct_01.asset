  m_Name: event_w006_letter_friend_1_direct__step_w006_letter_friend_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 6\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uBE73\uBE73\uD55C \uBD09\uD22C\uB97C \uB4E4\uACE0
    \uC628\uB2E4. \uBD09\uD22C \uAC89\uC5D0\uB294 '\uACC4\uC57D\uC11C'\uB77C\uACE0
    \uD07C\uC9C0\uB9C9\uD558\uAC8C \uC801\uD600 \uC788\uB2E4.)\r\n    \uD558\uB140
    : \uC774\uBC88\uC5D4 \uC544\uC8FC \uC911\uC694\uD55C \uD3B8\uC9C0\uC778 \uBAA8\uC591\uC785\uB2C8\uB2E4.\r\n       
    \r\n\r\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC544\uC8FC
    \uC9C4\uC9C0\uD55C \uC57D\uC18D\uC744 \uD558\uACE0 \uC2F6\uC5B4 \uD569\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : \uACC4\uC57D\uC11C? \uADF8\uAC8C \uBB50\uC57C?\r\n        (\uD558\uB140\uAC00
    \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)\r\n        \uB124\uBAA8 \uC548\uB155.
    \uC774\uC81C \uC6B0\uB9AC \uACE7 \uCCAD\uC18C\uB144\uC774 \uB05D\uB09C\uB300.
    \uC6B0\uB9AC \uC5B4\uB978 \uB418\uBA74 \uACBD\uBE44\uB300\uC7A5 \uC544\uC800\uC528
    \uD5C8\uB77D \uC5C6\uC774\uB3C4 \uB9E4\uC77C \uB9CC\uB098\uB294 \uAC70\uB2E4?
    \uC774 \uD3B8\uC9C0 \uC798 \uC228\uACA8\uB46C. \uC6B0\uB9AC\uC758 \uC5B4\uB978
    \uACC4\uC57D\uC11C\uC57C!\r\n        \uB124\uBAA8 : \uC5B4\uB978 \uB418\uBA74
    \uB9E4\uC77C \uB9CC\uB0A0 \uC218 \uC788\uC5B4?\r\n        \uD558\uB140 : \uB124.
    \uC8FC\uC778\uB2D8\uC774 \uC5B4\uB978\uC774 \uB418\uBA74 \uB204\uAD6C\uC758 \uD5C8\uB77D\uB3C4
    \uD544\uC694 \uC5C6\uC73C\uB2C8\uAE4C\uC694.\r\n        \uB124\uBAA8 : \uC640...
    \uADF8\uB7FC \uC774 \uD3B8\uC9C0 \uBC31\uC791\uB2D8\uC774 \uBABB \uBCF4\uAC8C
    \uC798 \uC228\uACA8\uC57C\uACA0\uB2E4. \uC6B0\uB9AC \uACC4\uC57D\uC11C\uB2C8\uAE4C!"
