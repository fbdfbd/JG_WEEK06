  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_letter_friend_3_direct__step_event_week_006_letter_friend_3_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC720\uD53C \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "letter friend_3 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC544\uC8FC \uC911\uC694\uD55C
      \uC0C1\uC0C1\uB825 \uBE44\uBC95\uC744 \uC804\uC218\uD574 \uC8FC\uACA0\uB2E4\uACE0
      \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBE44\uBC95? \uADF8\uAC8C \uBB50\uC57C?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uCC3D\uBB38\uC5D0 \uB9E4\uB2EC\uB9B0\uB300!"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC815\uB9D0 \uBB34\uC2DC\uBB34\uC2DC\uD55C \uC57D\uC18D\uC774\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD558\uD558, \uAC54\uB77C\uBA74 \uC9C4\uC9DC \uADF8\uB7F4\uC9C0\uB3C4
      \uBAB0\uB77C. \uC5B4\uB978 \uB3FC\uC11C \uAD6C\uB984 \uD0C0\uB294 \uAC70 \uC78A\uC9C0
      \uB9D0\uC544\uC57C\uACA0\uB2E4."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC544\uC8FC \uC911\uC694\uD55C
    \uC0C1\uC0C1\uB825 \uBE44\uBC95\uC744 \uC804\uC218\uD574 \uC8FC\uACA0\uB2E4\uACE0
    \uD569\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
