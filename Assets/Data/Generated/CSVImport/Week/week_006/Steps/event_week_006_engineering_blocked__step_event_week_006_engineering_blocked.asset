--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_engineering_blocked__step_event_week_006_engineering_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC644\uC131 \uC804 \uC791\uB3D9\uC744 \uB9C9\uB294\uB2E4"
  _bodyText: "\uC7A5\uCE58 \uC124\uACC4\uC640 \uAE30\uCD08 \uACF5\uD559 6\uC8FC\uCC28
    Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC791\uC740 \uBAA8\uD615 \uC7A5\uCE58\uAC00 \uC900\uBE44\uB418\uC5B4
      \uC788\uB2E4. \uC190\uC7A1\uC774\uB97C \uB3CC\uB9AC\uBA74 \uB36E\uAC1C\uAC00
      \uC5F4\uB9AC\uACE0, \uC548\uCABD\uC758 \uB098\uBB34 \uC0C8\uAC00 \uD280\uC5B4\uB098\uC624\uB294
      \uB2E8\uC21C\uD55C \uAD6C\uC870\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uBCF4\uB294 \uB370\uC11C \uB05D\uB0B4\uC9C0
      \uC54A\uACE0, \uC9C1\uC811 \uC6C0\uC9C1\uC774\uB294 \uC7A5\uCE58\uB97C \uB9CC\uB4E4\uC5B4
      \uBCFC \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624, \uC774\uAC74 \uC880 \uC7AC\uBC0C\uACA0\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uBC14\uB85C \uD0DC\uC5FD\uBD80\uD130 \uAC10\uC73C\uB824
      \uD558\uC790, \uACBD\uBE44\uB300\uC7A5\uC774 \uC190\uC744 \uB9C9\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC644\uC131 \uC804\uC5D0 \uC791\uB3D9\uC2DC\uD0A4\uC9C0 \uB9C8\uC2ED\uC2DC\uC624.
      \uBD80\uB7EC\uC9D1\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD55C \uBC88\uB9CC \uB3CC\uB824\uBCF4\uB294 \uAC74\uB370."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\u201C\uD55C \uBC88\uB9CC\u201D \uD558\uB2E4\uAC00 \uB9DD\uAC00\uC9C0\uB294
      \uACBD\uC6B0\uAC00 \uC81C\uC77C \uB9CE\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uADF8 \uB9D0\uC740 \uC9C4\uC9DC \uADF8\uB7F4\uB4EF\uD574\uC11C \uB354
      \uC2EB\uB2E4."
  _nemoLine: "(\uC791\uC740 \uBAA8\uD615 \uC7A5\uCE58\uAC00 \uC900\uBE44\uB418\uC5B4
    \uC788\uB2E4. \uC190\uC7A1\uC774\uB97C \uB3CC\uB9AC\uBA74 \uB36E\uAC1C\uAC00
    \uC5F4\uB9AC\uACE0, \uC548\uCABD\uC758 \uB098\uBB34 \uC0C8\uAC00 \uD280\uC5B4\uB098\uC624\uB294
    \uB2E8\uC21C\uD55C \uAD6C\uC870\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
