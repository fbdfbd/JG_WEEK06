  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_riding_direct__step_event_week_006_riding_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBA48\uCD94\uAE30\uC640 \uC804\uD658\uC744 \uD568\uAED8 \uC775\uD78C\uB2E4"
  _bodyText: "\uCCB4\uC804\uACFC \uC2B9\uB9C8 \uAE30\uCD08 6\uC8FC\uCC28 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD6C8\uB828\uC7A5 \uBC14\uAE65 \uC9E7\uC740 \uB458\uB808\uAE38. \uC774\uBC88\uC5D4
      \uB9D0\uACFC \uD568\uAED8 \uCC9C\uCC9C\uD788 \uC6D0\uC744 \uB3CC\uBA70 \uBC29\uD5A5
      \uC804\uD658\uAE4C\uC9C0 \uC5F0\uC2B5\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uBA48\uCD94\uAE30\uC640 \uBC29\uD5A5
      \uBC14\uAFB8\uAE30\uB97C \uAC19\uC774 \uD574 \uBCFC \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C0\uB09C\uBC88\uBCF4\uB2E4 \uB354 \uBC14\uBE60\uC84C\uB124."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4, \uC774\uBC88\uC5D4 \uC9C4\uC9DC \uB0B4\uAC00 \uB3CC\uB9B0 \uAC83
      \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB124. \uC190\uBCF4\uB2E4 \uBAB8\uC774 \uBA3C\uC800 \uC6C0\uC9C1\uC600\uAE30
      \uB54C\uBB38\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB9D0\uB3C4 \uB0B4\uAC00 \uAC81\uBA39\uC740 \uAC78 \uC544\uB294
      \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC798 \uC544\uB294 \uD3B8\uC774\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uAD1C\uD788 \uD5C8\uC138 \uBD80\uB9AC\uBA74 \uC548 \uB418\uACA0\uB2E4."
  _nemoLine: "(\uD6C8\uB828\uC7A5 \uBC14\uAE65 \uC9E7\uC740 \uB458\uB808\uAE38. \uC774\uBC88\uC5D4
    \uB9D0\uACFC \uD568\uAED8 \uCC9C\uCC9C\uD788 \uC6D0\uC744 \uB3CC\uBA70 \uBC29\uD5A5
    \uC804\uD658\uAE4C\uC9C0 \uC5F0\uC2B5\uD55C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
