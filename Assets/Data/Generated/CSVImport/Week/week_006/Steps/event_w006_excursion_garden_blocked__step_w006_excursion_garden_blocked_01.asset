  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_excursion_garden_blocked__step_w006_excursion_garden_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 6\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "6\uCC28 \uBC29\uBB38\r\n        \r\n        (\uD55C\uB0AE\uC758 \uC815\uC6D0.
    \uD587\uBE5B\uC740 \uAC15\uD55C\uB370 \uC774\uC0C1\uD560 \uB9CC\uD07C \uBC8C\uB808\uAC00
    \uC5C6\uB2E4. \uAF43\uC740 \uB9CE\uC740\uB370\uB3C4 \uC719\uC719\uAC70\uB9AC\uB294
    \uC18C\uB9AC\uB3C4, \uC78E\uC744 \uAC09\uC544 \uBA39\uC740 \uD754\uC801\uB3C4
    \uC798 \uBCF4\uC774\uC9C0 \uC54A\uB294\uB2E4.)\r\n        \r\n        \uB124\uBAA8
    : \uC774\uC0C1\uD558\uB124. \uC624\uB298\uC740 \uC870\uC6A9\uD558\uB2E4.\r\n       
    \r\n        (\uB124\uBAA8\uAC00 \uC7A5\uBBF8 \uB364\uBD88 \uCABD\uC73C\uB85C
    \uB2E4\uAC00\uAC00\uB2E4\uAC00, \uB364\uBD88 \uC544\uB798 \uC791\uC740 \uCC9C\uC8FC\uBA38\uB2C8
    \uD558\uB098\uB97C \uBC1C\uACAC\uD55C\uB2E4. \uC798 \uB9D0\uB9B0 \uC78E\uACFC
    \uAECD\uC9C8\uC774 \uB4E4\uC5B4 \uC788\uACE0 \uD5A5\uC774 \uC9C4\uD558\uAC8C
    \uB09C\uB2E4.)\r\n        \r\n        \uB124\uBAA8 : \uC774\uAC74 \uB610 \uBB50\uC57C?
    \uD5A5\uC8FC\uBA38\uB2C8?\r\n        \r\n        (\uC870\uAE08 \uB5A8\uC5B4\uC9C4
    \uC790\uB9AC, \uB610 \uD558\uB098. \uD5C8\uBE0C \uD654\uB2E8 \uC606\uC5D0\uB3C4
    \uD558\uB098. \uB124\uBAA8\uAC00 \uB458\uB7EC\uBCF4\uB2C8 \uC815\uC6D0 \uACF3\uACF3\uC5D0
    \uBE44\uC2B7\uD55C \uC8FC\uBA38\uB2C8\uAC00 \uC228\uC5B4 \uC788\uB2E4.)\r\n       
    \r\n        \uB124\uBAA8 : ...\uC65C \uC774\uB807\uAC8C \uB9CE\uC544?\r\n       
    \r\n\r\n(\uC815\uC6D0\uC0AC\uAC00 \uB180\uB77C\uC11C \uACE7\uC7A5 \uB2E4\uAC00\uC628\uB2E4.)\r\n       
    \r\n        \uC815\uC6D0\uC0AC : \uC8FC\uC778\uB2D8, \uADF8\uAC74 \uC190\uB300\uC2DC\uBA74
    \uC548 \uB429\uB2C8\uB2E4~\r\n        \r\n        \uB124\uBAA8 : \uC65C\uC694?\r\n       
    \r\n        \uC815\uC6D0\uC0AC : \uBC8C\uB808 \uB9C9\uB294 \uD5A5\uB8CC\uC785\uB2C8\uB2E4~
    \uC190\uC5D0 \uC9C4\uD558\uAC8C \uBC30\uC5B4\uC694~\r\n        \r\n        \uB124\uBAA8
    : \uC815\uC6D0\uC5D0 \uC65C \uC774\uB807\uAC8C \uB9CE\uC774 \uC228\uACA8 \uB1A8\uC5B4?\r\n       
    \r\n        \uC815\uC6D0\uC0AC : \uC5EC\uB984\uC774\uB77C \uC6D0\uB798 \uC880
    \uC501\uB2C8\uB2E4~\r\n        \r\n        \uB124\uBAA8 : \uADFC\uB370 \uB108\uBB34
    \uB9CE\uC796\uC544.\r\n        \r\n        \uC815\uC6D0\uC0AC : \uC624\uB298\uC740
    \uC720\uB09C\uD788 \uB354 \uB208\uC5D0 \uB744\uC168\uB098 \uBD05\uB2C8\uB2E4~\r\n       
    \r\n        \uB124\uBAA8 : \uC815\uC6D0\uC774 \uAC11\uC790\uAE30 \uB108\uBB34
    \uAE68\uB057\uD55C \uAC83\uB3C4 \uC880 \uC774\uC0C1\uD574.\r\n        \r\n       
    \uC815\uC6D0\uC0AC : \uAE68\uB057\uD558\uBA74 \uC88B\uC740 \uAC70\uC9C0\uC694~\r\n       
    \r\n        \uB124\uBAA8 : \uADF8\uAC74 \uB9DE\uB294\uB370\u2026"
  _dialogueLines: []
