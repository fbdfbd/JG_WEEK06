  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_letter_friend_3_modified__step_w006_letter_friend_3_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 6\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uC544\uC8FC \uD654\uB824\uD55C \uB099\uC11C\uAC00
    \uAC00\uB4DD\uD55C \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C\uC5D4
    '\uB124\uBAA8\uC5D0\uAC8C \uC8FC\uB294 \uB9C8\uBC95 \uB3C4\uC548'\uC774\uB77C\uACE0
    \uC801\uD600 \uC788\uB2E4.)\n    \uD558\uB140 : \uC774\uBC88\uC5D4 \uC544\uC8FC
    \uC791\uBCC4 \uC778\uC0AC\uAC00 \uB2F4\uAE34 \uC911\uC694\uD55C \uD3B8\uC9C0\uC778
    \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.\n        \n\n\uD558\uB140 : \uC8FC\uC778\uB2D8,
    \uCE5C\uAD6C\uBD84\uC774 \uC5B4\uB514\uC5D0 \uC788\uB4E0 \uC8FC\uC778\uB2D8\uC774
    \uC138\uC0C1\uC744 \uC990\uAC81\uACE0 \uC2E0\uAE30\uD558\uAC8C \uBC14\uB77C\uBCF4\uAE38
    \uBC14\uB780\uB300\uC694.\n        \uB124\uBAA8 : \uC5B4\uB5BB\uAC8C \uBC14\uB77C\uBCF4\uB294\uB370?\n       
    \uD558\uB140 : \uD558\uB298\uC758 \uAD6C\uB984 \uD558\uB098\uB3C4 \uB9DB\uC788\uB294
    \uC74C\uC2DD\uCC98\uB7FC, \uC7AC\uBC0C\uB294 \uC7A5\uB09C\uAC10\uCC98\uB7FC \uC0DD\uAC01\uD558\uBA70
    \uC6C3\uC5C8\uC73C\uBA74 \uC88B\uACA0\uB2E4\uACE0 \uD569\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uAC54\uB2E4\uC6B4 \uC0DD\uAC01\uC774\uB124.\n        \uD558\uB140
    : \uB098\uC911\uC5D0 \uC5B4\uB978\uC774 \uB418\uC5B4 \uB2E4\uC2DC \uB9CC\uB098\uBA74,
    \uB204\uAC00 \uB354 \uC7AC\uBC0C\uB294 \uAC78 \uB9CE\uC774 \uCC3E\uC558\uB294\uC9C0
    \uB0B4\uAE30\uD558\uC790\uACE0 \uD558\uB124\uC694.\n        \uB124\uBAA8 : \uC88B\uC544.
    \uC774\uBC88\uC5D4 \uB0B4\uAC00 \uAF2D \uC774\uAE38 \uAC70\uC57C!"
