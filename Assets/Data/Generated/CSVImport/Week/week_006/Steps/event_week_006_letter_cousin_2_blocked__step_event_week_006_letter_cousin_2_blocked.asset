  _titleOverride: "\uB9AC\uC548 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "letter cousin_2 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uB294 \uD3B8\uC9C0\uB97C \uC77D\uB2E4\uAC00 \uCF54 \uB05D\uC744
      \uCC21\uAE0B\uAC70\uB9AC\uB354\uB2C8, \uC774\uB0B4 \uB9C8\uC74C\uC744 \uB2E4\uC7A1\uACE0
      \uD3B8\uC9C0\uD568 \uBC11\uBC14\uB2E5\uC5D0 \uC228\uAE34\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uCE74\uD3AB \uBB34\uB2AC\uB97C \uB530\uB77C \uAC78\uC73C\uBA70
      \uC0AC\uCD0C 2\uB791\uC740 \uC774\uC81C \uBABB \uB178\uB294 \uAC74\uAC00 \uD558\uACE0
      \uC2DC\uBB34\uB8E9\uD574\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\u2026\u2026\uB3C4\uB828\uB2D8\uC774 \uC774 \uD3B8\uC9C0\uB97C \uC77D\uC73C\uBA74
      \uB9C8\uC74C\uC774 \uB108\uBB34 \uC57D\uD574\uC838\uC11C \uACF5\uBD80\uB97C
      \uBABB \uD558\uC2E4 \uAC70\uC57C."
  _nemoLine: "(\uD558\uB140\uB294 \uD3B8\uC9C0\uB97C \uC77D\uB2E4\uAC00 \uCF54 \uB05D\uC744
    \uCC21\uAE0B\uAC70\uB9AC\uB354\uB2C8, \uC774\uB0B4 \uB9C8\uC74C\uC744 \uB2E4\uC7A1\uACE0
    \uD3B8\uC9C0\uD568 \uBC11\uBC14\uB2E5\uC5D0 \uC228\uAE34\uB2E4.)"
