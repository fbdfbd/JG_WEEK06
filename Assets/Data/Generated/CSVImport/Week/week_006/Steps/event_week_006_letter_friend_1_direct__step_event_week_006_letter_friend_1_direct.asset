  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_letter_friend_1_direct__step_event_week_006_letter_friend_1_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9C9\uC2A4 \uD3B8\uC9C0 \uD5C8\uAC00"
  _bodyText: "letter friend_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC544\uC8FC \uC9C4\uC9C0\uD55C
      \uC57D\uC18D\uC744 \uD558\uACE0 \uC2F6\uC5B4 \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uACC4\uC57D\uC11C? \uADF8\uAC8C \uBB50\uC57C?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4\uB978 \uB418\uBA74 \uB9E4\uC77C \uB9CC\uB0A0 \uC218 \uC788\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC8FC\uC778\uB2D8\uC774 \uC5B4\uB978\uC774 \uB418\uBA74 \uB204\uAD6C\uC758
      \uD5C8\uB77D\uB3C4 \uD544\uC694 \uC5C6\uC73C\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC640... \uADF8\uB7FC \uC774 \uD3B8\uC9C0 \uBC31\uC791\uB2D8\uC774 \uBABB
      \uBCF4\uAC8C \uC798 \uC228\uACA8\uC57C\uACA0\uB2E4. \uC6B0\uB9AC \uACC4\uC57D\uC11C\uB2C8\uAE4C!"
  _nemoLine: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC544\uC8FC \uC9C4\uC9C0\uD55C
    \uC57D\uC18D\uC744 \uD558\uACE0 \uC2F6\uC5B4 \uD569\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
