  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_external_w006_modified__step_event_week_006_external_w006_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC2E0\uBE44\uD55C \uB300\uB959 \uC18C\uBB38 \uC218\uC815"
  _bodyText: "external w006 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: bb92d18cb19ba9944ac71077eb8aa4c5, type: 2}
    _text: "\uC0AC\uC2E4 \uD669\uAE08 \uB3C4\uC2DC\uB294 \uC544\uB2C8\uACE0, \uD587\uBE5B\uC774
      \uB108\uBB34 \uC608\uC058\uAC8C \uBE44\uCCD0\uC11C \uB3C4\uC2DC \uC804\uCCB4\uAC00
      \uAE08\uC0C9\uC73C\uB85C \uBCF4\uC774\uB294 \uACF3\uC774\uB798\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544, \uD587\uBE5B \uB54C\uBB38\uC5D0 \uADF8\uB7F0 \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: bb92d18cb19ba9944ac71077eb8aa4c5, type: 2}
    _text: "\uB124. \uAC70\uAE30 \uC0AC\uB78C\uB4E4\uC740 \uB9C8\uC74C\uC774 \uD558\uB3C4
      \uB113\uC5B4\uC11C \uAD6C\uB984 \uC704\uB97C \uAC77\uB294 \uAC83\uCC98\uB7FC
      \uAE30\uBD84\uC774 \uC88B\uB2E4\uACE0\uB4E4 \uD558\uC8E0."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB807\uAD6C\uB098... \uC6B0\uB9AC \uC800\uD0DD\uB3C4 \uD587\uBE5B
      \uBE44\uCE58\uBA74 \uD669\uAE08 \uC800\uD0DD \uB418\uB294\uB370! \uADF8\uB7FC
      \uC5EC\uAE30\uB3C4 \uD669\uAE08 \uB3C4\uC2DC\uB124?"
  _nemoLine: "\uC0AC\uC2E4 \uD669\uAE08 \uB3C4\uC2DC\uB294 \uC544\uB2C8\uACE0, \uD587\uBE5B\uC774
    \uB108\uBB34 \uC608\uC058\uAC8C \uBE44\uCCD0\uC11C \uB3C4\uC2DC \uC804\uCCB4\uAC00
    \uAE08\uC0C9\uC73C\uB85C \uBCF4\uC774\uB294 \uACF3\uC774\uB798\uC694."
  _useCustomVisualState: 0
  _visualState: 0
