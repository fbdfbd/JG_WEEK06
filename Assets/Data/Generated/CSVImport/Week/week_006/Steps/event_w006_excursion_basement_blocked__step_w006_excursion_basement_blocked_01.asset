  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_excursion_basement_blocked__step_w006_excursion_basement_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 6\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uC800\uB141 \uBB34\uB835. \uC9C0\uD558\uC2E4 \uC548\uCABD \uC120\uBC18\uC5D4
    \uC640\uC778\uBCD1\uB4E4\uC774 \uAC00\uC9C0\uB7F0\uD788 \uB204\uC6CC \uC788\uB2E4.
    \uBCD1\uBAA9\uB9C8\uB2E4 \uC5F0\uB3C4\uD45C\uC640 \uC791\uC740 \uBA54\uBAA8\uAC00
    \uB2EC\uB824 \uC788\uB2E4. \uB124\uBAA8\uB294 \uADF8\uC911 \uAC00\uC7A5 \uC55E\uC904\uC5D0
    \uB193\uC778 \uBCD1 \uD558\uB098\uB97C \uC720\uC2EC\uD788 \uBCF8\uB2E4.)\n       
    \n        \uB124\uBAA8 : \uC774\uAC74 \uC65C \uB2E4 \uB215\uD600 \uB194?\n       
    \n        \uB124\uBAA8 : \uC138\uC6CC \uB450\uBA74 \uB354 \uBCF4\uAE30 \uD3B8\uD560
    \uD150\uB370.\n        \n        (\uBCD1 \uC606 \uC791\uC740 \uD45C\uC5D4 \uC789\uD06C\uB85C
    \uC9E7\uC740 \uBB38\uC7A5\uC774 \uC801\uD600 \uC788\uB2E4. \u2018\uAC1C\uBD09
    \uC801\uAE30 \uC784\uBC15\u2019 \uAC19\uC740 \uB531\uB531\uD55C \uAE00 \uC606\uC5D0,
    \uB204\uAD70\uAC00 \uB354 \uC791\uAC8C \uB367\uC4F4 \uBA54\uBAA8\uAC00 \uBCF4\uC778\uB2E4.)\n       
    \n        \uB124\uBAA8 : ...\uC5BC\uB9C8 \uC548 \uB0A8\uC558\uB2E4?\n       
    \n\n(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uBC14\uB85C \uBA54\uBAA8\uD45C\uB97C \uB4A4\uC9D1\uC5B4
    \uB193\uB294\uB2E4.)\n        \n        \uCC3D\uACE0\uC9C0\uAE30 : \uC8FC\uC778\uB2D8,
    \uC774\uAC74 \uBCF4\uC2DC\uBA74 \uC548 \uB429\uB2C8\uB2E4.\n        \n       
    \uB124\uBAA8 : \uC65C\uC694?\n        \n        \uCC3D\uACE0\uC9C0\uAE30 : \uBC31\uC791\uB2D8
    \uBCF4\uAD00\uD488\uC785\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : \uADF8\uAC74
    \uC544\uB294\uB370, \uBC29\uAE08 \uBB50\uB77C\uACE0 \uC801\uD600 \uC788\uC5C8\uC5B4.\n       
    \n        \uCC3D\uACE0\uC9C0\uAE30 : \uC640\uC778 \uAD00\uB9AC\uC6A9 \uBA54\uBAA8\uC785\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uC5BC\uB9C8 \uC548 \uB0A8\uC558\uB2E4\uACE0 \uD588\uC796\uC544.\n       
    \n        \uCC3D\uACE0\uC9C0\uAE30 : \uB9C8\uC2E4 \uB54C\uAC00 \uB2E4\uAC00\uC654\uB2E4\uB294
    \uB73B\uC785\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : \uC624. \uADF8\uB7FC
    \uC774\uC81C \uACE7 \uC5C6\uC5B4\uC9C0\uB294 \uAC70\uB124.\n        \n       
    \uCC3D\uACE0\uC9C0\uAE30 : \uC608. \uADF8\uB7F0 \uC148\uC774\uC9C0\uC694.\n       
    \n        \uB124\uBAA8 : \uC774\uC0C1\uD558\uB2E4. \uB2E4\uB4E4 \uC624\uB798
    \uB450\uB824\uACE0 \uC544\uB07C\uB294 \uC904 \uC54C\uC558\uB294\uB370."
  _dialogueLines: []
