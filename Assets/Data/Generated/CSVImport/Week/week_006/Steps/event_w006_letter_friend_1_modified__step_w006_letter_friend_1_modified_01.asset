  m_Name: event_w006_letter_friend_1_modified__step_w006_letter_friend_1_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 6\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uBE73\uBE73\uD55C \uBD09\uD22C\uB97C \uB4E4\uACE0
    \uC628\uB2E4. \uBD09\uD22C \uAC89\uC5D0\uB294 '\uACC4\uC57D\uC11C'\uB77C\uACE0
    \uD07C\uC9C0\uB9C9\uD558\uAC8C \uC801\uD600 \uC788\uB2E4.)\r\n    \uD558\uB140
    : \uC774\uBC88\uC5D4 \uC544\uC8FC \uC911\uC694\uD55C \uD3B8\uC9C0\uC778 \uBAA8\uC591\uC785\uB2C8\uB2E4.\r\n       
    \r\n\r\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C
    \uCE5C\uAD6C\uBD84\uC774 \uC55E\uC73C\uB85C\uC758 \uC57D\uC18D\uC744 \uC801\uC5B4
    \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\r\n        \uB124\uBAA8 : \uBB34\uC2A8 \uC57D\uC18D?\r\n       
    \uD558\uB140 : \uC2DC\uAC04\uC774 \uC544\uC8FC \uB9CE\uC774 \uD758\uB7EC\uC11C
    \uC8FC\uC778\uB2D8\uC774 \uC5B4\uB978\uC774 \uB418\uC5B4\uB3C4, \uC601\uC6D0\uD788
    \uAC00\uC7A5 \uCE5C\uD55C \uCE5C\uAD6C\uB85C \uB0A8\uACE0 \uC2F6\uB300\uC694.\r\n       
    \uB124\uBAA8 : \uC9C4\uC9DC?\r\n        \uD558\uB140 : \uB124. \uADF8\uB54C\uAC00
    \uB418\uBA74 \uC544\uBB34 \uAC71\uC815 \uC5C6\uC774 \uD558\uB8E8 \uC885\uC77C
    \uAC19\uC774 \uB180\uC790\uACE0 \uD569\uB2C8\uB2E4.\r\n        \uB124\uBAA8 :
    \uC6B0\uC640. \uADF8\uB7FC \uB098\uB3C4 \uAC54\uB791 \uACC4\uC18D \uB180 \uC218
    \uC788\uB294 \uAC70\uB124?\r\n        \uD558\uB140 : \uB9CE\uC774 \uAE30\uC058\uC2E0\uAC00
    \uBD05\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.\r\n        \uB124\uBAA8 : \uC751. \uAC54\uB294
    \uC9C4\uC9DC \uC88B\uC740 \uCE5C\uAD6C\uC57C."
