  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_visitor_cousin_1_direct__step_event_week_006_visitor_cousin_1_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE74\uC774\uC548 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor cousin_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC0BC\uCD0C\uC758 \uBAA8\uC790\uB97C \uC790\uAE30
      \uBA38\uB9AC\uC5D0 \uD479 \uB20C\uB7EC\uC4F4\uB2E4. \uBAA8\uC790\uAC00 \uB108\uBB34
      \uCEE4\uC11C \uB208\uC774 \uAC00\uB824\uC9C4\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640, \uC55E\uC774 \uD558\uB098\uB3C4 \uC548 \uBCF4\uC5EC\uC694!
      \uC0BC\uCD0C\uC740 \uC774\uB7F0 \uAC78 \uC4F0\uACE0 \uC138\uC0C1\uC744 \uB2E4
      \uB3CC\uC544\uB2E4\uB2CC \uAC70\uC608\uC694?"
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uADF8\uB7FC! \uB208\uC744 \uAC00\uB824\uC57C \uB9C8\uC74C\uC758 \uB208\uC774
      \uB5A0\uC9C0\uB294 \uBC95\uC774\uAC70\uB4E0. \uC5B4\uB5A0\uB0D0, \uBC31\uC791\uB2D8
      \uC11C\uC7AC\uAC00 \uC544\uB2C8\uB77C \uB113\uC740 \uBC8C\uD310\uC5D0 \uC11C
      \uC788\uB294 \uAE30\uBD84\uC774 \uB4E4\uC9C0 \uC54A\uC544?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uBAA8\uC790 \uC18D\uC5D0\uC11C \uC6C5\uC5BC\uAC70\uB9AC\uBA70) \uB124...
      \uC2E0\uAE30\uD574\uC694. \uBC31\uC791\uB2D8 \uD5A5\uC218 \uB0C4\uC0C8 \uB9D0\uACE0
      \uC774\uB7F0 \uD22C\uBC15\uD55C \uB0C4\uC0C8\uB3C4 \uCC38 \uC88B\uB124\uC694.
      \uC81C \uC138\uACC4\uAC00 \uB113\uC5B4\uC9C0\uB294 \uAE30\uBD84\uC774\uC5D0\uC694."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC0BC\uCD0C\uC758 \uBAA8\uC790\uB97C \uC790\uAE30
    \uBA38\uB9AC\uC5D0 \uD479 \uB20C\uB7EC\uC4F4\uB2E4. \uBAA8\uC790\uAC00 \uB108\uBB34
    \uCEE4\uC11C \uB208\uC774 \uAC00\uB824\uC9C4\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
