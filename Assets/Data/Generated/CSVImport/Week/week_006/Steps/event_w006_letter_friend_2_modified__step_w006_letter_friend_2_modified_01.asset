  m_Name: event_w006_letter_friend_2_modified__step_w006_letter_friend_2_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 \uD3B8\uC9C0 6\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uB2E8\uC815\uD55C \uBD09\uD22C\uB97C \uB4E4\uACE0
    \uC628\uB2E4. \uBD09\uD22C \uAC89\uBA74\uC5D0\uB294 '\uB124\uBAA8\uB9CC \uC77D\uC744
    \uAC83'\uC774\uB77C\uACE0 \uD07C\uC9C1\uD558\uAC8C \uC801\uD600 \uC788\uB2E4.)\n   
    \uD558\uB140 : \uC774\uBC88 \uD3B8\uC9C0\uB294 \uC720\uB3C5 \uC2E0\uACBD\uC744
    \uB9CE\uC774 \uC4F4 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.\n        \n\n\uD558\uB140
    : \uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uCE5C\uAD6C\uBD84\uC774
    \uC55E\uC73C\uB85C\uC758 \uAFC8\uC744 \uC801\uC5B4 \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uBB34\uC2A8 \uAFC8\uC778\uB370?\n        \uD558\uB140 : \uB098\uC911\uC5D0
    \uC5B4\uB978\uC774 \uB418\uBA74 \uC8FC\uC778\uB2D8\uC744 \uC544\uC8FC \uD3B8\uC548\uD558\uACE0
    \uBA4B\uC9C4 \uACF3\uC73C\uB85C \uCD08\uB300\uD558\uACE0 \uC2F6\uB300\uC694.\n       
    \uB124\uBAA8 : \uBA4B\uC9C4 \uACF3?\n        \uD558\uB140 : \uB124. \uAC70\uAE30\uC120
    \uC8FC\uC778\uB2D8\uC774 \uD558\uACE0 \uC2F6\uC740 \uAC78 \uB9C8\uC74C\uAECF
    \uD560 \uC218 \uC788\uAC8C \uB3C4\uC640\uC8FC\uACA0\uB2E4\uACE0 \uD569\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uC6B0\uC640. \uAC54\uB294 \uACF5\uBD80\uB3C4 \uC798\uD558\uB2C8\uAE4C
    \uC9C4\uC9DC \uD560 \uC218 \uC788\uC744 \uAC70\uC57C.\n        \uD558\uB140 :
    \uC8FC\uC778\uB2D8\uC744 \uD5A5\uD55C \uB9C8\uC74C\uC774 \uC544\uC8FC \uC9C4\uC2EC\uC778
    \uAC83 \uAC19\uB124\uC694.\n        \uB124\uBAA8 : \uC751. \uAC54\uAC00 \uB9CC\uB4E0
    \uC11C\uC7AC\uB294 \uC138\uC0C1\uC5D0\uC11C \uC81C\uC77C \uC88B\uC744 \uAC83
    \uAC19\uC544."
