--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_excursion_garden_direct__step_event_week_006_excursion_garden_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: garden Direct
  _bodyText: "excursion garden Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC815\uC6D0\uC0AC\uAC00 \uC7A0\uAE50 \uB9DD\uC124\uC774\uB2E4\uAC00,
      \uACB0\uAD6D \uCC9C\uC8FC\uBA38\uB2C8 \uD558\uB098\uB97C \uB4E4\uC5B4 \uBCF4\uC778\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uCC9C\uC5F0 \uD5A5\uB8CC \uC8FC\uBA38\uB2C8\uC785\uB2C8\uB2E4~ \uBC8C\uB808\uAC00
      \uC2EB\uC5B4\uD558\uB294 \uB0C4\uC0C8\uB97C \uBAA8\uC544 \uB454 \uAC70\uC9C0\uC694~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB798\uC11C \uC624\uB298 \uBC8C\uB808\uAC00 \uC5C6\uB294 \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uB124~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB204\uAC00 \uC774\uB807\uAC8C \uB9CE\uC774 \uB450\uB798?"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\u2026\u2026\uBC31\uC791\uB2D8\uC774\uC2ED\uB2C8\uB2E4~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610?"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uAED8\uC11C \uBC8C\uB808 \uC9C8\uC0C9\uD558\uC2E0\uB2E4\uACE0,
      \uC815\uC6D0 \uC5B4\uB514\uB97C \uAC00\uC2DC\uB4E0 \uB35C \uBCF4\uC774\uAC8C
      \uD574 \uB450\uB77C \uD558\uC168\uC9C0\uC694~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB798\uC11C \uC7A5\uBBF8 \uC606\uC5D0\uB3C4, \uBCA4\uCE58 \uBC11\uC5D0\uB3C4,
      \uB2E4 \uC788\uB294 \uAC70\uAD6C\uB098."
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC608~ \uC8FC\uC778\uB2D8 \uC190 \uB2FF\uB294 \uC790\uB9AC\uC5D4 \uD2B9\uD788\uC694~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uC880 \uBB34\uC11C\uC6B8 \uB9CC\uD07C \uAF3C\uAF3C\uD55C\uB370."
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\u2026\uC2EB\uC73C\uC2ED\uB2C8\uAE4C~?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC2EB\uC9C4 \uC54A\uC544. \uADFC\uB370 \uB0B4\uAC00 \uBC8C\uB808 \uC2EB\uC5B4\uD558\uB294
      \uAC74 \uC815\uB9D0 \uC815\uD655\uD788 \uC544\uB124."
  _nemoLine: "(\uC815\uC6D0\uC0AC\uAC00 \uC7A0\uAE50 \uB9DD\uC124\uC774\uB2E4\uAC00,
    \uACB0\uAD6D \uCC9C\uC8FC\uBA38\uB2C8 \uD558\uB098\uB97C \uB4E4\uC5B4 \uBCF4\uC778\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
