--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_engineering_direct__step_event_week_006_engineering_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C1\uC811 \uC6C0\uC9C1\uC774\uB294 \uC7A5\uCE58\uB97C \uB9CC\uB4E0\uB2E4"
  _bodyText: "\uC7A5\uCE58 \uC124\uACC4\uC640 \uAE30\uCD08 \uACF5\uD559 6\uC8FC\uCC28
    Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC791\uC740 \uBAA8\uD615 \uC7A5\uCE58\uAC00 \uC900\uBE44\uB418\uC5B4
      \uC788\uB2E4. \uC190\uC7A1\uC774\uB97C \uB3CC\uB9AC\uBA74 \uB36E\uAC1C\uAC00
      \uC5F4\uB9AC\uACE0, \uC548\uCABD\uC758 \uB098\uBB34 \uC0C8\uAC00 \uD280\uC5B4\uB098\uC624\uB294
      \uB2E8\uC21C\uD55C \uAD6C\uC870\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uBCF4\uB294 \uB370\uC11C \uB05D\uB0B4\uC9C0
      \uC54A\uACE0, \uC9C1\uC811 \uC6C0\uC9C1\uC774\uB294 \uC7A5\uCE58\uB97C \uB9CC\uB4E4\uC5B4
      \uBCFC \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624, \uC774\uAC74 \uC880 \uC7AC\uBC0C\uACA0\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB410\uB2E4. \uB3CC\uB824\uB3C4 \uB3FC?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124, \uC774\uC81C \uD574 \uBCF4\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC791\uC740 \uB098\uBB34 \uC0C8\uAC00 \uD280\uC5B4\uB098\uC628\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC640."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB0B4\uAC00 \uB9CC\uB4E0 \uAC8C \uC9C4\uC9DC \uC6C0\uC9C1\uC600\uC5B4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uADF8\uB7EC\uB2C8 \uC124\uACC4\uAC00 \uC7AC\uBC0C\uB294 \uAC70\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uC778\uC815. \uD55C \uBC88 \uB354 \uB9CC\uB4E4\uC5B4 \uBCF4\uACE0
      \uC2F6\uB2E4."
  _nemoLine: "(\uC791\uC740 \uBAA8\uD615 \uC7A5\uCE58\uAC00 \uC900\uBE44\uB418\uC5B4
    \uC788\uB2E4. \uC190\uC7A1\uC774\uB97C \uB3CC\uB9AC\uBA74 \uB36E\uAC1C\uAC00
    \uC5F4\uB9AC\uACE0, \uC548\uCABD\uC758 \uB098\uBB34 \uC0C8\uAC00 \uD280\uC5B4\uB098\uC624\uB294
    \uB2E8\uC21C\uD55C \uAD6C\uC870\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
