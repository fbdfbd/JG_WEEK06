--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_riding_modified__step_event_week_006_riding_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9D0\uC5D0\uAC8C \uBA3C\uC800 \uBC29\uD5A5\uC744 \uC54C\uB824
    \uC900\uB2E4"
  _bodyText: "\uCCB4\uC804\uACFC \uC2B9\uB9C8 \uAE30\uCD08 6\uC8FC\uCC28 Modified
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD6C8\uB828\uC7A5 \uBC14\uAE65 \uC9E7\uC740 \uB458\uB808\uAE38. \uC774\uBC88\uC5D4
      \uB9D0\uACFC \uD568\uAED8 \uCC9C\uCC9C\uD788 \uC6D0\uC744 \uB3CC\uBA70 \uBC29\uD5A5
      \uC804\uD658\uAE4C\uC9C0 \uC5F0\uC2B5\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uBA48\uCD94\uAE30\uC640 \uBC29\uD5A5
      \uBC14\uAFB8\uAE30\uB97C \uAC19\uC774 \uD574 \uBCFC \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C0\uB09C\uBC88\uBCF4\uB2E4 \uB354 \uBC14\uBE60\uC84C\uB124."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uB9D0 \uADC0 \uC606\uC73C\uB85C \uC190\uC744 \uB0B4\uBC00\uC5B4
      \uC2DC\uC120\uC744 \uC720\uB3C4\uD574 \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC5B5\uC9C0\uB85C \uB3CC\uB9B0\uB2E4\uAE30\uBCF4\uB2E4, \u201C\uC774\uCABD\uC73C\uB85C
      \uAC00\uC790\u201D \uD558\uACE0 \uBA3C\uC800 \uC54C\uB824\uC900\uB2E4\uACE0
      \uC0DD\uAC01\uD574 \uBCF4\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9D0\uC5D0\uB3C4 \uC124\uBA85\uC774 \uD544\uC694\uD558\uB124."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC0AC\uB78C\uBCF4\uB2E4 \uB9D0\uC774 \uB354 \uC194\uC9C1\uD560
      \uB54C\uB3C4 \uC788\uC73C\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uC880 \uD3B8\uD558\uACA0\uB2E4. \uC2EB\uC73C\uBA74 \uBC14\uB85C
      \uD2F0 \uB098\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB9DE\uC544\uC694."
  _nemoLine: "(\uD6C8\uB828\uC7A5 \uBC14\uAE65 \uC9E7\uC740 \uB458\uB808\uAE38. \uC774\uBC88\uC5D4
    \uB9D0\uACFC \uD568\uAED8 \uCC9C\uCC9C\uD788 \uC6D0\uC744 \uB3CC\uBA70 \uBC29\uD5A5
    \uC804\uD658\uAE4C\uC9C0 \uC5F0\uC2B5\uD55C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
