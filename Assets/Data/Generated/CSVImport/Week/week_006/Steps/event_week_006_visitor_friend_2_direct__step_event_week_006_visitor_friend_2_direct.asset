  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_visitor_friend_2_direct__step_event_week_006_visitor_friend_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC00\uB9AC\uC544 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor friend_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBC00\uB9AC\uC544\uAC00 \uC885\uC774 \uADC0\uD241\uC774\uC5D0 \uC815\uAC08\uD55C
      \uAE00\uC528\uB85C '\uC6B0\uC815'\uC774\uB77C\uB294 \uB2E8\uC5B4\uB97C \uC801\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC640, \uC9C4\uC9DC \uC798 \uC4F4\uB2E4! \uBC31\uC791\uB2D8 \uAE00\uC528\uCC98\uB7FC
      \uBA4B\uC838."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "(\uC218\uC90D\uAC8C \uC6C3\uC73C\uBA70) \uACE0\uB9C8\uC6CC, \uB124\uBAA8\uC57C.
      \uC774 \uD39C\uC73C\uB85C \uC4F0\uB2C8\uAE4C \uC660\uC9C0 \uB098\uB3C4 \uBA4B\uC9C4
      \uC0AC\uB78C\uC774 \uB41C \uAC83 \uAC19\uC544. \uBC31\uC791\uB2D8 \uC11C\uC7AC\uB294
      \uCC38 \uB9C8\uBC95 \uAC19\uC740 \uACF3\uC774\uB124."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uBC00\uB9AC\uC544\uC758 \uC5B4\uAE68\uB97C \uAC10\uC2F8\uBA70) \uADF8\uCE58?
      \uB098\uC911\uC5D0 \uB108 \uC62C \uB54C\uB9C8\uB2E4 \uC774 \uD39C \uC4F0\uAC8C
      \uD574\uC904\uAC8C. \uBC31\uC791\uB2D8\uD55C\uD14C \uC6B0\uB9AC \uB458\uB9CC\uC758
      '\uAE30\uB85D\uC7A5' \uD558\uB098 \uB9CC\uB4E4\uC5B4\uB2EC\uB77C\uACE0 \uC870\uB97C
      \uAC70\uC57C!"
  _nemoLine: "(\uBC00\uB9AC\uC544\uAC00 \uC885\uC774 \uADC0\uD241\uC774\uC5D0 \uC815\uAC08\uD55C
    \uAE00\uC528\uB85C '\uC6B0\uC815'\uC774\uB77C\uB294 \uB2E8\uC5B4\uB97C \uC801\uB294\uB2E4.)"
