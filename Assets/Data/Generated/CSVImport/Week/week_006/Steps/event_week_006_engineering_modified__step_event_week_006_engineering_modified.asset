--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_engineering_modified__step_event_week_006_engineering_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC6C0\uC9C1\uC784 \uC21C\uC11C\uBD80\uD130 \uC9E7\uAC8C \uADF8\uB9B0\uB2E4"
  _bodyText: "\uC7A5\uCE58 \uC124\uACC4\uC640 \uAE30\uCD08 \uACF5\uD559 6\uC8FC\uCC28
    Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC791\uC740 \uBAA8\uD615 \uC7A5\uCE58\uAC00 \uC900\uBE44\uB418\uC5B4
      \uC788\uB2E4. \uC190\uC7A1\uC774\uB97C \uB3CC\uB9AC\uBA74 \uB36E\uAC1C\uAC00
      \uC5F4\uB9AC\uACE0, \uC548\uCABD\uC758 \uB098\uBB34 \uC0C8\uAC00 \uD280\uC5B4\uB098\uC624\uB294
      \uB2E8\uC21C\uD55C \uAD6C\uC870\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uBCF4\uB294 \uB370\uC11C \uB05D\uB0B4\uC9C0
      \uC54A\uACE0, \uC9C1\uC811 \uC6C0\uC9C1\uC774\uB294 \uC7A5\uCE58\uB97C \uB9CC\uB4E4\uC5B4
      \uBCFC \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624, \uC774\uAC74 \uC880 \uC7AC\uBC0C\uACA0\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uBE48 \uC885\uC774\uB97C \uD568\uAED8 \uB0B4\uBBFC\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB9CC\uB4E4\uAE30 \uC804\uC5D0, \uBB50\uAC00 \uBA3C\uC800 \uC6C0\uC9C1\uC5EC\uC57C
      \uD558\uB294\uC9C0\uB9CC \uC9E7\uAC8C \uADF8\uB824\uBCFC\uAE4C\uC694?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB3C4\uBA74?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uAC70\uCC3D\uD55C \uAC74 \uC544\uB2C8\uACE0, \uC21C\uC11C\uB9CC\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544. \uADF8\uB7FC \uB35C \uBD80\uB2F4\uB41C\uB2E4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC190\uBCF4\uB2E4 \uC0DD\uAC01\uC774 \uBC18 \uAC78\uC74C \uC55E\uC5D0\uB9CC
      \uC788\uC73C\uBA74 \uB3FC\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uAE30\uC5B5\uD574 \uB458 \uB9CC\uD558\uB124."
  _nemoLine: "(\uC791\uC740 \uBAA8\uD615 \uC7A5\uCE58\uAC00 \uC900\uBE44\uB418\uC5B4
    \uC788\uB2E4. \uC190\uC7A1\uC774\uB97C \uB3CC\uB9AC\uBA74 \uB36E\uAC1C\uAC00
    \uC5F4\uB9AC\uACE0, \uC548\uCABD\uC758 \uB098\uBB34 \uC0C8\uAC00 \uD280\uC5B4\uB098\uC624\uB294
    \uB2E8\uC21C\uD55C \uAD6C\uC870\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
