  _titleOverride: "\uAE30\uACC4 \uC218\uC5C5\uC744 \uD37C\uC990\uCC98\uB7FC \uD47C\uB2E4"
  _bodyText: "\uAE30\uACC4 \uC218\uC5C5\uC744 \uD37C\uC990\uCC98\uB7FC \uD47C\uB2E4
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBCF5\uC7A1\uD55C \uC6D0\uB9AC \uB300\uC2E0 \uAC04\uB2E8\uD55C \uC608\uC2DC\uB97C
      \uC368\uC11C \uAE30\uACC4 \uAD50\uC7AC\uB97C \uD37C\uC990\uCC98\uB7FC \uD480\uC5B4
      \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uB9DE\uD788\uAE30 \uB180\uC774 \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uC5B4\uB824\uC6B4 \uB9D0\uC740 \uC904\uC774\uACE0 \uC190\uC27D\uAC8C
      \uB5A0\uC62C\uB9B4 \uC218 \uC788\uB294 \uBE44\uC720\uB97C \uBD99\uC778\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uC74C \uC7A5\uB3C4 \uC774\uB7F0 \uC2DD\uC774\uBA74 \uD574 \uBCFC
      \uB9CC\uD574."
  _nemoLine: "(\uBCF5\uC7A1\uD55C \uC6D0\uB9AC \uB300\uC2E0 \uAC04\uB2E8\uD55C \uC608\uC2DC\uB97C
    \uC368\uC11C \uAE30\uACC4 \uAD50\uC7AC\uB97C \uD37C\uC990\uCC98\uB7FC \uD480\uC5B4
    \uC900\uB2E4.)"
