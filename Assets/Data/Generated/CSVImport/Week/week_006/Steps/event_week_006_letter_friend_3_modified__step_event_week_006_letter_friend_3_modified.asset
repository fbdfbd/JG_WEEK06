MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_letter_friend_3_modified__step_event_week_006_letter_friend_3_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC720\uD53C \uC218\uC815"
  _bodyText: "letter friend_3 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC5B4\uB514\uC5D0 \uC788\uB4E0
      \uC8FC\uC778\uB2D8\uC774 \uC138\uC0C1\uC744 \uC990\uAC81\uACE0 \uC2E0\uAE30\uD558\uAC8C
      \uBC14\uB77C\uBCF4\uAE38 \uBC14\uB780\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4\uB5BB\uAC8C \uBC14\uB77C\uBCF4\uB294\uB370?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uD558\uB298\uC758 \uAD6C\uB984 \uD558\uB098\uB3C4 \uB9DB\uC788\uB294
      \uC74C\uC2DD\uCC98\uB7FC, \uC7AC\uBC0C\uB294 \uC7A5\uB09C\uAC10\uCC98\uB7FC
      \uC0DD\uAC01\uD558\uBA70 \uC6C3\uC5C8\uC73C\uBA74 \uC88B\uACA0\uB2E4\uACE0
      \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC54\uB2E4\uC6B4 \uC0DD\uAC01\uC774\uB124."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB098\uC911\uC5D0 \uC5B4\uB978\uC774 \uB418\uC5B4 \uB2E4\uC2DC \uB9CC\uB098\uBA74,
      \uB204\uAC00 \uB354 \uC7AC\uBC0C\uB294 \uAC78 \uB9CE\uC774 \uCC3E\uC558\uB294\uC9C0
      \uB0B4\uAE30\uD558\uC790\uACE0 \uD558\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC88B\uC544. \uC774\uBC88\uC5D4 \uB0B4\uAC00 \uAF2D \uC774\uAE38 \uAC70\uC57C!"
  _nemoLine: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC5B4\uB514\uC5D0 \uC788\uB4E0
    \uC8FC\uC778\uB2D8\uC774 \uC138\uC0C1\uC744 \uC990\uAC81\uACE0 \uC2E0\uAE30\uD558\uAC8C
    \uBC14\uB77C\uBCF4\uAE38 \uBC14\uB780\uB300\uC694."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
