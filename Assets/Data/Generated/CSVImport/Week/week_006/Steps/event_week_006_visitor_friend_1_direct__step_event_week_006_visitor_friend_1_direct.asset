  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_visitor_friend_1_direct__step_event_week_006_visitor_friend_1_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9C9\uC2A4 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor friend_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC789\uD06C\uB97C \uD39C\uCD09\uC5D0 \uC0B4\uC9DD
      \uCC0D\uC5B4 \uCE5C\uAD6C 1\uC758 \uC190\uB4F1\uC5D0 \uC791\uC740 \uD558\uD2B8\uB97C
      \uADF8\uB824\uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC790, \uC774\uAC70 \uC548 \uC9C0\uC6CC\uC9C0\uB294 \uC789\uD06C\uC57C.
      \uC6B0\uB9AC \uC624\uB298 \uAC19\uC774 \uB180\uC558\uB2E4\uB294 \uC99D\uAC70!"
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "(\uC2E0\uAE30\uD55C \uB4EF \uC190\uB4F1\uC744 \uCCD0\uB2E4\uBCF4\uBA70)
      \uC640, \uC9C4\uC9DC \uC548 \uC9C0\uC6CC\uC838? \uBA4B\uC788\uB2E4! \uC57C,
      \uB098\uB3C4 \uB108\uD55C\uD14C \uADF8\uB824\uC904\uAC8C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uAE54\uAE54\uAC70\uB9AC\uBA70) \uBC31\uC791\uB2D8\uC774 \uBCF4\uC2DC\uBA74
      \"\uC11C\uC7AC \uBB3C\uAC74\uC73C\uB85C \uC7A5\uB09C\uCE58\uC9C0 \uB9C8\uB77C\"\uACE0
      \uD558\uC2DC\uACA0\uC9C0\uB9CC... \uBB50 \uC5B4\uB54C, \uC6B0\uB9AC\uB07C\uB9AC
      \uC7AC\uBC0C\uC73C\uBA74 \uB410\uC9C0!"
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC789\uD06C\uB97C \uD39C\uCD09\uC5D0 \uC0B4\uC9DD
    \uCC0D\uC5B4 \uCE5C\uAD6C 1\uC758 \uC190\uB4F1\uC5D0 \uC791\uC740 \uD558\uD2B8\uB97C
    \uADF8\uB824\uC900\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
