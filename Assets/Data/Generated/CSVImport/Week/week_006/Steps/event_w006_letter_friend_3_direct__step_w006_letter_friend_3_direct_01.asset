  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_letter_friend_3_direct__step_w006_letter_friend_3_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 6\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uC544\uC8FC \uD654\uB824\uD55C \uB099\uC11C\uAC00
    \uAC00\uB4DD\uD55C \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C\uC5D4
    '\uB124\uBAA8\uC5D0\uAC8C \uC8FC\uB294 \uB9C8\uBC95 \uB3C4\uC548'\uC774\uB77C\uACE0
    \uC801\uD600 \uC788\uB2E4.)\n    \uD558\uB140 : \uC774\uBC88\uC5D4 \uC544\uC8FC
    \uC791\uBCC4 \uC778\uC0AC\uAC00 \uB2F4\uAE34 \uC911\uC694\uD55C \uD3B8\uC9C0\uC778
    \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.\n        \n\n\uD558\uB140 : \uC8FC\uC778\uB2D8,
    \uCE5C\uAD6C\uBD84\uC774 \uC544\uC8FC \uC911\uC694\uD55C \uC0C1\uC0C1\uB825 \uBE44\uBC95\uC744
    \uC804\uC218\uD574 \uC8FC\uACA0\uB2E4\uACE0 \uD569\uB2C8\uB2E4.\n        \uB124\uBAA8
    : \uBE44\uBC95? \uADF8\uAC8C \uBB50\uC57C?\n        (\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C
    \uD3BC\uCE5C\uB2E4.)\n        \uB124\uBAA8 \uC548\uB155! \uC774\uC81C \uB0B4\uAC00
    \uC5C6\uC5B4\uB3C4 \uAD6C\uB984 \uBCF4\uBA74 \uB0B4 \uC0DD\uAC01 \uD574\uC57C
    \uB3FC! \uC800\uAC74 \uAD6D\uC218, \uC800\uAC74 \uB9CC\uB450! \uC54C\uC558\uC9C0?
    \uC78A\uC5B4\uBC84\uB9AC\uBA74 \uB0B4\uAC00 \uC11C\uC7AC \uCC3D\uBB38\uC5D0 \uB9E4\uB2EC\uB824\uC11C
    \uC18C\uB9AC \uC9C0\uB97C \uAC70\uC57C! \uC6B0\uB9AC\uAC00 \uC5B4\uB978\uC774
    \uB418\uBA74 \uADF8\uB550 \uC9C4\uC9DC\uB85C \uAD6C\uB984\uC744 \uD0C0\uACE0
    \uBAA8\uD5D8 \uAC00\uC790!\n        \uB124\uBAA8 : \uCC3D\uBB38\uC5D0 \uB9E4\uB2EC\uB9B0\uB300!\n       
    \uD558\uB140 : \uC815\uB9D0 \uBB34\uC2DC\uBB34\uC2DC\uD55C \uC57D\uC18D\uC774\uB124\uC694.\n       
    \uB124\uBAA8 : \uD558\uD558, \uAC54\uB77C\uBA74 \uC9C4\uC9DC \uADF8\uB7F4\uC9C0\uB3C4
    \uBAB0\uB77C. \uC5B4\uB978 \uB3FC\uC11C \uAD6C\uB984 \uD0C0\uB294 \uAC70 \uC78A\uC9C0
    \uB9D0\uC544\uC57C\uACA0\uB2E4."
