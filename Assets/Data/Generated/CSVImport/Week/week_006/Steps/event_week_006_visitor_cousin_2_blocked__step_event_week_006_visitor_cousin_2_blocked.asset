  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_visitor_cousin_2_blocked__step_event_week_006_visitor_cousin_2_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: cousin_2 Blocked
  _bodyText: "visitor cousin_2 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uB2E4\uAC00\uC640 \uB450 \uC18C\uB144\uC774
      \uC4F0\uACE0 \uC788\uB358 \uC885\uC774\uB97C \uC218\uAC70\uD574\uAC04\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB3C4\uB828\uB2D8, \uC8FC\uC778\uB2D8\uC758 \uC9D1\uBB34 \uC6A9\uC9C0\uB294
      \uACF5\uC801 \uAE30\uB85D\uC744 \uC704\uD55C \uAC83\uC785\uB2C8\uB2E4. \uB099\uC11C\uAC00
      \uB41C \uC885\uC774\uB294 \uD3D0\uAE30\uD558\uB3C4\uB85D \uD558\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544\uC800\uC528! \uADF8\uAC70 \uC0AC\uCD0C 2\uAC00 \uCC98\uC74C\uC73C\uB85C
      \uADF8\uB9B0 \uAC70\uB780 \uB9D0\uC774\uC5D0\uC694!"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "(\uACE0\uAC1C\uB97C \uD479 \uC219\uC774\uBA70) \uBBF8\uC548\uD574, \uB124\uBAA8\uC57C...
      \uB0B4\uAC00 \uAD1C\uD55C \uC9D3\uC744 \uD574\uC11C... \uBC31\uC791\uB2D8\uD55C\uD14C
      \uD63C\uB098\uBA74 \uC5B4\uB5A1\uD574... \uBBF8\uC548\uD574\u2026"
  _nemoLine: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uB2E4\uAC00\uC640 \uB450 \uC18C\uB144\uC774
    \uC4F0\uACE0 \uC788\uB358 \uC885\uC774\uB97C \uC218\uAC70\uD574\uAC04\uB2E4.)"
