  m_Name: event_w006_letter_cousin_2_modified__step_w006_letter_cousin_2_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 \uD3B8\uC9C0 6\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uC791\uC740 \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4.
    \uBD09\uD22C\uB294 \uC544\uC8FC \uAE68\uB057\uD558\uACE0, \uC885\uC774 \uC811\uD78C
    \uBAA8\uC591\uB3C4 \uBB34\uCC99 \uC815\uC131\uC2A4\uB7FD\uB2E4.)\r\n    \uD558\uB140
    : \uC774\uBC88\uC5D4 \uC544\uC8FC \uC9C4\uC2EC \uC5B4\uB9B0 \uC778\uC0AC\uAC00
    \uB2F4\uAE34 \uD3B8\uC9C0\uC778 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.\r\n        \r\n\r\n\uD558\uB140
    : \uC8FC\uC778\uB2D8, \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uAED8\uC11C \uC8FC\uC778\uB2D8\uACFC
    \uCE5C\uAD6C\uAC00 \uB41C \uAC83\uC744 \uC138\uC0C1\uC5D0\uC11C \uAC00\uC7A5
    \uC18C\uC911\uD55C \uC77C\uB85C \uC0DD\uAC01\uD558\uC2E0\uB300\uC694.\r\n       
    \uB124\uBAA8 : \uC9C4\uC9DC? \uAC54\uAC00 \uADF8\uB807\uAC8C \uB9D0\uD588\uC5B4?\r\n       
    \uD558\uB140 : \uB124. \uC55E\uC73C\uB85C \uC2DC\uAC04\uC774 \uC544\uC8FC \uB9CE\uC774
    \uD758\uB7EC\uB3C4 \uC8FC\uC778\uB2D8 \uACC1\uC5D0 \uAF2D \uB0A8\uACE0 \uC2F6\uB2E4\uACE0
    \uD569\uB2C8\uB2E4.\r\n        \uB124\uBAA8 : \uB098\uB3C4 \uAC54\uAC00 \uC606\uC5D0
    \uC788\uC73C\uBA74 \uC88B\uC544. \uC870\uC6A9\uD574\uC11C \uD3B8\uD558\uAC70\uB4E0.\r\n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8\uC758 \uC9C4\uC2EC\uC774 \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uAED8\uB3C4
    \uAF2D \uC804\uB2EC\uB418\uC5C8\uC73C\uBA74 \uC88B\uACA0\uB124\uC694.\r\n       
    \uB124\uBAA8 : \uC751. \uB2E4\uC74C\uC5D0 \uC624\uBA74 \uB0B4\uAC00 \uBA3C\uC800
    \uAF2D \uC548\uC544\uC904\uB798."
