MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_letter_friend_2_direct__step_event_week_006_letter_friend_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC00\uB9AC\uC544 \uD3B8\uC9C0 \uD5C8\uAC00"
  _bodyText: "letter friend_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uBBF8\uB798\uC758 \uC57D\uC18D\uC744
      \uC801\uC5B4\uC11C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBBF8\uB798? \uC5B4\uB978 \uB41C \uB2E4\uC74C \uC598\uAE30\uC57C?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC54\uAC00 \uB9AC\uBCF8 \uBB36\uC5B4\uC900\uB300?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uB204\uAD6C\uC758 \uBC29\uD574\uB3C4 \uBC1B\uC9C0 \uC54A\uB294
      \uB458\uB9CC\uC758 \uACF5\uAC04\uC744 \uB9CC\uB4E4\uACE0 \uC2F6\uC740\uAC00
      \uBD05\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC640... \uADF8\uB7FC \uB098 \uC774\uC81C \uB9AC\uBCF8 \uC5F0\uC2B5
      \uC548 \uD574\uB3C4 \uB418\uACA0\uB2E4! \uAC54\uAC00 \uD574\uC904 \uAC70\uB2C8\uAE4C!"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC544\uC8FC \uB4E0\uB4E0\uD55C \uCE5C\uAD6C\uB97C \uB450\uC168\uB124\uC694,
      \uC8FC\uC778\uB2D8."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uBBF8\uB798\uC758 \uC57D\uC18D\uC744
    \uC801\uC5B4\uC11C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
