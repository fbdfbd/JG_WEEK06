%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_astronomy_blocked__step_event_week_006_astronomy_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBCC4\uB85C \uBC29\uD5A5\uC744 \uC5C4\uACA9\uD788 \uC9DA\uB294\uB2E4"
  _bodyText: "\uBCC4\uC790\uB9AC\uC640 \uD56D\uD574 6\uC8FC\uCC28 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBC24. \uBCC4\uC790\uB9AC\uD310 \uC606\uC5D0 \uAC04\uB2E8\uD55C \uC9C0\uB3C4\uC640
      \uBAA8\uD615 \uBC30\uAC00 \uB193\uC5EC \uC788\uB2E4. \uCC3D\uBC16 \uD558\uB298\uACFC
      \uCC45\uC0C1 \uC704 \uC9C0\uB3C4\uB97C \uBC88\uAC08\uC544 \uBCF4\uBA70 \uC704\uCE58\uB97C
      \uB9DE\uCDB0 \uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uBCC4\uC744 \uBCF4\uB294 \uAC83\uC5D0\uC11C
      \uB05D\uB0B4\uC9C0 \uC54A\uACE0, \uBCC4\uB85C \uAE38\uC744 \uC9DA\uC5B4 \uBCFC
      \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uC81C \uC9C4\uC9DC \uD56D\uD574\uC220 \uAC19\uB124."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uBAA8\uD615 \uBC30\uB97C \uC9C0\uB3C4\uC758
      \uD55C\uAC00\uC6B4\uB370 \uB450\uACE0 \uAC01\uB3C4\uB97C \uC7AC\uAC8C \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB9C9\uC5F0\uD788 \u201C\uC800\uCABD\u201D\uC774\uB77C\uACE0 \uD558\uC9C0
      \uB9C8\uC2ED\uC2DC\uC624. \uBC29\uD5A5\uC740 \uC815\uD655\uD574\uC57C \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9D0\uC740 \uC26C\uC6B4\uB370 \uBCC4\uC774 \uC6C0\uC9C1\uC774\uB294
      \uAC83 \uAC19\uB2E8 \uB9D0\uC774\uC57C."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uBCC4\uC774 \uC544\uB2C8\uB77C \uC8FC\uC778\uB2D8 \uB208\uC774 \uD754\uB4E4\uB9AC\uB294
      \uAC81\uB2C8\uB2E4. \uB2E4\uC2DC \uBCF4\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\uADF8 \uB9D0\uC740 \uC880 \uC584\uBBF8\uC6CC."
  _nemoLine: "(\uBC24. \uBCC4\uC790\uB9AC\uD310 \uC606\uC5D0 \uAC04\uB2E8\uD55C \uC9C0\uB3C4\uC640
    \uBAA8\uD615 \uBC30\uAC00 \uB193\uC5EC \uC788\uB2E4. \uCC3D\uBC16 \uD558\uB298\uACFC
    \uCC45\uC0C1 \uC704 \uC9C0\uB3C4\uB97C \uBC88\uAC08\uC544 \uBCF4\uBA70 \uC704\uCE58\uB97C
    \uB9DE\uCDB0 \uBCF8\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
