  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_external_main_direct__step_w006_external_main_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "6\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uC751\uC811\uC2E4 \uBC16, \uBA40\uB9AC\uC11C \uC628 \uC190\uB2D8\uC758
    \uB9C8\uBD80\uAC00 \uC800\uD0DD \uB9C8\uBD80\uB4E4\uACFC \uB458\uB7EC\uC549\uC544
    \uC774\uC57C\uAE30\uD55C\uB2E4.)\r\n    \uB9C8\uBD801 : \uC774\uBC88\uC5D0 \uC190\uB2D8
    \uBAA8\uC2DC\uACE0 \uC624\uBA74\uC11C \uB4E4\uC5C8\uB294\uB370, \uBC14\uB2E4
    \uAC74\uB108\uC5D4 \uAE38\uBC14\uB2E5\uC774 \uC804\uBD80 \uAE08\uC73C\uB85C \uAE54\uB9B0
    \uB3C4\uC2DC\uAC00 \uC788\uB2E4\uBA70?\r\n    \uB9C8\uBD802 : \uAC70\uAE30 \uC0AC\uB78C\uB4E4\uC740
    \uAD6C\uB984 \uC704\uB97C \uAC78\uC5B4 \uB2E4\uB2CC\uB2E4\uB294 \uB9D0\uB3C4
    \uC548 \uB418\uB294 \uC18C\uB9AC\uB3C4 \uB4E4\uC5C8\uB124.\r\n    \uB124\uBAA8
    : \uAE38\uC774 \uB2E4 \uAE08\uC774\uC57C? \uAD6C\uB984\uC744 \uAC78\uC5B4?\r\n   
    \r\n\r\n\uB9C8\uBD801 : \uC544\uC8FC \uBA3C \uB0A8\uCABD\uC73C\uB85C \uBC30\uB97C
    \uD0C0\uACE0 \uD55C \uB2EC\uC744 \uAC00\uBA74 \uB098\uC624\uB294 \uC2E0\uBE44\uD55C
    \uB300\uB959\uC774 \uC788\uB300\uC694.\r\n    \uB124\uBAA8 : \uD55C \uB2EC\uC774\uB098?
    \uADF8\uB7FC \uAC70\uAE30 \uAC00\uBA74 \uC9C4\uC9DC \uD558\uB298\uC744 \uB0A0
    \uC218 \uC788\uC5B4?\r\n    \uB9C8\uBD802 : \uAC70\uAE30\uC120 \uCF54\uB07C\uB9AC\uB77C\uB294
    \uAC70\uB300\uD55C \uC9D0\uC2B9\uC744 \uD0C0\uACE0 \uB2E4\uB2C8\uACE0, \uC0AC\uD0D5\uC774
    \uC5F4\uB9AC\uB294 \uB098\uBB34\uB3C4 \uC788\uB300\uC694.\r\n    \uB124\uBAA8
    : \uC6B0\uC640! \uB098 \uB098\uC911\uC5D0 \uC5B4\uB978 \uB418\uBA74 \uAF2D \uBC30
    \uD0C0\uACE0 \uAC70\uAE30 \uAC08\uB798. \uC0AC\uD0D5 \uB098\uBB34 \uC9C4\uC9DC
    \uAD81\uAE08\uD574!"
