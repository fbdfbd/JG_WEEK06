--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_riding_blocked__step_event_week_006_riding_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC29\uD5A5 \uC804\uD658\uC744 \uC5C4\uACA9\uD788 \uC775\uD78C\uB2E4"
  _bodyText: "\uCCB4\uC804\uACFC \uC2B9\uB9C8 \uAE30\uCD08 6\uC8FC\uCC28 Blocked
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD6C8\uB828\uC7A5 \uBC14\uAE65 \uC9E7\uC740 \uB458\uB808\uAE38. \uC774\uBC88\uC5D4
      \uB9D0\uACFC \uD568\uAED8 \uCC9C\uCC9C\uD788 \uC6D0\uC744 \uB3CC\uBA70 \uBC29\uD5A5
      \uC804\uD658\uAE4C\uC9C0 \uC5F0\uC2B5\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uBA48\uCD94\uAE30\uC640 \uBC29\uD5A5
      \uBC14\uAFB8\uAE30\uB97C \uAC19\uC774 \uD574 \uBCFC \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C0\uB09C\uBC88\uBCF4\uB2E4 \uB354 \uBC14\uBE60\uC84C\uB124."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uACE0\uC090\uB97C \uD55C\uCABD\uC73C\uB85C \uAE09\uD788
      \uB2F9\uAE30\uC790, \uACBD\uBE44\uB300\uC7A5\uC774 \uC989\uC2DC \uC190 \uC704\uCE58\uB97C
      \uAD50\uC815\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uD798\uC73C\uB85C \uAEBE\uC9C0 \uB9C8\uC2ED\uC2DC\uC624. \uB9D0\uC740
      \uBC00\uC5B4\uBD99\uC774\uB294 \uAC8C \uC544\uB2C8\uB77C \uC720\uB3C4\uD558\uB294
      \uAC81\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB0E5 \uB3CC\uACE0 \uC2F6\uC5B4\uC11C \uADF8\uB7F0 \uAC74\uB370."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC870\uAE09\uD558\uBA74 \uB9D0\uBD80\uD130 \uAC70\uCE60\uC5B4\uC9D1\uB2C8\uB2E4.
      \uB2E4\uC2DC \uD558\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC54C\uACA0\uC5B4. \uCC9C\uCC9C\uD788 \uD560\uAC8C."
  _nemoLine: "(\uD6C8\uB828\uC7A5 \uBC14\uAE65 \uC9E7\uC740 \uB458\uB808\uAE38. \uC774\uBC88\uC5D4
    \uB9D0\uACFC \uD568\uAED8 \uCC9C\uCC9C\uD788 \uC6D0\uC744 \uB3CC\uBA70 \uBC29\uD5A5
    \uC804\uD658\uAE4C\uC9C0 \uC5F0\uC2B5\uD55C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
