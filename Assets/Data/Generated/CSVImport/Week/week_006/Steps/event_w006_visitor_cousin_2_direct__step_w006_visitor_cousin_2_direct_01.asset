  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_visitor_cousin_2_direct__step_w006_visitor_cousin_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 6\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uB124\uBAA8\uAC00 \uBC31\uC791\uC758 \uD654\uB824\uD55C \uAE43\uD39C\uC744
    \uC0AC\uCD0C 2\uC5D0\uAC8C \uC950\uC5EC\uC900\uB2E4. \uC0AC\uCD0C 2\uB294 \uB5A8\uB9AC\uB294
    \uC190\uC73C\uB85C \uC885\uC774 \uADC0\uD241\uC774\uC5D0 \uC791\uC740 \uAF43
    \uADF8\uB9BC\uC744 \uADF8\uB9B0\uB2E4.)\n        \n        \uC0AC\uCD0C 2 : \uB124\uBAA8\uC57C,
    \uC774\uAC70 \uC9C4\uC9DC \uBD80\uB4DC\uB7FD\uAC8C \uC368\uC9C4\uB2E4... \uADFC\uB370
    \uC774\uAC70 \uB0B4\uAC00 \uC368\uB3C4 \uB418\uB294 \uAC70\uC57C? \uBC31\uC791\uB2D8\uC774
    \uBCF4\uC2DC\uBA74...\n        \uB124\uBAA8 : \uAD1C\uCC2E\uC544, \uB0B4\uAC00
    \uADF8\uB9B0 \uAC70\uB77C\uACE0 \uD558\uBA74 \uB3FC. \uB108 \uADF8\uB9BC \uC9C4\uC9DC
    \uC798 \uADF8\uB9B0\uB2E4! \uC5EC\uAE30 \uB098\uBE44\uB3C4 \uADF8\uB824\uC918.\n       
    \n\n(\uB124\uBAA8\uAC00 \uC0AC\uCD0C 2\uAC00 \uADF8\uB9B0 \uAF43 \uC606\uC5D0
    \uC790\uC2E0\uC758 \uC774\uB984\uC744 \uC11C\uD234\uAC8C \uC801\uB294\uB2E4.)\n       
    \uB124\uBAA8 : \uBD10, '\uB124\uBAA8\uB791 \uC0AC\uCD0C 2'. \uC774\uB807\uAC8C
    \uC801\uC5B4\uB450\uBA74 \uC6B0\uB9AC \uB098\uC911\uC5D0\uB3C4 \uACC4\uC18D \uCE5C\uAD6C\uC778
    \uAC70\uB2E4?\n        \uC0AC\uCD0C 2 : (\uC5BC\uAD74\uC744 \uBD89\uD788\uBA70
    \uACE0\uAC1C\uB97C \uB044\uB355\uC778\uB2E4) \uC751... \uB124\uBAA8\uC57C, \uB108\uB791
    \uAC19\uC774 \uC788\uC73C\uBA74 \uC774 \uBB34\uC11C\uC6B4 \uC11C\uC7AC\uB3C4
    \uC660\uC9C0 \uB530\uB73B\uD558\uAC8C \uB290\uAEF4\uC838.\n        \uB124\uBAA8
    : (\uC0AC\uCD0C 2\uC758 \uC5B4\uAE68\uB97C \uD22D \uCE58\uBA70) \uADF8\uCE58?
    \uBC31\uC791\uB2D8\uB3C4 \uB098\uC911\uC5D0 \uC6B0\uB9AC\uAC00 \uCE5C\uD558\uAC8C
    \uC9C0\uB0B4\uB294 \uAC70 \uBCF4\uC2DC\uBA74 \uC88B\uC544\uD558\uC2E4 \uAC70\uC57C.
    \uB0B4\uAC00 \uB9DB\uC788\uB294 \uAC70 \uB354 \uAC00\uC838\uC62C\uAC8C, \uAE30\uB2E4\uB824!"
