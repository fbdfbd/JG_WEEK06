  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_excursion_garden_direct__step_w006_excursion_garden_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 6\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "6\uCC28 \uBC29\uBB38\n        \n        (\uD55C\uB0AE\uC758 \uC815\uC6D0.
    \uD587\uBE5B\uC740 \uAC15\uD55C\uB370 \uC774\uC0C1\uD560 \uB9CC\uD07C \uBC8C\uB808\uAC00
    \uC5C6\uB2E4. \uAF43\uC740 \uB9CE\uC740\uB370\uB3C4 \uC719\uC719\uAC70\uB9AC\uB294
    \uC18C\uB9AC\uB3C4, \uC78E\uC744 \uAC09\uC544 \uBA39\uC740 \uD754\uC801\uB3C4
    \uC798 \uBCF4\uC774\uC9C0 \uC54A\uB294\uB2E4.)\n        \n        \uB124\uBAA8
    : \uC774\uC0C1\uD558\uB124. \uC624\uB298\uC740 \uC870\uC6A9\uD558\uB2E4.\n       
    \n        (\uB124\uBAA8\uAC00 \uC7A5\uBBF8 \uB364\uBD88 \uCABD\uC73C\uB85C \uB2E4\uAC00\uAC00\uB2E4\uAC00,
    \uB364\uBD88 \uC544\uB798 \uC791\uC740 \uCC9C\uC8FC\uBA38\uB2C8 \uD558\uB098\uB97C
    \uBC1C\uACAC\uD55C\uB2E4. \uC798 \uB9D0\uB9B0 \uC78E\uACFC \uAECD\uC9C8\uC774
    \uB4E4\uC5B4 \uC788\uACE0 \uD5A5\uC774 \uC9C4\uD558\uAC8C \uB09C\uB2E4.)\n       
    \n        \uB124\uBAA8 : \uC774\uAC74 \uB610 \uBB50\uC57C? \uD5A5\uC8FC\uBA38\uB2C8?\n       
    \n        (\uC870\uAE08 \uB5A8\uC5B4\uC9C4 \uC790\uB9AC, \uB610 \uD558\uB098.
    \uD5C8\uBE0C \uD654\uB2E8 \uC606\uC5D0\uB3C4 \uD558\uB098. \uB124\uBAA8\uAC00
    \uB458\uB7EC\uBCF4\uB2C8 \uC815\uC6D0 \uACF3\uACF3\uC5D0 \uBE44\uC2B7\uD55C \uC8FC\uBA38\uB2C8\uAC00
    \uC228\uC5B4 \uC788\uB2E4.)\n        \n        \uB124\uBAA8 : ...\uC65C \uC774\uB807\uAC8C
    \uB9CE\uC544?\n        \n\n(\uC815\uC6D0\uC0AC\uAC00 \uC7A0\uAE50 \uB9DD\uC124\uC774\uB2E4\uAC00,
    \uACB0\uAD6D \uCC9C\uC8FC\uBA38\uB2C8 \uD558\uB098\uB97C \uB4E4\uC5B4 \uBCF4\uC778\uB2E4.)\n       
    \n        \uC815\uC6D0\uC0AC : \uCC9C\uC5F0 \uD5A5\uB8CC \uC8FC\uBA38\uB2C8\uC785\uB2C8\uB2E4~
    \uBC8C\uB808\uAC00 \uC2EB\uC5B4\uD558\uB294 \uB0C4\uC0C8\uB97C \uBAA8\uC544 \uB454
    \uAC70\uC9C0\uC694~\n        \n        \uB124\uBAA8 : \uADF8\uB798\uC11C \uC624\uB298
    \uBC8C\uB808\uAC00 \uC5C6\uB294 \uAC70\uC57C?\n        \n        \uC815\uC6D0\uC0AC
    : \uB124~\n        \n        \uB124\uBAA8 : \uB204\uAC00 \uC774\uB807\uAC8C \uB9CE\uC774
    \uB450\uB798?\n        \n        \uC815\uC6D0\uC0AC : \u2026\u2026\uBC31\uC791\uB2D8\uC774\uC2ED\uB2C8\uB2E4~\n       
    \n        \uB124\uBAA8 : \uB610?\n        \n        \uC815\uC6D0\uC0AC : \uC8FC\uC778\uB2D8\uAED8\uC11C
    \uBC8C\uB808 \uC9C8\uC0C9\uD558\uC2E0\uB2E4\uACE0, \uC815\uC6D0 \uC5B4\uB514\uB97C
    \uAC00\uC2DC\uB4E0 \uB35C \uBCF4\uC774\uAC8C \uD574 \uB450\uB77C \uD558\uC168\uC9C0\uC694~\n       
    \n        \uB124\uBAA8 : \uADF8\uB798\uC11C \uC7A5\uBBF8 \uC606\uC5D0\uB3C4,
    \uBCA4\uCE58 \uBC11\uC5D0\uB3C4, \uB2E4 \uC788\uB294 \uAC70\uAD6C\uB098.\n       
    \n        \uC815\uC6D0\uC0AC : \uC608~ \uC8FC\uC778\uB2D8 \uC190 \uB2FF\uB294
    \uC790\uB9AC\uC5D4 \uD2B9\uD788\uC694~\n        \n        \uB124\uBAA8 : \uC774\uAC74
    \uC880 \uBB34\uC11C\uC6B8 \uB9CC\uD07C \uAF3C\uAF3C\uD55C\uB370.\n        \n       
    \uC815\uC6D0\uC0AC : \u2026\uC2EB\uC73C\uC2ED\uB2C8\uAE4C~?\n        \n       
    \uB124\uBAA8 : \uC2EB\uC9C4 \uC54A\uC544. \uADFC\uB370 \uB0B4\uAC00 \uBC8C\uB808
    \uC2EB\uC5B4\uD558\uB294 \uAC74 \uC815\uB9D0 \uC815\uD655\uD788 \uC544\uB124."
