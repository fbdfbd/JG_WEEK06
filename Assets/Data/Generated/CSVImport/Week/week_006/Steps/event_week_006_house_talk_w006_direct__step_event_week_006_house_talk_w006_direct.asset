  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_house_talk_w006_direct__step_event_week_006_house_talk_w006_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uB77C\uC9C0\uB294 \uC2DD\uAE30\uB4E4 \uC18C\uBB38 \uD5C8\uAC00"
  _bodyText: "house_talk w006 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC740\uC2A4\uD47C\uC774 \uAC10\uCABD\uAC19\uC774 \uC0AC\uB77C\uC84C\uC5B4\uC694.
      \uC800\uD0DD\uC5D0 \uC0AC\uB294 \uC791\uC740 \uC694\uC815\uC774 \uC7A5\uB09C\uC744
      \uCE58\uB294 \uAC78\uAE4C\uC694?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC694\uC815\uC774 \uC21F\uAC00\uB77D\uC744 \uAC00\uC838\uAC00?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uBC18\uC9DD\uC774\uB294 \uAC78 \uC88B\uC544\uD574\uC11C \uC790\uAE30
      \uBC29\uC5D0 \uC228\uACA8\uB454\uB2E4\uB294 \uC18C\uBB38\uC774 \uC788\uAC70\uB4E0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640, \uADF8\uB7FC \uC694\uC815 \uBC29\uC740 \uC5C4\uCCAD \uBC18\uC9DD\uAC70\uB9AC\uACA0\uB2E4!"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uADF8\uB7F4\uC9C0\uB3C4 \uBAA8\uB974\uC8E0. \uD558\uC9C0\uB9CC \uC694\uC815\uC774
      \uB2E4\uC2DC \uB3CC\uB824\uC8FC\uC9C0 \uC54A\uC73C\uBA74 \uC694\uB9AC\uC0AC\uB2D8\uC774
      \uD654\uB0B4\uC2E4 \uD150\uB370 \uAC71\uC815\uC774\uC5D0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB0B4\uAC00 \uAC19\uC774 \uCC3E\uC544\uC904\uAE4C? \uC694\uC815\uC740
      \uC5B4\uB514 \uC228\uC5B4 \uC788\uC744\uAE4C?"
  _nemoLine: "\uC740\uC2A4\uD47C\uC774 \uAC10\uCABD\uAC19\uC774 \uC0AC\uB77C\uC84C\uC5B4\uC694.
    \uC800\uD0DD\uC5D0 \uC0AC\uB294 \uC791\uC740 \uC694\uC815\uC774 \uC7A5\uB09C\uC744
    \uCE58\uB294 \uAC78\uAE4C\uC694?"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
