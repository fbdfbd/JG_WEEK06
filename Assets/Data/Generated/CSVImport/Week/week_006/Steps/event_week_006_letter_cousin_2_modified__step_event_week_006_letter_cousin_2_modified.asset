  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_letter_cousin_2_modified__step_event_week_006_letter_cousin_2_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9AC\uC548 \uD3B8\uC9C0 \uC218\uC815"
  _bodyText: "letter cousin_2 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uAED8\uC11C \uC8FC\uC778\uB2D8\uACFC
      \uCE5C\uAD6C\uAC00 \uB41C \uAC83\uC744 \uC138\uC0C1\uC5D0\uC11C \uAC00\uC7A5
      \uC18C\uC911\uD55C \uC77C\uB85C \uC0DD\uAC01\uD558\uC2E0\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC? \uAC54\uAC00 \uADF8\uB807\uAC8C \uB9D0\uD588\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC55E\uC73C\uB85C \uC2DC\uAC04\uC774 \uC544\uC8FC \uB9CE\uC774
      \uD758\uB7EC\uB3C4 \uC8FC\uC778\uB2D8 \uACC1\uC5D0 \uAF2D \uB0A8\uACE0 \uC2F6\uB2E4\uACE0
      \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uAC54\uAC00 \uC606\uC5D0 \uC788\uC73C\uBA74 \uC88B\uC544.
      \uC870\uC6A9\uD574\uC11C \uD3B8\uD558\uAC70\uB4E0."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uC758 \uC9C4\uC2EC\uC774 \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uAED8\uB3C4
      \uAF2D \uC804\uB2EC\uB418\uC5C8\uC73C\uBA74 \uC88B\uACA0\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uB2E4\uC74C\uC5D0 \uC624\uBA74 \uB0B4\uAC00 \uBA3C\uC800 \uAF2D
      \uC548\uC544\uC904\uB798."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uAED8\uC11C \uC8FC\uC778\uB2D8\uACFC
    \uCE5C\uAD6C\uAC00 \uB41C \uAC83\uC744 \uC138\uC0C1\uC5D0\uC11C \uAC00\uC7A5
    \uC18C\uC911\uD55C \uC77C\uB85C \uC0DD\uAC01\uD558\uC2E0\uB300\uC694."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
