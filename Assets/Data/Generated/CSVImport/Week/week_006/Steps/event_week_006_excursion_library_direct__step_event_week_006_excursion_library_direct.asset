  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_excursion_library_direct__step_event_week_006_excursion_library_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 \uD5C8\uAC00"
  _bodyText: "excursion library Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uCF54\uD2B8\uB97C \uB354 \uAE4A\uAC8C \uB20C\uB7EC\uC4F0\uBA70
      \uCABD\uC9C0\uB97C \uB9CC\uC9C0\uC791\uAC70\uB9B0\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uCF54\uCF54\uC544... \uC544\uC9C1 \uC870\uAE08 \uB530\uB73B\uD558\uB124."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uCABD\uC9C0 \uB4B7\uBA74\uC744 \uBCF4\uB2C8 '\uB0B4\uC77C\uC740 \uC11C\uC7AC\uB85C
      \uC640\uB77C. \uAD81\uAE08\uD574\uD558\uB358 \uB2E4\uC74C \uAD8C\uC744 \uCC3E\uC544\uB450\uC5C8\uB2E4'\uB77C\uACE0
      \uC801\uD600 \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uD53C\uC2DD \uC6C3\uC73C\uBA70) \uBB50\uC57C, \uACF5\uBD80 \uB354 \uD558\uB77C\uB294
      \uC18C\uB9AC\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB798\uB3C4 \uBB50... \uD63C\uC790 \uB450\uB294 \uAC83\uBCF4\uB2E8
      \uB0AB\uB098. \uCF54\uD2B8 \uB530\uB73B\uD558\uB124."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uCF54\uD2B8\uB97C \uB354 \uAE4A\uAC8C \uB20C\uB7EC\uC4F0\uBA70
    \uCABD\uC9C0\uB97C \uB9CC\uC9C0\uC791\uAC70\uB9B0\uB2E4.)"
