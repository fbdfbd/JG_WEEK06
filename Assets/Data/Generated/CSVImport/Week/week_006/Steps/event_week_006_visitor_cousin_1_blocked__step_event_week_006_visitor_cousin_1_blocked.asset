  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_006_visitor_cousin_1_blocked__step_event_week_006_visitor_cousin_1_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE74\uC774\uC548 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor cousin_1 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC9D1\uC0AC\uAC00 \uC740\uC7C1\uBC18\uC744 \uB4E4\uACE0 \uC640 \uBAA8\uC790\uB97C
      \uC9D1\uAC8C\uB85C \uC9D1\uC5B4 \uC62C\uB9B0\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC678\uBD80\uC778\uC758 \uC18C\uC9C0\uD488\uC740 \uC11C\uC7AC\uC758
      \uCCAD\uACB0\uC744 \uD574\uCE69\uB2C8\uB2E4. \uC8FC\uC778\uB2D8\uAED8\uC11C
      \uBCF4\uC2DC\uAE30 \uC804\uC5D0 \uCE58\uC6B0\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uBAA8\uC790\uB97C \uBE8F\uAE30\uBA70) \uC544... \uC7A0\uAE50\uB9CC\uC694,
      \uC544\uC9C1 \uC81C\uB300\uB85C \uBABB \uB9E1\uC544\uBD24\uB294\uB370!"
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uC815\uB9D0 \uC5EC\uC804\uD558\uC2DC\uAD6C\uB9CC. \uD759\uB0C4\uC0C8
      \uC880 \uB9E1\uB294\uB2E4\uACE0 \uC601\uC9C0\uAC00 \uB9DD\uD558\uB294 \uAC83\uB3C4
      \uC544\uB2CC\uB370 \uB9D0\uC774\uC57C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uBB34\uC548\uD55C \uB4EF \uC190\uC744 \uBE44\uBE44\uBA70) \uBC31\uC791\uB2D8\uC774
      \uC800\uB97C \uC704\uD574 \uC644\uBCBD\uD55C \uD658\uACBD\uB9CC \uB9CC\uB4E4\uC5B4\uC8FC\uC2DC\uB824\uB294
      \uAC70\uB2C8\uAE4C... \uC774\uD574\uD574\uC57C\uC8E0. \uBBF8\uC548\uD574\uC694."
  _nemoLine: "(\uC9D1\uC0AC\uAC00 \uC740\uC7C1\uBC18\uC744 \uB4E4\uACE0 \uC640 \uBAA8\uC790\uB97C
    \uC9D1\uAC8C\uB85C \uC9D1\uC5B4 \uC62C\uB9B0\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
