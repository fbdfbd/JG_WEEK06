  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w006_house_main_direct__step_w006_house_main_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "6\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uC8FC\uBC29 \uADFC\uCC98 \uBCF5\uB3C4. \uD558\uB140 \uB458\uC774
    \uC55E\uCE58\uB9C8\uB97C \uD138\uBA70 \uC5B4\uB9AC\uB465\uC808\uD55C \uD45C\uC815\uC744
    \uC9D3\uACE0 \uC788\uB2E4.)\r\n    \uD558\uB1401 : \uBD84\uBA85\uD788 \uC2DD\uD0C1
    \uC704\uC5D0 \uB480\uB294\uB370, \uAE5C\uBE61\uD558\uB294 \uC0AC\uC774\uC5D0
    \uC5C6\uC5B4\uC84C\uC5B4.\r\n    \uD558\uB1402 : \uC124\uD0D5 \uB3C4\uB451\uC5D0
    \uC774\uC5B4\uC11C \uC774\uBC88\uC5D4 \uC2A4\uD47C\uC774\uC57C? \uAE4C\uB9C8\uADC0\uAC00
    \uAC00\uC838\uAC14\uB098?\r\n    \uB124\uBAA8 : \uC774\uBC88\uC5D4 \uB610 \uBB50\uAC00
    \uC5C6\uC5B4\uC84C\uC5B4?\r\n    \r\n\r\n\uD558\uB1401 : \uC740\uC2A4\uD47C\uC774
    \uAC10\uCABD\uAC19\uC774 \uC0AC\uB77C\uC84C\uC5B4\uC694. \uC800\uD0DD\uC5D0 \uC0AC\uB294
    \uC791\uC740 \uC694\uC815\uC774 \uC7A5\uB09C\uC744 \uCE58\uB294 \uAC78\uAE4C\uC694?\r\n   
    \uB124\uBAA8 : \uC694\uC815\uC774 \uC21F\uAC00\uB77D\uC744 \uAC00\uC838\uAC00?\r\n   
    \uD558\uB1402 : \uBC18\uC9DD\uC774\uB294 \uAC78 \uC88B\uC544\uD574\uC11C \uC790\uAE30
    \uBC29\uC5D0 \uC228\uACA8\uB454\uB2E4\uB294 \uC18C\uBB38\uC774 \uC788\uAC70\uB4E0\uC694.\r\n   
    \uB124\uBAA8 : \uC6B0\uC640, \uADF8\uB7FC \uC694\uC815 \uBC29\uC740 \uC5C4\uCCAD
    \uBC18\uC9DD\uAC70\uB9AC\uACA0\uB2E4!\r\n    \uD558\uB1401 : \uADF8\uB7F4\uC9C0\uB3C4
    \uBAA8\uB974\uC8E0. \uD558\uC9C0\uB9CC \uC694\uC815\uC774 \uB2E4\uC2DC \uB3CC\uB824\uC8FC\uC9C0
    \uC54A\uC73C\uBA74 \uC694\uB9AC\uC0AC\uB2D8\uC774 \uD654\uB0B4\uC2E4 \uD150\uB370
    \uAC71\uC815\uC774\uC5D0\uC694.\r\n    \uB124\uBAA8 : \uB0B4\uAC00 \uAC19\uC774
    \uCC3E\uC544\uC904\uAE4C? \uC694\uC815\uC740 \uC5B4\uB514 \uC228\uC5B4 \uC788\uC744\uAE4C?"
