  _bodyText: "letter friend_1 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uB294 '\uACC4\uC57D\uC11C'\uB77C\uB294 \uAE00\uC790\uB97C
