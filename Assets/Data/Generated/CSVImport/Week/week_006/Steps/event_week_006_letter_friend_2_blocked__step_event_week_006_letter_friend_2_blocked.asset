  _titleOverride: "\uBC00\uB9AC\uC544 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "letter friend_2 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uB294 '\uB124\uBAA8\uB9CC \uC77D\uC744 \uAC83'\uC774\uB77C\uB294
      \uBB38\uAD6C\uB97C \uBCF4\uACE0\uB294 \uB9D0\uC5C6\uC774 \uBCBD\uB09C\uB85C
      \uADFC\uCC98\uB85C \uAC00\uC838\uAC04\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uC11C\uC7AC \uC758\uC790\uC5D0 \uC549\uC544 \uBC1C\uC744
      \uB300\uB871\uAC70\uB9AC\uBA70 \uCE5C\uAD6C 2\uB97C \uAE30\uB2E4\uB9AC\uACE0
      \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\u2026\u2026\uBE44\uBC00\uC774 \uB108\uBB34 \uB9CE\uC73C\uBA74 \uC8FC\uC778\uB2D8\uAED8
      \uC88B\uC9C0 \uC54A\uC73C\uB2C8\uAE4C\uC694."
  _nemoLine: "(\uD558\uB140\uB294 '\uB124\uBAA8\uB9CC \uC77D\uC744 \uAC83'\uC774\uB77C\uB294
    \uBB38\uAD6C\uB97C \uBCF4\uACE0\uB294 \uB9D0\uC5C6\uC774 \uBCBD\uB09C\uB85C \uADFC\uCC98\uB85C
