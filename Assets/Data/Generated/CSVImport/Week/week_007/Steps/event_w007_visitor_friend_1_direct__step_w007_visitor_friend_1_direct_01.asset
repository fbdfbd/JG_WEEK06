  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_visitor_friend_1_direct__step_w007_visitor_friend_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 7\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uC131\uC778\uC2DD\uC744 \uC55E\uB454 \uC5B4\uB290 \uB0A0, \uC11C\uC7AC\uC5D0
    \uB178\uC744\uC774 \uAE4A\uAC8C \uB4DC\uB9AC\uC6CC\uC838 \uC788\uB2E4. \uCE5C\uAD6C
    1\uC774 \uD3C9\uC18C\uBCF4\uB2E4 \uC815\uC911\uD55C \uCC28\uB9BC\uC73C\uB85C
    \uB4E4\uC5B4\uC640 \uBC31\uC791\uB2D8\uC758 \uCC45\uC0C1 \uC704\uC5D0 \uC791\uC740
    \uC8FC\uBA38\uB2C8\uB97C \uB193\uB294\uB2E4. \uADF8 \uC548\uC5D0\uB294 \uC5B4\uB9B4
    \uC801 \uB450 \uC0AC\uB78C\uC774 \uD568\uAED8 \uBAA8\uC558\uB358 \uBC18\uC9DD\uC774\uB294
    \uC870\uC57D\uB3CC\uB4E4\uACFC \uBE44\uBC00 \uC9C0\uB3C4 \uC870\uAC01\uB4E4\uC774
    \uB4E4\uC5B4\uC788\uB2E4.)\n        \n        \uCE5C\uAD6C 1 : \uB124\uBAA8\uC57C,
    \uC774\uC81C \uB0B4\uC77C\uBD80\uD130\uB294 \uB124\uAC00 \uC774 \uC601\uC9C0\uC758
    \uACF5\uC2DD\uC801\uC778 \uD6C4\uACC4\uC790\uAC00 \uB418\uACA0\uC9C0? \uADF8\uB7FC
    \uC774\uC81C \uC774\uB7F0 '\uBCF4\uBB3C'\uB4E4\uC740 \uC5EC\uAE30 \uC5B4\uC6B8\uB9AC\uC9C0
    \uC54A\uC744\uC9C0\uB3C4 \uBAB0\uB77C. \uD558\uC9C0\uB9CC \uB09C \uB124\uAC00
    \uBC31\uC791\uB2D8\uC758 \uB4A4\uB97C \uC774\uC5B4 \uC774 \uC11C\uC7AC\uC758
    \uC8FC\uC778\uC774 \uB418\uC5B4\uB3C4, \uC6B0\uB9AC\uB791 \uC0B0\uC73C\uB85C
    \uB4E4\uB85C \uB6F0\uC5B4\uB2E4\uB2C8\uB358 \uADF8 \uB124\uBAA8\uB77C\uB294 \uAC78
    \uC78A\uC9C0 \uC54A\uC558\uC73C\uBA74 \uC88B\uACA0\uC5B4.\n        \uB124\uBAA8
    : (\uC870\uC57D\uB3CC\uC744 \uB9CC\uC9C0\uBA70 \uBBF8\uC18C \uC9D3\uB294\uB2E4)
    \uB2F9\uC5F0\uD558\uC9C0. \uBC31\uC791\uB2D8\uC774 \uB0B4\uAC8C \uAC00\uB974\uCCD0\uC8FC\uC2E0
    \uD488\uC704\uB294 \uC774\uB7F0 \uC18C\uC911\uD55C \uC6B0\uC815\uC744 \uC9C0\uD0A4\uAE30
    \uC704\uD55C \uD798\uC774\uC57C. \uC78A\uC744 \uB9AC\uAC00 \uC5C6\uC796\uC544.\n       
    \n\n- (\uB124\uBAA8\uAC00 \uBC31\uC791\uB2D8\uC758 \uACE0\uAE09 \uAE43\uD39C\uC744
    \uB4E4\uC5B4, \uCE5C\uAD6C 1\uC774 \uAC00\uC838\uC628 \uC9C0\uB3C4 \uC870\uAC01
    \uB4B7\uBA74\uC5D0 \uC790\uC2E0\uC758 \uBB38\uC7A5\uC744 \uC815\uAC08\uD558\uAC8C
    \uADF8\uB824 \uB123\uB294\uB2E4. \uADF8\uB9AC\uACE0 \uADF8\uAC83\uC744 \uB2E4\uC2DC
    \uCE5C\uAD6C 1\uC5D0\uAC8C \uAC74\uB128\uB2E4.)\n        - \uB124\uBAA8 : \uC774\uAC74
    \uB0B4 \uC131\uC778\uC2DD \uCCAB \uBC88\uC9F8 '\uCE59\uB839'\uC774\uC57C. \uB124\uAC00
    \uC5B4\uB514\uC5D0 \uC788\uB4E0, \uC774 \uBB38\uC7A5\uB9CC \uC788\uC73C\uBA74
    \uC5B8\uC81C\uB4E0 \uC774 \uC11C\uC7AC\uC5D0 \uB4E4\uC5B4\uC62C \uC218 \uC788\uC5B4.
    \uBC31\uC791\uB2D8\uB3C4 \uC774\uC81C \uC6B0\uB9AC\uAC00 \uD568\uAED8 \uBBF8\uB798\uB97C
    \uC124\uACC4\uD558\uB294 \uAC78 \uD5C8\uB77D\uD574\uC8FC\uC2E4 \uAC70\uC57C.\n       
    \uCE5C\uAD6C 1 : (\uAC10\uACA9\uD55C \uB4EF \uBB38\uC7A5\uC744 \uBC14\uB77C\uBCF4\uBA70)
    \uC640... \uC9C4\uC9DC \uBA4B\uC9C0\uB2E4! \uC774\uC81C \uBE44\uBC00 \uD1B5\uB85C\uB85C
    \uBAB0\uB798 \uB4E4\uC5B4\uC624\uC9C0 \uC54A\uC544\uB3C4 \uB41C\uB2E4\uB294 \uAC70\uC9C0?
    \uBC31\uC791\uB2D8 \uC11C\uC7AC\uB97C \uC6B0\uB9AC\uB4E4\uC758 \uC9C4\uC9DC \uC544\uC9C0\uD2B8\uB85C
    \uB9CC\uB4DC\uB294 \uAC70\uC57C?\n        \uB124\uBAA8 : (\uC6C3\uC73C\uBA70)
    \uB2F9\uC5F0\uD558\uC9C0! \uBC31\uC791\uB2D8\uC774 \uC313\uC544 \uC62C\uB9B0
    \uC774 \uACAC\uACE0\uD55C \uC138\uACC4 \uC704\uC5D0, \uC6B0\uB9AC\uAC00 \uAFC8\uAFB8\uB294
    \uC0C8\uB85C\uC6B4 \uC138\uC0C1\uC744 \uADF8\uB824 \uB123\uC790. \uB10C \uB0B4
    \uC601\uC6D0\uD55C \uB3D9\uB8CC\uB2C8\uAE4C!"
  _dialogueLines: []
