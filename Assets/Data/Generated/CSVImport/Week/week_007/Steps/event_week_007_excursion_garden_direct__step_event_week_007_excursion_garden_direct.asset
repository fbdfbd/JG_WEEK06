  _titleOverride: "\uC815\uC6D0 \uD5C8\uAC00"
  _bodyText: "excursion garden Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124, \uC8FC\uC778\uB2D8. \uB098\uBB34\uAC00 \uC790\uB780 \uB9CC\uD07C
      \uC8FC\uC778\uB2D8\uB3C4 \uC544\uC8FC \uBA4B\uC9C4 \uC5B4\uB978\uC774 \uB418\uC168\uB294\uAC78\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD788\uD788, \uB098\uC911\uC5D4 \uC5EC\uAE30 \uC758\uC790\uB3C4 \uAC00\uC838\uB2E4
      \uB193\uACE0 \uCC45\uB3C4 \uC77D\uACE0 \uC2F6\uC5B4. \uB0B4\uAC00 \uC9C1\uC811
      \uAC00\uAFBC \uB098\uBB34\uB2C8\uAE4C \uB354 \uC88B\uC544."
  _nemoLine: "\uB124, \uC8FC\uC778\uB2D8. \uB098\uBB34\uAC00 \uC790\uB780 \uB9CC\uD07C
    \uC8FC\uC778\uB2D8\uB3C4 \uC544\uC8FC \uBA4B\uC9C4 \uC5B4\uB978\uC774 \uB418\uC168\uB294\uAC78\uC694."
