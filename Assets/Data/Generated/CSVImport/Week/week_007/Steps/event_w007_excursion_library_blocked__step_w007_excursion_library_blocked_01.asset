  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_excursion_library_blocked__step_w007_excursion_library_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 7\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uCC9C\uC7A5\uAE4C\uC9C0 \uB2FF\uC740 \uB192\uC740 \uC11C\uAC00 \uC0AC\uC774.
    \uB124\uBAA8\uAC00 \uC0AC\uB2E4\uB9AC\uC5D0 \uC62C\uB77C\uAC00 \uB450\uAEBC\uC6B4
    \uC601\uC9C0 \uAD00\uB9AC\uBC95 \uC804\uC9D1\uC744 \uAEBC\uB0B8\uB2E4. \uC720\uB144\uAE30\uC5D4
    \uADF8\uB9BC\uCC45\uB9CC \uBCF4\uB358 \uC544\uC774\uAC00 \uC774\uC81C\uB294 \uBCF5\uC7A1\uD55C
    \uBC95\uC804\uACFC \uD1B5\uACC4 \uC218\uCE58\uB97C \uC77D\uC5B4\uB0B4\uACE0 \uC788\uB2E4.)\r\n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8, \uADF8\uB7F0 \uB531\uB531\uD55C \uCC45\uB9CC
    \uBCF4\uC2DC\uBA74 \uBA38\uB9AC \uC544\uD504\uC9C0 \uC54A\uC73C\uC138\uC694?
    \uC800\uAE30 \uCC3D\uAC00 \uCABD\uC5D0 \uC694\uC998 \uC720\uD589\uD558\uB294
    \uC5F0\uC560 \uC18C\uC124\uB3C4 \uC0C8\uB85C \uB4E4\uC5B4\uC654\uB358\uB370.\r\n       
    \r\n\r\n(\uACBD\uBE44\uB300\uC7A5\uC774 \uC0AC\uB2E4\uB9AC \uC544\uB798\uC5D0\uC11C
    \uB124\uBAA8\uB97C \uC5C4\uD558\uAC8C \uC62C\uB824\uB2E4\uBCF8\uB2E4.)\r\n       
    \uACBD\uBE44\uB300\uC7A5 : \uC601\uC560\uB85C\uC11C \uAC16\uCDB0\uC57C \uD560
    \uAD50\uC591\uBCF4\uB2E4 \uC2E4\uC9C8\uC801\uC778 \uD1B5\uCE58 \uC9C0\uC2DD\uC774
    \uC6B0\uC120\uC785\uB2C8\uB2E4. \uC18C\uC124 \uAC19\uC740 \uD5C8\uC0C1\uC740
    \uD310\uB2E8\uB825\uC744 \uD750\uB9B4 \uBFD0\uC774\uB2C8, \uC624\uB298 \uC815\uD574\uC9C4
    \uBD84\uB7C9\uC758 \uBC95\uC804\uC744 \uB2E4 \uC77D\uAE30 \uC804\uC5D4 \uC11C\uAC00\uB97C
    \uBC97\uC5B4\uB098\uC9C0 \uB9C8\uC2ED\uC2DC\uC624.\r\n        \uB124\uBAA8 :
    \uC800\uB3C4 \uC54C\uC544\uC694, \uC544\uC800\uC528. \uD558\uC9C0\uB9CC \uAC00\uB054\uC740
    \uC228\uC744 \uC880 \uB3CC\uB9AC\uACE0 \uC2F6\uC740\uAC78\uC694. \uBC95 \uBB38\uC7A5\uB4E4\uC774
    \uB108\uBB34 \uBE7D\uBE7D\uD574\uC11C \uB208\uC774 \uCE68\uCE68\uD574\uC694.\r\n       
    \uACBD\uBE44\uB300\uC7A5 : \uADF8 \uCE68\uCE68\uD568\uC744 \uACAC\uB514\uB294
    \uC790\uB9CC\uC774 \uC778\uC7A5\uC744 \uC958 \uC790\uACA9\uC774 \uC788\uC2B5\uB2C8\uB2E4.
    \uACC4\uC18D\uD558\uC2ED\uC2DC\uC624."
