  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB0B4\uAC00 \uAD00\uB9AC\uD574\uC57C \uD560 \uB545\uC774\uB2C8\uAE4C,
      \uB0B4 \uC190\uC73C\uB85C \uADF8\uB9B0 \uC9C0\uB3C4\uB97C \uBCF4\uBA74\uC11C
      \uB9E4\uC77C \uB2E4\uC9D0\uD558\uACE0 \uC2F6\uC5B4."
  _nemoLine: "\uC5B4\uBA38, \uC8FC\uC778\uB2D8\uC774 \uC9C1\uC811 \uADF8\uB9AC\uC2E0
