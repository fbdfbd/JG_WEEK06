  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_excursion_basement_blocked__step_w007_excursion_basement_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 7\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uC5B4\uB450\uC6B4 \uC9C0\uD558\uC2E4 \uC548\uCABD. \uD654\uB824\uD55C
    \uBCF8\uAD00\uACFC \uB2EC\uB9AC, \uC774\uACF3\uC5D0\uB294 \uBE5B\uC774 \uBC14\uB798\uACE0
    \uCC22\uC5B4\uC9C4 \uC61B \uC120\uB300\uB4E4\uC758 \uCD08\uC0C1\uD654\uC640 \uB0A1\uC740
    \uAC00\uAD6C\uB4E4\uC774 \uCC9C\uC73C\uB85C \uB36E\uC5EC \uC788\uB2E4.)\r\n       
    \uD558\uB140 : \uCF5C\uB85D, \uC5EC\uAE30\uB294 \uBA3C\uC9C0\uAC00 \uB108\uBB34
    \uB9CE\uC544\uC694, \uC8FC\uC778\uB2D8. \uCE58\uB9DB\uC790\uB77D\uC774 \uC0C1\uD560
    \uD14C\uB2C8 \uADF8\uB9CC \uC62C\uB77C\uAC00\uC2DC\uB294 \uAC8C \uC5B4\uB5A8\uAE4C\uC694?\r\n       
    \uB124\uBAA8 : \uC7A0\uAE50\uB9CC. \uC774 \uCD08\uC0C1\uD654 \uC18D \uBD80\uC778,
    \uB098\uB791 \uB208\uB9E4\uAC00 \uC544\uC8FC \uBE44\uC2B7\uD558\uAC8C \uC0DD\uAE30\uC168\uC5B4.
    \uC65C \uC774\uB7F0 \uAD6C\uC11D\uC5D0 \uBC84\uB824\uC838 \uC788\uB294 \uAC78\uAE4C?\r\n       
    \r\n\r\n(\uACBD\uBE44\uB300\uC7A5\uC774 \uD683\uBD88\uC744 \uB192\uC774 \uB4E4\uBA70
    \uB124\uBAA8\uC640 \uCD08\uC0C1\uD654 \uC0AC\uC774\uB97C \uAC00\uB85C\uB9C9\uB294\uB2E4.)\r\n       
    \uACBD\uBE44\uB300\uC7A5 : \uBE5B\uC744 \uC783\uACE0 \uC9C0\uD558\uB85C \uB0B4\uB824\uC628
    \uB370\uC5D0\uB294 \uB2E4 \uADF8\uB9CC\uD55C \uC774\uC720\uAC00 \uC788\uB294
    \uBC95\uC785\uB2C8\uB2E4. \uAC00\uBB38\uC758 \uC601\uAD11\uC744 \uC774\uC5B4\uB098\uAC08
    \uC544\uAC00\uC528\uAED8\uC11C \uAD73\uC774 \uC2E4\uD328\uD55C \uACFC\uAC70\uB97C
    \uB4E4\uCDB0\uBCF4\uC2E4 \uD544\uC694\uB294 \uC5C6\uC2B5\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : \uC2E4\uD328\uB77C\uB2C8, \uADF8\uAC8C \uBB34\uC2A8 \uB73B\uC774\uC5D0\uC694?
    \uC774\uBD84\uB3C4 \uC6B0\uB9AC \uAC00\uC871\uC774\uC796\uC544\uC694.\r\n       
    \uACBD\uBE44\uB300\uC7A5 : (\uB2E8\uD638\uD558\uAC8C) \uC704\uB85C \uC62C\uB77C\uAC00\uC2DC\uC8E0.
    \uC9C0\uD558\uC758 \uACF0\uD321\uC774 \uB0C4\uC0C8\uB294 \uAE30\uD488\uC744 \uD574\uCE69\uB2C8\uB2E4."
