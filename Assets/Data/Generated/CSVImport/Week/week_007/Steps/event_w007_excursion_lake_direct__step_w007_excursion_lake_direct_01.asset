  m_Name: event_w007_excursion_lake_direct__step_w007_excursion_lake_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 7\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uC794\uC794\uD55C \uD638\uC22B\uAC00. \uB124\uBAA8\uAC00 \uBB3C\uAC00\uC5D0
    \uC11C\uC11C \uBE44\uCE5C \uC790\uC2E0\uC758 \uBAA8\uC2B5\uC744 \uBB3C\uB044\uB7EC\uBBF8
    \uBC14\uB77C\uBCF4\uACE0 \uC788\uB2E4. \uC720\uB144\uAE30\uBCF4\uB2E4 \uD6CC\uCA4D
    \uC790\uB780 \uD0A4\uC640 \uCC28\uBD84\uD558\uAC8C \uB54B\uC544 \uB0B4\uB9B0
    \uBA38\uB9AC\uCE7C, \uAE30\uD488 \uC788\uB294 \uC790\uD0DC\uAC00 \uC218\uBA74\uC5D0
    \uBE44\uCE5C\uB2E4.)\n        \uD558\uB140 : \uC8FC\uC778\uB2D8, \uC774\uC81C\uB294
    \uC815\uB9D0 \uC544\uB984\uB2E4\uC6B4 \uC601\uC560\uAC00 \uB2E4 \uB418\uC168\uC5B4\uC694.
    \uD638\uC218\uC5D0 \uBE44\uCE5C \uBAA8\uC2B5\uC774 \uBC31\uC791\uB2D8\uC744 \uAF2D
    \uB2EE\uC544 \uC544\uC8FC \uB2E8\uB2E8\uD558\uACE0 \uC6B0\uC544\uD574 \uBCF4\uC774\uC2ED\uB2C8\uB2E4.\n       
    \n\n\uD558\uB140 : \uB124, \uBC1C\uAC78\uC74C \uD558\uB098\uD558\uB098\uAC00
    \uC544\uC8FC \uAC00\uBCBC\uC6B0\uC2E0\uAC78\uC694. \uD638\uC218\uB3C4 \uD6CC\uCA4D
    \uC790\uB77C\uC2E0 \uC8FC\uC778\uB2D8\uC744 \uBC18\uAE30\uB294 \uAC83 \uAC19\uC544\uC694.\n       
    \uB124\uBAA8 : \uB098\uC911\uC5D0 \uC131\uC778\uC2DD \uB54C \uC785\uC744 \uB4DC\uB808\uC2A4\uB3C4
    \uC774 \uD638\uC218 \uC0C9\uAE54\uC774\uB791 \uBE44\uC2B7\uD55C \uD478\uB978\uC0C9\uC774\uBA74
    \uC88B\uACA0\uB2E4."
