  _titleOverride: "\uB9C9\uC2A4\uC758 \uD3B8\uC9C0 \uC218\uC815"
  _bodyText: "letter friend_1 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uB9C9\uC2A4 \uB3C4\uB828\uB2D8\uC774 \uC131\uC778\uC2DD
      \uB0A0 \uB204\uAD6C\uBCF4\uB2E4 \uD06C\uAC8C \uCD95\uD558\uD574 \uB4DC\uB9AC\uACE0
      \uC2F6\uB2E4\uACE0 \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC54\uB2E4\uC6B4 \uB9D0\uC774\uB2E4. \uBC8C\uC368 \uC2DC\uB044\uB7EC\uC6B8
      \uAC83 \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uAE34\uC7A5\uD558\uC9C0 \uB9D0\uACE0 \uC6C3\uC73C\uBA74\uC11C \uAC78\uC5B4\uC624\uBA74
      \uB41C\uB2E4\uACE0\uB3C4 \uB367\uBD99\uC600\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uADF8\uB7FC \uB098\uB3C4 \uC6C3\uC73C\uBA74\uC11C \uC778\uC0AC\uD574\uC57C\uC9C0."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uB9C9\uC2A4 \uB3C4\uB828\uB2D8\uC774 \uC131\uC778\uC2DD
    \uB0A0 \uB204\uAD6C\uBCF4\uB2E4 \uD06C\uAC8C \uCD95\uD558\uD574 \uB4DC\uB9AC\uACE0
    \uC2F6\uB2E4\uACE0 \uD569\uB2C8\uB2E4."
