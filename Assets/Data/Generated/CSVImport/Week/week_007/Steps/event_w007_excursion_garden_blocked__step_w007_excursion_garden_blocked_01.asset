  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_excursion_garden_blocked__step_w007_excursion_garden_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 7\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uC815\uC6D0 \uC548\uCABD, \uC720\uB144\uAE30 \uB54C \uC2EC\uC5C8\uB358
    \uC5B4\uB9B0\uB098\uBB34\uAC00 \uC774\uC81C \uB124\uBAA8\uC758 \uD0A4\uB97C \uD6CC\uCA4D
    \uB118\uACA8 \uBB34\uC131\uD558\uAC8C \uC790\uB77C \uC788\uB2E4.)\r\n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8, \uAE30\uC5B5\uB098\uC138\uC694? \uC774 \uB098\uBB34
    \uC8FC\uC778\uB2D8\uC774 \uC694\uB9CC\uD560 \uB54C \uAC19\uC774 \uC2EC\uC5C8\uC796\uC544\uC694.
    \uC774\uC81C\uB294 \uC8FC\uC778\uB2D8\uC744 \uC9C0\uCF1C\uC904 \uB9CC\uD07C \uB4E0\uB4E0\uD574\uC84C\uB124\uC694.\r\n       
    \r\n\r\n(\uACBD\uBE44\uB300\uC7A5\uC774 \uB098\uBB34 \uC904\uAE30\uB97C \uC0B4\uD53C\uBA70
    \uAC00\uC9C0\uCE58\uAE30 \uAC00\uC704\uB97C \uB4E0\uB2E4.)\r\n        \uACBD\uBE44\uB300\uC7A5
    : \uB108\uBB34 \uC81C\uBA4B\uB300\uB85C \uC790\uB790\uAD70\uC694. \uC8FC\uC778\uC758
    \uB098\uBB34\uB77C\uBA74 \uC808\uC81C\uB41C \uD615\uD0DC\uB97C \uC720\uC9C0\uD574\uC57C
    \uD569\uB2C8\uB2E4. \uBCF4\uAE30 \uD749\uD55C \uAC00\uC9C0\uB4E4\uC740 \uCCD0\uB0B4\uACA0\uC2B5\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : \uC790\uC5F0\uC2A4\uB7EC\uC6B4 \uAC8C \uB354 \uBCF4\uAE30 \uC88B\uC740\uB370...
    \uAF2D \uADF8\uB807\uAC8C \uB531\uB531\uD558\uAC8C \uC798\uB77C\uC57C \uD574\uC694?\r\n       
    \uACBD\uBE44\uB300\uC7A5 : \uBB34\uC9C8\uC11C\uB294 \uACE7 \uC57D\uC810\uC785\uB2C8\uB2E4.
    \uB3C4\uB828\uB2D8\uB3C4 \uC774 \uB098\uBB34\uCC98\uB7FC \uC2A4\uC2A4\uB85C\uB97C
    \uAC08\uACE0\uB2E6\uC73C\uC154\uC57C \uD569\uB2C8\uB2E4."
