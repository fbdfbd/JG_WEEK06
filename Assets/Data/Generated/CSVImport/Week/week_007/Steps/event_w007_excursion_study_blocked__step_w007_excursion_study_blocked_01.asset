  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_excursion_study_blocked__step_w007_excursion_study_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC 7\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uC11C\uC7AC \uCC45\uC0C1 \uC704\uC5D0 \uC720\uB144\uAE30 \uC2DC\uC808
    \uC544\uB07C\uB358 \uC791\uC740 \uC778\uD615\uACFC \uC9C0\uAE08\uC740 \uC190\uB54C
    \uBB3B\uC740 \uB450\uAEBC\uC6B4 \uACBD\uC81C\uD559 \uC11C\uC801\uC774 \uB098\uB780\uD788
    \uB193\uC5EC \uC788\uB2E4. \uC8FC\uC778\uB2D8\uC740 \uC774\uC81C \uC758\uC790\uC5D0
    \uC549\uC544\uB3C4 \uBC1C\uC774 \uBC14\uB2E5\uC5D0 \uB2FF\uC9C0 \uC54A\uB358
    \uAF2C\uB9C8\uAC00 \uC544\uB2C8\uB2E4.)\n        \n        \uD558\uB140 : \uC8FC\uC778\uB2D8,
    \uC774 \uC778\uD615\uC740 \uC774\uC81C \uB2E4\uB978 \uACF3\uC73C\uB85C \uC62E\uACA8\uB458\uAE4C\uC694?
    \uC774\uC81C\uB294 \uC911\uC694\uD55C \uC11C\uB958\uB4E4\uC774 \uB9CE\uC544\uC11C
    \uC790\uB9AC\uAC00 \uC881\uC544 \uBCF4\uC774\uB124\uC694.\n        \n\n(\uACBD\uBE44\uB300\uC7A5\uC774
    \uC11C\uC7AC\uB85C \uB4E4\uC5B4\uC640 \uC778\uD615\uC744 \uC9D1\uC5B4 \uB4E4\uC5B4
    \uD558\uB140\uC5D0\uAC8C \uAC74\uB128\uB2E4.)\n        \uACBD\uBE44\uB300\uC7A5
    : \uC8FC\uC778\uC758 \uC9D1\uBB34\uC2E4\uC5D0 \uC544\uC774\uB4E4\uC758 \uC7A5\uB09C\uAC10\uC740
    \uC5B4\uC6B8\uB9AC\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4. \uACFC\uAC70\uC758 \uD754\uC801\uC744
    \uC9C0\uC6B0\uACE0 \uD604\uC7AC\uC758 \uCC45\uC784\uC5D0\uB9CC \uC9D1\uC911\uD558\uC2ED\uC2DC\uC624.
    \uADF8\uAC83\uC774 \uBC31\uC791\uB2D8\uAED8\uC11C \uC6D0\uD558\uC2DC\uB294 \uBAA8\uC2B5\uC785\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uC544\uC9C1\uC740 \uBC84\uB9AC\uACE0 \uC2F6\uC9C0 \uC54A\uC740\uB370...
    \uD558\uC9C0\uB9CC \uC544\uC800\uC528 \uB9D0\uC774 \uB9DE\uACA0\uC8E0. \uC774\uC81C
    \uC800\uB294 \uC544\uC774\uAC00 \uC544\uB2C8\uB2C8\uAE4C\uC694.\n        \uACBD\uBE44\uB300\uC7A5
    : \uD604\uBA85\uD55C \uC120\uD0DD\uC785\uB2C8\uB2E4. \uC790, \uC624\uB298\uC758
    \uC601\uC9C0 \uC608\uC0B0\uC548\uC744 \uAC80\uD1A0\uD558\uC2DC\uC8E0."
