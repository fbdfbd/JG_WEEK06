  _titleOverride: "\uD68C\uACC4 \uC218\uC5C5\uC744 \uC0DD\uD65C \uC608\uC2DC\uB85C
    \uD47C\uB2E4"
  _bodyText: "\uD68C\uACC4 \uC218\uC5C5\uC744 \uC0DD\uD65C \uC608\uC2DC\uB85C \uD47C\uB2E4
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC800\uD0DD \uC0B4\uB9BC \uC608\uC2DC\uB97C \uB4E4\uC5B4 \uC22B\uC790\uC758
      \uC758\uBBF8\uB97C \uC27D\uAC8C \uD480\uC5B4 \uC124\uBA85\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7EC\uB2C8\uAE4C \uC0AC\uACFC \uC5F4 \uAC1C\uAC00 \uC5B4\uB514\uB85C
      \uAC14\uB294\uC9C0 \uC138\uB294 \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uC0DD\uD65C \uC18D \uACC4\uC0B0\uC73C\uB85C \uBC14\uAFB8\uC5B4 \uAD50\uC7AC\uC758
      \uC7A5\uBCBD\uC744 \uB0AE\uCD98\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774 \uC815\uB3C4\uBA74 \uC800\uB3C4 \uC870\uAE08\uC740 \uB530\uB77C\uAC08
      \uC218 \uC788\uC5B4."
  _nemoLine: "(\uC800\uD0DD \uC0B4\uB9BC \uC608\uC2DC\uB97C \uB4E4\uC5B4 \uC22B\uC790\uC758
    \uC758\uBBF8\uB97C \uC27D\uAC8C \uD480\uC5B4 \uC124\uBA85\uD55C\uB2E4.)"
