  _titleOverride: "\uCCA0\uAC11 \uAE30\uBCD1\uB300 \uC18C\uBB38 - \uC218\uC815"
  _bodyText: "\uCCA0\uAC11 \uAE30\uBCD1\uB300 \uC18C\uBB38 - \uC218\uC815 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uAD6D\uACBD\uC744 \uC9C0\uD0A4\uB294 \uAE30\uBCD1\uB300\uAC00 \uB354
      \uC6C0\uC9C1\uC778\uB2E4\uB294 \uC18C\uC2DD\uC774 \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC804\uC7C1 \uC598\uAE30\uCC98\uB7FC \uB4E4\uB9AC\uB294\uB370."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uBC14\uB85C \uACF5\uD3EC\uB85C \uBC1B\uC544\uB4E4\uC774\uAE30\uBCF4\uB2E8,
      \uBBF8\uB9AC \uB300\uBE44\uD574\uC11C \uC548\uCABD\uC744 \uC9C0\uD0A4\uB294
      \uC808\uCC28\uB77C\uACE0 \uC0DD\uAC01\uD558\uBA74 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uADF8\uB807\uAC8C \uB4E4\uC73C\uB2C8\uAE4C \uC870\uAE08 \uB35C
      \uBB34\uAC70\uC6CC."
  _nemoLine: "\uAD6D\uACBD\uC744 \uC9C0\uD0A4\uB294 \uAE30\uBCD1\uB300\uAC00 \uB354
    \uC6C0\uC9C1\uC778\uB2E4\uB294 \uC18C\uC2DD\uC774 \uC788\uC5B4\uC694."
