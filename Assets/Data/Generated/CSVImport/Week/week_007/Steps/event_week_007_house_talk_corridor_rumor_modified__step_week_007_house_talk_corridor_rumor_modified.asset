  _titleOverride: "\uAE30\uC774\uD55C \uBB38 \uC18C\uBB38 - \uC218\uC815"
  _bodyText: "\uAE30\uC774\uD55C \uBB38 \uC18C\uBB38 - \uC218\uC815 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uBC24 \uBCF5\uB3C4\uAC00 \uAD1C\uD788 \uAE38\uC5B4 \uBCF4\uC778\uB2E4\uB294
      \uB9D0\uC740 \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uC9C4\uC9DC \uBB38\uC774 \uC0DD\uAE34\uB2E4\uB294 \uC18C\uBB38\uC740
      \uAC70\uC9D3\uB9D0\uC774\uC57C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uBB34\uC11C\uC6B4 \uAD34\uB2F4\uBCF4\uB2E4\uB294, \uBD88\uBE5B\uACFC
      \uADF8\uB9BC\uC790 \uD0D3\uC5D0 \uCC29\uAC01\uD558\uB294 \uAC70\uB77C\uACE0
      \uC0DD\uAC01\uD558\uBA74 \uB3FC\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uADF8\uB807\uAC8C \uB4E4\uC73C\uB2C8\uAE4C \uADF8\uB0E5 \uC870\uC2EC\uD558\uBA74
      \uB420 \uAC83 \uAC19\uC544."
  _nemoLine: "\uBC24 \uBCF5\uB3C4\uAC00 \uAD1C\uD788 \uAE38\uC5B4 \uBCF4\uC778\uB2E4\uB294
    \uB9D0\uC740 \uC788\uC5B4\uC694."
