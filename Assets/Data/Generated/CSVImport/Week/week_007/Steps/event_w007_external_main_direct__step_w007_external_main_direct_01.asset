  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_external_main_direct__step_w007_external_main_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "7\uCC28 - \uD5C8\uB77D"
  _bodyText: "\uAD6D\uACBD\uC758 \uAE34\uC7A5\uACFC \uCCA0\uAC11 \uAE30\uBCD1\uB300\n   
    \n    (\uC800\uD0DD \uB4B7\uBB38, \uC2DD\uC790\uC7AC\uB97C \uB0A9\uD488\uD558\uB294
    \uC0C1\uC778\uC774 \uACBD\uBE44\uBCD1\uC5D0\uAC8C \uC740\uBC00\uD558\uAC8C \uAC00\uC8FD
    \uC8FC\uBA38\uB2C8\uB97C \uAC74\uB124\uBA70 \uC18D\uC0AD\uC778\uB2E4.)\n    \n   
    \uC0C1\uC778 : \uC774\uBD10, \uAD6D\uACBD \uB108\uBA38 \uC81C\uAD6D\uAD70\uC774
    \uC2EC\uC0C1\uCE58 \uC54A\uC544. \uC628\uBAB8\uC744 \uCCA0\uAC11\uC73C\uB85C
    \uB450\uB978 \uAE30\uBCD1\uB300\uAC00 \uBC8C\uC368 \uADFC\uCC98 \uB9C8\uC744\uAE4C\uC9C0
    \uB0B4\uB824\uC654\uB2E4\uB354\uAD70.\n    \uACBD\uBE44\uBCD1 : \uC27F! \uBC31\uC791\uB2D8\uC774
    \uD568\uAD6C\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4. \uC131\uC778\uC2DD \uCD95\uC81C
    \uBD84\uC704\uAE30\uB97C \uB9DD\uCE58\uACE0 \uC2F6\uC9C0 \uC54A\uC73C\uC2E0 \uAC8C\uC9C0.\n   
    \uB124\uBAA8 : \uCCA0\uAC11 \uAE30\uBCD1\uB300? \uC6B0\uB9AC \uC601\uC9C0\uB85C
    \uCCD0\uB4E4\uC5B4\uC624\uB294 \uAC70\uC57C?\n    \n\n- \uC0C1\uC778 : \uC2E4\uC740
    \uBC31\uC791\uB2D8\uC758 \uC704\uC5C4\uC774 \uC6CC\uB099 \uB300\uB2E8\uD574\uC11C,
    \uC81C\uAD6D\uC5D0\uC11C\uB3C4 \uC8FC\uC778\uB2D8\uC758 \uC131\uC778\uC2DD\uC744
    \uCD95\uD558\uD558\uB7EC \uD638\uC704 \uBCD1\uB825\uC744 \uBCF4\uB0B8\uB2E4\uB294
    \uC18C\uBB38\uC774 \uC788\uC5B4\uC694.\n    \uB124\uBAA8 : \uB098\uB97C \uCD95\uD558\uD574\uC8FC\uB7EC
    \uADF8 \uBB34\uC11C\uC6B4 \uAE30\uBCD1\uB300\uAC00 \uC624\uB294 \uAC70\uC57C?
    \uADF8\uB7FC \uC6B0\uB9AC \uAC00\uBB38\uC774 \uC815\uB9D0 \uD798\uC774 \uC13C
    \uAC70\uB124!\n    \uACBD\uBE44\uBCD1 : \uADF8\uB7FC\uC694. \uC8FC\uC778\uB2D8\uC774
    \uC131\uC778\uC774 \uB418\uBA74 \uADF8 \uAE30\uBCD1\uB300\uB3C4 \uC8FC\uC778\uB2D8
    \uBC1C\uC544\uB798 \uBB34\uB98E\uC744 \uAFC7\uC744 \uAC81\uB2C8\uB2E4. \uB2F9\uB2F9\uD558\uAC8C
    \uACC4\uC2ED\uC2DC\uC624.\n    \uB124\uBAA8 : \uC6B0\uC640... \uB098\uB3C4 \uB098\uC911\uC5D0
    \uADF8 \uCCA0\uAC11 \uB9D0\uC744 \uD0C0\uBCFC \uC218 \uC788\uC744\uAE4C? \uC870\uAE08
    \uB5A8\uB9AC\uC9C0\uB9CC \uAE30\uB300\uB3FC!"
