  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "(\uC11C\uB958\uB97C \uC0B4\uD53C\uBA70) \uC6B0\uC640, \uC9C4\uC9DC\uB124?
      \uBC31\uC791\uB2D8\uC740 \uAC89\uC73C\uB860 \uBB34\uB69D\uB69D\uD574\uB3C4
      \uB4A4\uC5D0\uC11C \uC774\uB7F0 \uC77C\uC744 \uD558\uACE0 \uACC4\uC168\uAD6C\uB098.
      \uB124\uBAA8 \uB108\uB3C4 \uB098\uC911\uC5D0 \uC774\uB7F0 \uBA4B\uC9C4 \uC8FC\uC778\uC774
      \uB420 \uAC70\uC9C0?"
  _nemoLine: "(\uC11C\uB958\uB97C \uC0B4\uD53C\uBA70) \uC6B0\uC640, \uC9C4\uC9DC\uB124?
