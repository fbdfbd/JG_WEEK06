  _titleOverride: "\uCE74\uC774\uC548 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor cousin_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uC624, \uC81C\uBC95 \uB0A0\uCE74\uB85C\uC6B4\uB370? \uD558\uC9C0\uB9CC
      \uBC31\uC791\uC774 \uB110 \uC774 \uC11C\uC7AC\uC5D0 \uAC00\uB46C\uB454 \uC9C4\uC9DC
      \uC774\uC720\uAC00 '\uBCF4\uD638'\uB77C\uACE0 \uBBFF\uB294\uB2E4\uBA74 \uB10C
      \uD3C9\uC0DD \uADF8\uBD84\uC758 \uAF2D\uB450\uAC01\uC2DC\uC77C \uBFD0\uC774\uC57C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC778\uC7A5\uC744 \uAF49 \uC950\uBA70) \uBC31\uC791\uB2D8\uC774 \uC228\uAE30\uB294
      \uAC8C \uC788\uB2E4\uBA74 \uB0B4\uAC00 \uC9C1\uC811 \uC54C\uC544\uB0BC \uAC70\uC608\uC694.
      \uC0BC\uCD0C \uAC19\uC740 \uC801\uC758 \uC190\uC744 \uC7A1\uB294 \uC77C\uC740
      \uC5C6\uC744 \uD14C\uB2C8\uAE4C \uB2F9\uC7A5 \uB098\uAC00\uC694!"
  _nemoLine: "\uC624, \uC81C\uBC95 \uB0A0\uCE74\uB85C\uC6B4\uB370? \uD558\uC9C0\uB9CC
    \uBC31\uC791\uC774 \uB110 \uC774 \uC11C\uC7AC\uC5D0 \uAC00\uB46C\uB454 \uC9C4\uC9DC
    \uC774\uC720\uAC00 '\uBCF4\uD638'\uB77C\uACE0 \uBBFF\uB294\uB2E4\uBA74 \uB10C
    \uD3C9\uC0DD \uADF8\uBD84\uC758 \uAF2D\uB450\uAC01\uC2DC\uC77C \uBFD0\uC774\uC57C."
