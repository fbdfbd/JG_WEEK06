  _titleOverride: "\uC804\uC220 \uC218\uC5C5\uC744 \uD310\uC9DC\uAE30\uCC98\uB7FC
    \uD47C\uB2E4"
  _bodyText: "\uC804\uC220 \uC218\uC5C5\uC744 \uD310\uC9DC\uAE30\uCC98\uB7FC \uD47C\uB2E4
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB9D0\uD310\uC744 \uC6C0\uC9C1\uC774\uB4EF \uC0C1\uD669\uC744 \uAC00\uC815\uD574
      \uC804\uC220 \uAD50\uC7AC\uB97C \uC27D\uAC8C \uD480\uC5B4 \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uB3CC \uB193\uB294 \uAC8C\uC784\uC774\uB791 \uC880 \uBE44\uC2B7\uD574."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uBD80\uB2F4\uC2A4\uB7EC\uC6B4 \uC804\uC7C1 \uC774\uC57C\uAE30 \uB300\uC2E0
      \uC120\uD0DD\uC758 \uD750\uB984\uC5D0 \uC9D1\uC911\uD558\uAC8C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uB807\uAC8C \uD558\uBA74 \uB35C \uBB34\uC12D\uACE0 \uB354 \uC798
      \uBCF4\uC774\uB124."
  _nemoLine: "(\uB9D0\uD310\uC744 \uC6C0\uC9C1\uC774\uB4EF \uC0C1\uD669\uC744 \uAC00\uC815\uD574
    \uC804\uC220 \uAD50\uC7AC\uB97C \uC27D\uAC8C \uD480\uC5B4 \uC900\uB2E4.)"
