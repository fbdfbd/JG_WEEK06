  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_visitor_cousin_2_blocked__step_w007_visitor_cousin_2_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 7\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uBC31\uC791\uB2D8\uC774 \uC790\uB9AC\uB97C \uBE44\uC6B4 \uC11C\uC7AC.
    \uC0AC\uCD0C 2\uAC00 \uBB38\uC55E\uC5D0\uC11C \uB4E4\uC5B4\uC624\uC9C0 \uBABB\uD558\uACE0
    \uBA38\uBB47\uAC70\uB9AC\uACE0 \uC788\uC5B4. \uC0AC\uCD0C 1\uC774 \uD718\uC800\uC5B4
    \uB193\uC740 \uBE44\uB9BF\uD55C \uACF5\uAE30\uAC00 \uC544\uC9C1 \uB0A8\uC544\uC788\uB294\uB370,
    \uC0AC\uCD0C 2\uB294 \uB124\uBAA8\uC758 \uC548\uC0C9\uC744 \uC0B4\uD53C\uBA70
    \uC791\uC740 \uC8FC\uBA38\uB2C8\uB97C \uB0B4\uBC00\uC5B4.)\n        \n       
    \uC0AC\uCD0C 2 : \uB124\uBAA8\uC57C... \uC548\uC0C9\uC774 \uC65C \uADF8\uB798?
    \uC6B0\uB9AC \uC544\uBE60\uAC00 \uB610 \uC774\uC0C1\uD55C \uC18C\uB9AC \uD558\uACE0
    \uAC14\uC5B4? \uC5EC\uAE30... \uC774\uAC70 \uBA39\uACE0 \uAE30\uC6B4 \uB0B4.
    \uB124\uAC00 \uC88B\uC544\uD558\uB294 \uAC70\uC57C.\n        \uB124\uBAA8 : (\uC0AC\uCD0C
    1\uC774 \uC92C\uB358 \uC778\uC7A5\uC744 \uB5A0\uC62C\uB9AC\uBA70) \uC0AC\uCD0C
    2, \uB108\uD76C \uC544\uBC84\uC9C0\uB294 \uB098\uD55C\uD14C \uBB58 \uC6D0\uD558\uC2DC\uB294
    \uAC78\uAE4C?\n        \n\n- (\uB124\uBAA8\uAC00 \uC0AC\uD0D5 \uC8FC\uBA38\uB2C8\uB97C
    \uBC1B\uC73C\uB824 \uD558\uC790, \uC9D1\uC0AC\uAC00 \uB098\uD0C0\uB098 \uC8FC\uBA38\uB2C8\uB97C
    \uB09A\uC544\uCC44 \uAC80\uC0AC\uD55C\uB2E4.)\n        - \uC9D1\uC0AC : \uC678\uBD80
    \uC74C\uC2DD\uC740 \uB3C5\uADF9\uBB3C \uAC80\uC0AC \uC804\uAE4C\uC9C0 \uAE08\uC9C0\uC785\uB2C8\uB2E4.
    \uC0AC\uCD0C 2 \uB3C4\uB828\uB2D8, \uC11C\uC7AC\uC758 \uADDC\uC728\uC744 \uC5B4\uAE30\uC9C0
    \uB9C8\uC2ED\uC2DC\uC624.\n        \uC0AC\uCD0C 2 : (\uAE5C\uC9DD \uB180\uB77C\uBA70)
    \uC544, \uC544\uB2C8\uC5D0\uC694! \uADF8\uB0E5 \uC0AC\uD0D5\uC77C \uBFD0\uC778\uB370...
    \uB124\uBAA8\uC57C, \uBBF8\uC548\uD574. \uB0B4\uAC00 \uB610 \uBC31\uC791\uB2D8
    \uADDC\uCE59\uC744 \uC5B4\uACBC\uB098 \uBD10.\n        \uB124\uBAA8 : (\uC9D1\uC0AC\uC5D0\uAC8C)
    \uB0B4 \uCE5C\uAD6C\uAC00 \uC8FC\uB294 \uC0AC\uD0D5 \uD558\uB098\uB3C4 \uB9C8\uC74C\uB300\uB85C
    \uBABB \uBA39\uAC8C \uD558\uB294 \uAC8C \uBC31\uC791\uB2D8\uC758 '\uBCF4\uD638'\uC778\uAC00\uC694?
    \uC0AC\uCD0C 2, \uB108\uAE4C\uC9C0 \uB098\uB97C \uB3D9\uC815\uD558\uC9C0 \uB9C8.\n       
    \uC0AC\uCD0C 2 : (\uC6B8\uBA39\uC774\uBA70) \uB09C \uADF8\uB0E5... \uB124\uAC00
    \uB108\uBB34 \uD798\uB4E4\uC5B4 \uBCF4\uC5EC\uC11C... \uBBF8\uC548\uD574, \uB098
    \uAC08\uAC8C."
