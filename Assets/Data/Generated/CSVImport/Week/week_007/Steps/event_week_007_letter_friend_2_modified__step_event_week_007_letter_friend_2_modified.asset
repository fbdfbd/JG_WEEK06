  _titleOverride: "\uBC00\uB9AC\uC544\uC758 \uD3B8\uC9C0 \uC218\uC815"
  _bodyText: "letter friend_2 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uBC00\uB9AC\uC544 \uC591\uC774 \uC131\uC778\uC2DD\uC5D0
      \uC5B4\uC6B8\uB9B4 \uC7A5\uC2DD\uC744 \uAC19\uC774 \uACE0\uB974\uACE0 \uC2F6\uB2E4\uACE0
      \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544, \uADF8\uAC74 \uC7AC\uBC0C\uACA0\uB2E4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uC774 \uAC00\uC7A5 \uBE5B\uB098 \uBCF4\uC774\uB294
      \uC0C9\uC744 \uACE0\uB974\uACE0 \uC2F6\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB098\uB3C4 \uC9C4\uC9C0\uD558\uAC8C \uACE8\uB77C\uC57C\uC9C0."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uBC00\uB9AC\uC544 \uC591\uC774 \uC131\uC778\uC2DD\uC5D0
    \uC5B4\uC6B8\uB9B4 \uC7A5\uC2DD\uC744 \uAC19\uC774 \uACE0\uB974\uACE0 \uC2F6\uB2E4\uACE0
    \uD569\uB2C8\uB2E4."
