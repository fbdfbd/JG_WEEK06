  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_visitor_cousin_1_blocked__step_w007_visitor_cousin_1_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 7\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uBC31\uC791\uB2D8\uC774 \uC790\uB9AC\uB97C \uBE44\uC6B4 \uC11C\uC7AC.
    \uC0AC\uCD0C 1\uC774 \uC18C\uD30C\uC5D0 \uC549\uC544 \uBD89\uC740 \uBCF4\uC11D\uC774
    \uBC15\uD78C \uC778\uC7A5\uC744 \uB9CC\uC9C0\uC791\uAC70\uB9AC\uB2E4 \uB124\uBAA8\uAC00
    \uB4E4\uC5B4\uC624\uC790 \uC18C\uB984 \uB07C\uCE58\uB294 \uBBF8\uC18C\uB97C \uC9C0\uC73C\uBA70
    \uAC74\uB128\uB2E4.)\n        \n        \uC0AC\uCD0C 1 : \uC57C, \uB124\uBAA8.
    \uC774\uAC70 \uC6D0\uB798 \uB124 \uC9C4\uC9DC \uBD80\uBAA8\uB2D8\uC774 \uB9C8\uC9C0\uB9C9\uAE4C\uC9C0
    \uC950\uACE0 \uC788\uB358 \uAC70\uB2E4. \uBC31\uC791\uB2D8\uC740 \"\uC0AC\uACE0\uB85C
    \uC720\uC2E4\uB410\uB2E4\"\uACE0 \uD558\uC168\uC9C0? \uADFC\uB370 \uC65C \uC774\uAC8C
    \uB0B4 \uC190\uC5D0 \uC788\uC744\uAE4C?\n        \uB124\uBAA8 : (\uB4B7\uAC78\uC74C\uC9C8
    \uCE58\uBA70) \uADF8\uAC78 \uC0BC\uCD0C\uC774 \uC65C... \uBC31\uC791\uB2D8\uC740
    \uBD84\uBA85\uD788 \uB2E4 \uC0AC\uB77C\uC84C\uB2E4\uACE0 \uD558\uC168\uC5B4\uC694.\n       
    \uC0AC\uCD0C 1 : \uD558\uD558, \uBC31\uC791\uB2D8\uC740 \uCC38 \uAE68\uB057\uD55C
    \uCC99\uC744 \uC798\uD558\uC2E0\uB2E8 \uB9D0\uC774\uC57C. \uADF8\uBD84\uC774
    \uC815\uD574\uC900 '\uC9C4\uC2E4'\uB9CC \uBBFF\uACE0 \uC0B4\uAE30\uC5D4 \uB108\uB3C4
    \uC774\uC81C \uB108\uBB34 \uB9CE\uC774 \uC54C\uC9C0 \uC54A\uB0D0?\n        \n\n-
    (\uACBD\uBE44\uB300\uC7A5\uC774 \uBB38\uC744 \uC5F4\uACE0 \uB4E4\uC5B4\uC640
    \uC0AC\uCD0C 1\uC758 \uC190\uC5D0\uC11C \uC0C1\uC790\uB97C \uCCD0\uB0B4 \uBC14\uB2E5\uC5D0
    \uB5A8\uC5B4\uB728\uB9B0\uB2E4.)\n        - \uACBD\uBE44\uB300\uC7A5 : \uC8FC\uC778\uB2D8,
    \uC800\uC790\uC758 \uAC04\uC0AC\uD55C \uD600\uC5D0 \uB180\uC544\uB098\uC9C0 \uB9C8\uC2ED\uC2DC\uC624.
    \uBC31\uC791\uB2D8\uAED8\uC11C \uAE08\uD558\uC2E0 \uC678\uBD80 \uBB3C\uAC74\uC785\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : (\uBC14\uB2E5\uC5D0 \uB5A8\uC5B4\uC9C4 \uC778\uC7A5\uACFC \uACBD\uBE44\uB300\uC7A5\uC744
    \uBC88\uAC08\uC544 \uBCF4\uBA70) \uCE58\uC6B0\uC9C0 \uB9C8! (\uC0AC\uCD0C 1\uC744
    \uB178\uB824\uBCF4\uBA70) \uC0BC\uCD0C, \uC9C0\uAE08 \uBC31\uC791\uB2D8\uC774
    \uC6B0\uB9AC \uBD80\uBAA8\uB2D8 \uC8FD\uC74C\uC744 \uBC29\uCE58\uD588\uB2E4\uB294
    \uB73B\uC774\uC5D0\uC694? \uAC10\uD788 \uB0B4 \uC55E\uC5D0\uC11C \uADF8\uB7F0
    \uAC70\uC9D3\uB9D0\uC744...!\n        \uC0AC\uCD0C 1 : \uAC70\uC9D3\uB9D0\uC778\uC9C0
    \uC544\uB2CC\uC9C0\uB294 \uBC31\uC791\uB2D8\uAED8 \uC9C1\uC811 \uBB3C\uC5B4\uBCF4\uB4E0\uAC00.
    \uC544, \uBB34\uC11C\uC6CC\uC11C \uC785\uB3C4 \uBABB \uB5BC\uACA0\uC9C0?"
