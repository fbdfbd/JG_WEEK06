  _titleOverride: cousin_1 Blocked
  _bodyText: "visitor cousin_1 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uBC14\uB2E5\uC5D0 \uB5A8\uC5B4\uC9C4 \uC778\uC7A5\uACFC \uACBD\uBE44\uB300\uC7A5\uC744
      \uBC88\uAC08\uC544 \uBCF4\uBA70) \uCE58\uC6B0\uC9C0 \uB9C8! (\uC0AC\uCD0C 1\uC744
      \uB178\uB824\uBCF4\uBA70) \uC0BC\uCD0C, \uC9C0\uAE08 \uBC31\uC791\uB2D8\uC774
      \uC6B0\uB9AC \uBD80\uBAA8\uB2D8 \uC8FD\uC74C\uC744 \uBC29\uCE58\uD588\uB2E4\uB294
      \uB73B\uC774\uC5D0\uC694? \uAC10\uD788 \uB0B4 \uC55E\uC5D0\uC11C \uADF8\uB7F0
      \uAC70\uC9D3\uB9D0\uC744...!"
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uAC70\uC9D3\uB9D0\uC778\uC9C0 \uC544\uB2CC\uC9C0\uB294 \uBC31\uC791\uB2D8\uAED8
      \uC9C1\uC811 \uBB3C\uC5B4\uBCF4\uB4E0\uAC00. \uC544, \uBB34\uC11C\uC6CC\uC11C
      \uC785\uB3C4 \uBABB \uB5BC\uACA0\uC9C0?"
  _nemoLine: "(\uBC14\uB2E5\uC5D0 \uB5A8\uC5B4\uC9C4 \uC778\uC7A5\uACFC \uACBD\uBE44\uB300\uC7A5\uC744
