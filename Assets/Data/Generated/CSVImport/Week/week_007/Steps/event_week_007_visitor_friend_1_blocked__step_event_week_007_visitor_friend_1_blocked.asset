  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_007_visitor_friend_1_blocked__step_event_week_007_visitor_friend_1_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9C9\uC2A4 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor friend_1 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uB2E4\uAC00\uC640 \uB178\uC744\uBE5B\uC5D0
      \uBC18\uC9DD\uC774\uB294 \uC870\uC57D\uB3CC\uB4E4\uC744 \uBCF4\uBA70 \uC605\uAC8C
      \uBBF8\uC18C \uC9D3\uB294\uB2E4. \uADF8\uB294 \uD3C9\uC18C\uCC98\uB7FC \uB531\uB531\uD55C
      \uD0DC\uB3C4 \uB300\uC2E0, \uBD80\uB4DC\uB7FD\uAC8C \uC8FC\uBA38\uB2C8\uB97C
      \uC815\uB9AC\uD574 \uBC31\uC791\uB2D8\uC758 \uBCF4\uAD00\uD568 \uC606\uC5D0
      \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uBC31\uC791\uB2D8\uAED8\uC11C \uB9D0\uC500\uD558\uC168\uC2B5\uB2C8\uB2E4.
      \"\uC9C4\uC815\uD55C \uD1B5\uCE58\uC790\uB294 \uBC31\uC131\uC758 \uB9C8\uC74C\uC744
      \uB2F4\uC740 \uC791\uC740 \uB3CC \uD558\uB098\uB3C4 \uADC0\uD788 \uC5EC\uAE38
      \uC904 \uC54C\uC544\uC57C \uD55C\uB2E4\"\uACE0\uC694. \uCE5C\uAD6C\uBD84\uACFC\uC758
      \uC6B0\uC815\uC740 \uC774 \uC11C\uC7AC\uC758 \uC0C8\uB85C\uC6B4 \uC5ED\uC0AC\uAC00
      \uB420 \uAC83\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC5D0\uAC8C \uACE0\uAC1C\uB97C \uB044\uB355\uC774\uBA70)
      \uB9DE\uC544\uC694. \uBC31\uC791\uB2D8\uC774 \uC815\uD574\uC8FC\uC2E0 \uADDC\uCE59\uB4E4\uC740
      \uC800\uB97C \uAC00\uB450\uAE30 \uC704\uD574\uC11C\uAC00 \uC544\uB2C8\uB77C,
      \uC81C\uAC00 \uC18C\uC911\uD788 \uC5EC\uAE30\uB294 \uAC83\uB4E4\uC744 \uC9C0\uD0A4\uAE30
      \uC704\uD55C \uC6B8\uD0C0\uB9AC\uC600\uC74C\uC744 \uC774\uC81C\uC57C \uAE68\uB2EC\uC544\uC694."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uC5ED\uC2DC \uBA4B\uC9C0\uB124, \uB124\uBAA8. \uB10C \uBC31\uC791\uB2D8\uB9CC\uD07C\uC774\uB098
      \uD6CC\uB96D\uD558\uACE0 \uB2E8\uB2E8\uD55C \uC5B4\uB978\uC774 \uB420 \uAC70\uC57C.
      \uC131\uC778\uC2DD\uC7A5\uC5D0\uC11C \uB2F9\uB2F9\uD558\uAC8C \uAC77\uB294
      \uB124 \uBAA8\uC2B5\uC744 \uAE30\uB300\uD560\uAC8C!"
  _nemoLine: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uB2E4\uAC00\uC640 \uB178\uC744\uBE5B\uC5D0
    \uBC18\uC9DD\uC774\uB294 \uC870\uC57D\uB3CC\uB4E4\uC744 \uBCF4\uBA70 \uC605\uAC8C
    \uBBF8\uC18C \uC9D3\uB294\uB2E4. \uADF8\uB294 \uD3C9\uC18C\uCC98\uB7FC \uB531\uB531\uD55C
    \uD0DC\uB3C4 \uB300\uC2E0, \uBD80\uB4DC\uB7FD\uAC8C \uC8FC\uBA38\uB2C8\uB97C
    \uC815\uB9AC\uD574 \uBC31\uC791\uB2D8\uC758 \uBCF4\uAD00\uD568 \uC606\uC5D0 \uB454\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
