  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_007_external_cavalry_news_direct__step_week_007_external_cavalry_news_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCCA0\uAC11 \uAE30\uBCD1\uB300 \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "\uCCA0\uAC11 \uAE30\uBCD1\uB300 \uC18C\uBB38 - \uD5C8\uB77D \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uAD6D\uACBD \uCABD\uC5D0 \uCCA0\uAC11 \uAE30\uBCD1\uB300\uAC00 \uB354
      \uBC30\uCE58\uB410\uB2E4\uB294 \uC18C\uC2DD\uC774 \uB4E4\uC5B4\uC654\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uC815\uB9D0 \uD070\uC77C\uC774 \uAC00\uAE4C\uC6CC\uC9C4
      \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uAE34\uC7A5\uC774 \uB192\uC544\uC9C4 \uAC74 \uB9DE\uC9C0\uB9CC, \uADF8\uB798\uC11C
      \uB354 \uB2E8\uB2E8\uD788 \uC9C0\uD0A4\uB824\uB294 \uC6C0\uC9C1\uC784\uC774\uAE30\uB3C4
      \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB34\uC12D\uAE34 \uD574\uB3C4... \uC9C0\uD0A4\uB824\uB294 \uC0AC\uB78C\uB4E4\uC774
      \uC788\uB2E4\uB294 \uAC74 \uC54C\uACA0\uC5B4."
  _nemoLine: "\uAD6D\uACBD \uCABD\uC5D0 \uCCA0\uAC11 \uAE30\uBCD1\uB300\uAC00 \uB354
    \uBC30\uCE58\uB410\uB2E4\uB294 \uC18C\uC2DD\uC774 \uB4E4\uC5B4\uC654\uC2B5\uB2C8\uB2E4."
