  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_007_letter_friend_3_modified__step_event_week_007_letter_friend_3_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC720\uD53C\uC758 \uD3B8\uC9C0 \uC218\uC815"
  _bodyText: "letter friend_3 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC720\uD53C \uAD70\uC774 \uC131\uC778\uC2DD \uC804\uC5D0
      \uAE34\uC7A5\uC744 \uD480\uC5B4 \uC8FC\uACA0\uB2E4\uACE0 \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610 \uC6C3\uAE34 \uC18C\uB9AC \uD574 \uC8FC\uB824\uB294 \uAC70\uC9C0?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC8FC\uC778\uB2D8\uC774 \uBB34\uC11C\uC6CC\uD560 \uD2C8\uC774
      \uC5C6\uB3C4\uB85D \uC6C3\uAC8C \uB9CC\uB4E4\uACA0\uB2E4\uACE0 \uD588\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC88B\uC544. \uADF8\uB7FC \uADF8\uB0A0\uC740 \uAF2D \uC6C3\uAC8C \uD574
      \uB2EC\uB77C\uACE0 \uD574\uC57C\uACA0\uB2E4."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC720\uD53C \uAD70\uC774 \uC131\uC778\uC2DD \uC804\uC5D0
    \uAE34\uC7A5\uC744 \uD480\uC5B4 \uC8FC\uACA0\uB2E4\uACE0 \uD569\uB2C8\uB2E4."
