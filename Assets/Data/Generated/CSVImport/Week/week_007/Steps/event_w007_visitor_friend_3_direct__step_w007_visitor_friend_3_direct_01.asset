  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_visitor_friend_3_direct__step_w007_visitor_friend_3_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 7\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "\uCE5C\uAD6C 3 : \uC57C, \uB124\uBAA8! \uC624\uB298\uB3C4 \uADF8 \uB531\uB531\uD55C
    \uCC45\uC774\uB791 \uC528\uB984 \uC911\uC774\uB0D0? \uBC16\uC740 \uBC8C\uC368
    \uBD04\uBC14\uB78C\uC774 \uBD88\uC5B4\uC11C \uAF43\uC774 \uC9C0\uCC9C\uC73C\uB85C
    \uD53C\uC5C8\uB294\uB370 \uB9D0\uC774\uC57C. \uC0AC\uCD0C 1 \uADF8 \uC778\uAC04\uC774
    \uC11C\uC7AC\uC5D0 \uD53C\uBE44\uB9B0\uB0B4\uAC00 \uB098\uB124 \uC5B4\uCA4C\uB124
    \uD5DB\uC18C\uB9AC\uD558\uACE0 \uAC14\uB2E4\uBA70? \uC790, \uC774 \uAF43 \uD5A5\uAE30\uB098
    \uB9E1\uC544\uBD10. \uC774\uAC8C \uC9C4\uC9DC \uC138\uC0C1 \uB0C4\uC0C8\uC9C0!\n       
    \n\n- (\uB124\uBAA8\uAC00 \uC77D\uB358 \uCC45\uC744 \uB36E\uACE0 \uCE5C\uAD6C
    3\uC774 \uAC00\uC838\uC628 \uAF43\uC744 \uD558\uB098 \uB4E4\uC5B4 \uBA38\uB9AC\uC5D0
    \uAF42\uC544\uBCF8\uB2E4.)\n        - \uB124\uBAA8 : \uC640, \uC9C4\uC9DC \uD5A5\uAE30
    \uC88B\uB2E4! \uBC31\uC791\uB2D8\uC774 \uC8FC\uC2DC\uB294 \uD5A5\uC218\uBCF4\uB2E4
    \uD6E8\uC52C \uC9C4\uD574. \uCE5C\uAD6C 3, \uC131\uC778\uC2DD \uB05D\uB098\uBA74
    \uB098\uB791 \uAC19\uC774 \uC774 \uAF43\uC774 \uD540 \uB4E4\uD310\uC73C\uB85C
    \uB2EC\uB824\uAC00 \uC904 \uAC70\uC9C0?\n        \uCE5C\uAD6C 3 : \uB9D0\uC774\uB77C\uACE0
    \uD574? \uB0B4\uAC00 \uC138\uC0C1\uC5D0\uC11C \uC81C\uC77C \uBE60\uB978 \uB9D0\uC744
    \uC900\uBE44\uD574\uB458\uAC8C. \uBC31\uC791\uB2D8\uB3C4 \uB124\uAC00 \uB098\uB791
    \uAC19\uC774 \uB098\uAC00\uB294 \uAC70\uB77C\uBA74 \uAE30\uC058\uAC8C \uBCF4\uB0B4\uC8FC\uC2E4\uAC78!"
