  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_house_main_modified__step_w007_house_main_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "7\uC8FC\uCC28 \uC18C\uBB38 - \uC218\uC815"
  _bodyText: "(\uB2A6\uC740 \uBC24, \uC11C\uC7AC\uB85C \uD5A5\uD558\uB294 \uBCF5\uB3C4.
    \uD558\uC778 \uB458\uC774 \uCD1B\uBD88\uC744 \uB4E0 \uCC44 \uBCBD\uBA74\uC758
    \uC624\uB798\uB41C \uC7A5\uC2DD\uC7A5\uC744 \uC870\uC0AC\uD558\uACE0 \uC788\uB2E4.)\n   
    \n    \uD558\uC778 1 : \uBD84\uBA85\uD788 \uC774 \uBCF5\uB3C4\uB294 \uC2A4\uBB34
    \uAC78\uC74C\uC774\uBA74 \uB05D\uB0AC\uB294\uB370, \uC5B4\uC81C\uB294 \uC11C\uB978
    \uAC78\uC74C\uC744 \uAC78\uC5B4\uB3C4 \uBB38\uC774 \uC548 \uB098\uC624\uB354\uB77C\uACE0.\n   
    \uD558\uC778 2 : \uC790\uB124\uB3C4 \uADF8\uB7AC\uB098? \uAF2D \uC800\uD0DD\uC774
    \uBC24\uB9C8\uB2E4 \uBAB8\uC9D1\uC744 \uBD88\uB9AC\uB294 \uAC83 \uAC19\uC544.\n   
    \uB124\uBAA8 : \uBCF5\uB3C4\uAC00 \uAE38\uC5B4\uC84C\uB2E4\uACE0? \uB0B4\uAC00
    \uC9C1\uC811 \uC138\uC5B4\uBCFC\uAE4C?\n    \n\n- \uD558\uC778 1 : \uC544, \uC774\uAC74
    \uC870\uBA85 \uB54C\uBB38\uC774\uC5D0\uC694. \uBC24\uC5D0\uB294 \uADF8\uB9BC\uC790\uAC00
    \uAE38\uAC8C \uB298\uC5B4\uC838\uC11C \uBCF5\uB3C4\uAC00 \uC2E4\uC81C\uBCF4\uB2E4
    \uD6E8\uC52C \uAE38\uC5B4 \uBCF4\uC774\uB294 \uCC29\uC2DC \uD604\uC0C1\uC774\uC8E0.\n   
    \uB124\uBAA8 : \uCC29\uC2DC \uD604\uC0C1? \uADF8\uB9BC\uC790\uAC00 \uC18D\uC774\uB294
    \uAC70\uC57C?\n    \uD558\uC778 2 : \uB124. \uD654\uAC00\uB4E4\uC774 \uC6D0\uADFC\uBC95\uC744
    \uC4F0\uB294 \uAC83\uACFC \uBE44\uC2B7\uD574\uC694. \uC8FC\uC778\uB2D8\uAED8
    \uACF5\uAC04\uAC10\uC744 \uB354 \uB113\uAC8C \uBCF4\uC5EC\uC8FC\uB824\uB294 \uBC31\uC791\uB2D8\uC758
    \uBC30\uB824 \uC11E\uC778 \uAC74\uCD95 \uC124\uACC4\uB78D\uB2C8\uB2E4.\n    \uB124\uBAA8
    : \uC544, \uBC31\uC791\uB2D8\uC774 \uC77C\uBD80\uB7EC \uADF8\uB807\uAC8C \uB9CC\uB4DC\uC2E0
    \uAC70\uAD6C\uB098! \uADF8\uB7FC \uBB34\uC11C\uC6CC\uD560 \uAC70 \uC5C6\uB124."
