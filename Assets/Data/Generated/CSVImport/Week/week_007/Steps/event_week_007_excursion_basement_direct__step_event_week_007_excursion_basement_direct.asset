  _titleOverride: "\uC9C0\uD558\uC2E4 \uD5C8\uAC00"
  _bodyText: "excursion basement Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4\uB824\uC6B4 \uACB0\uC815... \uADF8\uB798\uC11C \uC624\uD574\uB97C
      \uBC1B\uACE0 \uC774\uACF3\uC5D0 \uB0A8\uACA8\uC9C0\uC2E0 \uAC70\uAD6C\uB098."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uBAA8\uB450\uAC00 \uC54C\uC544\uC8FC\uC9C4 \uC54A\uC544\uB3C4 \uAC00\uBB38\uC744
      \uC9C0\uD0A4\uB824 \uD558\uC168\uB358 \uAC70\uACA0\uC8E0."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uCD08\uC0C1\uD654\uC758 \uBA3C\uC9C0\uB97C \uC870\uC2EC\uC2A4\uB808
      \uB2E6\uC544\uB0B4\uBA70) \uB098\uB3C4 \uB098\uC911\uC5D0 \uC800\uD0DD\uC744
      \uC774\uB04C\uB2E4 \uBCF4\uBA74, \uBAA8\uB450\uC5D0\uAC8C \uD658\uC601\uBC1B\uC9C0
      \uBABB\uD558\uB294 \uACB0\uC815\uC744 \uD574\uC57C \uD560 \uB54C\uAC00 \uC624\uACA0\uC9C0?"
  _nemoLine: "\uC5B4\uB824\uC6B4 \uACB0\uC815... \uADF8\uB798\uC11C \uC624\uD574\uB97C
    \uBC1B\uACE0 \uC774\uACF3\uC5D0 \uB0A8\uACA8\uC9C0\uC2E0 \uAC70\uAD6C\uB098."
