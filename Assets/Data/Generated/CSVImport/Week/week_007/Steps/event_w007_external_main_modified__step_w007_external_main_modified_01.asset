  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_external_main_modified__step_w007_external_main_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "7\uCC28 - \uC218\uC815"
  _bodyText: "\uAD6D\uACBD\uC758 \uAE34\uC7A5\uACFC \uCCA0\uAC11 \uAE30\uBCD1\uB300\r\n   
    \r\n    (\uC800\uD0DD \uB4B7\uBB38, \uC2DD\uC790\uC7AC\uB97C \uB0A9\uD488\uD558\uB294
    \uC0C1\uC778\uC774 \uACBD\uBE44\uBCD1\uC5D0\uAC8C \uC740\uBC00\uD558\uAC8C \uAC00\uC8FD
    \uC8FC\uBA38\uB2C8\uB97C \uAC74\uB124\uBA70 \uC18D\uC0AD\uC778\uB2E4.)\r\n   
    \r\n    \uC0C1\uC778 : \uC774\uBD10, \uAD6D\uACBD \uB108\uBA38 \uC81C\uAD6D\uAD70\uC774
    \uC2EC\uC0C1\uCE58 \uC54A\uC544. \uC628\uBAB8\uC744 \uCCA0\uAC11\uC73C\uB85C
    \uB450\uB978 \uAE30\uBCD1\uB300\uAC00 \uBC8C\uC368 \uADFC\uCC98 \uB9C8\uC744\uAE4C\uC9C0
    \uB0B4\uB824\uC654\uB2E4\uB354\uAD70.\r\n    \uACBD\uBE44\uBCD1 : \uC27F! \uBC31\uC791\uB2D8\uC774
    \uD568\uAD6C\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4. \uC131\uC778\uC2DD \uCD95\uC81C
    \uBD84\uC704\uAE30\uB97C \uB9DD\uCE58\uACE0 \uC2F6\uC9C0 \uC54A\uC73C\uC2E0 \uAC8C\uC9C0.\r\n   
    \uB124\uBAA8 : \uCCA0\uAC11 \uAE30\uBCD1\uB300? \uC6B0\uB9AC \uC601\uC9C0\uB85C
    \uCCD0\uB4E4\uC5B4\uC624\uB294 \uAC70\uC57C?\r\n    \r\n\r\n- \uC0C1\uC778 :
    \uC0AC\uC2E4\uC740 \uC774\uC6C3 \uC601\uC9C0\uB791 \uACF5\uB3D9\uC73C\uB85C \uC9C4\uD589\uD558\uB294
    \uCE58\uC548 \uC720\uC9C0 \uD6C8\uB828\uC774\uB798\uC694. \uAC15\uB3C4\uB4E4\uC744
    \uC7A1\uC73C\uB824\uACE0 \uAE30\uC0AC\uB2D8\uB4E4\uC774 \uBAA8\uC778 \uAC70\uC8E0.\r\n   
    \uB124\uBAA8 : \uAC15\uB3C4\uB4E4\uC744 \uC7A1\uC73C\uB824\uACE0? \uADF8\uB7FC
    \uC6B0\uB9AC \uB9C8\uC744\uC740 \uB354 \uC548\uC804\uD574\uC9C0\uACA0\uB124?\r\n   
    \uACBD\uBE44\uBCD1 : \uB9DE\uC2B5\uB2C8\uB2E4. \uC8FC\uC778\uB2D8\uC774 \uC548\uC804\uD558\uAC8C
    \uC131\uC778\uC2DD\uC744 \uCE58\uB974\uC2E4 \uC218 \uC788\uB3C4\uB85D \uBC31\uC791\uB2D8\uC774
    \uD2B9\uBCC4\uD788 \uC694\uCCAD\uD558\uC2E0 \uBC29\uC5B4\uBCBD \uAC19\uC740 \uAC70\uC608\uC694.\r\n   
    \uB124\uBAA8 : \uC544, \uB098\uB97C \uC9C0\uCF1C\uC8FC\uB824\uACE0 \uB2E4\uB4E4
    \uACE0\uC0DD\uD558\uC2DC\uB294\uAD6C\uB098. \uAC10\uC0AC\uD558\uB2E4\uACE0 \uC778\uC0AC\uB4DC\uB824\uC57C\uACA0\uB2E4!"
