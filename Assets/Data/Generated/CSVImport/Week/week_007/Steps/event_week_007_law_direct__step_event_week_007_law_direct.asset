  _titleOverride: "\uC601\uC9C0\uC758 \uADDC\uCE59\uACFC \uD310\uACB0\uC744 \uAC00\uB974\uCE5C\uB2E4"
  _bodyText: "\uC601\uC9C0\uC758 \uADDC\uCE59\uACFC \uD310\uACB0\uC744 \uAC00\uB974\uCE5C\uB2E4
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC601\uC9C0\uC758 \uADDC\uCE59\uACFC \uD310\uACB0 \uC0AC\uB840\uB97C
      \uC9DA\uC73C\uBA70 \uBC95\uC774 \uC65C \uD544\uC694\uD55C\uC9C0 \uCC28\uADFC\uCC28\uADFC
      \uC124\uBA85\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC19\uC740 \uC798\uBABB\uC774\uC5B4\uB3C4 \uC65C \uD310\uACB0\uC774
      \uB2EC\uB77C\uC9C8 \uC218 \uC788\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uADDC\uCE59\uB9CC \uC678\uC6B0\uC9C0 \uC54A\uAC8C \uD558\uB824\uACE0
      \uC774\uC720\uC640 \uACB0\uACFC\uB97C \uD568\uAED8 \uC124\uBA85\uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uADF8\uB0E5 \uC678\uC6B0\uB294 \uAC83\uBCF4\uB2E4 \uC0DD\uAC01\uD558\uB294
      \uAC8C \uB9CE\uB124."
  _nemoLine: "(\uC601\uC9C0\uC758 \uADDC\uCE59\uACFC \uD310\uACB0 \uC0AC\uB840\uB97C
    \uC9DA\uC73C\uBA70 \uBC95\uC774 \uC65C \uD544\uC694\uD55C\uC9C0 \uCC28\uADFC\uCC28\uADFC
    \uC124\uBA85\uD55C\uB2E4.)"
