  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_letter_friend_1_direct__step_w007_letter_friend_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 7\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "- (\uD558\uB140\uAC00 \uBD89\uC740 \uC9C4\uD759\uC774 \uBB3B\uC740
    \uAC70\uCE5C \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C \uB05D\uC5D0\uB294
    \uC791\uC740 \uAE43\uD138 \uD558\uB098\uAC00 \uAF42\uD600 \uC788\uB2E4.)\n       
    \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C \uC628 \uD3B8\uC9C0\uB124\uC694.
    \uC774\uBC88\uC5D4 \uC232\uC774\uB77C\uB3C4 \uD5E4\uCE58\uACE0 \uC628 \uBAA8\uC591\uC785\uB2C8\uB2E4.\n\n(\uD558\uB140\uAC00
    \uBD09\uD22C\uB97C \uB124\uBAA8\uC5D0\uAC8C \uAC74\uB124\uBA70 \uBBF8\uC18C \uC9D3\uB294\uB2E4.)\n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC232\uC758 \uC804\uB839\uC744
    \uBCF4\uB0B4\uC168\uB124\uC694. \uBB50\uB77C\uACE0 \uC801\uC5C8\uC744\uAE4C\uC694?\n       
    \uB124\uBAA8 : (\uAE43\uD138\uC744 \uB9CC\uC9C0\uBA70) \uBE68\uB9AC \uC77D\uC5B4
    \uC918!\n        (\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uC77D\uC5B4 \uC900\uB2E4.)\n       
    \uB124\uBAA8\uC57C! \uC131\uC778\uC2DD \uC900\uBE44\uB294 \uC798 \uB3FC\uAC00?
    \uB098 \uC800\uBC88\uC5D0 \uC0AC\uCD0C 1\uC774 \uB9D0\uD55C \uADF8 \uC808\uBCBD
    \uADFC\uCC98\uC5D0 \uAC00\uBD24\uC5B4. \uADFC\uB370 \uAC70\uAE30 \uBB34\uC11C\uC6B4
    \uACF3\uC774 \uC544\uB2C8\uB77C, \uD574 \uC9C8 \uB158 \uB178\uC744\uC774 \uC138\uC0C1\uC5D0\uC11C
    \uC81C\uC77C \uC608\uC058\uAC8C \uBCF4\uC774\uB294 \uACF3\uC774\uB354\uB77C!
    \uBC31\uC791\uB2D8\uC774 \uC65C \uB110 \uC544\uB07C\uC168\uB294\uC9C0 \uC54C
    \uAC83 \uAC19\uC544. \uB0B4\uC77C \uC131\uC778\uC2DD \uB05D\uB098\uBA74 \uB098\uB791
    \uAC70\uAE30\uB85C \uB9D0 \uD0C0\uACE0 \uB2EC\uB9AC\uC790!\n        \uB124\uBAA8
    : \uC0AC\uCD0C 1 \uB9D0\uC774 \uD2C0\uB838\uB124! \uC5ED\uC2DC \uC9C1\uC811 \uAC00\uBD10\uC57C
    \uC54C\uC544.\n        \uD558\uB140 : \uC8FC\uC778\uB2D8\uC740 \uC774\uC81C \uC138\uC0C1\uC744
    \uC9C1\uC811 \uBCFC \uC900\uBE44\uAC00 \uB418\uC2E0 \uBAA8\uC591\uC785\uB2C8\uB2E4."
