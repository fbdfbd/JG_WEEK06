  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_visitor_friend_1_blocked__step_w007_visitor_friend_1_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 7\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uC131\uC778\uC2DD\uC744 \uC55E\uB454 \uC5B4\uB290 \uB0A0, \uC11C\uC7AC\uC5D0
    \uB178\uC744\uC774 \uAE4A\uAC8C \uB4DC\uB9AC\uC6CC\uC838 \uC788\uB2E4. \uCE5C\uAD6C
    1\uC774 \uD3C9\uC18C\uBCF4\uB2E4 \uC815\uC911\uD55C \uCC28\uB9BC\uC73C\uB85C
    \uB4E4\uC5B4\uC640 \uBC31\uC791\uB2D8\uC758 \uCC45\uC0C1 \uC704\uC5D0 \uC791\uC740
    \uC8FC\uBA38\uB2C8\uB97C \uB193\uB294\uB2E4. \uADF8 \uC548\uC5D0\uB294 \uC5B4\uB9B4
    \uC801 \uB450 \uC0AC\uB78C\uC774 \uD568\uAED8 \uBAA8\uC558\uB358 \uBC18\uC9DD\uC774\uB294
    \uC870\uC57D\uB3CC\uB4E4\uACFC \uBE44\uBC00 \uC9C0\uB3C4 \uC870\uAC01\uB4E4\uC774
    \uB4E4\uC5B4\uC788\uB2E4.)\r\n        \r\n        \uCE5C\uAD6C 1 : \uB124\uBAA8\uC57C,
    \uC774\uC81C \uB0B4\uC77C\uBD80\uD130\uB294 \uB124\uAC00 \uC774 \uC601\uC9C0\uC758
    \uACF5\uC2DD\uC801\uC778 \uD6C4\uACC4\uC790\uAC00 \uB418\uACA0\uC9C0? \uADF8\uB7FC
    \uC774\uC81C \uC774\uB7F0 '\uBCF4\uBB3C'\uB4E4\uC740 \uC5EC\uAE30 \uC5B4\uC6B8\uB9AC\uC9C0
    \uC54A\uC744\uC9C0\uB3C4 \uBAB0\uB77C. \uD558\uC9C0\uB9CC \uB09C \uB124\uAC00
    \uBC31\uC791\uB2D8\uC758 \uB4A4\uB97C \uC774\uC5B4 \uC774 \uC11C\uC7AC\uC758
    \uC8FC\uC778\uC774 \uB418\uC5B4\uB3C4, \uC6B0\uB9AC\uB791 \uC0B0\uC73C\uB85C
    \uB4E4\uB85C \uB6F0\uC5B4\uB2E4\uB2C8\uB358 \uADF8 \uB124\uBAA8\uB77C\uB294 \uAC78
    \uC78A\uC9C0 \uC54A\uC558\uC73C\uBA74 \uC88B\uACA0\uC5B4.\r\n        \uB124\uBAA8
    : (\uC870\uC57D\uB3CC\uC744 \uB9CC\uC9C0\uBA70 \uBBF8\uC18C \uC9D3\uB294\uB2E4)
    \uB2F9\uC5F0\uD558\uC9C0. \uBC31\uC791\uB2D8\uC774 \uB0B4\uAC8C \uAC00\uB974\uCCD0\uC8FC\uC2E0
    \uD488\uC704\uB294 \uC774\uB7F0 \uC18C\uC911\uD55C \uC6B0\uC815\uC744 \uC9C0\uD0A4\uAE30
    \uC704\uD55C \uD798\uC774\uC57C. \uC78A\uC744 \uB9AC\uAC00 \uC5C6\uC796\uC544.\r\n       
    \r\n\r\n(\uACBD\uBE44\uB300\uC7A5\uC774 \uB2E4\uAC00\uC640 \uB178\uC744\uBE5B\uC5D0
    \uBC18\uC9DD\uC774\uB294 \uC870\uC57D\uB3CC\uB4E4\uC744 \uBCF4\uBA70 \uC605\uAC8C
    \uBBF8\uC18C \uC9D3\uB294\uB2E4. \uADF8\uB294 \uD3C9\uC18C\uCC98\uB7FC \uB531\uB531\uD55C
    \uD0DC\uB3C4 \uB300\uC2E0, \uBD80\uB4DC\uB7FD\uAC8C \uC8FC\uBA38\uB2C8\uB97C
    \uC815\uB9AC\uD574 \uBC31\uC791\uB2D8\uC758 \uBCF4\uAD00\uD568 \uC606\uC5D0 \uB454\uB2E4.)\r\n       
    \r\n        \uACBD\uBE44\uB300\uC7A5 : \uC8FC\uC778\uB2D8, \uBC31\uC791\uB2D8\uAED8\uC11C
    \uB9D0\uC500\uD558\uC168\uC2B5\uB2C8\uB2E4. \"\uC9C4\uC815\uD55C \uD1B5\uCE58\uC790\uB294
    \uBC31\uC131\uC758 \uB9C8\uC74C\uC744 \uB2F4\uC740 \uC791\uC740 \uB3CC \uD558\uB098\uB3C4
    \uADC0\uD788 \uC5EC\uAE38 \uC904 \uC54C\uC544\uC57C \uD55C\uB2E4\"\uACE0\uC694.
    \uCE5C\uAD6C\uBD84\uACFC\uC758 \uC6B0\uC815\uC740 \uC774 \uC11C\uC7AC\uC758 \uC0C8\uB85C\uC6B4
    \uC5ED\uC0AC\uAC00 \uB420 \uAC83\uC785\uB2C8\uB2E4.\r\n        \uB124\uBAA8 :
    (\uACBD\uBE44\uB300\uC7A5\uC5D0\uAC8C \uACE0\uAC1C\uB97C \uB044\uB355\uC774\uBA70)
    \uB9DE\uC544\uC694. \uBC31\uC791\uB2D8\uC774 \uC815\uD574\uC8FC\uC2E0 \uADDC\uCE59\uB4E4\uC740
    \uC800\uB97C \uAC00\uB450\uAE30 \uC704\uD574\uC11C\uAC00 \uC544\uB2C8\uB77C,
    \uC81C\uAC00 \uC18C\uC911\uD788 \uC5EC\uAE30\uB294 \uAC83\uB4E4\uC744 \uC9C0\uD0A4\uAE30
    \uC704\uD55C \uC6B8\uD0C0\uB9AC\uC600\uC74C\uC744 \uC774\uC81C\uC57C \uAE68\uB2EC\uC544\uC694.\r\n       
    \uCE5C\uAD6C 1 : \uC5ED\uC2DC \uBA4B\uC9C0\uB124, \uB124\uBAA8. \uB10C \uBC31\uC791\uB2D8\uB9CC\uD07C\uC774\uB098
    \uD6CC\uB96D\uD558\uACE0 \uB2E8\uB2E8\uD55C \uC5B4\uB978\uC774 \uB420 \uAC70\uC57C.
    \uC131\uC778\uC2DD\uC7A5\uC5D0\uC11C \uB2F9\uB2F9\uD558\uAC8C \uAC77\uB294 \uB124
    \uBAA8\uC2B5\uC744 \uAE30\uB300\uD560\uAC8C!"
