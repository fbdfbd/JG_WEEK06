  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_visitor_cousin_2_direct__step_w007_visitor_cousin_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 7\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D (\uB124\uBAA8\uAC00
    \uC0AC\uCD0C 2\uC758 \uC190\uC744 \uC7A1\uACE0 \uC11C\uC7AC \uAD6C\uC11D \uC18C\uD30C\uB85C
    \uC774\uB048\uB2E4. \uBC31\uC791\uB2D8\uC758 \uCC45\uC0C1\uC5D0\uC11C \uCD5C\uB300\uD55C
    \uBA40\uB9AC \uB5A8\uC5B4\uC9C4 \uACF3\uC774\uC57C."
  _bodyText: "(\uBC31\uC791\uB2D8\uC774 \uC790\uB9AC\uB97C \uBE44\uC6B4 \uC11C\uC7AC.
    \uC0AC\uCD0C 2\uAC00 \uBB38\uC55E\uC5D0\uC11C \uB4E4\uC5B4\uC624\uC9C0 \uBABB\uD558\uACE0
    \uBA38\uBB47\uAC70\uB9AC\uACE0 \uC788\uC5B4. \uC0AC\uCD0C 1\uC774 \uD718\uC800\uC5B4
    \uB193\uC740 \uBE44\uB9BF\uD55C \uACF5\uAE30\uAC00 \uC544\uC9C1 \uB0A8\uC544\uC788\uB294\uB370,
    \uC0AC\uCD0C 2\uB294 \uB124\uBAA8\uC758 \uC548\uC0C9\uC744 \uC0B4\uD53C\uBA70
    \uC791\uC740 \uC8FC\uBA38\uB2C8\uB97C \uB0B4\uBC00\uC5B4.)\r\n        \r\n       
    \uC0AC\uCD0C 2 : \uB124\uBAA8\uC57C... \uC548\uC0C9\uC774 \uC65C \uADF8\uB798?
    \uC6B0\uB9AC \uC544\uBE60\uAC00 \uB610 \uC774\uC0C1\uD55C \uC18C\uB9AC \uD558\uACE0
    \uAC14\uC5B4? \uC5EC\uAE30... \uC774\uAC70 \uBA39\uACE0 \uAE30\uC6B4 \uB0B4.
    \uB124\uAC00 \uC88B\uC544\uD558\uB294 \uAC70\uC57C.\r\n        \uB124\uBAA8 :
    (\uC0AC\uCD0C 1\uC774 \uC92C\uB358 \uC778\uC7A5\uC744 \uB5A0\uC62C\uB9AC\uBA70)
    \uC0AC\uCD0C 2, \uB108\uD76C \uC544\uBC84\uC9C0\uB294 \uB098\uD55C\uD14C \uBB58
    \uC6D0\uD558\uC2DC\uB294 \uAC78\uAE4C?\r\n        \r\n\r\n- )\uB124\uBAA8 : \uACE0\uB9C8\uC6CC.
    \uC9C0\uAE08\uC740 \uC774\uB7F0 \uB2EC\uCF64\uD55C \uAC8C \uC815\uB9D0 \uD544\uC694\uD588\uC5B4.
    \uC0AC\uCD0C 2, \uB108\uB294 \uC54C\uC9C0? \uB108\uD76C \uC544\uBC84\uC9C0\uAC00
    \uB098\uD55C\uD14C \uBCF4\uC5EC\uC900 \uADF8 \uBD89\uC740 \uC778\uC7A5 \uB9D0\uC774\uC57C.\r\n       
    \uC0AC\uCD0C 2 : (\uC548\uC0C9\uC774 \uCC3D\uBC31\uD574\uC9C0\uBA70) ...\uADF8\uAC78
    \uBC8C\uC368 \uBCF4\uC5EC\uC8FC\uC168\uC5B4? \uB124\uBAA8\uC57C, \uC6B0\uB9AC
    \uC544\uBE60 \uB9D0 \uB108\uBB34 \uBBFF\uC9C0 \uB9C8. \uD558\uC9C0\uB9CC... \uBC31\uC791\uB2D8\uB3C4
    \uAC00\uB054\uC740 \uB108\uBB34 \uBB34\uC11C\uC6CC. \uB10C \uC774 \uAC10\uC625
    \uAC19\uC740 \uACF3\uC5D0\uC11C \uC5B4\uB5BB\uAC8C \uACAC\uB514\uB294 \uAC70\uC57C?\r\n       
    \uB124\uBAA8 : (\uC0AC\uD0D5\uC744 \uC785\uC5D0 \uB123\uC73C\uBA70) \uACAC\uB514\uB294
    \uAC8C \uC544\uB0D0. \uC0B4\uC544\uB0A8\uC73C\uB824\uACE0 \uB178\uB825\uD558\uB294
    \uAC70\uC9C0. \uB108\uB9CC\uC740 \uB0B4 \uD3B8\uC774\uC5B4\uC57C \uD574, \uC54C\uACA0\uC5B4?"
