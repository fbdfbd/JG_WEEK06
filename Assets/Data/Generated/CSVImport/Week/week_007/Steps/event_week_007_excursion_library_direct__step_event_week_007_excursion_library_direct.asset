  _titleOverride: library Direct
  _bodyText: "excursion library Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC5B4\uBA38\uB098, \uC6B0\uB9AC \uC8FC\uC778 \uC815\uB9D0 \uB2E4 \uB418\uC168\uB124\uC694.
      \uBC31\uC791\uB2D8\uC774 \uB4E4\uC73C\uC2DC\uBA74 \uB300\uACAC\uD574\uC11C
      \uB208\uBB3C\uC744 \uD758\uB9AC\uC2E4 \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uBBF8\uC18C \uC9C0\uC73C\uBA70) \uB098\uC911\uC5D0 \uB0B4\uAC00 \uBA4B\uC9C4
      \uC8FC\uC778\uC774 \uB418\uBA74, \uB3C4\uC11C\uAD00\uC744 \uB354 \uD06C\uAC8C
      \uC9C0\uC5B4\uC11C \uC601\uC9C0 \uC0AC\uB78C\uB4E4\uB3C4 \uCC45\uC744 \uC77D\uC744
      \uC218 \uC788\uAC8C \uD574\uC8FC\uACE0 \uC2F6\uC5B4."
  _nemoLine: "\uC5B4\uBA38\uB098, \uC6B0\uB9AC \uC8FC\uC778 \uC815\uB9D0 \uB2E4 \uB418\uC168\uB124\uC694.
    \uBC31\uC791\uB2D8\uC774 \uB4E4\uC73C\uC2DC\uBA74 \uB300\uACAC\uD574\uC11C \uB208\uBB3C\uC744
    \uD758\uB9AC\uC2E4 \uAC70\uC608\uC694."
