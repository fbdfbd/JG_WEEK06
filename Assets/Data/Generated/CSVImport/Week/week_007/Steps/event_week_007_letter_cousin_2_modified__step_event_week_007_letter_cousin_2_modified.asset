  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_007_letter_cousin_2_modified__step_event_week_007_letter_cousin_2_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9AC\uC548\uC758 \uD3B8\uC9C0 \uC218\uC815"
  _bodyText: "letter cousin_2 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uB9AC\uC548 \uB3C4\uB828\uB2D8\uC774 \uC131\uC778\uC2DD
      \uC804\uC5D0 \uAF2D \uB3CC\uC544\uC640 \uACC1\uC5D0 \uC11C\uACA0\uB2E4\uACE0
      \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBA40\uB9AC \uC788\uC5B4\uB3C4 \uADF8\uB7F0 \uB9D0\uC744 \uD574\uC8FC\uB294\uAD6C\uB098."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC8FC\uC778\uB2D8\uC774 \uD63C\uC790\uB77C\uACE0 \uB290\uB07C\uC9C0
      \uC54A\uAC8C \uD558\uACA0\uB2E4\uACE0 \uC804\uD588\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB098\uB3C4 \uC529\uC529\uD558\uAC8C \uAE30\uB2E4\uB9B4\uB798."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uB9AC\uC548 \uB3C4\uB828\uB2D8\uC774 \uC131\uC778\uC2DD
    \uC804\uC5D0 \uAF2D \uB3CC\uC544\uC640 \uACC1\uC5D0 \uC11C\uACA0\uB2E4\uACE0
    \uD569\uB2C8\uB2E4."
