  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_excursion_lake_blocked__step_w007_excursion_lake_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 7\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uC794\uC794\uD55C \uD638\uC22B\uAC00. \uB124\uBAA8\uAC00 \uBB3C\uAC00\uC5D0
    \uC11C\uC11C \uBE44\uCE5C \uC790\uC2E0\uC758 \uBAA8\uC2B5\uC744 \uBB3C\uB044\uB7EC\uBBF8
    \uBC14\uB77C\uBCF4\uACE0 \uC788\uB2E4. \uC720\uB144\uAE30\uBCF4\uB2E4 \uD6CC\uCA4D
    \uC790\uB780 \uD0A4\uC640 \uCC28\uBD84\uD558\uAC8C \uB54B\uC544 \uB0B4\uB9B0
    \uBA38\uB9AC\uCE7C, \uAE30\uD488 \uC788\uB294 \uC790\uD0DC\uAC00 \uC218\uBA74\uC5D0
    \uBE44\uCE5C\uB2E4.)\r\n        \uD558\uB140 : \uC8FC\uC778\uB2D8, \uC774\uC81C\uB294
    \uC815\uB9D0 \uC544\uB984\uB2E4\uC6B4 \uC601\uC560\uAC00 \uB2E4 \uB418\uC168\uC5B4\uC694.
    \uD638\uC218\uC5D0 \uBE44\uCE5C \uBAA8\uC2B5\uC774 \uBC31\uC791\uB2D8\uC744 \uAF2D
    \uB2EE\uC544 \uC544\uC8FC \uB2E8\uB2E8\uD558\uACE0 \uC6B0\uC544\uD574 \uBCF4\uC774\uC2ED\uB2C8\uB2E4.\r\n       
    \r\n\r\n(\uACBD\uBE44\uB300\uC7A5\uC774 \uB124\uBAA8\uC758 \uB4F1 \uB4A4\uB85C
    \uB2E4\uAC00\uC640 \uC790\uC138\uB97C \uBC14\uB85C\uC7A1\uC544 \uC900\uB2E4.)\r\n       
    \uACBD\uBE44\uB300\uC7A5 : \uC678\uC591\uC758 \uC544\uB984\uB2E4\uC6C0\uC5D0
    \uCDE8\uD558\uB294 \uAC83\uC740 \uAE08\uBB3C\uC785\uB2C8\uB2E4. \uC9C4\uC815\uD55C
    \uAE30\uD488\uC740 \uD654\uB824\uD55C \uB4DC\uB808\uC2A4\uAC00 \uC544\uB2C8\uB77C,
    \uD754\uB4E4\uB9AC\uC9C0 \uC54A\uB294 \uB0B4\uBA74\uC5D0\uC11C \uB098\uC624\uB294
    \uBC95\uC774\uC9C0\uC694.\r\n        \uB124\uBAA8 : \uC544\uC800\uC528\uB3C4
    \uCC38, \uAC00\uB054\uC740 \uC608\uC058\uB2E4\uB294 \uCE6D\uCC2C \uC815\uB3C4\uB294
    \uD574\uC904 \uC218 \uC788\uC796\uC544\uC694.\r\n        \uACBD\uBE44\uB300\uC7A5
    : \uC8FC\uC778\uB2D8\uC758 \uAC00\uCE58\uB294 \uACE0\uC791 \uADF8\uB7F0 \uAC00\uBCBC\uC6B4
    \uCE6D\uCC2C\uC73C\uB85C \uB9E4\uAE38 \uC218 \uC788\uB294 \uAC83\uC774 \uC544\uB2D9\uB2C8\uB2E4.
    \uC790, \uCE58\uB9DB\uC790\uB77D\uC774 \uC816\uC9C0 \uC54A\uAC8C \uBB3C\uB7EC\uC11C\uC2DC\uC8E0."
