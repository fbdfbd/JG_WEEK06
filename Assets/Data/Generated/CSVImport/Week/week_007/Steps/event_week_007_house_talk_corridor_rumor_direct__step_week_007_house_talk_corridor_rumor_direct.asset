  _titleOverride: "\uAE30\uC774\uD55C \uBB38 \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "\uAE30\uC774\uD55C \uBB38 \uC18C\uBB38 - \uD5C8\uB77D \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uBC24\uC774 \uB418\uBA74 \uC11C\uCABD \uBCF5\uB3C4\uAC00 \uD3C9\uC18C\uBCF4\uB2E4
      \uB354 \uAE38\uC5B4 \uBCF4\uC778\uB2E4\uB294 \uB9D0\uC774 \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAE38\uC5B4\uC838? \uC9C4\uC9DC \uBCF5\uB3C4\uAC00 \uB298\uC5B4\uB098\uB294
      \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB4F1\uBD88\uC774 \uC801\uACE0 \uADF8\uB9BC\uC790\uAC00 \uACB9\uCE58\uBA74
      \uB05D\uC774 \uBA40\uC5B4 \uBCF4\uC5EC\uC11C, \uB2E4\uB4E4 \uAE30\uC774\uD55C
      \uBB38\uC774 \uC0DD\uAE34\uB2E4\uACE0 \uC218\uAD70\uAC70\uB9B0\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uC0C1\uD558\uC9C0\uB9CC... \uADF8\uB798\uB3C4 \uC65C \uADF8\uB7F0\uC9C0
      \uC54C\uACE0 \uB098\uB2C8\uAE4C \uB35C \uBB34\uC12D\uB2E4."
  _nemoLine: "\uBC24\uC774 \uB418\uBA74 \uC11C\uCABD \uBCF5\uB3C4\uAC00 \uD3C9\uC18C\uBCF4\uB2E4
    \uB354 \uAE38\uC5B4 \uBCF4\uC778\uB2E4\uB294 \uB9D0\uC774 \uC788\uC5B4\uC694."
