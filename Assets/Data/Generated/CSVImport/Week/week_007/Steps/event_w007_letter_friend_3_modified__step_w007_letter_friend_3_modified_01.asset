  m_Name: event_w007_letter_friend_3_modified__step_w007_letter_friend_3_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 7\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uC54C\uB85D\uB2EC\uB85D\uD55C \uAF43\uC78E\uC774
    \uC5EC\uAE30\uC800\uAE30 \uBD99\uC740 \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4.
    \uBD09\uD22C \uAC89\uBA74\uC5D0\uB294 \uC5F0\uD544\uB85C \uADF8\uB9B0 \uC6B0\uC2A4\uAF5D\uC2A4\uB7EC\uC6B4
    \uC0AC\uCD0C 1\uC758 \uC5BC\uAD74\uC774 \uADF8\uB824\uC838 \uC788\uACE0, \uADF8
    \uC704\uC5D0 '\uBC14\uBCF4'\uB77C\uACE0 \uC801\uD600 \uC788\uB2E4.)\r\n       
    \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C \uC628 \uD3B8\uC9C0\uB124\uC694.
    \uADF8\uB9BC \uC19C\uC528\uAC00 \uC5EC\uC804\uD558\uC2ED\uB2C8\uB2E4.\r\n       
    \r\n\r\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC0AC\uCD0C
    1 \uC8FC\uC778\uB2D8\uC758 \uC2EC\uC220\uAD82\uC740 \uB9D0\uB4E4\uC744 \uC544\uC8FC
    \uC720\uCF8C\uD558\uAC8C \uC6C3\uC5B4\uB118\uAE30\uB77C\uACE0 \uD558\uB124\uC694.\r\n       
    \uB124\uBAA8 : \uC5B4\uB5BB\uAC8C \uC6C3\uC5B4\uB118\uACA8?\r\n        \uD558\uB140
    : \uADF8 \uB9D0\uB4E4\uC740 \uB2E4 \uAC00\uC9DC \uB9C8\uBC95\uC774\uB77C\uC11C,
    \uC8FC\uC778\uB2D8\uC774 \uBC31\uC791\uB2D8\uC744 \uBBFF\uACE0 \uD55C \uBC88\uB9CC
    \uD06C\uAC8C \uC6C3\uC73C\uBA74 \uB2E4 \uC0AC\uB77C\uC838\uBC84\uB9B0\uB2E4\uACE0
    \uD569\uB2C8\uB2E4.\r\n        \uB124\uBAA8 : \uC624... \uADF8\uB7FC \uB098 \uC774\uC81C
    \uBB34\uC11C\uC6B4 \uC598\uAE30 \uB4E4\uC5B4\uB3C4 \uC548 \uBB34\uC12D\uACA0\uB2E4.
    \uADF8\uB0E5 \uC6C3\uC73C\uBA74 \uB418\uB2C8\uAE4C!"
