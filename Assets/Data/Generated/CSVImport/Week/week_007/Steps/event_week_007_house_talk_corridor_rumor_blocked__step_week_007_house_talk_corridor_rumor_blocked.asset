  _titleOverride: "\uAE30\uC774\uD55C \uBB38 \uC18C\uBB38 - \uD1B5\uC81C"
  _bodyText: "\uAE30\uC774\uD55C \uBB38 \uC18C\uBB38 - \uD1B5\uC81C \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBCF5\uB3C4\uAC00 \uBC24\uB9C8\uB2E4 \uAE38\uC5B4\uC9C4\uB2E4\uB294
      \uC18C\uBB38\uC740 \uAD73\uC774 \uC790\uC138\uD788 \uB9D0\uD574 \uC8FC\uC9C0
      \uC54A\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610 \uC774\uC0C1\uD55C \uC18C\uBB38 \uC788\uC5C8\uC5B4\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBD88\uC548\uB9CC \uB0A8\uAE38 \uC774\uC57C\uAE30\uB294 \uB35C\uC5B4\uB0B4\uACE0,
      \uB2A6\uC740 \uC2DC\uAC04\uC5D4 \uAE38\uC744 \uC870\uC2EC\uD558\uB77C\uACE0\uB9CC
      \uC77C\uB7EC \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC54C\uACA0\uC5B4\uC694. \uADF8\uB7FC \uAD1C\uD788 \uD63C\uC790 \uC548
      \uAC78\uC744\uB798."
  _nemoLine: "(\uBCF5\uB3C4\uAC00 \uBC24\uB9C8\uB2E4 \uAE38\uC5B4\uC9C4\uB2E4\uB294
    \uC18C\uBB38\uC740 \uAD73\uC774 \uC790\uC138\uD788 \uB9D0\uD574 \uC8FC\uC9C0
    \uC54A\uB294\uB2E4.)"
