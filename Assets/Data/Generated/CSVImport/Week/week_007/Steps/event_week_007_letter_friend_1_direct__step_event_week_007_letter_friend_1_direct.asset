  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_007_letter_friend_1_direct__step_event_week_007_letter_friend_1_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9C9\uC2A4\uC758 \uD3B8\uC9C0 \uD5C8\uAC00"
  _bodyText: "letter friend_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uB9C9\uC2A4 \uB3C4\uB828\uB2D8\uC774 \uC131\uC778\uC2DD
      \uB0A0 \uC81C\uC77C \uBA3C\uC800 \uCD95\uD558\uD574 \uB4DC\uB9AC\uACE0 \uC2F6\uB2E4\uACE0
      \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC? \uAC54\uAC00 \uBB38 \uC55E\uC5D0\uC11C \uC81C\uC77C \uD06C\uAC8C
      \uB9D0\uD560 \uAC83 \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\"\uB124\uAC00 \uC815\uC2DD \uC8FC\uC778\uB2D8\uC774 \uB418\uB294 \uB0A0,
      \uB0B4\uAC00 \uC81C\uC77C \uBA3C\uC800 \uBC15\uC218\uCE60 \uAC70\uC57C. \uADF8\uB7EC\uB2C8\uAE4C
      \uB108\uBB34 \uAE34\uC7A5\uD558\uC9C0 \uB9C8.\"\uB77C\uACE0 \uC801\uD600 \uC788\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD6C4\uD6C4, \uBC8C\uC368 \uB4E4\uB9B0\uB2E4. \uAC54 \uBAA9\uC18C\uB9AC
      \uC5C4\uCCAD \uD074 \uD150\uB370."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uB9C9\uC2A4 \uB3C4\uB828\uB2D8\uC774 \uC131\uC778\uC2DD
    \uB0A0 \uC81C\uC77C \uBA3C\uC800 \uCD95\uD558\uD574 \uB4DC\uB9AC\uACE0 \uC2F6\uB2E4\uACE0
    \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
