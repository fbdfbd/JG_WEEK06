  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_visitor_friend_2_direct__step_w007_visitor_friend_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 7\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uBC31\uC791\uB2D8\uC758 \uC11C\uC7AC, \uB124\uBAA8\uAC00 \uC0B0\uB354\uBBF8
    \uAC19\uC740 \uBC95\uBB34 \uC11C\uB958\uC5D0 \uD30C\uBB3B\uD600 \uC788\uB2E4.
    \uCE5C\uAD6C 2\uAC00 \uCC28\uBD84\uD55C \uAC78\uC74C\uC73C\uB85C \uB4E4\uC5B4\uC640
    \uB124\uBAA8\uC758 \uCC45\uC0C1 \uC704\uC5D0 \uB530\uB73B\uD55C \uCC3B\uC794\uC744
    \uB193\uB294\uB2E4.)\r\n        \r\n        \uCE5C\uAD6C 2 : \uB124\uBAA8, \uC0AC\uCD0C
    1\uC774 \uB2E4\uB140\uAC14\uB2E4\uBA74\uC11C? \uADF8 \uC778\uAC04\uC774 \uD558\uB294
    \uB9D0\uC740 \uC808\uBC18\uC758 \uC9C4\uC2E4\uC5D0 \uC544\uD649 \uBC30\uC758
    \uAC70\uC9D3\uC744 \uC11E\uC740 \uB3C5\uC774\uC57C. \uBC31\uC791\uB2D8\uC774
    \uB108\uD55C\uD14C \uC774 \uB9CE\uC740 \uC11C\uB958\uB97C \uC77D\uAC8C \uD558\uB294
    \uAC74, \uB124\uAC00 \uB098\uC911\uC5D0 \uB204\uAD6C\uC5D0\uAC8C\uB3C4 \uC18D\uC9C0
    \uC54A\uAC8C \uD558\uB824\uB294 '\uBB34\uAE30'\uB97C \uC950\uC5EC\uC8FC\uB294
    \uAC70\uB77C\uACE0 \uC0DD\uAC01\uD574.\r\n        \r\n\r\n- (\uB124\uBAA8\uAC00
    \uCE5C\uAD6C 2\uC5D0\uAC8C \uC11C\uB958 \uD55C \uC7A5\uC744 \uBCF4\uC5EC\uC8FC\uBA70
    \uC529 \uC6C3\uB294\uB2E4.)\r\n        - \uB124\uBAA8 : \uC774 \uC870\uD56D \uC880
    \uBD10. \uBC31\uC791\uB2D8\uC774 \uC608\uC804\uC5D0 \uC218\uC815\uD558\uC2E0
    \uAC74\uB370, \uAC00\uB09C\uD55C \uC544\uC774\uB4E4\uC758 \uAD50\uC721\uBE44\uB97C
    \uC9C0\uC6D0\uD55C\uB2E4\uB294 \uB0B4\uC6A9\uC774\uC57C. \uC0AC\uCD0C 1\uC740
    \uBC31\uC791\uB2D8\uC774 \uB0C9\uD608\uD55C\uC774\uB77C\uACE0 \uD588\uC9C0\uB9CC,
    \uC0AC\uC2E4 \uB204\uAD6C\uBCF4\uB2E4 \uB530\uB73B\uD55C \uBD84\uC774\uC5C8\uC5B4.\r\n       
    \uCE5C\uAD6C 2 : (\uC11C\uB958\uB97C \uC0B4\uD53C\uBA70) \uC6B0\uC640, \uC9C4\uC9DC\uB124?
    \uBC31\uC791\uB2D8\uC740 \uAC89\uC73C\uB860 \uBB34\uB69D\uB69D\uD574\uB3C4 \uB4A4\uC5D0\uC11C
    \uC774\uB7F0 \uC77C\uC744 \uD558\uACE0 \uACC4\uC168\uAD6C\uB098. \uB124\uBAA8
    \uB108\uB3C4 \uB098\uC911\uC5D0 \uC774\uB7F0 \uBA4B\uC9C4 \uC8FC\uC778\uC774
    \uB420 \uAC70\uC9C0?"
