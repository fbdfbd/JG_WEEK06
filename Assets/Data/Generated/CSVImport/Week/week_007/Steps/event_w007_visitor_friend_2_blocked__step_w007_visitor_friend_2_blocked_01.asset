  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_visitor_friend_2_blocked__step_w007_visitor_friend_2_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 7\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uBC31\uC791\uB2D8\uC758 \uC11C\uC7AC, \uB124\uBAA8\uAC00 \uC0B0\uB354\uBBF8
    \uAC19\uC740 \uBC95\uBB34 \uC11C\uB958\uC5D0 \uD30C\uBB3B\uD600 \uC788\uB2E4.
    \uCE5C\uAD6C 2\uAC00 \uCC28\uBD84\uD55C \uAC78\uC74C\uC73C\uB85C \uB4E4\uC5B4\uC640
    \uB124\uBAA8\uC758 \uCC45\uC0C1 \uC704\uC5D0 \uB530\uB73B\uD55C \uCC3B\uC794\uC744
    \uB193\uB294\uB2E4.)\n        \n        \uCE5C\uAD6C 2 : \uB124\uBAA8, \uC0AC\uCD0C
    1\uC774 \uB2E4\uB140\uAC14\uB2E4\uBA74\uC11C? \uADF8 \uC778\uAC04\uC774 \uD558\uB294
    \uB9D0\uC740 \uC808\uBC18\uC758 \uC9C4\uC2E4\uC5D0 \uC544\uD649 \uBC30\uC758
    \uAC70\uC9D3\uC744 \uC11E\uC740 \uB3C5\uC774\uC57C. \uBC31\uC791\uB2D8\uC774
    \uB108\uD55C\uD14C \uC774 \uB9CE\uC740 \uC11C\uB958\uB97C \uC77D\uAC8C \uD558\uB294
    \uAC74, \uB124\uAC00 \uB098\uC911\uC5D0 \uB204\uAD6C\uC5D0\uAC8C\uB3C4 \uC18D\uC9C0
    \uC54A\uAC8C \uD558\uB824\uB294 '\uBB34\uAE30'\uB97C \uC950\uC5EC\uC8FC\uB294
    \uAC70\uB77C\uACE0 \uC0DD\uAC01\uD574.\n        \n\n- (\uC9D1\uC0AC\uAC00 \uB2E4\uAC00\uC640
    \uCC3B\uC794\uC758 \uC628\uB3C4\uB97C \uD655\uC778\uD558\uACE0 \uACE0\uAC1C\uB97C
    \uB044\uB355\uC778\uB2E4. \uB124\uBAA8\uB294 \uD39C\uC744 \uB0B4\uB824\uB193\uACE0
    \uCC28\uB97C \uD55C \uBAA8\uAE08 \uB9C8\uC2E0\uB2E4.)\n        - \uB124\uBAA8
    : \uB9DE\uC544. \uCC98\uC74C\uC5D4 \uC774 \uC11C\uB958\uB4E4\uC774 \uB098\uB97C
    \uAC00\uB450\uB294 \uBCBD\uC778 \uC904 \uC54C\uC558\uB294\uB370, \uC77D\uB2E4
    \uBCF4\uB2C8 \uC774\uAC8C \uB2E4 \uC601\uC9C0\uBBFC\uB4E4\uC744 \uC9C0\uD0A4\uB294
    \uBC95\uB839\uC774\uB354\uB77C\uACE0. \uBC31\uC791\uB2D8\uC740 \uB0B4\uAC00 \uAC10\uC815\uC5D0
    \uD718\uB458\uB9AC\uC9C0 \uC54A\uB294 \uB0C9\uCCA0\uD55C \uC8FC\uC778\uC774 \uB418\uAE38
    \uBC14\uB77C\uC2DC\uB294 \uAC70\uC57C.\n        \uCE5C\uAD6C 2 : \uC5ED\uC2DC
    \uB124\uBAA8\uB124. \uBC31\uC791\uB2D8\uC758 \uC5C4\uACA9\uD568\uC774 \uACB0\uAD6D
    \uB124 \uC9C0\uD61C\uAC00 \uB418\uACE0 \uC788\uC5B4. \uADF8\uBD84\uC740 \uB110
    \uC815\uB9D0 \uAC15\uD558\uAC8C \uD0A4\uC6B0\uACE0 \uACC4\uC2E0 \uAC70\uC57C."
