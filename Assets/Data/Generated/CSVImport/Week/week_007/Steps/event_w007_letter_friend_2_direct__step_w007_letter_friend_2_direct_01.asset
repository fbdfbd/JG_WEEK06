  m_Name: event_w007_letter_friend_2_direct__step_w007_letter_friend_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 \uD3B8\uC9C0 7\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "- (\uD558\uB140\uAC00 \uC740\uC740\uD55C \uAF43 \uD5A5\uC774 \uB098\uB294
    \uB2E8\uC815\uD55C \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C
    \uADC0\uD241\uC774\uC5D0 '\uC624\uB3C5(\u8AA4\u8B80) \uC8FC\uC758'\uB77C\uACE0
    \uC801\uD600 \uC788\uB2E4.)\r\n\r\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uAF3C\uAF3C\uD55C
    \uCE5C\uAD6C\uBD84\uC774 \uC774\uBC88\uC5D4 \uC0AC\uCD0C 1\uC758 \uADA4\uBCC0\uC744
    \uB17C\uB9AC\uC801\uC73C\uB85C \uBC18\uBC15\uD558\uB294 \uAE00\uC744 \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : \uAC54\uAC00 \uC0AC\uCD0C 1\uC744 \uD63C\uB0B4\uC900 \uAC70\uC57C?\r\n       
    (\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uC77D\uC5B4 \uC900\uB2E4.)\r\n       
    \uB124\uBAA8\uC5D0\uAC8C. \uC0AC\uCD0C 1\uC774 \uC900 \uC778\uC7A5\uC5D0 \uD604\uD639\uB418\uC9C0
    \uB9C8. \uADF8 \uBCF4\uC11D\uC740 \uC9C4\uC2E4\uC774 \uC544\uB2C8\uB77C \uC695\uB9DD\uC744
    \uBE44\uCD94\uB294 \uAC70\uC57C. \uC9C4\uC9DC \uC9C4\uC2E4\uC740 \uBC31\uC791\uB2D8\uC774
    \uB124\uAC8C \uC8FC\uC2E0 \uADF8 \uB0A1\uC740 \uBC95\uC804 \uC18D\uC5D0 \uC788\uC5B4.
    142\uD398\uC774\uC9C0\uC758 \uC138\uAE08\uC744 \uBD10. \uBC31\uC791\uB2D8\uC774
    \uC5BC\uB9C8\uB098 \uBC31\uC131\uB4E4\uC744 \uC544\uB07C\uB294\uC9C0 \uC54C \uC218
    \uC788\uAC70\uB4E0.\r\n        \uB124\uBAA8 : 142\uD398\uC774\uC9C0... \uC5ED\uC2DC
    \uCE5C\uAD6C 2\uB294 \uC544\uB294 \uAC8C \uB9CE\uC544.\r\n        \uD558\uB140
    : \uC8FC\uC778\uB2D8\uC758 \uACC1\uC744 \uC9C0\uD0A4\uB294 \uAC00\uC7A5 \uD604\uBA85\uD55C
    \uB208\uC774 \uB418\uC5B4\uC8FC\uACE0 \uC788\uB124\uC694.\r\n        \uB124\uBAA8
    : \uC751. \uB098\uB3C4 \uC5BC\uB978 \uACF5\uBD80\uD574\uC11C \uBC31\uC791\uB2D8\uCC98\uB7FC
    \uBA4B\uC9C4 \uC22B\uC790\uB97C \uC4F0\uACE0 \uC2F6\uC5B4."
