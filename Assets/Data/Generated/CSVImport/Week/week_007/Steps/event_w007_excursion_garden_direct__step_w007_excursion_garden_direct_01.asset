  m_Name: event_w007_excursion_garden_direct__step_w007_excursion_garden_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 7\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uC815\uC6D0 \uC548\uCABD, \uC720\uB144\uAE30 \uB54C \uC2EC\uC5C8\uB358
    \uC5B4\uB9B0\uB098\uBB34\uAC00 \uC774\uC81C \uB124\uBAA8\uC758 \uD0A4\uB97C \uD6CC\uCA4D
    \uB118\uACA8 \uBB34\uC131\uD558\uAC8C \uC790\uB77C \uC788\uB2E4.)\n        \uD558\uB140
    : \uC8FC\uC778\uB2D8, \uAE30\uC5B5\uB098\uC138\uC694? \uC774 \uB098\uBB34 \uC8FC\uC778\uB2D8\uC774
    \uC694\uB9CC\uD560 \uB54C \uAC19\uC774 \uC2EC\uC5C8\uC796\uC544\uC694. \uC774\uC81C\uB294
    \uC8FC\uC778\uB2D8\uC744 \uC9C0\uCF1C\uC904 \uB9CC\uD07C \uB4E0\uB4E0\uD574\uC84C\uB124\uC694.\n       
    \n\n- \uB124\uBAA8 : \uC6B0\uC640, \uC9C4\uC9DC \uB9CE\uC774 \uCEF8\uB2E4. \uC774\uC81C\uB294
    \uD574\uAC00 \uB728\uAC70\uC6CC\uB3C4 \uC774 \uC544\uB798 \uC788\uC73C\uBA74
    \uC2DC\uC6D0\uD558\uACA0\uC5B4.\n        \uD558\uB140 : \uB124, \uC8FC\uC778\uB2D8.
    \uB098\uBB34\uAC00 \uC790\uB780 \uB9CC\uD07C \uC8FC\uC778\uB2D8\uB3C4 \uC544\uC8FC
    \uBA4B\uC9C4 \uC5B4\uB978\uC774 \uB418\uC168\uB294\uAC78\uC694.\n        \uB124\uBAA8
    : \uD788\uD788, \uB098\uC911\uC5D4 \uC5EC\uAE30 \uC758\uC790\uB3C4 \uAC00\uC838\uB2E4
    \uB193\uACE0 \uCC45\uB3C4 \uC77D\uACE0 \uC2F6\uC5B4. \uB0B4\uAC00 \uC9C1\uC811
    \uAC00\uAFBC \uB098\uBB34\uB2C8\uAE4C \uB354 \uC88B\uC544."
