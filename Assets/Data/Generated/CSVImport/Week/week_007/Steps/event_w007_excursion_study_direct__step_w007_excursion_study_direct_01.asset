  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_excursion_study_direct__step_w007_excursion_study_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC 7\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uC11C\uC7AC \uCC45\uC0C1 \uC704\uC5D0 \uC720\uB144\uAE30 \uC2DC\uC808
    \uC544\uB07C\uB358 \uC791\uC740 \uC778\uD615\uACFC \uC9C0\uAE08\uC740 \uC190\uB54C
    \uBB3B\uC740 \uB450\uAEBC\uC6B4 \uACBD\uC81C\uD559 \uC11C\uC801\uC774 \uB098\uB780\uD788
    \uB193\uC5EC \uC788\uB2E4. \uC8FC\uC778\uB2D8\uC740 \uC774\uC81C \uC758\uC790\uC5D0
    \uC549\uC544\uB3C4 \uBC1C\uC774 \uBC14\uB2E5\uC5D0 \uB2FF\uC9C0 \uC54A\uB358
    \uAF2C\uB9C8\uAC00 \uC544\uB2C8\uB2E4.)\n        \n        \uD558\uB140 : \uC8FC\uC778\uB2D8,
    \uC774 \uC778\uD615\uC740 \uC774\uC81C \uB2E4\uB978 \uACF3\uC73C\uB85C \uC62E\uACA8\uB458\uAE4C\uC694?
    \uC774\uC81C\uB294 \uC911\uC694\uD55C \uC11C\uB958\uB4E4\uC774 \uB9CE\uC544\uC11C
    \uC790\uB9AC\uAC00 \uC881\uC544 \uBCF4\uC774\uB124\uC694.\n        \n\n- \uB124\uBAA8
    : \uC751, \uC774\uC81C \uC774 \uC544\uC774\uB3C4 \uD3B8\uD558\uAC8C \uC26C\uAC8C
    \uD574\uC918\uC57C\uC9C0. \uB300\uC2E0 \uADF8 \uC790\uB9AC\uC5D0 \uB0B4\uAC00
    \uC9C1\uC811 \uADF8\uB9B0 \uC601\uC9C0 \uC9C0\uB3C4\uB97C \uB193\uC544\uB458\uB798.\n       
    \uD558\uB140 : \uC5B4\uBA38, \uC8FC\uC778\uB2D8\uC774 \uC9C1\uC811 \uADF8\uB9AC\uC2E0
    \uC9C0\uB3C4\uC694? \uC774\uC81C\uB294 \uC815\uB9D0 \uC774 \uBC29\uC758 \uC9C4\uC9DC
    \uC8FC\uC778\uC774 \uB418\uC168\uB124\uC694.\n        \uB124\uBAA8 : \uB0B4\uAC00
    \uAD00\uB9AC\uD574\uC57C \uD560 \uB545\uC774\uB2C8\uAE4C, \uB0B4 \uC190\uC73C\uB85C
    \uADF8\uB9B0 \uC9C0\uB3C4\uB97C \uBCF4\uBA74\uC11C \uB9E4\uC77C \uB2E4\uC9D0\uD558\uACE0
    \uC2F6\uC5B4."
