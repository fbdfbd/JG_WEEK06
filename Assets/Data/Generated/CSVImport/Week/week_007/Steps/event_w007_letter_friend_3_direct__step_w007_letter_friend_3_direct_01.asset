  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_letter_friend_3_direct__step_w007_letter_friend_3_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 7\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uC54C\uB85D\uB2EC\uB85D\uD55C \uAF43\uC78E\uC774
    \uC5EC\uAE30\uC800\uAE30 \uBD99\uC740 \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4.
    \uBD09\uD22C \uAC89\uBA74\uC5D0\uB294 \uC5F0\uD544\uB85C \uADF8\uB9B0 \uC6B0\uC2A4\uAF5D\uC2A4\uB7EC\uC6B4
    \uC0AC\uCD0C 1\uC758 \uC5BC\uAD74\uC774 \uADF8\uB824\uC838 \uC788\uACE0, \uADF8
    \uC704\uC5D0 '\uBC14\uBCF4'\uB77C\uACE0 \uC801\uD600 \uC788\uB2E4.)\n       
    \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C \uC628 \uD3B8\uC9C0\uB124\uC694.
    \uADF8\uB9BC \uC19C\uC528\uAC00 \uC5EC\uC804\uD558\uC2ED\uB2C8\uB2E4.\n       
    \n\n(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uB4E4\uACE0 \uB124\uBAA8\uC5D0\uAC8C
    \uB2E4\uAC00\uAC04\uB2E4.)\n        \uD558\uB140 : \uC8FC\uC778\uB2D8, \uC0C1\uC0C1\uB825\uC774
    \uD48D\uBD80\uD55C \uCE5C\uAD6C\uBD84\uC774 \uC774\uBC88\uC5D4 \uC0AC\uCD0C 1
    \uC8FC\uC778\uB2D8\uC744 \uBB34\uCC0C\uB974\uB294 \uB9C8\uBC95 \uC8FC\uBB38\uC744
    \uBCF4\uB0C8\uC5B4\uC694.\n        \uB124\uBAA8 : \uB9C8\uBC95 \uC8FC\uBB38?
    \uBB50\uC57C, \uBE68\uB9AC \uC77D\uC5B4 \uC918!\n        (\uD558\uB140\uAC00
    \uBD09\uD22C\uB97C \uC5F4\uC5B4 \uD3B8\uC9C0\uB97C \uC77D\uC5B4 \uC900\uB2E4.)\n       
    \uB124\uBAA8 \uC548\uB155! \uC0AC\uCD0C 1 \uADF8 \uC544\uC800\uC528\uAC00 \uB108\uD55C\uD14C
    \uB610 \uBEE5\uCE58\uACE0 \uAC14\uC9C0? \uAC71\uC815 \uB9C8, \uB0B4\uAC00 \uADF8
    \uC544\uC800\uC528 \uC785\uC5D0 \uC9C0\uD37C\uB97C \uCC44\uC6B0\uB294 \uB9C8\uBC95
    \uAC00\uB8E8\uB97C \uAD6C\uD574\uC654\uC5B4! \uC0AC\uC2E4 \uADF8\uB0E5 \uC124\uD0D5
    \uAC00\uB8E8\uC9C0\uB9CC... \uC544\uBB34\uD2BC! \uB10C \uBC31\uC791\uB2D8\uCC98\uB7FC
    \uBA4B\uC9C4 \uC0AC\uC790\uB2C8\uAE4C, \uADF8\uB7F0 \uC5EC\uC6B0 \uAC19\uC740
    \uC18C\uB9AC\uC5D0 \uC18D\uC73C\uBA74 \uC548 \uB3FC. \uC54C\uC558\uC9C0?\n       
    \uB124\uBAA8 : \uC0AC\uC790? \uB0B4\uAC00 \uC0AC\uC790\uC57C?\n        \uD558\uB140
    : \uB124, \uC8FC\uC778\uB2D8. \uCE5C\uAD6C\uBD84 \uB208\uC5D0\uB294 \uC8FC\uC778\uB2D8\uC774
    \uC544\uC8FC \uC6A9\uB9F9\uD574 \uBCF4\uC774\uB098 \uBD05\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uD788\uD788, \uADF8 \uC544\uC800\uC528\uD55C\uD14C \uC9C4\uC9DC
    \uC124\uD0D5 \uAC00\uB8E8\uB77C\uB3C4 \uBFCC\uB824\uC8FC\uACE0 \uC2F6\uB2E4!"
