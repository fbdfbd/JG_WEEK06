  _titleOverride: "\uB9C9\uC2A4 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor friend_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "(\uAC10\uACA9\uD55C \uB4EF \uBB38\uC7A5\uC744 \uBC14\uB77C\uBCF4\uBA70)
      \uC640... \uC9C4\uC9DC \uBA4B\uC9C0\uB2E4! \uC774\uC81C \uBE44\uBC00 \uD1B5\uB85C\uB85C
      \uBAB0\uB798 \uB4E4\uC5B4\uC624\uC9C0 \uC54A\uC544\uB3C4 \uB41C\uB2E4\uB294
      \uAC70\uC9C0? \uBC31\uC791\uB2D8 \uC11C\uC7AC\uB97C \uC6B0\uB9AC\uB4E4\uC758
      \uC9C4\uC9DC \uC544\uC9C0\uD2B8\uB85C \uB9CC\uB4DC\uB294 \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC6C3\uC73C\uBA70) \uB2F9\uC5F0\uD558\uC9C0! \uBC31\uC791\uB2D8\uC774
      \uC313\uC544 \uC62C\uB9B0 \uC774 \uACAC\uACE0\uD55C \uC138\uACC4 \uC704\uC5D0,
      \uC6B0\uB9AC\uAC00 \uAFC8\uAFB8\uB294 \uC0C8\uB85C\uC6B4 \uC138\uC0C1\uC744
      \uADF8\uB824 \uB123\uC790. \uB10C \uB0B4 \uC601\uC6D0\uD55C \uB3D9\uB8CC\uB2C8\uAE4C!"
  _nemoLine: "(\uAC10\uACA9\uD55C \uB4EF \uBB38\uC7A5\uC744 \uBC14\uB77C\uBCF4\uBA70)
    \uC640... \uC9C4\uC9DC \uBA4B\uC9C0\uB2E4! \uC774\uC81C \uBE44\uBC00 \uD1B5\uB85C\uB85C
    \uBAB0\uB798 \uB4E4\uC5B4\uC624\uC9C0 \uC54A\uC544\uB3C4 \uB41C\uB2E4\uB294 \uAC70\uC9C0?
    \uBC31\uC791\uB2D8 \uC11C\uC7AC\uB97C \uC6B0\uB9AC\uB4E4\uC758 \uC9C4\uC9DC \uC544\uC9C0\uD2B8\uB85C
    \uB9CC\uB4DC\uB294 \uAC70\uC57C?"
