  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_external_main_blocked__step_w007_external_main_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "7\uCC28 - \uD1B5\uC81C"
  _bodyText: "\uAD6D\uACBD\uC758 \uAE34\uC7A5\uACFC \uCCA0\uAC11 \uAE30\uBCD1\uB300\r\n   
    \r\n    (\uC800\uD0DD \uB4B7\uBB38, \uC2DD\uC790\uC7AC\uB97C \uB0A9\uD488\uD558\uB294
    \uC0C1\uC778\uC774 \uACBD\uBE44\uBCD1\uC5D0\uAC8C \uC740\uBC00\uD558\uAC8C \uAC00\uC8FD
    \uC8FC\uBA38\uB2C8\uB97C \uAC74\uB124\uBA70 \uC18D\uC0AD\uC778\uB2E4.)\r\n   
    \r\n    \uC0C1\uC778 : \uC774\uBD10, \uAD6D\uACBD \uB108\uBA38 \uC81C\uAD6D\uAD70\uC774
    \uC2EC\uC0C1\uCE58 \uC54A\uC544. \uC628\uBAB8\uC744 \uCCA0\uAC11\uC73C\uB85C
    \uB450\uB978 \uAE30\uBCD1\uB300\uAC00 \uBC8C\uC368 \uADFC\uCC98 \uB9C8\uC744\uAE4C\uC9C0
    \uB0B4\uB824\uC654\uB2E4\uB354\uAD70.\r\n    \uACBD\uBE44\uBCD1 : \uC27F! \uBC31\uC791\uB2D8\uC774
    \uD568\uAD6C\uB839\uC744 \uB0B4\uB9AC\uC168\uC5B4. \uC131\uC778\uC2DD \uCD95\uC81C
    \uBD84\uC704\uAE30\uB97C \uB9DD\uCE58\uACE0 \uC2F6\uC9C0 \uC54A\uC73C\uC2E0 \uAC8C\uC9C0.\r\n   
    \uB124\uBAA8 : \uCCA0\uAC11 \uAE30\uBCD1\uB300? \uC6B0\uB9AC \uC601\uC9C0\uB85C
    \uCCD0\uB4E4\uC5B4\uC624\uB294 \uAC70\uC57C?\r\n    \r\n\r\n- \uC0C1\uC778 :
    (\uB124\uBAA8\uB97C \uBC1C\uACAC\uD558\uACE0 \uC18C\uC2A4\uB77C\uCE58\uAC8C \uB180\uB77C\uBA70)
    \uC544\uC720, \uB3C4\uB828\uB2D8! \uADF8\uB0E5 \uC81C\uAD6D\uC5D0\uC11C \uBA4B\uC9C4
    \uD37C\uB808\uC774\uB4DC\uB97C \uD55C\uB2E4\uB294 \uC18C\uB9AC\uC600\uC2B5\uB2C8\uB2E4\uC694.\r\n   
    \uACBD\uBE44\uBCD1 : \uB124, \uC8FC\uC778\uB2D8. \uC131\uC778\uC2DD \uB54C \uBCF4\uC5EC\uC904
    \uCD95\uD558 \uACF5\uC5F0 \uC5F0\uC2B5\uC778\uAC00 \uBD05\uB2C8\uB2E4. \uAC71\uC815
    \uB9D0\uACE0 \uC548\uC73C\uB85C \uB4E4\uC5B4\uAC00\uC2DC\uC9C0\uC694.\r\n   
    \uB124\uBAA8 : \uD568\uAD6C\uB839\uC774\uB77C\uBA70! \uC804\uC7C1\uC774\uB77C\uB3C4
    \uB098\uB294 \uAC70\uBA74 \uB098\uB3C4 \uC54C\uC544\uC57C \uD558\uC796\uC544!"
