  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_excursion_basement_direct__step_w007_excursion_basement_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 7\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uC5B4\uB450\uC6B4 \uC9C0\uD558\uC2E4 \uC548\uCABD. \uD654\uB824\uD55C
    \uBCF8\uAD00\uACFC \uB2EC\uB9AC, \uC774\uACF3\uC5D0\uB294 \uBE5B\uC774 \uBC14\uB798\uACE0
    \uCC22\uC5B4\uC9C4 \uC61B \uC120\uB300\uB4E4\uC758 \uCD08\uC0C1\uD654\uC640 \uB0A1\uC740
    \uAC00\uAD6C\uB4E4\uC774 \uCC9C\uC73C\uB85C \uB36E\uC5EC \uC788\uB2E4.)\n       
    \uD558\uB140 : \uCF5C\uB85D, \uC5EC\uAE30\uB294 \uBA3C\uC9C0\uAC00 \uB108\uBB34
    \uB9CE\uC544\uC694, \uC8FC\uC778\uB2D8. \uCE58\uB9DB\uC790\uB77D\uC774 \uC0C1\uD560
    \uD14C\uB2C8 \uADF8\uB9CC \uC62C\uB77C\uAC00\uC2DC\uB294 \uAC8C \uC5B4\uB5A8\uAE4C\uC694?\n       
    \uB124\uBAA8 : \uC7A0\uAE50\uB9CC. \uC774 \uCD08\uC0C1\uD654 \uC18D \uBD80\uC778,
    \uB098\uB791 \uB208\uB9E4\uAC00 \uC544\uC8FC \uBE44\uC2B7\uD558\uAC8C \uC0DD\uAE30\uC168\uC5B4.
    \uC65C \uC774\uB7F0 \uAD6C\uC11D\uC5D0 \uBC84\uB824\uC838 \uC788\uB294 \uAC78\uAE4C?\n       
    \n\n\uB124\uBAA8 : \uC5B4\uB824\uC6B4 \uACB0\uC815... \uADF8\uB798\uC11C \uC624\uD574\uB97C
    \uBC1B\uACE0 \uC774\uACF3\uC5D0 \uB0A8\uACA8\uC9C0\uC2E0 \uAC70\uAD6C\uB098.\n       
    \uD558\uB140 : \uBAA8\uB450\uAC00 \uC54C\uC544\uC8FC\uC9C4 \uC54A\uC544\uB3C4
    \uAC00\uBB38\uC744 \uC9C0\uD0A4\uB824 \uD558\uC168\uB358 \uAC70\uACA0\uC8E0.\n       
    \uB124\uBAA8 : (\uCD08\uC0C1\uD654\uC758 \uBA3C\uC9C0\uB97C \uC870\uC2EC\uC2A4\uB808
    \uB2E6\uC544\uB0B4\uBA70) \uB098\uB3C4 \uB098\uC911\uC5D0 \uC800\uD0DD\uC744
    \uC774\uB04C\uB2E4 \uBCF4\uBA74, \uBAA8\uB450\uC5D0\uAC8C \uD658\uC601\uBC1B\uC9C0
    \uBABB\uD558\uB294 \uACB0\uC815\uC744 \uD574\uC57C \uD560 \uB54C\uAC00 \uC624\uACA0\uC9C0?"
