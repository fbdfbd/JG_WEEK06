  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_visitor_cousin_1_direct__step_w007_visitor_cousin_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 7\uCC28 \uB9CC\uB0A8 - \uC218\uB77D (\uB3D9\uC758"
  _bodyText: "(\uBC31\uC791\uB2D8\uC774 \uC790\uB9AC\uB97C \uBE44\uC6B4 \uC11C\uC7AC.
    \uC0AC\uCD0C 1\uC774 \uC18C\uD30C\uC5D0 \uC549\uC544 \uBD89\uC740 \uBCF4\uC11D\uC774
    \uBC15\uD78C \uC778\uC7A5\uC744 \uB9CC\uC9C0\uC791\uAC70\uB9AC\uB2E4 \uB124\uBAA8\uAC00
    \uB4E4\uC5B4\uC624\uC790 \uC18C\uB984 \uB07C\uCE58\uB294 \uBBF8\uC18C\uB97C \uC9C0\uC73C\uBA70
    \uAC74\uB128\uB2E4.)\r\n        \r\n        \uC0AC\uCD0C 1 : \uC57C, \uB124\uBAA8.
    \uC774\uAC70 \uC6D0\uB798 \uB124 \uC9C4\uC9DC \uBD80\uBAA8\uB2D8\uC774 \uB9C8\uC9C0\uB9C9\uAE4C\uC9C0
    \uC950\uACE0 \uC788\uB358 \uAC70\uB2E4. \uBC31\uC791\uB2D8\uC740 \"\uC0AC\uACE0\uB85C
    \uC720\uC2E4\uB410\uB2E4\"\uACE0 \uD558\uC168\uC9C0? \uADFC\uB370 \uC65C \uC774\uAC8C
    \uB0B4 \uC190\uC5D0 \uC788\uC744\uAE4C?\r\n        \uB124\uBAA8 : (\uB4B7\uAC78\uC74C\uC9C8
    \uCE58\uBA70) \uADF8\uAC78 \uC0BC\uCD0C\uC774 \uC65C... \uBC31\uC791\uB2D8\uC740
    \uBD84\uBA85\uD788 \uB2E4 \uC0AC\uB77C\uC84C\uB2E4\uACE0 \uD558\uC168\uC5B4\uC694.\r\n       
    \uC0AC\uCD0C 1 : \uD558\uD558, \uBC31\uC791\uB2D8\uC740 \uCC38 \uAE68\uB057\uD55C
    \uCC99\uC744 \uC798\uD558\uC2E0\uB2E8 \uB9D0\uC774\uC57C. \uADF8\uBD84\uC774
    \uC815\uD574\uC900 '\uC9C4\uC2E4'\uB9CC \uBBFF\uACE0 \uC0B4\uAE30\uC5D4 \uB108\uB3C4
    \uC774\uC81C \uB108\uBB34 \uB9CE\uC774 \uC54C\uC9C0 \uC54A\uB0D0?\r\n       
    \r\n\r\n- )(\uB124\uBAA8\uAC00 \uCC28\uAC00\uC6B4 \uB208\uC73C\uB85C \uC0AC\uCD0C
    1\uC744 \uC3D8\uC544\uBCF4\uBA70 \uBC14\uB2E5\uC5D0 \uB5A8\uC5B4\uC9C4 \uC778\uC7A5\uC744
    \uC9C1\uC811 \uC9D1\uC5B4 \uB4E0\uB2E4.)\r\n        - \uB124\uBAA8 : \uC774\uAC8C
    \uC815\uB9D0 \uC6B0\uB9AC \uBD80\uBAA8\uB2D8\uC758 \uAC83\uC774\uB77C\uBA74,
    \uBC31\uC791\uB2D8\uC774 \uC544\uB2C8\uB77C \uC0BC\uCD0C\uC774 \uC774\uAC78 \uAC00\uC9C0\uACE0
    \uC788\uB2E4\uB294 \uAC8C \uB354 \uC218\uC0C1\uD558\uB124\uC694. \uC0BC\uCD0C\uC774
    \uD6D4\uCE5C \uAC70 \uC544\uB2C8\uC5D0\uC694?\r\n        \uC0AC\uCD0C 1 : \uC624,
    \uC81C\uBC95 \uB0A0\uCE74\uB85C\uC6B4\uB370? \uD558\uC9C0\uB9CC \uBC31\uC791\uC774
    \uB110 \uC774 \uC11C\uC7AC\uC5D0 \uAC00\uB46C\uB454 \uC9C4\uC9DC \uC774\uC720\uAC00
    '\uBCF4\uD638'\uB77C\uACE0 \uBBFF\uB294\uB2E4\uBA74 \uB10C \uD3C9\uC0DD \uADF8\uBD84\uC758
    \uAF2D\uB450\uAC01\uC2DC\uC77C \uBFD0\uC774\uC57C.\r\n        \uB124\uBAA8 :
    (\uC778\uC7A5\uC744 \uAF49 \uC950\uBA70) \uBC31\uC791\uB2D8\uC774 \uC228\uAE30\uB294
    \uAC8C \uC788\uB2E4\uBA74 \uB0B4\uAC00 \uC9C1\uC811 \uC54C\uC544\uB0BC \uAC70\uC608\uC694.
    \uC0BC\uCD0C \uAC19\uC740 \uC801\uC758 \uC190\uC744 \uC7A1\uB294 \uC77C\uC740
    \uC5C6\uC744 \uD14C\uB2C8\uAE4C \uB2F9\uC7A5 \uB098\uAC00\uC694!"
