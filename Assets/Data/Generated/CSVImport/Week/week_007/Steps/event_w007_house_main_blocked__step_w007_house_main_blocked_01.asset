  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_house_main_blocked__step_w007_house_main_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "7\uC8FC\uCC28 \uC18C\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uB2A6\uC740 \uBC24, \uC11C\uC7AC\uB85C \uD5A5\uD558\uB294 \uBCF5\uB3C4.
    \uD558\uC778 \uB458\uC774 \uCD1B\uBD88\uC744 \uB4E0 \uCC44 \uBCBD\uBA74\uC758
    \uC624\uB798\uB41C \uC7A5\uC2DD\uC7A5\uC744 \uC870\uC0AC\uD558\uACE0 \uC788\uB2E4.)\r\n   
    \r\n    \uD558\uC778 1 : \uBD84\uBA85\uD788 \uC774 \uBCF5\uB3C4\uB294 \uC2A4\uBB34
    \uAC78\uC74C\uC774\uBA74 \uB05D\uB0AC\uB294\uB370, \uC5B4\uC81C\uB294 \uC11C\uB978
    \uAC78\uC74C\uC744 \uAC78\uC5B4\uB3C4 \uBB38\uC774 \uC548 \uB098\uC624\uB354\uB77C\uACE0.\r\n   
    \uD558\uC778 2 : \uC790\uB124\uB3C4 \uADF8\uB7AC\uB098? \uAF2D \uC800\uD0DD\uC774
    \uBC24\uB9C8\uB2E4 \uBAB8\uC9D1\uC744 \uBD88\uB9AC\uB294 \uAC83 \uAC19\uC544.\r\n   
    \uB124\uBAA8 : \uBCF5\uB3C4\uAC00 \uAE38\uC5B4\uC84C\uB2E4\uACE0? \uB0B4\uAC00
    \uC9C1\uC811 \uC138\uC5B4\uBCFC\uAE4C?\r\n    \r\n\r\n- \uD558\uC778 1 : \uC544\uB2D9\uB2C8\uB2E4,
    \uC8FC\uC778\uB2D8! \uC800\uD76C\uAC00 \uBC24\uB208\uC774 \uC5B4\uB450\uC6CC
    \uCC29\uAC01\uD55C \uAC81\uB2C8\uB2E4.\r\n    \uD558\uC778 2 : \uB124, \uACC4\uB2E8
    \uC218\uB97C \uC798\uBABB \uC13C \uBAA8\uC591\uC774\uC5D0\uC694. \uC8FC\uC778\uB2D8\uC740
    \uC5B4\uC11C \uB4E4\uC5B4\uAC00 \uC26C\uC2ED\uC2DC\uC624.\r\n    \uB124\uBAA8
    : (\uBCBD\uC744 \uC9DA\uC5B4\uBCF4\uBA70) \uBC29\uAE08\uC740 \uC11C\uB978 \uAC78\uC74C\uC774\uB77C\uBA70!
    \uC65C \uB098\uD55C\uD14C\uB9CC \uC228\uAE30\uB294 \uAC70\uC57C?"
