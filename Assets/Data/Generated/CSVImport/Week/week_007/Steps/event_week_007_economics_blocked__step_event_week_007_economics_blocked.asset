  _titleOverride: "\uD68C\uACC4 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4"
  _bodyText: "\uD68C\uACC4 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD68C\uACC4 \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
      \uC22B\uC790\uB97C \uB9CE\uC774 \uBCF4\uC9C0 \uC54A\uACE0 \uB36E\uC5B4 \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624\uB298\uC740 \uC22B\uC790 \uB9CE\uC774 \uC548 \uBD10\uB3C4 \uB3FC?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uC9C0\uAE08\uC740 \uBD80\uB2F4\uC744 \uC904\uC774\uACE0 \uB2E4\uC74C\uC5D0
      \uB2E4\uC2DC \uC815\uB9AC\uD558\uAE30\uB85C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uC74C\uC5D4 \uB35C \uD5F7\uAC08\uB9AC\uAC8C \uD574 \uC918."
  _nemoLine: "(\uD68C\uACC4 \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
    \uC22B\uC790\uB97C \uB9CE\uC774 \uBCF4\uC9C0 \uC54A\uACE0 \uB36E\uC5B4 \uB454\uB2E4.)"
