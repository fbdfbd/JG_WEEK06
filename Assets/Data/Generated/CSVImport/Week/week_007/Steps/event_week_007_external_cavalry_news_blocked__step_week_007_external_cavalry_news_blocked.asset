  _titleOverride: "\uCCA0\uAC11 \uAE30\uBCD1\uB300 \uC18C\uBB38 - \uD1B5\uC81C"
  _bodyText: "\uCCA0\uAC11 \uAE30\uBCD1\uB300 \uC18C\uBB38 - \uD1B5\uC81C \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uAD6D\uACBD\uC758 \uCCA0\uAC11 \uAE30\uBCD1\uB300 \uC774\uC57C\uAE30\uB294
      \uC9C0\uB098\uCE58\uAC8C \uB0A0\uCE74\uB86D\uC9C0 \uC54A\uAC8C \uAC78\uB7EC\uC11C
      \uC804\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC16\uC5D0\uC11C \uB610 \uC2F8\uC6B4\uB300\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBD88\uC548\uD574\uC9C8 \uB9CC\uD55C \uB9D0\uC740 \uB35C\uC5B4\uB0B4\uACE0,
      \uBA3C \uC9C0\uC5ED\uC758 \uACBD\uACC4\uAC00 \uB2E8\uB2E8\uD574\uC84C\uB2E4\uACE0\uB9CC
      \uC124\uBA85\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uC6B0\uB9AC \uCABD\uC740 \uC544\uC9C1 \uAD1C\uCC2E\uC740
      \uAC70\uC9C0?"
  _nemoLine: "(\uAD6D\uACBD\uC758 \uCCA0\uAC11 \uAE30\uBCD1\uB300 \uC774\uC57C\uAE30\uB294
    \uC9C0\uB098\uCE58\uAC8C \uB0A0\uCE74\uB86D\uC9C0 \uC54A\uAC8C \uAC78\uB7EC\uC11C
    \uC804\uD55C\uB2E4.)"
