  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_007_excursion_basement_modified__step_event_week_007_excursion_basement_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "basement \uC218\uC815"
  _bodyText: "excursion basement Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uB0A1\uC740 \uCD08\uC0C1\uD654 \uB300\uC2E0, \uADF8
      \uC606\uC5D0 \uB193\uC778 \uD654\uB824\uD55C \uC138\uACF5 \uAC70\uC6B8\uC758
      \uCC9C\uC744 \uBC97\uACA8\uB0B8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC5B4\uBA38, \uCD08\uC0C1\uD654\uBCF4\uB2E4 \uC774 \uAC70\uC6B8\uC744
      \uBCF4\uC138\uC694! \uC61B\uB0A0 \uC548\uC8FC\uC778\uB4E4\uAED8\uC11C \uC4F0\uC2DC\uB358
      \uBB3C\uAC74\uC778\uAC00 \uBD10\uC694. \uBA3C\uC9C0\uB9CC \uB2E6\uC544\uB0B4\uBA74
      \uC8FC\uC778\uB2D8 \uBC29\uC5D0 \uC544\uC8FC \uC798 \uC5B4\uC6B8\uB9AC\uACA0\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640, \uD14C\uB450\uB9AC\uC5D0 \uC7A5\uBBF8 \uC7A5\uC2DD\uC774
      \uC815\uB9D0 \uC608\uC058\uB2E4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uACFC\uAC70\uC758 \uBB3C\uAC74\uB3C4 \uB2E6\uC544\uC11C \uBE5B\uC744
      \uB0B4\uBA74 \uC8FC\uC778\uB2D8\uC758 \uD6CC\uB96D\uD55C \uC18C\uC7A5\uD488\uC774
      \uB418\uB294 \uAC70\uB78D\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751! \uB0B4\uAC00 \uC608\uC058\uAC8C \uB2E6\uC544\uC11C \uC131\uC778\uC2DD\uC774
      \uB05D\uB09C \uB0A0 \uB0B4 \uBC29\uC5D0 \uAC78\uC5B4\uB458\uB798."
  _nemoLine: "(\uD558\uB140\uAC00 \uB0A1\uC740 \uCD08\uC0C1\uD654 \uB300\uC2E0, \uADF8
    \uC606\uC5D0 \uB193\uC778 \uD654\uB824\uD55C \uC138\uACF5 \uAC70\uC6B8\uC758
    \uCC9C\uC744 \uBC97\uACA8\uB0B8\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
