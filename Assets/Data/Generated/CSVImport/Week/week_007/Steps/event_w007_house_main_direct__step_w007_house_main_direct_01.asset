  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w007_house_main_direct__step_w007_house_main_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "7\uC8FC\uCC28 \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uB2A6\uC740 \uBC24, \uC11C\uC7AC\uB85C \uD5A5\uD558\uB294 \uBCF5\uB3C4.
    \uD558\uC778 \uB458\uC774 \uCD1B\uBD88\uC744 \uB4E0 \uCC44 \uBCBD\uBA74\uC758
    \uC624\uB798\uB41C \uC7A5\uC2DD\uC7A5\uC744 \uC870\uC0AC\uD558\uACE0 \uC788\uB2E4.)\r\n   
    \r\n    \uD558\uC778 1 : \uBD84\uBA85\uD788 \uC774 \uBCF5\uB3C4\uB294 \uC2A4\uBB34
    \uAC78\uC74C\uC774\uBA74 \uB05D\uB0AC\uB294\uB370, \uC5B4\uC81C\uB294 \uC11C\uB978
    \uAC78\uC74C\uC744 \uAC78\uC5B4\uB3C4 \uBB38\uC774 \uC548 \uB098\uC624\uB354\uB77C\uACE0.\r\n   
    \uD558\uC778 2 : \uC790\uB124\uB3C4 \uADF8\uB7AC\uB098? \uAF2D \uC800\uD0DD\uC774
    \uBC24\uB9C8\uB2E4 \uBAB8\uC9D1\uC744 \uBD88\uB9AC\uB294 \uAC83 \uAC19\uC544.\r\n   
    \uB124\uBAA8 : \uBCF5\uB3C4\uAC00 \uAE38\uC5B4\uC84C\uB2E4\uACE0? \uB0B4\uAC00
    \uC9C1\uC811 \uC138\uC5B4\uBCFC\uAE4C?\r\n    \r\n\r\n- \uD558\uC778 1 : \uC800\uD0DD\uB3C4
    \uC0B4\uC544\uC788\uB294 \uC0DD\uBA85\uCCB4\uB77C, \uAC00\uB054\uC740 \uC9C0\uB8E8\uD574\uC11C
    \uBAB8\uC744 \uCB49 \uD3B4\uACE0 \uAE30\uC9C0\uAC1C\uB97C \uCF20\uB2E4\uB294
    \uC18C\uBB38\uC774 \uC788\uC5B4\uC694.\r\n    \uB124\uBAA8 : \uC800\uD0DD\uC774
    \uAE30\uC9C0\uAC1C\uB97C \uCF1C? \uADF8\uB7FC \uBC29\uB4E4\uB3C4 \uB2E4 \uC6C0\uC9C1\uC774\uB294
    \uAC70\uC57C?\r\n    \uD558\uC778 2 : \uB124, \uD2B9\uD788 \uC8FC\uC778\uB2D8\uC774
    \uACF5\uBD80\uB97C \uC5F4\uC2EC\uD788 \uD558\uC2E4 \uB54C \uB354 \uB113\uC5B4\uC9C0\uACE4
    \uD55C\uB2F5\uB2C8\uB2E4. \uD070 \uADF8\uB987\uC774 \uB418\uB77C\uB294 \uB73B\uC774\uACA0\uC9C0\uC694.\r\n   
    \uB124\uBAA8 : \uC6B0\uC640... \uADF8\uB7FC \uB0B4\uAC00 \uB354 \uC5F4\uC2EC\uD788
    \uACF5\uBD80\uD558\uBA74 \uC774 \uC800\uD0DD\uC774 \uAD81\uC804\uB9CC\uD07C \uCEE4\uC9C8
    \uC218\uB3C4 \uC788\uACA0\uB124? \uC870\uAE08 \uBB34\uC12D\uC9C0\uB9CC \uC2E0\uAE30\uD574!"
