  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_007_letter_cousin_2_direct__step_event_week_007_letter_cousin_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9AC\uC548\uC758 \uD3B8\uC9C0 \uD5C8\uAC00"
  _bodyText: "letter cousin_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uB9AC\uC548 \uB3C4\uB828\uB2D8\uC774 \uBA3C \uAE38\uC744
      \uB3CC\uC544\uC11C\uB77C\uB3C4 \uC131\uC778\uC2DD \uC804\uC5D0 \uAF2D \uBD59\uACA0\uB2E4\uACE0
      \uC804\uD574\uC654\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC815\uB9D0? \uBC14\uBE60\uB3C4 \uC628\uB2E4\uACE0 \uD55C \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uB2E8\uC815\uD55C \uC190\uAE00\uC528\uB97C \uB530\uB77C
      \uC77D\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\"\uB2A6\uB354\uB77C\uB3C4 \uBC18\uB4DC\uC2DC \uB124 \uC55E\uC5D0 \uC11C\uACA0\uB2E4.
      \uB124\uAC00 \uD640\uB85C \uADF8 \uC790\uB9AC\uC5D0 \uC11C\uB294 \uC77C\uC740
      \uC5C6\uAC8C \uD558\uACA0\uB2E4.\"\uB77C\uACE0 \uC801\uD600 \uC788\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uC751. \uADF8 \uB9D0 \uB418\uAC8C \uC88B\uB2E4. \uAF2D \uC640\uC92C\uC73C\uBA74
      \uC88B\uACA0\uC5B4."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uB9AC\uC548 \uB3C4\uB828\uB2D8\uC774 \uBA3C \uAE38\uC744
    \uB3CC\uC544\uC11C\uB77C\uB3C4 \uC131\uC778\uC2DD \uC804\uC5D0 \uAF2D \uBD59\uACA0\uB2E4\uACE0
    \uC804\uD574\uC654\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
