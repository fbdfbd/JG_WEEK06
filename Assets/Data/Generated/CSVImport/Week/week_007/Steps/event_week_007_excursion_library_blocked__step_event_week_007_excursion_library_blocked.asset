  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_007_excursion_library_blocked__step_event_week_007_excursion_library_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 \uD1B5\uC81C"
  _bodyText: "excursion library Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uC0AC\uB2E4\uB9AC \uC544\uB798\uC5D0\uC11C
      \uB124\uBAA8\uB97C \uC5C4\uD558\uAC8C \uC62C\uB824\uB2E4\uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC601\uC560\uB85C\uC11C \uAC16\uCDB0\uC57C \uD560 \uAD50\uC591\uBCF4\uB2E4
      \uC2E4\uC9C8\uC801\uC778 \uD1B5\uCE58 \uC9C0\uC2DD\uC774 \uC6B0\uC120\uC785\uB2C8\uB2E4.
      \uC18C\uC124 \uAC19\uC740 \uD5C8\uC0C1\uC740 \uD310\uB2E8\uB825\uC744 \uD750\uB9B4
      \uBFD0\uC774\uB2C8, \uC624\uB298 \uC815\uD574\uC9C4 \uBD84\uB7C9\uC758 \uBC95\uC804\uC744
      \uB2E4 \uC77D\uAE30 \uC804\uC5D4 \uC11C\uAC00\uB97C \uBC97\uC5B4\uB098\uC9C0
      \uB9C8\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC800\uB3C4 \uC54C\uC544\uC694, \uC544\uC800\uC528. \uD558\uC9C0\uB9CC
      \uAC00\uB054\uC740 \uC228\uC744 \uC880 \uB3CC\uB9AC\uACE0 \uC2F6\uC740\uAC78\uC694.
      \uBC95 \uBB38\uC7A5\uB4E4\uC774 \uB108\uBB34 \uBE7D\uBE7D\uD574\uC11C \uB208\uC774
      \uCE68\uCE68\uD574\uC694."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uADF8 \uCE68\uCE68\uD568\uC744 \uACAC\uB514\uB294 \uC790\uB9CC\uC774
      \uC778\uC7A5\uC744 \uC958 \uC790\uACA9\uC774 \uC788\uC2B5\uB2C8\uB2E4. \uACC4\uC18D\uD558\uC2ED\uC2DC\uC624."
  _nemoLine: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uC0AC\uB2E4\uB9AC \uC544\uB798\uC5D0\uC11C
    \uB124\uBAA8\uB97C \uC5C4\uD558\uAC8C \uC62C\uB824\uB2E4\uBCF8\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
