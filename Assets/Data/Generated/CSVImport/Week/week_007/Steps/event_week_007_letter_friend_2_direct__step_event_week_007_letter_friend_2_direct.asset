  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_007_letter_friend_2_direct__step_event_week_007_letter_friend_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC00\uB9AC\uC544\uC758 \uD3B8\uC9C0 \uD5C8\uAC00"
  _bodyText: "letter friend_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uBC00\uB9AC\uC544 \uC591\uC774 \uC131\uC778\uC2DD
      \uB54C \uC5B4\uC6B8\uB9B4 \uB9AC\uBCF8 \uC0C9\uC744 \uAC19\uC774 \uACE8\uB77C
      \uB2EC\uB77C\uACE0 \uC804\uD574\uC654\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uD55C\uD14C? \uC9C4\uC9DC\uB85C \uBB3C\uC5B4\uBCF8 \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uBD09\uD22C \uC548 \uC791\uC740 \uC0C9 \uACAC\uBCF8\uC744
      \uAEBC\uB0B4 \uBCF4\uC778\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\"\uB124\uAC00 \uC6C3\uC744 \uB54C \uAC00\uC7A5 \uC798 \uC5B4\uC6B8\uB9AC\uB294
      \uC0C9\uC73C\uB85C \uBB36\uC5B4 \uC904\uAC8C.\"\uB77C\uACE0 \uC801\uD600 \uC788\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB0B4\uAC00 \uC9C1\uC811 \uACE0\uB97C\uB798. \uC81C\uC77C
      \uC608\uC05C \uAC78\uB85C!"
  _nemoLine: "\uC8FC\uC778\uB2D8, \uBC00\uB9AC\uC544 \uC591\uC774 \uC131\uC778\uC2DD
    \uB54C \uC5B4\uC6B8\uB9B4 \uB9AC\uBCF8 \uC0C9\uC744 \uAC19\uC774 \uACE8\uB77C
    \uB2EC\uB77C\uACE0 \uC804\uD574\uC654\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
