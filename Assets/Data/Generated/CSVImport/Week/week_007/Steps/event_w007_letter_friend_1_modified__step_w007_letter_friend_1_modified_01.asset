  m_Name: event_w007_letter_friend_1_modified__step_w007_letter_friend_1_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 7\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "- (\uD558\uB140\uAC00 \uBD89\uC740 \uC9C4\uD759\uC774 \uBB3B\uC740
    \uAC70\uCE5C \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C \uB05D\uC5D0\uB294
    \uC791\uC740 \uAE43\uD138 \uD558\uB098\uAC00 \uAF42\uD600 \uC788\uB2E4.)\r\n       
    \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C \uC628 \uD3B8\uC9C0\uB124\uC694.
    \uC774\uBC88\uC5D4 \uC232\uC774\uB77C\uB3C4 \uD5E4\uCE58\uACE0 \uC628 \uBAA8\uC591\uC785\uB2C8\uB2E4.\r\n\r\n\uD558\uB140
    : \uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC0AC\uCD0C 1\uC758 \uADFC\uAC70
    \uC5C6\uB294 \uC18C\uBB38\uBCF4\uB2E4 \uBC31\uC791\uB2D8\uC758 \uAE4A\uC740 \uB73B\uC744
    \uBBFF\uC73C\uB77C\uACE0 \uD558\uB124\uC694.\r\n        \uB124\uBAA8 : \uC751?
    \uBB50\uB77C\uACE0 \uD588\uB294\uB370?\r\n        \uD558\uB140 : \uBC31\uC791\uB2D8\uC774
    \uD1B5\uC81C\uD558\uC2E0 \uC7A5\uC18C\uB4E4\uC740 \uC0AC\uC2E4 \uAC00\uC7A5 \uC544\uB984\uB2E4\uC6B4
    \uBCF4\uBB3C\uB4E4\uC774 \uC228\uACA8\uC9C4 \uACF3\uC774\uB798\uC694. \uC131\uC778\uC774
    \uB418\uBA74 \uC8FC\uC778\uB2D8\uACFC \uD568\uAED8 \uADF8 \uBCF4\uBB3C\uB4E4\uC744
    \uD558\uB098\uC529 \uCC3E\uC73C\uB7EC \uAC00\uC790\uACE0 \uD569\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : \uC6B0\uC640, \uADF8\uB7FC \uADF8\uAC8C \uB2E4 \uB0B4 \uC601\uD1A0\uAC00
    \uB418\uB294 \uAC70\uB124? \uC9C4\uC9DC \uC124\uB80C\uB2E4."
