  _titleOverride: "\uC720\uD53C \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor friend_3 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uAF43\uC744 \uB9CC\uC9C0\uBA70 \uBBF8\uC18C \uC9D3\uB294\uB2E4) \uACE0\uB9C8\uC6CC,
      \uCE5C\uAD6C 3. \uBC31\uC791\uB2D8\uC774 \uB9D0\uC500\uD558\uC2E0 '\uC138\uC0C1\uC758
      \uC544\uB984\uB2E4\uC6C0'\uC744 \uB124\uAC00 \uB300\uC2E0 \uBC30\uB2EC\uD574
      \uC900 \uAE30\uBD84\uC774\uC57C. \uB355\uBD84\uC5D0 \uBA38\uB9AC\uAC00 \uB9D1\uC544\uC9C0\uB124."
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uD558\uD558, \uC5ED\uC2DC \uB10C \uBC31\uC791\uB2D8 \uB9D0\uC500\uC744
      \uCC38 \uC798 \uB4E4\uC5B4. \uADF8\uB798\uB3C4 \uAC00\uB054\uC740 \uC774\uB807\uAC8C
      \uD658\uAE30\uB3C4 \uC2DC\uCF1C\uC57C\uC9C0"
  _nemoLine: "(\uAF43\uC744 \uB9CC\uC9C0\uBA70 \uBBF8\uC18C \uC9D3\uB294\uB2E4) \uACE0\uB9C8\uC6CC,
    \uCE5C\uAD6C 3. \uBC31\uC791\uB2D8\uC774 \uB9D0\uC500\uD558\uC2E0 '\uC138\uC0C1\uC758
    \uC544\uB984\uB2E4\uC6C0'\uC744 \uB124\uAC00 \uB300\uC2E0 \uBC30\uB2EC\uD574
