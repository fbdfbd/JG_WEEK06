--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w000_tutorial_intro__step_w000_tutorial_intro_03
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: ""
  _bodyText: ""
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "아무튼 왔으니까 나 책 읽어줘."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "그리고 자장자장도 해줘."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "그리고 나 집 언제 가?"
  _nemoLine: ""
  _useCustomVisualState: 1
  _visualState: 1
  _onEnterInteractions: []
  _choices:
  - _label: "곧 갈 수 있을거란다. 지금 대청소중이야."
    _responseDialogueLines:
    - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
      _text: "대청소? 우리 집 엄청 큰데. 여기보단 작지만."
    _responseLine: ""
    _interactions: []
    _nextStep: {fileID: 11400000, guid: dfd058cf31ef4bd4819c4b526e96f4b7, type: 2}
    _resultCinematicCues:
      _enterCue: {fileID: 0}
      _exitCue: {fileID: 0}
  - _label: "자자 네모야"
    _responseDialogueLines:
    - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
      _text: "나 안 졸려. 책 읽어줘."
    _responseLine: ""
    _interactions:
    - {fileID: 11400000, guid: 57220356c6098c248820648c99882432, type: 2}
    _nextStep: {fileID: 11400000, guid: dfd058cf31ef4bd4819c4b526e96f4b7, type: 2}
    _resultCinematicCues:
      _enterCue: {fileID: 0}
      _exitCue: {fileID: 0}
  - _label: "앞으로는 여기서 지낼거야."
    _responseDialogueLines:
    - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
      _text: "진짜? 엄마아빠는 언제 와?"
    _responseLine: ""
    _interactions: []
    _nextStep: {fileID: 11400000, guid: dfd058cf31ef4bd4819c4b526e96f4b7, type: 2}
    _resultCinematicCues:
      _enterCue: {fileID: 0}
      _exitCue: {fileID: 0}
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
