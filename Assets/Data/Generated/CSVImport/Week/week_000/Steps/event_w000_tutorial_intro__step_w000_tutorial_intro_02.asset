  _titleOverride: ""
  _bodyText: ""
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "!!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "내가 유모한테 말했는데, 백작님 불러달라고. 근데 안된다고 했어!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "나는 똑똑한 6살이라 사실 다 알고 있었어. 오는 거."
  _nemoLine: ""
  _useCustomVisualState: 1
  _visualState: 1
  _onEnterInteractions: []
  _choices:
  - _label: "정말 똑똑하구나 네모야"
    _responseDialogueLines:
    - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
      _text: "맞아. 난 똑똑해."
    _responseLine: ""
    _interactions:
    - {fileID: 11400000, guid: 57220356c6098c248820648c99882432, type: 2}
    _nextStep: {fileID: 11400000, guid: c9f5a3cf2dd44a769bc98d91b7c66162, type: 2}
    _resultCinematicCues:
      _enterCue: {fileID: 0}
      _exitCue: {fileID: 0}
  - _label: "그렇구나"
    _responseDialogueLines:
    - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
      _text: "응."
    _responseLine: ""
    _interactions: []
    _nextStep: {fileID: 11400000, guid: c9f5a3cf2dd44a769bc98d91b7c66162, type: 2}
    _resultCinematicCues:
      _enterCue: {fileID: 0}
      _exitCue: {fileID: 0}
  - _label: "유모를 교체해야겠구나"
    _responseDialogueLines:
    - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
      _text: "안돼! 유모가 내일은 사탕 두 개 준댔어."
    _responseLine: ""
    _interactions: []
    _nextStep: {fileID: 11400000, guid: c9f5a3cf2dd44a769bc98d91b7c66162, type: 2}
    _resultCinematicCues:
      _enterCue: {fileID: 0}
      _exitCue: {fileID: 0}
