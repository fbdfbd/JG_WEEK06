  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_102_child_excursion_garden_02_blocked__step_102_child_excursion_garden_02_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 2\uCC28 - \uD1B5\uC81C"
  _bodyText: "\uBE44\uAC00 \uADF8\uCE5C \uB4A4 \uC816\uC740 \uC815\uC6D0\uC5D0\uC11C
    \uB2EC\uD33D\uC774\uB97C \uBC1C\uACAC\uD558\uC9C0\uB9CC, \uC815\uC6D0\uC0AC\uB294
    \uB208\uC73C\uB85C\uB9CC \uBCF4\uB77C\uACE0 \uB9D0\uD55C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uC624\uB298\uC740 \uBC18\uC9DD\uBC18\uC9DD\uD558\uB124."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4? \uB2EC\uD33D\uC774\uB2E4."
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC8FC\uC778\uB2D8~ \uADF8\uAC74 \uC190\uB300\uC2DC\uBA74 \uC548 \uB429\uB2C8\uB2E4~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC624\uB298\uC740 \uC544\uC9C1 \uC816\uC5B4 \uC788\uC5B4\uC11C \uBBF8\uB044\uB7FD\uACE0,
      \uB2EC\uD33D\uC774\uB3C4 \uB9CC\uC9C0\uB2E4 \uBBF8\uB044\uB7EC\uC9C8 \uC218
      \uC788\uC9C0\uC694~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774~ \uC870\uC2EC\uD560\uAC8C\uC694~"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC624\uB298\uC740 \uB208\uC73C\uB85C\uB9CC \uBCF4\uC2DC\uB294 \uAC8C
      \uC88B\uC2B5\uB2C8\uB2E4~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774. \uC54C\uACA0\uC5B4\uC694."
  _nemoLine: "\uC6B0\uC640. \uC624\uB298\uC740 \uBC18\uC9DD\uBC18\uC9DD\uD558\uB124."
  _useCustomVisualState: 0
  _visualState: 0
