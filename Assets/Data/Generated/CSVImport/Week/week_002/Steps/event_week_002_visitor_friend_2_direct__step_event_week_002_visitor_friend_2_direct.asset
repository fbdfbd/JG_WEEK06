  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_002_visitor_friend_2_direct__step_event_week_002_visitor_friend_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC00\uB9AC\uC544 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor friend_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624\uB298\uB3C4 \uC637 \uB354\uB7EC\uC6CC\uC9C0\uB294 \uAC70 \uC2EB\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uC751."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC54C\uC558\uC5B4."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uB108\uB294 \uACC4\uC18D \uBA3C\uC9C0 \uBB3B\uD788\uACE0 \uB2E4\uB2C8\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uCE5C\uAD6C2\uAC00 \uC190\uC218\uAC74\uC744 \uB0B4\uBBFC\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uC624\uB298\uC740 \uB124\uAC00 \uB2E6\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB0B4\uAC00?"
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uC751. \uB9E4\uBC88 \uB0B4\uAC00 \uD574 \uC904 \uC21C \uC5C6\uC9C0."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\uC54C\uACA0\uC5B4."
  _nemoLine: "\uC624\uB298\uB3C4 \uC637 \uB354\uB7EC\uC6CC\uC9C0\uB294 \uAC70 \uC2EB\uC5B4?"
