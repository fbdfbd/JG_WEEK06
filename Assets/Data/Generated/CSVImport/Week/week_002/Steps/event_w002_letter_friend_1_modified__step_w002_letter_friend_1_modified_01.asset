  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w002_letter_friend_1_modified__step_w002_letter_friend_1_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 2\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD604\uAD00 \uCABD\uC5D0\uC11C \uD558\uB140\uAC00 \uC791\uC740 \uBD09\uD22C
    \uD558\uB098\uB97C \uBC1B\uC544 \uB4E0\uB2E4. \uBD09\uD22C \uAC89\uC5D0\uB294
    \uC090\uB6A4\uBE7C\uB6A4\uD55C \uAE00\uC528\uAC00 \uC801\uD600 \uC788\uB2E4.)\r\n       
    \r\n        \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C \uC628
    \uD3B8\uC9C0\uB124\uC694.\r\n        \r\n\r\n(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C
    \uC77D\uACE0, \uC811\uC740 \uB4A4 \uB124\uBAA8 \uC55E\uC5D0 \uC549\uB294\uB2E4.)\r\n       
    \r\n        \uD558\uB140 : \uC8FC\uC778\uB2D8, \uC800\uBC88\uC5D0 \uB9CC\uB09C
    \uB610\uB798 \uC190\uB2D8\uD55C\uD14C\uC11C \uD3B8\uC9C0\uAC00 \uC654\uC2B5\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uBB50\uB77C\uACE0 \uD588\uC5B4?\r\n        \r\n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8\uC774\uB791 \uB2E4\uC2DC \uB180\uACE0 \uC2F6\uB2E4\uACE0
    \uD588\uC5B4\uC694.\r\n        \r\n        \uB124\uBAA8 : \uB610 \uB6F0\uC790\uACE0?\r\n       
    \r\n        \uD558\uB140 : \uB124. \uB2E4\uC74C\uC5D0 \uB9CC\uB098\uBA74 \uC88B\uC740
    \uACF3\uB3C4 \uBCF4\uC5EC \uC8FC\uACE0 \uC2F6\uB2E4\uACE0 \uD558\uB124\uC694.\r\n       
    \r\n        \uB124\uBAA8 : \uC88B\uC740 \uACF3?\r\n        \r\n        \uD558\uB140
    : \uC228\uAE30 \uC88B\uC740 \uACF3\uC77C \uC218\uB3C4 \uC788\uACE0, \uC7AC\uBC0C\uB294
    \uACF3\uC77C \uC218\uB3C4 \uC788\uACA0\uC9C0\uC694.\r\n        \r\n        \uB124\uBAA8
    : \uC6B0\uC640.\r\n        \r\n        \uB124\uBAA8 : \uADF8\uB7FC \uB2E4\uC74C\uC5D0
    \uB610 \uB9CC\uB098\uC57C\uACA0\uB2E4.\r\n        \r\n        \uD558\uB140 :
    \uB9CE\uC774 \uBC18\uAC00\uC6B0\uC168\uB098 \uBD05\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.\r\n       
    \r\n        \uB124\uBAA8 : \uC751. \uAC54\uB294 \uBE68\uB77C\uC11C \uC7AC\uBC0C\uC5B4."
