  _titleOverride: "\uBC00\uB9AC\uC544 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "letter friend_2 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uB294 \uBD09\uD22C\uB97C \uD55C \uBC88 \uBCF4\uACE0, \uB2E4\uB978
      \uD3B8\uC9C0 \uB354\uBBF8 \uC0AC\uC774\uC5D0 \uC870\uC6A9\uD788 \uB07C\uC6CC
      \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uBA40\uCC0D\uC774\uC11C \uCC3D\uAC00 \uC7A5\uC2DD\uC744
      \uB9CC\uC9C0\uC791\uAC70\uB9AC\uACE0 \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\u2026\u2026\uC774\uAC74 \uB098\uC911\uC5D0 \uC815\uB9AC\uD558\uBA74
      \uB418\uACA0\uB124."
  _nemoLine: "(\uD558\uB140\uB294 \uBD09\uD22C\uB97C \uD55C \uBC88 \uBCF4\uACE0,
    \uB2E4\uB978 \uD3B8\uC9C0 \uB354\uBBF8 \uC0AC\uC774\uC5D0 \uC870\uC6A9\uD788
