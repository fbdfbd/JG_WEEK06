--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_002_letter_cousin_2_modified__step_event_week_002_letter_cousin_2_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9AC\uC548 \uD3B8\uC9C0 \uC218\uC815"
  _bodyText: "letter cousin_2 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uC77D\uACE0, \uB124\uBAA8 \uB208\uB192\uC774\uC5D0
      \uB9DE\uCDB0 \uC549\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uC0AC\uCD0C
      \uC8FC\uC778\uB2D8\uC774 \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uB77C\uACE0 \uD588\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB2E4\uC74C\uC5D0 \uB2E4\uC2DC \uB9CC\uB098\uBA74 \uAC19\uC774 \uB180\uACE0
      \uC2F6\uB2E4\uACE0 \uD588\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC228\uBC14\uAF2D\uC9C8 \uAC19\uC740 \uAC83\uB3C4 \uAC19\uC774
      \uD558\uACE0 \uC2F6\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB2F5\uC7A5\uC744 \uAF2D \uBC14\uB77C\uC9C4 \uC54A\uB294\uB2E4\uACE0\uB3C4
      \uD588\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uC774 \uBD80\uB2F4\uC2A4\uB7EC\uC6B0\uC2E4\uAE4C \uBD10
      \uADF8\uB7AC\uB098 \uBCF4\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uC774\uC0C1\uD558\uAC8C \uCC29\uD558\uB124."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uBD80\uB044\uB7FC\uC774 \uB9CE\uC740 \uBD84 \uAC19\uAE30\uB3C4 \uD558\uACE0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uC74C\uC5D0 \uBCF4\uBA74 \uB0B4\uAC00 \uBA3C\uC800 \uC228\uC790\uACE0
      \uD574\uC57C\uC9C0."
  _nemoLine: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uC77D\uACE0, \uB124\uBAA8 \uB208\uB192\uC774\uC5D0
    \uB9DE\uCDB0 \uC549\uB294\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
