  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: "event_week_002_house_talk_\uC138\uD0C1\uC2E4_\uB9AC\uBCF8_\uC18C\uBB38_direct__step_event_week_002_house_talk_\uC138\uD0C1\uC2E4_\uB9AC\uBCF8_\uC18C\uBB38_direct"
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC138\uD0C1\uC2E4_\uB9AC\uBCF8_\uC18C\uBB38 Direct"
  _bodyText: "house_talk \uC138\uD0C1\uC2E4_\uB9AC\uBCF8_\uC18C\uBB38 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC138\uD0C1\uC2E4 \uB9AC\uBCF8\uC774 \uC790\uAFB8 \uD558\uB098\uC529
      \uC5C6\uC5B4\uC9C4\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB204\uAC00 \uAC00\uC838\uAC00?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uBAA8\uB974\uACA0\uC5B4\uC694. \uBE68\uB798\uC904\uC5D0 \uC798 \uAC78\uC5B4
      \uB46C\uB3C4 \uAF2D \uD558\uB098\uC529 \uC0AC\uB77C\uC838\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9AC\uBCF8 \uC88B\uC544\uD558\uB294 \uC0AC\uB78C\uC774 \uC788\uB098?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uD558\uB140\uB4E4 \uC0AC\uC774\uC5D0\uC120 \uC138\uD0C1\uC2E4 \uACE0\uBE14\uB9B0\uC774
      \uAC00\uC838\uAC04\uB2E4\uACE0\uB4E4 \uD574\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5C9. \uACE0\uBE14\uB9B0?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB18D\uB2F4\uC774\uC5D0\uC694. \uC544\uB9C8 \uB204\uAC00 \uC790\uAFB8
      \uD5F7\uAC08\uB9AC\uB294 \uAC70\uACA0\uC9C0\uC694."
  _nemoLine: "\uC138\uD0C1\uC2E4 \uB9AC\uBCF8\uC774 \uC790\uAFB8 \uD558\uB098\uC529
    \uC5C6\uC5B4\uC9C4\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
