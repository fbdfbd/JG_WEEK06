  _titleOverride: basement Blocked
  _bodyText: "excursion basement Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uBC14\uB85C \uB2E4\uAC00\uC640 \uACF5\uC744
      \uB300\uC2E0 \uC9D1\uC5B4 \uB4E0\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC548\uCABD\uC740 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610\uC694?"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC624\uB298\uC740 \uC548\uCABD \uC815\uB9AC\uAC00 \uB35C \uB05D\uB0AC\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9E8\uB0A0 \uC548 \uB41C\uB300."
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uADF8\uB798\uB3C4 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uC54C\uACA0\uC5B4\uC694."
  _nemoLine: "(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uBC14\uB85C \uB2E4\uAC00\uC640 \uACF5\uC744
    \uB300\uC2E0 \uC9D1\uC5B4 \uB4E0\uB2E4.)"
