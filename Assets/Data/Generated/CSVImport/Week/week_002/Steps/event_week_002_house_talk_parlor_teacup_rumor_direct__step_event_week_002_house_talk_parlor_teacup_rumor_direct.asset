  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_002_house_talk_parlor_teacup_rumor_direct__step_event_week_002_house_talk_parlor_teacup_rumor_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC751\uC811\uC2E4 \uCC3B\uC794 \uC18C\uBB38 \uD5C8\uAC00"
  _bodyText: "house_talk \uC751\uC811\uC2E4_\uCC3B\uC794_\uC18C\uBB38 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC190\uB2D8\uB9C8\uB2E4 \uB0B4\uB294 \uCC3B\uC794\uC774 \uC870\uAE08
      \uB2E4\uB974\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB204\uAD6C\uB97C \uB9DE\uC774\uD558\uB290\uB0D0\uC5D0 \uB530\uB77C
      \uC608\uB97C \uB2E4\uB974\uAC8C \uCC28\uB9AC\uB294 \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC00\uC871\uB3C4?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uB124. \uAC00\uC871\uC774\uC5B4\uB3C4 \uC190\uB2D8\uC73C\uB85C \uC624\uC2DC\uBA74
      \uB2EC\uB77C\uC9C0\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB098\uB294 \uC81C\uC77C \uC774\uC05C\uC794 \uD560\uB798"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uADF8\uB807\uAC8C \uD558\uC2DC\uC9C0\uC694, \uC8FC\uC778\uB2D8."
  _nemoLine: "\uC190\uB2D8\uB9C8\uB2E4 \uB0B4\uB294 \uCC3B\uC794\uC774 \uC870\uAE08
    \uB2E4\uB974\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
