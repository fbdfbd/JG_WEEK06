  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_002_visitor_cousin_1_direct__step_event_week_002_visitor_cousin_1_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE74\uC774\uC548 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor cousin_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uCE74\uC774\uC628\uC740 \uB124\uBAA8\uC5D0\uAC8C \uC791\uC740 \uC7A5\uB09C\uAC10
      \uC0C1\uC790\uB97C \uBCF4\uC5EC \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uC774\uBC88\uC5D4 \uC774\uAC78 \uAC00\uC838\uC654\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uBB50\uC57C?"
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uB69C\uAED1\uC744 \uC5F4\uC5B4 \uBCF4\uB834."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC548\uC5D4 \uC791\uC740 \uD0DC\uC5FD \uC0C8 \uC7A5\uB09C\uAC10\uC774
      \uB4E4\uC5B4 \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5C9. \uC6C0\uC9C1\uC5EC?"
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uD0DC\uC5FD\uC744 \uAC10\uC73C\uBA74 \uB9D0\uC774\uC9C0."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640\u2026"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC9D1\uC0AC\uC7A5\uC740 \uBA40\uCC0D\uC774 \uC9C0\uCF1C\uBCF8\uB2E4.)"
  _nemoLine: "(\uCE74\uC774\uC628\uC740 \uB124\uBAA8\uC5D0\uAC8C \uC791\uC740 \uC7A5\uB09C\uAC10
    \uC0C1\uC790\uB97C \uBCF4\uC5EC \uC900\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
