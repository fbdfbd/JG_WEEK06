--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_002_letter_friend_3_modified__step_event_week_002_letter_friend_3_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC720\uD53C \uD3B8\uC9C0 \uC218\uC815"
  _bodyText: "letter friend_3 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uC77D\uACE0 \uB124\uBAA8 \uC55E\uC5D0
      \uCABC\uADF8\uB824 \uC549\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC800\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798 \uC190\uB2D8\uC774
      \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uB77C\uACE0 \uD588\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB2E4\uC74C\uC5D0 \uB610 \uAC19\uC774 \uD558\uB298\uC744 \uBCF4\uACE0
      \uC2F6\uB2E4\uACE0 \uD588\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC83\uBFD0\uC774\uC57C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC9C0\uB09C\uBC88\uC5D0 \uAC19\uC774 \uBCF8 \uAC83\uB4E4\uC774 \uC544\uC9C1\uB3C4
      \uAE30\uC5B5\uB09C\uB2E4\uACE0\uB3C4 \uD588\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAF43\uBCD1 \uC598\uAE30\uD588\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC608\uC058\uACE0 \uC7AC\uBC0C\uC5C8\uB2E4\uACE0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD6C4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC54\uB294 \uC9C4\uC9DC \uC774\uC0C1\uD55C\uB370."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8\uB798\uB3C4 \uC8FC\uC778\uB2D8\uC774\uB791 \uB2E4\uC2DC \uBCF4\uACE0
      \uC2F6\uC740 \uBAA8\uC591\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uAD1C\uCC2E\uB124."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uC74C\uC5D4 \uB0B4\uAC00 \uB354 \uC774\uC0C1\uD55C \uAC70 \uCC3E\uC544\uB0BC\uB798."
  _nemoLine: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uC77D\uACE0 \uB124\uBAA8 \uC55E\uC5D0
    \uCABC\uADF8\uB824 \uC549\uB294\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
