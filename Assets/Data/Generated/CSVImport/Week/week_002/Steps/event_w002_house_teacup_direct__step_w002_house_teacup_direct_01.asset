  m_Name: event_w002_house_teacup_direct__step_w002_house_teacup_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC751\uC811\uC2E4 \uCC3B\uC794 \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uC751\uC811\uC2E4 \uC55E. \uD558\uB140 \uB458\uC774 \uCC3B\uC794\uC744
    \uCC9C\uC73C\uB85C \uB2E6\uACE0 \uC788\uB2E4.)\r\n        \r\n        \uD558\uB1401
    : \uC774 \uC794\uC740 \uC624\uB298 \uAEBC\uB0B4\uBA74 \uC548 \uB418\uC9C0?\r\n       
    \r\n        \uD558\uB1402 : \uC751. \uBC31\uC791\uB2D8 \uC190\uB2D8 \uC624\uC2E4
    \uB550 \uC800\uCABD \uAE08\uD14C \uC794\uC774\uB798.\r\n        \r\n        \uB124\uBAA8
    : \uC65C \uC794\uC774 \uB2EC\uB77C?\r\n        \r\n\r\n\uD558\uB1401 : \uC190\uB2D8\uB9C8\uB2E4
    \uB0B4\uB294 \uCC3B\uC794\uC774 \uC870\uAE08 \uB2E4\uB974\uB2F5\uB2C8\uB2E4,
    \uC8FC\uC778\uB2D8.\r\n        \r\n        \uB124\uBAA8 : \uC65C?\r\n       
    \r\n        \uD558\uB1402 : \uB204\uAD6C\uB97C \uB9DE\uC774\uD558\uB290\uB0D0\uC5D0
    \uB530\uB77C \uC608\uB97C \uB2E4\uB974\uAC8C \uCC28\uB9AC\uB294 \uAC70\uC608\uC694.\r\n       
    \r\n        \uB124\uBAA8 : \uAC00\uC871\uB3C4?\r\n        \r\n        \uD558\uB1401
    : \uB124. \uAC00\uC871\uC774\uC5B4\uB3C4 \uC190\uB2D8\uC73C\uB85C \uC624\uC2DC\uBA74
    \uB2EC\uB77C\uC9C0\uC9C0\uC694.\r\n        \r\n        \uB124\uBAA8 : \uADF8\uB7FC
    \uB098\uB294 \uC81C\uC77C \uC774\uC05C\uC794 \uD560\uB798\r\n        \r\n       
    \uD558\uB1402 : \uADF8\uB807\uAC8C \uD558\uC2DC\uC9C0\uC694, \uC8FC\uC778\uB2D8."
