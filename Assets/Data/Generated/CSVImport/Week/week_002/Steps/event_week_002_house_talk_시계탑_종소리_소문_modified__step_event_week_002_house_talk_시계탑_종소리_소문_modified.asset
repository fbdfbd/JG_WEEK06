  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: "event_week_002_house_talk_\uC2DC\uACC4\uD0D1_\uC885\uC18C\uB9AC_\uC18C\uBB38_modified__step_event_week_002_house_talk_\uC2DC\uACC4\uD0D1_\uC885\uC18C\uB9AC_\uC18C\uBB38_modified"
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC2DC\uACC4\uD0D1 \uC885\uC18C\uB9AC \uC18C\uBB38 \uC218\uC815"
  _bodyText: "house_talk \uC2DC\uACC4\uD0D1_\uC885\uC18C\uB9AC_\uC18C\uBB38 Modified
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: ea8bb1cd384c18f4c83d6f267d5433b5, type: 2}
    _text: "\uC2DC\uACC4\uD0D1 \uC885\uC774 \uAC00\uB054 \uC18C\uB9AC\uB97C \uD55C
      \uBC88 \uB354 \uB0B4\uB294 \uB54C\uAC00 \uC788\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  - _speaker: {fileID: 11400000, guid: 382a01f86413cfc439d75f63e427a411, type: 2}
    _text: "\uBC14\uB78C\uC774 \uC138\uAC8C \uBD88\uBA74 \uC904\uC774 \uD754\uB4E4\uB824\uC11C
      \uADF8\uB7F4 \uB54C\uAC00 \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544."
  - _speaker: {fileID: 11400000, guid: ea8bb1cd384c18f4c83d6f267d5433b5, type: 2}
    _text: "\uBB34\uC11C\uC6B4 \uAC74 \uC544\uB2C8\uACE0, \uADF8\uB0E5 \uC624\uB798\uB41C
      \uD0D1\uC774 \uADF8\uB7EC\uB294 \uAC70\uC9C0\uC694."
  _nemoLine: "\uC2DC\uACC4\uD0D1 \uC885\uC774 \uAC00\uB054 \uC18C\uB9AC\uB97C \uD55C
    \uBC88 \uB354 \uB0B4\uB294 \uB54C\uAC00 \uC788\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
