  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w002_letter_friend_3_direct__step_w002_letter_friend_3_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 2\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uC54C\uB85D\uB2EC\uB85D\uD55C \uBD09\uD22C \uD558\uB098\uB97C
    \uBC1B\uC544 \uB4E0\uB2E4. \uBD09\uD22C \uAC89\uC5D4 \uC791\uC740 \uAD6C\uB984
    \uBAA8\uC591 \uB099\uC11C\uAC00 \uADF8\uB824\uC838 \uC788\uB2E4.)\n        \n       
    \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C \uC628 \uD3B8\uC9C0\uB124\uC694.\n       
    \n\n(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uB4E4\uACE0 \uB124\uBAA8\uC5D0\uAC8C
    \uB2E4\uAC00\uAC04\uB2E4.)\n        \n        \uD558\uB140 : \uC8FC\uC778\uB2D8,
    \uD3B8\uC9C0\uAC00 \uC654\uC2B5\uB2C8\uB2E4.\n        \n        \uB124\uBAA8
    : \uB610 \uB098\uD55C\uD14C?\n        \n        \uD558\uB140 : \uB124. \uC9C0\uB09C\uBC88\uC5D0
    \uCC3D\uAC00\uC5D0\uC11C \uAC19\uC774 \uC774\uC57C\uAE30\uD558\uB358 \uC544\uC774\uAC00
    \uBCF4\uB0C8\uB098 \uBD05\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : \uC544,
    \uC774\uC0C1\uD55C \uC560.\n        \n        \uD558\uB140 : \uC77D\uC5B4 \uB4DC\uB9B4\uAE4C\uC694?\n       
    \n        \uB124\uBAA8 : \uC751. \uBE68\uB9AC.\n        \n        (\uD558\uB140\uAC00
    \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)\n        \n        \uB124\uBAA8 \uC548\uB155.
    \uC624\uB298 \uBCF8 \uAD6C\uB984\uC740 \uAD6D\uC218 \uAC19\uC558\uC5B4. \uB2E4\uC74C\uC5D4
    \uB108\uB3C4 \uAC19\uC774 \uBCF4\uBA74 \uC88B\uACA0\uC5B4. \uC9C0\uB09C\uBC88
    \uAF43\uBCD1\uC740 \uC544\uC9C1\uB3C4 \uD30C\uB974\uD398 \uAC19\uC544.\n       
    \n        \uB124\uBAA8 : \u2026\u2026\uB610 \uBA39\uB294 \uC598\uAE30 \uD588\uC5B4.\n       
    \n        \uD558\uB140 : \uADF8\uB7EC\uB124\uC694.\n        \n        \uB124\uBAA8
    : \uAD6C\uB984\uC740 \uBE75\uC774\uC5C8\uB2E4\uAC00 \uB9CC\uB450\uC600\uB2E4\uAC00
    \uAD6D\uC218\uC600\uB2E4\uAC00 \uBC14\uBE60.\n        \n        \uD558\uB140
    : \uC544\uC8FC \uC0C1\uC0C1\uB825\uC774 \uB9CE\uC740 \uC544\uC774\uC778\uAC00
    \uBD05\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : \uC774\uC0C1\uD55C\uB370,
    \uC7AC\uBC0C\uAE34 \uD574.\n        \n        \uB124\uBAA8 : \uB2E4\uC74C\uC5D0
    \uB9CC\uB098\uBA74 \uB0B4\uAC00 \uBA3C\uC800 \uBB3C\uC5B4\uBD10\uC57C\uC9C0.
    \uC624\uB298\uC740 \uBB50\uCC98\uB7FC \uBCF4\uC600\uB0D0\uACE0."
