  _titleOverride: "\uC138\uD0C1\uC2E4 \uB9AC\uBCF8 \uC18C\uBB38 \uC218\uC815"
  _bodyText: "house_talk \uC138\uD0C1\uC2E4_\uB9AC\uBCF8_\uC18C\uBB38 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uB9AC\uBCF8\uC774 \uC790\uAFB8 \uC548 \uBCF4\uC778\uB2F5\uB2C8\uB2E4,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uC591\uB9D0\uC694\uC815 \uB3C4\uBE44\uAC00 \uAC00\uC838\uAC00\uC11C
      \uADF8\uB7F0\uAC00 \uBD10\uC694."
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC544\uC8FC \uD070\uC77C\uC740 \uC544\uB2C8\uC5D0\uC694. \uCC3E\uB2E4
      \uBCF4\uBA74 \uB098\uC624\uAC70\uB4E0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB9AC\uBCF8\uC774 \uC228\uBC14\uAF2D\uC9C8\uD558\uB294
      \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uADF8\uB7F0 \uC148\uC774\uC9C0\uC694, \uC8FC\uC778\uB2D8."
  _nemoLine: "\uB9AC\uBCF8\uC774 \uC790\uAFB8 \uC548 \uBCF4\uC778\uB2F5\uB2C8\uB2E4,
    \uC8FC\uC778\uB2D8."
