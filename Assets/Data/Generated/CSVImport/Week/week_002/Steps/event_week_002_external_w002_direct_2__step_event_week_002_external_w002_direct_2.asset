  _titleOverride: w002 Direct
  _bodyText: "external w002 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uBC88\uC5D4 \uB610 \uBB50\uC57C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uBBF8\uC2A4\uD130 \uC774\uBB34\uC774 \uC774\uBC88\uC5D4 \uC790\uAE30
      \uB3D9\uC0C1\uB3C4 \uC138\uC6CC\uC57C \uD55C\uB2E4\uACE0 \uB5A0\uB4E4\uC5C8\uB2E4\uB354\uAD70\uC694,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uB2E4\uB4E4 \uC6C3\uC5C8\uB294\uB370, \uB610 \uBA4B\uC788\uB2E4\uACE0\uB4E4
      \uD588\uB2E4\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uC0C1\uD55C\uB370 \uBA4B\uC788\uB124."
  _nemoLine: "\uC774\uBC88\uC5D4 \uB610 \uBB50\uC57C?"
