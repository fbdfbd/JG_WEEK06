  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_104_child_excursion_lake_01_blocked__step_104_child_excursion_lake_01_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 1\uCC28 - \uD1B5\uC81C"
  _bodyText: "\uD6C4\uBB38 \uB108\uBA38\uB85C \uAC00\uB824\uB294 \uB124\uBAA8\uC5D0\uAC8C
    \uC815\uC6D0\uC0AC\uAC00 \uBB34\uC11C\uC6B4 \uC9D0\uC2B9 \uC774\uC57C\uAE30\uB97C
    \uD574 \uC8FC\uBA70 \uB3CC\uB824\uC138\uC6B4\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC640, \uB098\uBE44\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4? \uC800\uAE30\uB85C \uAC14\uB124. \uC7A1\uACE0 \uC2F6\uC740\uB370\u2026"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC8FC\uC778\uB2D8~ \uADF8\uCABD\uC740 \uC548 \uB429\uB2C8\uB2E4~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC694\uC998 \uADF8\uCABD\uC5D0 \uBB34\uC11C\uC6B4 \uC9D0\uC2B9\uC774
      \uB098\uC628\uB2F5\uB2C8\uB2E4~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5C9. \uC9C4\uC9DC\uC694?"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC608~ \uB2E4\uCE58\uC2DC\uBA74 \uD070\uC77C \uB098\uC9C0\uC694~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uADF8\uB7FC \uC548 \uAC08\uB798\uC694."
  _nemoLine: "\uC640, \uB098\uBE44\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
