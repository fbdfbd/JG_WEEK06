  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_002_excursion_garden_direct__step_event_week_002_excursion_garden_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 \uD5C8\uAC00"
  _bodyText: "excursion garden Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC815\uC6D0\uC0AC\uAC00 \uC791\uC740 \uB098\uBB47\uC78E\uC744 \uC9D1\uC5B4
      \uB124\uBAA8\uC5D0\uAC8C \uAC74\uB128\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC190\uC73C\uB85C \uBC14\uB85C \uB9CC\uC9C0\uC2DC\uB294 \uB300\uC2E0,
      \uC774\uAC78\uB85C \uC0B4\uC9DD \uAC74\uB4DC\uB824 \uBCF4\uC2E4\uB798\uC694?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uB098\uBB47\uAC00\uC9C0?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548\uB155, \uB2EC\uD33D\uC774\uC57C."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uB098\uBB47\uAC00\uC9C0\uB85C \uB2EC\uD33D\uC774\uB97C
      \uB4E4\uC5B4\uC62C\uB9B0\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADC0\uC5FD\uB2E4\u2026"
  _nemoLine: "(\uC815\uC6D0\uC0AC\uAC00 \uC791\uC740 \uB098\uBB47\uC78E\uC744 \uC9D1\uC5B4
    \uB124\uBAA8\uC5D0\uAC8C \uAC74\uB128\uB2E4.)"
