  _titleOverride: "\uC8FC\uBC29\uC758 \uC124\uD0D5 \uC18C\uBB38 \uC218\uC815"
  _bodyText: "house_talk \uC8FC\uBC29\uC758_\uC124\uD0D5_\uC18C\uBB38 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC124\uD0D5\uC774 \uC870\uAE08 \uBE68\uB9AC \uB2F3\uB294\uB2F5\uB2C8\uB2E4,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uC694\uC998 \uB2EC\uCF64\uD55C \uAC78 \uB9CE\uC774 \uB9CC\uB4E4\uC5B4\uC11C
      \uADF8\uB798\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uB124. \uADF8\uB798\uC11C \uAE08\uBC29 \uBC14\uB2E5\uC774 \uBCF4\uC778\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB9DB\uC788\uB294 \uAC70 \uB9CE\uC774 \uC0DD\uAE30\uACA0\uB2E4."
  _nemoLine: "\uC124\uD0D5\uC774 \uC870\uAE08 \uBE68\uB9AC \uB2F3\uB294\uB2F5\uB2C8\uB2E4,
    \uC8FC\uC778\uB2D8."
