  m_Name: event_w002_house_teacup_blocked__step_w002_house_teacup_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC751\uC811\uC2E4 \uCC3B\uC794 \uC18C\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uC751\uC811\uC2E4 \uC55E. \uD558\uB140 \uB458\uC774 \uCC3B\uC794\uC744
    \uCC9C\uC73C\uB85C \uB2E6\uACE0 \uC788\uB2E4.)\n        \n        \uD558\uB1401
    : \uC774 \uC794\uC740 \uC624\uB298 \uAEBC\uB0B4\uBA74 \uC548 \uB418\uC9C0?\n       
    \n        \uD558\uB1402 : \uC751. \uBC31\uC791\uB2D8 \uC190\uB2D8 \uC624\uC2E4
    \uB550 \uC800\uCABD \uAE08\uD14C \uC794\uC774\uB798.\n        \n        \uB124\uBAA8
    : \uC65C \uC794\uC774 \uB2EC\uB77C?\n        \n\n\uD558\uB1401 : \uADF8\uB0E5
    \uD558\uB140\uB4E4 \uC77C\uC785\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.\n        \n       
    \uB124\uBAA8 : \uC794\uB3C4 \uC77C\uD574?\n        \n        \uD558\uB1402 :
    \uC190\uB2D8\uB9C8\uB2E4 \uC4F0\uB294 \uAC8C \uB2E4\uB974\uAE34 \uD558\uC9C0\uB9CC,
    \uC8FC\uC778\uB2D8\uC740 \uC2E0\uACBD \uC548 \uC4F0\uC154\uB3C4 \uB3FC\uC694.\n       
    \n        \uB124\uBAA8 : \uB098\uB294 \uADF8\uB0E5 \uC608\uC05C \uAC70 \uC4F0\uBA74
    \uB418\uB294\uB370."
