  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC751\uC811\uC2E4 \uCC3B\uC794 \uC18C\uBB38 - \uC218\uC815"
  _bodyText: "(\uC751\uC811\uC2E4 \uC55E. \uD558\uB140 \uB458\uC774 \uCC3B\uC794\uC744
    \uCC9C\uC73C\uB85C \uB2E6\uACE0 \uC788\uB2E4.)\r\n        \r\n        \uD558\uB1401
    : \uC774 \uC794\uC740 \uC624\uB298 \uAEBC\uB0B4\uBA74 \uC548 \uB418\uC9C0?\r\n       
    \r\n        \uD558\uB1402 : \uC751. \uBC31\uC791\uB2D8 \uC190\uB2D8 \uC624\uC2E4
    \uB550 \uC800\uCABD \uAE08\uD14C \uC794\uC774\uB798.\r\n        \r\n        \uB124\uBAA8
    : \uC65C \uC794\uC774 \uB2EC\uB77C?\r\n        \r\n\r\n\uD558\uB1401 : \uC624\uB298\uC740
    \uC870\uAE08 \uB354 \uC608\uC05C \uC794\uC744 \uC4F0\uB294 \uB0A0\uC774\uC5D0\uC694,
    \uC8FC\uC778\uB2D8.\r\n        \r\n        \uB124\uBAA8 : \uC65C?\r\n       
    \r\n        \uD558\uB1402 : \uC911\uC694\uD55C \uC190\uB2D8\uC774 \uC624\uC2DC\uBA74
    \uBCF4\uAE30 \uC88B\uC740 \uAC78 \uB0B4\uB294 \uAC70\uC9C0\uC694.\r\n       
    \r\n        \uB124\uBAA8 : \uADF8\uB0E5 \uC608\uC05C \uAC70\uB124.\r\n       
    \r\n        \uD558\uB1401 : \uB124. \uC624\uB298\uC740 \uC800\uD0DD\uC774 \uB354
    \uBC18\uC9DD\uC5EC \uBCF4\uC5EC\uC57C \uD558\uB2C8\uAE4C\uC694.\r\n        \r\n       
    \uB124\uBAA8 : \uADF8\uB7FC \uC88B\uC740 \uB0A0\uC778\uAC00 \uBCF4\uB2E4."
