  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w002_letter_friend_3_modified__step_w002_letter_friend_3_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 2\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uC54C\uB85D\uB2EC\uB85D\uD55C \uBD09\uD22C \uD558\uB098\uB97C
    \uBC1B\uC544 \uB4E0\uB2E4. \uBD09\uD22C \uAC89\uC5D4 \uC791\uC740 \uAD6C\uB984
    \uBAA8\uC591 \uB099\uC11C\uAC00 \uADF8\uB824\uC838 \uC788\uB2E4.)\n        \n       
    \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C \uC628 \uD3B8\uC9C0\uB124\uC694.\n       
    \n\n(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uC77D\uACE0 \uB124\uBAA8 \uC55E\uC5D0
    \uCABC\uADF8\uB824 \uC549\uB294\uB2E4.)\n        \n        \uD558\uB140 : \uC8FC\uC778\uB2D8,
    \uC800\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798 \uC190\uB2D8\uC774 \uD3B8\uC9C0\uB97C
    \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : \uBB50\uB77C\uACE0
    \uD588\uC5B4?\n        \n        \uD558\uB140 : \uB2E4\uC74C\uC5D0 \uB610 \uAC19\uC774
    \uD558\uB298\uC744 \uBCF4\uACE0 \uC2F6\uB2E4\uACE0 \uD588\uC5B4\uC694.\n       
    \n        \uB124\uBAA8 : \uADF8\uAC83\uBFD0\uC774\uC57C?\n        \n        \uD558\uB140
    : \uC9C0\uB09C\uBC88\uC5D0 \uAC19\uC774 \uBCF8 \uAC83\uB4E4\uC774 \uC544\uC9C1\uB3C4
    \uAE30\uC5B5\uB09C\uB2E4\uACE0\uB3C4 \uD588\uC2B5\uB2C8\uB2E4.\n        \n       
    \uB124\uBAA8 : \uAF43\uBCD1 \uC598\uAE30\uD588\uC5B4?\n        \n        \uD558\uB140
    : \uB124. \uC608\uC058\uACE0 \uC7AC\uBC0C\uC5C8\uB2E4\uACE0\uC694.\n        \n       
    \uB124\uBAA8 : \uD6C4.\n        \n        \uB124\uBAA8 : \uAC54\uB294 \uC9C4\uC9DC
    \uC774\uC0C1\uD55C\uB370.\n        \n        \uD558\uB140 : \uADF8\uB798\uB3C4
    \uC8FC\uC778\uB2D8\uC774\uB791 \uB2E4\uC2DC \uBCF4\uACE0 \uC2F6\uC740 \uBAA8\uC591\uC785\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uADF8\uAC74 \uAD1C\uCC2E\uB124.\n        \n       
    \uB124\uBAA8 : \uB2E4\uC74C\uC5D4 \uB0B4\uAC00 \uB354 \uC774\uC0C1\uD55C \uAC70
    \uCC3E\uC544\uB0BC\uB798."
