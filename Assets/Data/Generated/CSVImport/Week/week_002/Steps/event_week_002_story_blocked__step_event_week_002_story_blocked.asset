  _titleOverride: "\uB3D9\uD654 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4"
  _bodyText: "\uB3D9\uD654\uC640 \uAE00\uC790 \uAD50\uC7AC Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB3D9\uD654\uCC45\uC744 \uC190\uC5D0 \uB4E4\uC5C8\uB2E4\uAC00, \uC624\uB298\uC740
      \uB2E4\uB978 \uC77C\uC815\uC73C\uB85C \uB118\uAE34\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774 \uC774\uC57C\uAE30 \uB2E4\uC74C \uC7A5 \uAD81\uAE08\uD588\uB294\uB370."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uCC45\uAC08\uD53C\uB9CC \uB07C\uC6CC \uB450\uACE0 \uB2E4\uC74C \uAE30\uD68C\uB97C
      \uC57D\uC18D\uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uC78A\uC9C0 \uB9C8\uC694."
  _nemoLine: "(\uB3D9\uD654\uCC45\uC744 \uC190\uC5D0 \uB4E4\uC5C8\uB2E4\uAC00, \uC624\uB298\uC740
    \uB2E4\uB978 \uC77C\uC815\uC73C\uB85C \uB118\uAE34\uB2E4.)"
