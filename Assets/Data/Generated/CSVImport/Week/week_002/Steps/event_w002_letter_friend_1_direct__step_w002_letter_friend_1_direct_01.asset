  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w002_letter_friend_1_direct__step_w002_letter_friend_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 2\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD604\uAD00 \uCABD\uC5D0\uC11C \uD558\uB140\uAC00 \uC791\uC740 \uBD09\uD22C
    \uD558\uB098\uB97C \uBC1B\uC544 \uB4E0\uB2E4. \uBD09\uD22C \uAC89\uC5D0\uB294
    \uC090\uB6A4\uBE7C\uB6A4\uD55C \uAE00\uC528\uAC00 \uC801\uD600 \uC788\uB2E4.)\r\n       
    \r\n        \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C \uC628
    \uD3B8\uC9C0\uB124\uC694.\r\n        \r\n\r\n(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C
    \uB4E4\uACE0 \uB124\uBAA8\uC5D0\uAC8C \uB2E4\uAC00\uAC04\uB2E4.)\r\n        \r\n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8, \uD3B8\uC9C0\uAC00 \uC654\uC2B5\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uB098\uD55C\uD14C?\r\n        \r\n        \uD558\uB140
    : \uB124. \uC800\uBC88\uC5D0 \uAC19\uC774 \uB6F0\uC5B4 \uB180\uB358 \uC544\uC774\uAC00
    \uBCF4\uB0B8 \uBAA8\uC591\uC774\uC5D0\uC694.\r\n        \r\n        \uB124\uBAA8
    : \uC9C4\uC9DC? \uBE68\uB9AC \uBD10.\r\n        \r\n        (\uD558\uB140\uAC00
    \uBD09\uD22C\uB97C \uC5F4\uC5B4 \uD3B8\uC9C0\uB97C \uC77D\uC5B4 \uC900\uB2E4.)\r\n       
    \r\n        \uB124\uBAA8 \uC548\uB155. \uC800\uBC88\uC5D0 \uB6F0\uC5B4\uC11C
    \uC7AC\uBC0C\uC5C8\uC5B4. \uB2E4\uC74C\uC5D4 \uB0B4\uAC00 \uB354 \uBE68\uB9AC
    \uB6F8 \uAC70\uC57C. \uB108\uB3C4 \uAF2D \uB2E4\uC2DC \uC640. \uC774\uBC88\uC5D4
    \uB0B4\uAC00 \uC88B\uC740 \uC228\uB294 \uACF3\uB3C4 \uBCF4\uC5EC \uC904\uAC8C.\r\n       
    \r\n        \uB124\uBAA8 : \uB610 \uB6F0\uACE0 \uC2F6\uB300.\r\n        \r\n       
    \uD558\uB140 : \uC544\uC8FC \uC2E0\uB098 \uC788\uC5C8\uB098 \uBD05\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uB098\uB3C4 \uB2E4\uC2DC \uB180\uACE0 \uC2F6\uC740\uB370.\r\n       
    \r\n        \uD558\uB140 : \uADF8\uB7EC\uC168\uAD70\uC694, \uC8FC\uC778\uB2D8.\r\n       
    \r\n        \uB124\uBAA8 : \uC228\uB294 \uACF3\uB3C4 \uBCF4\uC5EC \uC900\uB314\uC5B4.
    \uADF8\uAC70 \uAD81\uAE08\uD574."
