  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w002_letter_friend_2_modified__step_w002_letter_friend_2_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 \uD3B8\uC9C0 2\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uB2E8\uC815\uD55C \uBD09\uD22C \uD558\uB098\uB97C
    \uBC1B\uC544 \uB4E0\uB2E4. \uBD09\uD22C\uB294 \uBC18\uB4EF\uD558\uAC8C \uC811\uD600
    \uC788\uACE0, \uAE00\uC528\uB3C4 \uC791\uACE0 \uACE0\uB974\uAC8C \uC4F0\uC5EC
    \uC788\uB2E4.)\n        \n        \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C
    \uD3B8\uC9C0\uAC00 \uC654\uB124\uC694.\n        \n\n(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C
    \uC77D\uACE0, \uB124\uBAA8 \uC55E\uC5D0 \uC549\uC544 \uB0B4\uC6A9\uC744 \uCC9C\uCC9C\uD788
    \uC804\uD574 \uC900\uB2E4.)\n        \n        \uD558\uB140 : \uC8FC\uC778\uB2D8,
    \uC800\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798 \uC190\uB2D8\uC774 \uD3B8\uC9C0\uB97C
    \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : \uBB50\uB77C\uACE0
    \uD588\uC5B4?\n        \n        \uD558\uB140 : \uB2E4\uC74C\uC5D4 \uC190\uC218\uAC74\uC744
    \uCC59\uAE30\uACE0, \uB108\uBB34 \uAE09\uD558\uAC8C \uB6F0\uC9C0 \uB9D0\uB77C\uACE0
    \uD588\uC5B4\uC694.\n        \n        \uB124\uBAA8 : \uC65C?\n        \n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8 \uC637\uC5D0 \uBA3C\uC9C0\uAC00 \uB9CE\uC774
    \uBB3B\uC5B4 \uC788\uC5C8\uB358 \uAC8C \uAE30\uC5B5\uC5D0 \uB0A8\uC558\uB098
    \uBD05\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : \uB610 \uADF8 \uC598\uAE30\uC57C?\n       
    \n        \uD558\uB140 : \uADF8\uB798\uB3C4 \uB2E4\uC2DC \uB9CC\uB098\uBA74 \uC778\uC0AC\uB294
    \uD558\uACE0 \uC2F6\uB2E4\uACE0 \uD588\uC2B5\uB2C8\uB2E4.\n        \n       
    \uB124\uBAA8 : \u2026\u2026\uC9C4\uC9DC?\n        \n        \uD558\uB140 : \uB124.
    \uC870\uAE08 \uBB34\uB69D\uB69D\uD560 \uBFD0, \uC2EB\uC5B4\uD558\uB294 \uAC74
    \uC544\uB2CC \uBAA8\uC591\uC774\uC5D0\uC694.\n        \n        \uB124\uBAA8
    : \uADF8\uB7FC \uB2E4\uC74C\uC5D4 \uB0B4\uAC00 \uBA3C\uC800 \uC548\uB155 \uD574\uC57C\uACA0\uB2E4."
