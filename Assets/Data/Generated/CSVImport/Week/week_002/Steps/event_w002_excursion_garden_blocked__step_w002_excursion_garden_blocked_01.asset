  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w002_excursion_garden_blocked__step_w002_excursion_garden_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 2\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uBE44\uAC00 \uADF8\uCE5C \uB2E4\uC74C \uB0A0. \uC815\uC6D0 \uBC14\uB2E5\uC5D4
    \uC544\uC9C1 \uBB3C\uBC29\uC6B8\uC774 \uB0A8\uC544 \uC788\uACE0, \uC78E\uC0AC\uADC0
    \uB05D\uC5D0\uC11C \uBE57\uBB3C\uC774 \uB610\uB974\uB974 \uB5A8\uC5B4\uC9C4\uB2E4.)\n       
    \n                    \uB124\uBAA8 : \uC6B0\uC640. \uC624\uB298\uC740 \uBC18\uC9DD\uBC18\uC9DD\uD558\uB124.\n       
    \n                    (\uC6C5\uB369\uC774 \uADFC\uCC98\uC5D0\uC11C \uB2EC\uD33D\uC774
    \uD55C \uB9C8\uB9AC\uAC00 \uB290\uB9BF\uB290\uB9BF \uC9C0\uB098\uAC04\uB2E4.)\n       
    \n                    \uB124\uBAA8 : \uC5B4? \uB2EC\uD33D\uC774\uB2E4.\n       
    \n\n(\uC815\uC6D0\uC0AC\uAC00 \uBE57\uC790\uB8E8\uB97C \uB4E4\uACE0 \uB2E4\uAC00\uC628\uB2E4.)\n       
    \n                        \uC815\uC6D0\uC0AC : \uC8FC\uC778\uB2D8~ \uADF8\uAC74
    \uC190\uB300\uC2DC\uBA74 \uC548 \uB429\uB2C8\uB2E4~\n        \n                       
    \uB124\uBAA8 : \uC65C\uC694?\n        \n                        \uC815\uC6D0\uC0AC
    : \uC624\uB298\uC740 \uC544\uC9C1 \uC816\uC5B4 \uC788\uC5B4\uC11C \uBBF8\uB044\uB7FD\uACE0,
    \uB2EC\uD33D\uC774\uB3C4 \uB9CC\uC9C0\uB2E4 \uBBF8\uB044\uB7EC\uC9C8 \uC218 \uC788\uC9C0\uC694~\n       
    \n                        \uB124\uBAA8 : \uC5D0\uC774~\uC870\uC2EC\uD560\uAC8C\uC694~\n       
    \n                        \uC815\uC6D0\uC0AC : \uC624\uB298\uC740 \uB208\uC73C\uB85C\uB9CC
    \uBCF4\uC2DC\uB294 \uAC8C \uC88B\uC2B5\uB2C8\uB2E4~\n        \n                       
    \uB124\uBAA8 : \uC5D0\uC774. \uC54C\uACA0\uC5B4\uC694."
