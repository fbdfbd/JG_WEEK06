--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_205_child_visitor_friend_1_01_blocked__step_205_child_visitor_friend_1_01_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uCCAB \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "\uD568\uAED8 \uB180\uACE0 \uC2F6\uC5B4 \uD558\uB294 \uCE5C\uAD6C1\uC744
    \uB450\uACE0 \uC624\uB298\uC740 \uC778\uC0AC\uB9CC \uD558\uB77C\uACE0 \uD55C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC7E4\uB3C4 \uC190\uB2D8\uC774\uC57C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC608, \uC8FC\uC778\uB2D8. \uC624\uB298\uC740 \uB610\uB798 \uC190\uB2D8\uB3C4
      \uD568\uAED8 \uC654\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uC548\uB155! \uB108 \uB124\uBAA8\uC9C0?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4? \uC751."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uB09C \u25CB\u25CB\uC774\uC57C. \uC6B0\uB9AC \uAC19\uC774 \uB180\uB798?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC624\uB798 \uB180\uBA74 \uC548
      \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC190\uB2D8\uB3C4 \uAE08\uBC29 \uB3CC\uC544\uAC00\uC2E4 \uD14C\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uC7A0\uAE50\uB9CC \uB180\uC544\uB3C4 \uC548 \uB3FC?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC624\uB298\uC740 \uC778\uC0AC\uB9CC \uD558\uC154\uC57C \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC19\uC774 \uB180\uACE0 \uC2F6\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uAD1C\uCC2E\uC544. \uB2E4\uC74C\uC5D0 \uB610 \uBCF4\uC790!"
  _nemoLine: "\uC7E4\uB3C4 \uC190\uB2D8\uC774\uC57C?"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
