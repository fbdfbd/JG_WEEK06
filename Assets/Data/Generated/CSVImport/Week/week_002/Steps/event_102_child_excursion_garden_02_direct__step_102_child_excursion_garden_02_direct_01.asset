  m_Name: event_102_child_excursion_garden_02_direct__step_102_child_excursion_garden_02_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 2\uCC28 - \uD5C8\uB77D"
  _bodyText: "\uC815\uC6D0\uC0AC\uAC00 \uC791\uC740 \uC78E\uC0AC\uADC0\uB97C \uAC74\uB124\uBA70
    \uB2EC\uD33D\uC774\uB97C \uC870\uC2EC\uD788 \uAD00\uCC30\uD558\uAC8C \uD55C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uC624\uB298\uC740 \uBC18\uC9DD\uBC18\uC9DD\uD558\uB124."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4? \uB2EC\uD33D\uC774\uB2E4."
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC190\uC73C\uB85C \uBC14\uB85C \uB9CC\uC9C0\uC2DC\uB294 \uB300\uC2E0,
      \uC774\uAC78\uB85C \uC0B4\uC9DD \uAC74\uB4DC\uB824 \uBCF4\uC2E4\uB798\uC694?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uB098\uBB47\uAC00\uC9C0?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548\uB155, \uB2EC\uD33D\uC774\uC57C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADC0\uC5FD\uB2E4\u2026"
  _nemoLine: "\uC6B0\uC640. \uC624\uB298\uC740 \uBC18\uC9DD\uBC18\uC9DD\uD558\uB124."
