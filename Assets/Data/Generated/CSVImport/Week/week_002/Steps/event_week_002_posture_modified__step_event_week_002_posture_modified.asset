  m_Name: event_week_002_posture_modified__step_event_week_002_posture_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC2DC\uC120\uC73C\uB85C \uBC29\uD5A5\uC744 \uBA3C\uC800 \uC7A1\uAC8C
    \uD55C\uB2E4"
  _bodyText: "\uBAB8\uAC00\uC9D0\uACFC \uBC1C\uB180\uB9BC 2\uC8FC\uCC28 Modified
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBC14\uB2E5\uC758 \uC120\uC744 \uB530\uB77C \uAC77\uB294 \uC5F0\uC2B5.
      \uC774\uBC88\uC5D4 \uBC29\uD5A5 \uC804\uD658\uAE4C\uC9C0 \uCD94\uAC00\uB41C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC624\uB298\uC740 \uB3CC\uC544\uC11C\uB294 \uAC83\uAE4C\uC9C0 \uD574
      \uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB354 \uC5B4\uB835\uB124, \uC774\uAC70."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uBC1C\uBCF4\uB2E4 \uC2DC\uC120\uC744 \uBA3C\uC800 \uC6C0\uC9C1\uC5EC
      \uBCF4\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544\u2026 \uADF8\uAC8C \uB354 \uC27D\uB2E4."
  _nemoLine: "(\uBC14\uB2E5\uC758 \uC120\uC744 \uB530\uB77C \uAC77\uB294 \uC5F0\uC2B5.
    \uC774\uBC88\uC5D4 \uBC29\uD5A5 \uC804\uD658\uAE4C\uC9C0 \uCD94\uAC00\uB41C\uB2E4.)"
