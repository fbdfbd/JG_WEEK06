  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w002_letter_friend_2_direct__step_w002_letter_friend_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 \uD3B8\uC9C0 2\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uB2E8\uC815\uD55C \uBD09\uD22C \uD558\uB098\uB97C
    \uBC1B\uC544 \uB4E0\uB2E4. \uBD09\uD22C\uB294 \uBC18\uB4EF\uD558\uAC8C \uC811\uD600
    \uC788\uACE0, \uAE00\uC528\uB3C4 \uC791\uACE0 \uACE0\uB974\uAC8C \uC4F0\uC5EC
    \uC788\uB2E4.)\n        \n        \uD558\uB140 : \uB610\uB798 \uC190\uB2D8 \uCABD\uC5D0\uC11C
    \uD3B8\uC9C0\uAC00 \uC654\uB124\uC694.\n        \n\n(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C
    \uB4E4\uACE0 \uB124\uBAA8\uC5D0\uAC8C \uB2E4\uAC00\uAC04\uB2E4.)\n        \n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8, \uD3B8\uC9C0\uAC00 \uC654\uC2B5\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uB098\uD55C\uD14C?\n        \n        \uD558\uB140
    : \uB124. \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798 \uC190\uB2D8\uC774
    \uBCF4\uB0B8 \uBAA8\uC591\uC774\uC5D0\uC694.\n        \n        \uB124\uBAA8
    : \uAC54\uAC00?\n        \n        \uD558\uB140 : \uC77D\uC5B4 \uB4DC\uB9B4\uAE4C\uC694?\n       
    \n        \uB124\uBAA8 : \uC751.\n        \n        (\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C
    \uD3BC\uCE5C\uB2E4.)\n        \n        \uB124\uBAA8\uC5D0\uAC8C. \uC9C0\uB09C\uBC88
    \uC637\uC5D0 \uBA3C\uC9C0\uAC00 \uB9CE\uC774 \uBB3B\uC5B4 \uC788\uC5C8\uB2E4.
    \uB2E4\uC74C\uC5D4 \uC190\uC218\uAC74\uC744 \uCC59\uACA8. \uADF8\uB9AC\uACE0
    \uB108\uBB34 \uBE68\uB9AC \uB6F0\uC9C0 \uB9C8. \uADF8\uB798\uB3C4\u2026 \uB2E4\uC2DC
    \uBCF4\uBA74 \uC778\uC0AC\uB294 \uD574\uB3C4 \uB41C\uB2E4.\n        \n       
    \uB124\uBAA8 : \uBB50\uC57C.\n        \n        \uB124\uBAA8 : \uC794\uC18C\uB9AC\uB9CC
    \uD588\uC5B4.\n        \n        \uD558\uB140 : \uADF8\uB798\uB3C4 \uB9C8\uC9C0\uB9C9\uC740
    \uBD80\uB4DC\uB7FD\uC9C0 \uC54A\uC2B5\uB2C8\uAE4C?\n        \n        \uB124\uBAA8
    : \uC778\uC0AC\uB294 \uD574\uB3C4 \uB41C\uB300. \uC774\uC0C1\uD55C \uC560\uC57C.\n       
    \n        \uD558\uB140 : \uADF8\uB798\uB3C4 \uC8FC\uC778\uB2D8\uC744 \uAE30\uC5B5\uD558\uACE0
    \uC788\uB098 \uBD05\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : \u2026\u2026\uADF8\uAC74
    \uB9DE\uB124."
