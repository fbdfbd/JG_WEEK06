  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_202_child_visitor_cousin_1_02_blocked__step_202_child_visitor_cousin_1_02_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 \uB450 \uBC88\uC9F8 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "\uC0AC\uCD0C1\uACFC\uC758 \uB450 \uBC88\uC9F8 \uB9CC\uB0A8\uC5D0\uC11C
    \uC9D1\uC0AC\uC7A5\uC774 \uD55C \uAC78\uC74C \uB4A4\uB85C \uBB3C\uB9AC\uBA70
    \uAE38\uAC8C \uBA38\uBB3C\uC9C0 \uBABB\uD558\uAC8C \uD55C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uB610 \uB9CC\uB098\uB294\uAD6C\uB098."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548\uB155\uD558\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uAE38\uAC8C \uACC4\uC2DC\uBA74
      \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uC544\uC27D\uAD70. \uC9C0\uB09C\uBC88\uC5D4 \uC544\uC8FC \uBC18\uAC00\uC6E0\uB294\uB370."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC870\uAE08\uB9CC \uB354 \uBCF4\uBA74 \uC548 \uB3FC\uC694?"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uB2E4\uC74C\uC5D4 \uAF2D \uC120\uBB3C\uC744 \uC8FC\uB9C8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC?"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uC751."
  _nemoLine: "\uB610 \uB9CC\uB098\uB294\uAD6C\uB098."
  _useCustomVisualState: 0
  _visualState: 0
