  _titleOverride: "\uC790\uC138\uC640 \uBC1C\uB180\uB9BC\uC744 \uBC14\uB85C\uC7A1\uB294\uB2E4"
  _bodyText: "\uBAB8\uAC00\uC9D0\uACFC \uBC1C\uB180\uB9BC \uAD50\uC7AC Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBC1C \uAC04\uACA9\uACFC \uC2DC\uC120\uC744 \uD558\uB098\uC529 \uBC14\uB85C\uC7A1\uC73C\uBA70
      \uAE30\uBCF8 \uC790\uC138\uB97C \uBC18\uBCF5\uD558\uAC8C \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC00\uB9CC\uD788 \uC11C \uC788\uB294 \uAC8C \uB354 \uC5B4\uB824\uC6CC."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uD750\uD2B8\uB7EC\uC9C4 \uC5B4\uAE68\uC640 \uBC1C\uB05D\uC744 \uB2E4\uC2DC
      \uB9DE\uCD94\uAC8C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB798\uB3C4 \uC774\uBC88\uC5D4 \uC870\uAE08 \uB35C \uBE44\uD2C0\uAC70\uB838\uC5B4."
  _nemoLine: "(\uBC1C \uAC04\uACA9\uACFC \uC2DC\uC120\uC744 \uD558\uB098\uC529 \uBC14\uB85C\uC7A1\uC73C\uBA70
    \uAE30\uBCF8 \uC790\uC138\uB97C \uBC18\uBCF5\uD558\uAC8C \uD55C\uB2E4.)"
