  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_205_child_visitor_friend_1_01_direct__step_205_child_visitor_friend_1_01_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uCCAB \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "\uCE5C\uAD6C1\uC774 \uB124\uBAA8\uC758 \uC190\uBAA9\uC744 \uC7A1\uACE0
    \uB2EC\uB824 \uB098\uAC00\uBA70 \uAE08\uC138 \uC220\uB798\uB180\uC774\uAC00 \uC2DC\uC791\uB41C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uC548\uB155! \uB108 \uB124\uBAA8\uC9C0?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4? \uC751."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uB09C \u25CB\u25CB\uC774\uC57C. \uC6B0\uB9AC \uAC19\uC774 \uB180\uB798?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB108\uBB34 \uBA40\uB9AC\uB9CC \uAC00\uC9C0 \uB9C8\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC\uC694?"
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uC640! \uAC00\uC790!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4\uC5B4? \uBE68\uB77C!"
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uB108 \uC220\uB798 \uD560\uB798?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC2EB\uC5B4! \uB098 \uC228\uC744\uB798!"
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uADF8\uB7FC \uB0B4\uAC00 \uCC3E\uB294\uB2E4!"
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uCC3E\uC558\uB2E4!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC5D0! \uBC8C\uC368?"
  _nemoLine: "\uC548\uB155! \uB108 \uB124\uBAA8\uC9C0?"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
