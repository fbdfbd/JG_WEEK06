  m_Name: event_w002_house_laundry_ribbon_direct__step_w002_house_laundry_ribbon_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC138\uD0C1\uC2E4 \uB9AC\uBCF8 \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uC138\uD0C1\uC2E4 \uC55E. \uD558\uB140 \uB458\uC774 \uC0C9 \uB9AC\uBCF8\uC744
    \uC815\uB9AC\uD558\uBA70 \uD55C\uC228 \uC270\uB2E4.)\r\n        \r\n        \uD558\uB1401
    : \uC774\uC0C1\uD558\uC9C0. \uBD84\uBA85 \uC9DD \uB9DE\uCDB0 \uB480\uB294\uB370.\r\n       
    \r\n        \uD558\uB1402 : \uB610 \uD558\uB098 \uC5C6\uC5B4\uC84C\uC5B4.\r\n       
    \r\n        \uB124\uBAA8 : \uBB50 \uC5C6\uC5B4\uC84C\uC5B4?\r\n        \r\n\r\n\uD558\uB1401
    : \uC138\uD0C1\uC2E4 \uB9AC\uBCF8\uC774 \uC790\uAFB8 \uD558\uB098\uC529 \uC5C6\uC5B4\uC9C4\uB2F5\uB2C8\uB2E4,
    \uC8FC\uC778\uB2D8.\r\n        \r\n        \uB124\uBAA8 : \uB204\uAC00 \uAC00\uC838\uAC00?\r\n       
    \r\n        \uD558\uB1402 : \uBAA8\uB974\uACA0\uC5B4\uC694. \uBE68\uB798\uC904\uC5D0
    \uC798 \uAC78\uC5B4 \uB46C\uB3C4 \uAF2D \uD558\uB098\uC529 \uC0AC\uB77C\uC838\uC694.\r\n       
    \r\n        \uB124\uBAA8 : \uB9AC\uBCF8 \uC88B\uC544\uD558\uB294 \uC0AC\uB78C\uC774
    \uC788\uB098?\r\n        \r\n        \uD558\uB1401 : \uD558\uB140\uB4E4 \uC0AC\uC774\uC5D0\uC120
    \uC138\uD0C1\uC2E4 \uACE0\uBE14\uB9B0\uC774 \uAC00\uC838\uAC04\uB2E4\uACE0\uB4E4
    \uD574\uC694.\r\n        \r\n        \uB124\uBAA8 : \uD5C9. \uACE0\uBE14\uB9B0?\r\n       
    \r\n        \uD558\uB1402 : \uB18D\uB2F4\uC774\uC5D0\uC694. \uC544\uB9C8 \uB204\uAC00
    \uC790\uAFB8 \uD5F7\uAC08\uB9AC\uB294 \uAC70\uACA0\uC9C0\uC694."
