--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_002_letter_friend_1_modified__step_event_week_002_letter_friend_1_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: friend_1 Modified
  _bodyText: "letter friend_1 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uC77D\uACE0, \uC811\uC740 \uB4A4
      \uB124\uBAA8 \uC55E\uC5D0 \uC549\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC800\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798 \uC190\uB2D8\uD55C\uD14C\uC11C
      \uD3B8\uC9C0\uAC00 \uC654\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uB77C\uACE0 \uD588\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uC774\uB791 \uB2E4\uC2DC \uB180\uACE0 \uC2F6\uB2E4\uACE0
      \uD588\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610 \uB6F0\uC790\uACE0?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uB2E4\uC74C\uC5D0 \uB9CC\uB098\uBA74 \uC88B\uC740 \uACF3\uB3C4
      \uBCF4\uC5EC \uC8FC\uACE0 \uC2F6\uB2E4\uACE0 \uD558\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC88B\uC740 \uACF3?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC228\uAE30 \uC88B\uC740 \uACF3\uC77C \uC218\uB3C4 \uC788\uACE0, \uC7AC\uBC0C\uB294
      \uACF3\uC77C \uC218\uB3C4 \uC788\uACA0\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB2E4\uC74C\uC5D0 \uB610 \uB9CC\uB098\uC57C\uACA0\uB2E4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB9CE\uC774 \uBC18\uAC00\uC6B0\uC168\uB098 \uBD05\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uAC54\uB294 \uBE68\uB77C\uC11C \uC7AC\uBC0C\uC5B4."
  _nemoLine: "(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uC77D\uACE0, \uC811\uC740 \uB4A4
    \uB124\uBAA8 \uC55E\uC5D0 \uC549\uB294\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
