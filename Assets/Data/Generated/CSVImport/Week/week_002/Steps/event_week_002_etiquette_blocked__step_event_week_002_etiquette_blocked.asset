--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_002_etiquette_blocked__step_event_week_002_etiquette_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC218\uD504 \uC608\uC808\uC744 \uC5C4\uD558\uAC8C \uC775\uD78C\uB2E4"
  _bodyText: "\uC778\uC0AC\uC640 \uC2DD\uC0AC \uC608\uC808 2\uC8FC\uCC28 Blocked
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC2DD\uD0C1. \uC774\uBC88\uC5D4 \uC2DD\uAE30\uAC00 \uB354 \uB298\uC5B4\uB098
      \uC788\uACE0, \uC218\uD504\uAC00 \uBA3C\uC800 \uB098\uC628\uB2E4. \uD558\uB140\uAC00
      \uC870\uC6A9\uD788 \uC218\uD504 \uC2A4\uD47C\uC744 \uC9DA\uC5B4 \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC21C\uC11C\uC640 \uC18C\uB9AC\uB97C
      \uD568\uAED8 \uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610 \uC870\uC6A9\uD788 \uBA39\uB294 \uAC70\uC9C0\u2026 \uC54C\uACA0\uC5B4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC2A4\uD47C\uC744 \uAE4A\uAC8C \uB123\uC5B4 \uC18C\uB9AC\uB97C
      \uB0B4\uC790, \uACBD\uBE44\uB300\uC7A5\uC774 \uC2A4\uD47C\uC744 \uC0B4\uC9DD
      \uB4E4\uC5B4 \uC62C\uB824 \uAC01\uB3C4\uB97C \uBC14\uB85C\uC7A1\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC18C\uB9AC\uB294 \uC904\uC774\uC2ED\uC2DC\uC624. \uC2DD\uD0C1\uC5D0\uC11C\uB294
      \uC18C\uB9AC\uB3C4 \uD589\uB3D9\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB0E5 \uBA39\uC73C\uBA74 \uC548 \uB4E4\uB9AC\uAC8C \uBA39\uB294
      \uAC8C \uB354 \uC5B4\uB824\uC6CC\u2026"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uADF8 \uC5B4\uB824\uC6B4 \uAC78 \uD558\uB294 \uAC8C \uC608\uBC95\uC785\uB2C8\uB2E4.
      \uB2E4\uC2DC \uD558\uC2ED\uC2DC\uC624."
  _nemoLine: "(\uC2DD\uD0C1. \uC774\uBC88\uC5D4 \uC2DD\uAE30\uAC00 \uB354 \uB298\uC5B4\uB098
    \uC788\uACE0, \uC218\uD504\uAC00 \uBA3C\uC800 \uB098\uC628\uB2E4. \uD558\uB140\uAC00
    \uC870\uC6A9\uD788 \uC218\uD504 \uC2A4\uD47C\uC744 \uC9DA\uC5B4 \uC900\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
