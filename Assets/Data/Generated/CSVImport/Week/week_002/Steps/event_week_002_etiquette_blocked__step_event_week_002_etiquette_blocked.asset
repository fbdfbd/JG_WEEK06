  _titleOverride: "\uC608\uC808 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4"
  _bodyText: "\uC778\uC0AC\uC640 \uC2DD\uC0AC \uC608\uC808 \uAD50\uC7AC Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uAD50\uC7AC\uB97C \uD3BC\uCE58\uB824\uB2E4, \uC624\uB298\uC740 \uC218\uC5C5\uC744
      \uBBF8\uB8E8\uAE30\uB85C \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624\uB298\uC740 \uC548 \uD574\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uC9E7\uAC8C \uC26C\uACE0 \uB2E4\uC74C\uC73C\uB85C \uB118\uAE34\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB2E4\uC74C\uC5D4 \uAF2D \uD574\uC694."
  _nemoLine: "(\uAD50\uC7AC\uB97C \uD3BC\uCE58\uB824\uB2E4, \uC624\uB298\uC740 \uC218\uC5C5\uC744
    \uBBF8\uB8E8\uAE30\uB85C \uD55C\uB2E4.)"
