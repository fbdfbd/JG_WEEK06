  _titleOverride: "\uAF43\uACFC \uBC8C\uB808\uB97C \uCC28\uADFC\uCC28\uADFC \uC0B4\uD540\uB2E4"
  _bodyText: "\uAF43\uACFC \uBC8C\uB808 \uAD00\uCC30 \uAD50\uC7AC Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uAD50\uC7AC \uADF8\uB9BC\uACFC \uC2E4\uC81C \uC2DD\uBB3C\uC744 \uBC88\uAC08\uC544
      \uBCF4\uC774\uBA70 \uC774\uB984\uACFC \uD2B9\uC9D5\uC744 \uC9DA\uC5B4 \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAF43\uC78E \uBAA8\uC591\uC774 \uB2E4 \uB2EC\uB77C."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uAD00\uCC30\uD55C \uAC83\uC744 \uD558\uB098\uC529 \uBE44\uAD50\uD558\uAC8C
      \uD558\uBA70 \uCC9C\uCC9C\uD788 \uC815\uB9AC\uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uC81C\uAC00 \uBA3C\uC800 \uCC3E\uC558\uC5B4\uC694."
  _nemoLine: "(\uAD50\uC7AC \uADF8\uB9BC\uACFC \uC2E4\uC81C \uC2DD\uBB3C\uC744 \uBC88\uAC08\uC544
    \uBCF4\uC774\uBA70 \uC774\uB984\uACFC \uD2B9\uC9D5\uC744 \uC9DA\uC5B4 \uC900\uB2E4.)"
