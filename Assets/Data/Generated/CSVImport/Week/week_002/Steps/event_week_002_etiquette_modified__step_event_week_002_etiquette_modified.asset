  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_002_etiquette_modified__step_event_week_002_etiquette_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC794\uC794\uD55C \uC2DD\uC0AC \uAC10\uAC01\uC744 \uC775\uD78C\uB2E4"
  _bodyText: "\uC778\uC0AC\uC640 \uC2DD\uC0AC \uC608\uC808 2\uC8FC\uCC28 Modified
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC2DD\uD0C1. \uC774\uBC88\uC5D4 \uC2DD\uAE30\uAC00 \uB354 \uB298\uC5B4\uB098
      \uC788\uACE0, \uC218\uD504\uAC00 \uBA3C\uC800 \uB098\uC628\uB2E4. \uD558\uB140\uAC00
      \uC870\uC6A9\uD788 \uC218\uD504 \uC2A4\uD47C\uC744 \uC9DA\uC5B4 \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC21C\uC11C\uC640 \uC18C\uB9AC\uB97C
      \uD568\uAED8 \uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610 \uC870\uC6A9\uD788 \uBA39\uB294 \uAC70\uC9C0\u2026 \uC54C\uACA0\uC5B4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uC791\uC740 \uCC3B\uC794\uC744 \uC606\uC5D0 \uB450\uBA70
      \uB9D0\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uBB3C \uC704\uC5D0 \uBB3C\uACB0\uC744 \uB9CC\uB4E4\uC9C0 \uC54A\uB294\uB2E4\uACE0
      \uC0DD\uAC01\uD574 \uBCF4\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB3C\uACB0\u2026"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC2A4\uD47C\uC774 \uB2FF\uC744 \uB54C\uB9C8\uB2E4 \uC794\uC794\uD558\uAC8C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\uADF8\uB807\uAC8C \uC0DD\uAC01\uD558\uB2C8\uAE4C \uC880 \uB35C
      \uC2E0\uACBD \uC4F0\uC778\uB2E4."
  _nemoLine: "(\uC2DD\uD0C1. \uC774\uBC88\uC5D4 \uC2DD\uAE30\uAC00 \uB354 \uB298\uC5B4\uB098
    \uC788\uACE0, \uC218\uD504\uAC00 \uBA3C\uC800 \uB098\uC628\uB2E4. \uD558\uB140\uAC00
    \uC870\uC6A9\uD788 \uC218\uD504 \uC2A4\uD47C\uC744 \uC9DA\uC5B4 \uC900\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
