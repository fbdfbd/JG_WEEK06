  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 \uCCAB \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "\uB0AF\uC744 \uB9CE\uC774 \uAC00\uB9AC\uB294 \uC0AC\uCD0C2\uC640 \uC9E7\uC9C0\uB9CC
    \uC911\uC694\uD55C \uCCAB \uB300\uD654\uB97C \uB098\uB208\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\u2026\u2026\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB108 \uC774\uB984 \uBB50\uC57C?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\u2026\u2026"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C \uB300\uB2F5 \uC548 \uD574?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uBBF8, \uBBF8\uC548. \uB098\u2026 \u25CB\u25CB\uC774\uC57C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB09C \uB124\uBAA8\uC57C."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uC751."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB108\uB3C4 \uC0AC\uD0D5 \uC88B\uC544\uD574?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\u2026\u2026\uC88B\uC544\uD574."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uC74C\uC5D4 \uAC19\uC774 \uB180\uB798?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\u2026\u2026\uC751. \uC544\uB9C8\uB3C4."
  _nemoLine: "\uC548\uB155."
  _useCustomVisualState: 0
  _visualState: 0
