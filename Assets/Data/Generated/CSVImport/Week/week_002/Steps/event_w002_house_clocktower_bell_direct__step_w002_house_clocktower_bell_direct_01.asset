  m_Name: event_w002_house_clocktower_bell_direct__step_w002_house_clocktower_bell_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC2DC\uACC4\uD0D1 \uC885\uC18C\uB9AC \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uACC4\uB2E8 \uC544\uB798. \uC0AC\uC6A9\uC778 \uB458\uC774 \uB192\uC740
    \uCC9C\uC7A5\uC744 \uC62C\uB824\uB2E4\uBCF8\uB2E4.)\n        \n        \uC0AC\uC6A9\uC7781
    : \uC5B4\uC82F\uBC24\uC5D4 \uC885\uC774 \uD55C \uBC88 \uB354 \uC6B8\uB9B0 \uAC83
    \uAC19\uB358\uB370.\n        \n        \uC0AC\uC6A9\uC7782 : \uB098\uB3C4 \uB4E4\uC5C8\uC5B4.
    \uC2DC\uACC4\uD0D1\uC774 \uB610 \uC2EC\uC220 \uBD80\uB838\uB098 \uBD10.\n       
    \n        \uB124\uBAA8 : \uC885\uC774 \uC65C \uB354 \uC6B8\uB824?\n        \n\n\uC0AC\uC6A9\uC7781
    : \uC2DC\uACC4\uD0D1 \uC885\uC774 \uAC00\uB054 \uC2DC\uAC04\uBCF4\uB2E4 \uD55C
    \uBC88 \uB354 \uC6B8\uB9B4 \uB54C\uAC00 \uC788\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.\n       
    \n        \uB124\uBAA8 : \uC65C?\n        \n        \uC0AC\uC6A9\uC7782 : \uC624\uB798\uB3FC\uC11C
    \uADF8\uB7F0\uAC00 \uBD10\uC694. \uADF8\uB798\uC11C \uBC24\uC5D4 \uB2E4\uB4E4
    \uAE5C\uC9DD \uB180\uB77C\uC9C0\uC694.\n        \n        \uB124\uBAA8 : \uD5C9.
    \uB098\uB3C4 \uB4E4\uC73C\uBA74 \uB180\uB784 \uAC83 \uAC19\uC544.\n        \n       
    \uC0AC\uC6A9\uC7781 : \uB124. \uADF8\uB798\uB3C4 \uB098\uC05C \uAC74 \uC544\uB2C8\uB78D\uB2C8\uB2E4.\n       
    \n        \uC0AC\uC6A9\uC7782 : \uADF8\uB0E5 \uC800\uD0DD \uC885\uC774 \uAC00\uB054
    \uC2EC\uC220\uC744 \uBD80\uB9AC\uB294 \uAC70\uC9C0\uC694."
