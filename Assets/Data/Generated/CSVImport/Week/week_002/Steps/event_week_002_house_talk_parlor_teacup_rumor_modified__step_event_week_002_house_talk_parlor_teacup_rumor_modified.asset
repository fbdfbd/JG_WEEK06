  _titleOverride: "\uC751\uC811\uC2E4 \uCC3B\uC794 \uC18C\uBB38 \uC218\uC815"
  _bodyText: "house_talk \uC751\uC811\uC2E4_\uCC3B\uC794_\uC18C\uBB38 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC624\uB298\uC740 \uC870\uAE08 \uB354 \uC608\uC05C \uC794\uC744 \uC4F0\uB294
      \uB0A0\uC774\uC5D0\uC694, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uC911\uC694\uD55C \uC190\uB2D8\uC774 \uC624\uC2DC\uBA74 \uBCF4\uAE30
      \uC88B\uC740 \uAC78 \uB0B4\uB294 \uAC70\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB0E5 \uC608\uC05C \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uB124. \uC624\uB298\uC740 \uC800\uD0DD\uC774 \uB354 \uBC18\uC9DD\uC5EC
      \uBCF4\uC5EC\uC57C \uD558\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uC88B\uC740 \uB0A0\uC778\uAC00 \uBCF4\uB2E4."
  _nemoLine: "\uC624\uB298\uC740 \uC870\uAE08 \uB354 \uC608\uC05C \uC794\uC744 \uC4F0\uB294
    \uB0A0\uC774\uC5D0\uC694, \uC8FC\uC778\uB2D8."
