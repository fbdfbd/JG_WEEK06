  _titleOverride: library Blocked
  _bodyText: "excursion library Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uCC45\uC744 \uC7A1\uAE30 \uC9C1\uC804, \uC11C\uACE0\uAD00\uB9AC\uC778\uC774
      \uB098\uC640 \uADF8 \uCC45\uC744 \uBD99\uB4E0\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC774 \uCC45\uC740 \uC190\uB300\uC154\uC120 \uC548\uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uCC45\uC774 \uC624\uB798\uB418\uC5B4 \uC790\uCE6B\uD558\uB2E8 \uD6FC\uC190
      \uB420 \uC218 \uC788\uAE30 \uB54C\uBB38\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC870\uAE08\uB9CC\uC778\uB370."
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774\u2026"
  _nemoLine: "(\uB124\uBAA8\uAC00 \uCC45\uC744 \uC7A1\uAE30 \uC9C1\uC804, \uC11C\uACE0\uAD00\uB9AC\uC778\uC774
    \uB098\uC640 \uADF8 \uCC45\uC744 \uBD99\uB4E0\uB2E4.)"
