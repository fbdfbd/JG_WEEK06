  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_002_house_talk_clock_tower_rumor_direct__step_event_week_002_house_talk_clock_tower_rumor_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC2DC\uACC4\uD0D1 \uC885\uC18C\uB9AC \uC18C\uBB38 \uD5C8\uAC00"
  _bodyText: "house_talk \uC2DC\uACC4\uD0D1_\uC885\uC18C\uB9AC_\uC18C\uBB38 Direct
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: ea8bb1cd384c18f4c83d6f267d5433b5, type: 2}
    _text: "\uC2DC\uACC4\uD0D1 \uC885\uC774 \uAC00\uB054 \uC2DC\uAC04\uBCF4\uB2E4
      \uD55C \uBC88 \uB354 \uC6B8\uB9B4 \uB54C\uAC00 \uC788\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  - _speaker: {fileID: 11400000, guid: 382a01f86413cfc439d75f63e427a411, type: 2}
    _text: "\uC624\uB798\uB3FC\uC11C \uADF8\uB7F0\uAC00 \uBD10\uC694. \uADF8\uB798\uC11C
      \uBC24\uC5D4 \uB2E4\uB4E4 \uAE5C\uC9DD \uB180\uB77C\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5C9. \uB098\uB3C4 \uB4E4\uC73C\uBA74 \uB180\uB784 \uAC83 \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: ea8bb1cd384c18f4c83d6f267d5433b5, type: 2}
    _text: "\uB124. \uADF8\uB798\uB3C4 \uB098\uC05C \uAC74 \uC544\uB2C8\uB78D\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 382a01f86413cfc439d75f63e427a411, type: 2}
    _text: "\uADF8\uB0E5 \uC800\uD0DD \uC885\uC774 \uAC00\uB054 \uC2EC\uC220\uC744
      \uBD80\uB9AC\uB294 \uAC70\uC9C0\uC694."
  _nemoLine: "\uC2DC\uACC4\uD0D1 \uC885\uC774 \uAC00\uB054 \uC2DC\uAC04\uBCF4\uB2E4
    \uD55C \uBC88 \uB354 \uC6B8\uB9B4 \uB54C\uAC00 \uC788\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
