  m_Name: event_w002_excursion_garden_direct__step_w002_excursion_garden_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 2\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uBE44\uAC00 \uADF8\uCE5C \uB2E4\uC74C \uB0A0. \uC815\uC6D0 \uBC14\uB2E5\uC5D4
    \uC544\uC9C1 \uBB3C\uBC29\uC6B8\uC774 \uB0A8\uC544 \uC788\uACE0, \uC78E\uC0AC\uADC0
    \uB05D\uC5D0\uC11C \uBE57\uBB3C\uC774 \uB610\uB974\uB974 \uB5A8\uC5B4\uC9C4\uB2E4.)\r\n       
    \r\n                    \uB124\uBAA8 : \uC6B0\uC640. \uC624\uB298\uC740 \uBC18\uC9DD\uBC18\uC9DD\uD558\uB124.\r\n       
    \r\n                    (\uC6C5\uB369\uC774 \uADFC\uCC98\uC5D0\uC11C \uB2EC\uD33D\uC774
    \uD55C \uB9C8\uB9AC\uAC00 \uB290\uB9BF\uB290\uB9BF \uC9C0\uB098\uAC04\uB2E4.)\r\n       
    \r\n                    \uB124\uBAA8 : \uC5B4? \uB2EC\uD33D\uC774\uB2E4.\r\n       
    \r\n\r\n(\uC815\uC6D0\uC0AC\uAC00 \uC791\uC740 \uB098\uBB47\uC78E\uC744 \uC9D1\uC5B4
    \uB124\uBAA8\uC5D0\uAC8C \uAC74\uB128\uB2E4.)\r\n        \r\n                       
    \uC815\uC6D0\uC0AC : \uC190\uC73C\uB85C \uBC14\uB85C \uB9CC\uC9C0\uC2DC\uB294
    \uB300\uC2E0, \uC774\uAC78\uB85C \uC0B4\uC9DD \uAC74\uB4DC\uB824 \uBCF4\uC2E4\uB798\uC694?\r\n       
    \r\n                        \uB124\uBAA8 : \uC6B0\uC640. \uB098\uBB47\uAC00\uC9C0?\r\n       
    \r\n                        \uB124\uBAA8 : \uC548\uB155, \uB2EC\uD33D\uC774\uC57C.\r\n       
    \r\n                        (\uB124\uBAA8\uB294 \uB098\uBB47\uAC00\uC9C0\uB85C
    \uB2EC\uD33D\uC774\uB97C \uB4E4\uC5B4\uC62C\uB9B0\uB2E4.)\r\n        \r\n                       
    \uB124\uBAA8 : \uADC0\uC5FD\uB2E4\u2026"
