  _titleOverride: "\uAD00\uCC30 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4"
  _bodyText: "\uAF43\uACFC \uBC8C\uB808 \uAD00\uCC30 \uAD50\uC7AC Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uAD00\uCC30 \uAD50\uC7AC\uB97C \uAEBC\uB0C8\uB2E4\uAC00, \uC624\uB298\uC740
      \uCC3D\uAC00\uB9CC \uD55C\uBC88 \uBCF4\uACE0 \uB118\uC5B4\uAC04\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC8C\uB808 \uC548 \uBD10\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uAD50\uC7AC\uB97C \uB2EB\uACE0 \uB2E4\uC74C\uC5D0 \uB354 \uC790\uC138\uD788
      \uBCF4\uAE30\uB85C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uC74C\uC5D4 \uAF2D \uC791\uC740 \uAC83\uB3C4 \uBCF4\uC5EC \uC918\uC694."
  _nemoLine: "(\uAD00\uCC30 \uAD50\uC7AC\uB97C \uAEBC\uB0C8\uB2E4\uAC00, \uC624\uB298\uC740
    \uCC3D\uAC00\uB9CC \uD55C\uBC88 \uBCF4\uACE0 \uB118\uC5B4\uAC04\uB2E4.)"
