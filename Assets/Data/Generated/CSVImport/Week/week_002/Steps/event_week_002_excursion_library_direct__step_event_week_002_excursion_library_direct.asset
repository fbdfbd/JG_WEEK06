  _titleOverride: library Direct
  _bodyText: "excursion library Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC11C\uACE0\uAD00\uB9AC\uC778\uC774 \uB4A4\uC5D0\uC11C \uC9C0\uCF1C\uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uADF8 \uCC45\uC740 \uC5B4\uB824\uC6B0\uC2E4\uAC81\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC870\uC2EC\uC870\uC2EC \uD398\uC774\uC9C0\uB97C
      \uC5F0\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uBAA8\uB974\uB294 \uAE00\uC790 \uC5C4\uCCAD \uB9CE\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB9BC\uB3C4 \uC5C6\uB124 \uC7AC\uBBF8\uC5C6\uC5B4."
  _nemoLine: "(\uC11C\uACE0\uAD00\uB9AC\uC778\uC774 \uB4A4\uC5D0\uC11C \uC9C0\uCF1C\uBCF8\uB2E4.)"
