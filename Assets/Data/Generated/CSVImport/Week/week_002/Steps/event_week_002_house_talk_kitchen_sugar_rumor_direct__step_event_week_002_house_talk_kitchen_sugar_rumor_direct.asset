  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_002_house_talk_kitchen_sugar_rumor_direct__step_event_week_002_house_talk_kitchen_sugar_rumor_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC8FC\uBC29\uC758 \uC124\uD0D5 \uC18C\uBB38 \uD5C8\uAC00"
  _bodyText: "house_talk \uC8FC\uBC29\uC758_\uC124\uD0D5_\uC18C\uBB38 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC124\uD0D5\uC774 \uB610 \uC904\uC5C8\uC5B4\uC694, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB204\uAC00 \uBA39\uC5C8\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uADF8\uAC8C \uBB38\uC81C\uB78D\uB2C8\uB2E4. \uBAB0\uB798 \uC9D1\uC5B4\uBA39\uB294
      \uC0AC\uB78C\uC774 \uC788\uB294 \uAC83 \uAC19\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5C9. \uB3C4\uB451?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC124\uD0D5 \uB3C4\uB451\uC774\uBA74 \uC880 \uADC0\uC5FD\uAE34 \uD558\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB204\uAD70\uC9C0 \uAD81\uAE08\uD574."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uC8FC\uBC29\uC5D0\uC120 \uC694 \uBA70\uCE60 \uADF8 \uC598\uAE30\uBFD0\uC774\uC5D0\uC694."
  _nemoLine: "\uC124\uD0D5\uC774 \uB610 \uC904\uC5C8\uC5B4\uC694, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
