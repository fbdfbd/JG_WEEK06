  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_letter_friend_2_direct__step_event_week_008_letter_friend_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: friend_2 Direct
  _bodyText: "letter friend_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uCE5C\uAD6C\uBD84\uC774 \uC8FC\uC778\uB2D8\uC744 \uC704\uD574 \uC9C1\uC811
      \uB9CC\uB4E0 \uCC45\uAC08\uD53C\uC640 \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uCC45\uAC08\uD53C? \uC608\uC058\uB2E4!"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC31\uC791\uB2D8\uC774 \uC2EC\uC73C\uC2E0 \uAF43... \uAC54\uB294 \uB0B4
      \uB9C8\uC74C\uC744 \uB2E4 \uC544\uB294 \uAC83 \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uC744 \uB204\uAD6C\uBCF4\uB2E4 \uAC00\uAE4C\uC774\uC11C
      \uC9C0\uCF1C\uBCF4\uACE0 \uC751\uC6D0\uD558\uB294 \uCE5C\uAD6C\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uC774 \uAF43 \uD5A5\uAE30 \uB9E1\uC73C\uB2C8\uAE4C \uBC31\uC791\uB2D8\uC774
      \uBCF4\uACE0 \uC2F6\uC5B4."
  _nemoLine: "\uCE5C\uAD6C\uBD84\uC774 \uC8FC\uC778\uB2D8\uC744 \uC704\uD574 \uC9C1\uC811
    \uB9CC\uB4E0 \uCC45\uAC08\uD53C\uC640 \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
