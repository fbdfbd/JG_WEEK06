  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_external_princess_news_direct__step_week_008_external_princess_news_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC655\uB140 \uD53C\uC2E0 \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "\uC655\uB140 \uD53C\uC2E0 \uC18C\uBB38 - \uD5C8\uB77D \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC218\uB3C4\uC5D0\uC11C\uB294 \uC0AC\uB77C\uC9C4 \uC655\uB140\uC758
      \uD589\uBC29\uC744 \uB450\uACE0 \uC5EC\uB7EC \uB9D0\uC774 \uC624\uAC00\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC815\uB9D0 \uC5B4\uB514 \uC228\uC5B4 \uACC4\uC2E0 \uAC78\uAE4C?"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC815\uBCC0 \uB4A4\uB77C \uC18C\uBB38\uC774 \uB354 \uCEE4\uC84C\uC9C0\uB9CC,
      \uB204\uAD70\uAC00\uB294 \uBCF4\uD638\uBC1B\uACE0 \uC788\uB2E4\uACE0\uB3C4
      \uD558\uACE0 \uB204\uAD70\uAC00\uB294 \uB3C4\uB9DD\uCCE4\uB2E4\uACE0\uB3C4
      \uD558\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uC57C\uAE30\uCC98\uB7FC \uB4E4\uB9AC\uC9C0\uB9CC, \uC9C4\uC9DC
      \uC0AC\uB78C \uC77C\uC774\uB77C \uB354 \uC870\uC2EC\uD574\uC57C\uACA0\uB124."
  _nemoLine: "\uC218\uB3C4\uC5D0\uC11C\uB294 \uC0AC\uB77C\uC9C4 \uC655\uB140\uC758
    \uD589\uBC29\uC744 \uB450\uACE0 \uC5EC\uB7EC \uB9D0\uC774 \uC624\uAC00\uACE0
    \uC788\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
