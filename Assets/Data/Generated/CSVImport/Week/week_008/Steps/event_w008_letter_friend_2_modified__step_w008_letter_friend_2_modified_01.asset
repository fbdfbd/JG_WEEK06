  m_Name: event_w008_letter_friend_2_modified__step_w008_letter_friend_2_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 \uD3B8\uC9C0 8\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uC870\uAE08 \uB450\uAEBC\uC6B4 \uD3B8\uC9C0\uB97C
    \uB4E4\uACE0 \uC628\uB2E4. \uC548\uC5D0\uB294 \uBE73\uBE73\uD558\uAC8C \uB9D0\uB9B0
    \uAF43\uC78E \uCC45\uAC08\uD53C\uAC00 \uB4E4\uC5B4 \uC788\uB2E4.)\r\n       
    \r\n\r\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC8FC\uC778\uB2D8\uC758
    \uD488\uACA9 \uC788\uB294 \uBAA8\uC2B5\uC774 \uC774\uBBF8 \uBC31\uC791\uB2D8\uC744
    \uB2EE\uC558\uB2E4\uACE0 \uCE6D\uCC2C\uD588\uC2B5\uB2C8\uB2E4.\r\n        \uB124\uBAA8
    : \uC9C4\uC9DC? \uB098 \uBC31\uC791\uB2D8 \uB2EE\uC558\uC5B4?\r\n        \uD558\uB140
    : \uB124. \uC0AC\uCD0C 1\uC758 \uC774\uAC04\uC9C8\uC5D0\uB3C4 \uD754\uB4E4\uB9AC\uC9C0
    \uC54A\uB294 \uC8FC\uC778\uB2D8\uC758 \uCC28\uBD84\uD568\uC774 \uC9C4\uC815\uD55C
    \uADC0\uC871\uC758 \uBAA8\uC2B5\uC774\uB77C\uACE0 \uD558\uB124\uC694.\r\n       
    \uB124\uBAA8 : \uD788\uD788, \uAC54\uD55C\uD14C \uCE6D\uCC2C\uBC1B\uC73C\uB2C8\uAE4C
    \uC9C4\uC9DC \uAE30\uBD84 \uC88B\uB2E4."
