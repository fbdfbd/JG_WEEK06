  _titleOverride: basement Direct
  _bodyText: "excursion basement Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uB9AC \uC544\uBC84\uC9C0\uB3C4 \uBAA8\uB974\uAC8C \uC9D0\uC744
      \uB4E4\uC5EC\uB1A8\uB2E4\uACE0? \uC774 \uC548\uC5D0 \uBB50\uAC00 \uB4E4\uC5C8\uAE38\uB798?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uC1E0\uAC00 \uBD80\uB52A\uCE58\uB294 \uC18C\uB9AC\uAC00 \uB0AC\uB2E4\uB294
      \uB9D0\uB3C4 \uC788\uACE0... \uBB34\uAE30\uB77C\uB294 \uC18C\uBB38\uB3C4 \uB3CC\uC544\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC0C1\uC790\uB97C \uCC28\uAC11\uAC8C \uB178\uB824\uBCF4\uBA70) \uC6B0\uB9AC
      \uC800\uD0DD\uC758 \uC2EC\uC7A5\uBD80\uB098 \uB2E4\uB984\uC5C6\uB294 \uC9C0\uD558\uC2E4\uC5D0
      \uBB34\uAE30\uB97C \uC228\uACA8\uB46C? \uB2F9\uC7A5 \uC544\uBC84\uB2D8\uAED8
      \uB9D0\uC500\uB4DC\uB824\uC57C\uACA0\uC5B4."
  _nemoLine: "\uC6B0\uB9AC \uC544\uBC84\uC9C0\uB3C4 \uBAA8\uB974\uAC8C \uC9D0\uC744
    \uB4E4\uC5EC\uB1A8\uB2E4\uACE0? \uC774 \uC548\uC5D0 \uBB50\uAC00 \uB4E4\uC5C8\uAE38\uB798?"
