--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_economics_blocked__step_event_week_008_economics_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCD1D\uC561\uBCF4\uB2E4 \uD56D\uBAA9\uBD80\uD130 \uB098\uB208\uB2E4"
  _bodyText: "\uD654\uD3D0 \uACBD\uC81C\uC640 \uD68C\uACC4 \uAE30\uCD08 8\uC8FC\uCC28
    Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC11C\uC7AC. \uC7A5\uBD80 \uD55C \uAD8C\uACFC \uC8FC\uD654, \uC601\uC218\uC99D
      \uBB36\uC74C\uC774 \uB193\uC5EC \uC788\uB2E4. \uBE44\uC11C\uB294 \uB3C8\uC758
      \uC591\uBCF4\uB2E4 \uD750\uB984\uC744 \uBA3C\uC800 \uBCF4\uB77C\uACE0 \uB9D0\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uB3C8\uC774 \uB9CE\uACE0 \uC801\uC74C\uC744
      \uBCF4\uB294 \uB0A0\uC774 \uC544\uB2C8\uB77C, \uC5B4\uB514\uC11C \uB4E4\uC5B4\uC624\uACE0
      \uC5B4\uB514\uB85C \uB098\uAC00\uB294\uC9C0 \uBCF4\uB294 \uB0A0\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC22B\uC790\uBCF4\uB2E4 \uAE38\uC744 \uBCF4\uB77C\uB294 \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uB124. \uC798 \uC544\uC168\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uC7A5\uBD80\uB97C \uD3BC\uCCD0 \uD56D\uBAA9\uC744
      \uC190\uAC00\uB77D\uC73C\uB85C \uC9DA\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uCD1D\uC561\uB9CC \uBCF4\uC9C0 \uB9C8\uC2ED\uC2DC\uC624. \uD56D\uBAA9\uC744
      \uB098\uB220 \uBCF4\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uCD1D\uC561\uC774 \uC81C\uC77C \uB208\uC5D0 \uB744\uB294\uB370."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uADF8\uB798\uC11C \uC18D\uAE30 \uC27D\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uADF8\uAC74 \uC880 \uC2EB\uB124."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uADF8\uB7FC \uB354 \uC790\uC138\uD788 \uBCF4\uC154\uC57C\uC9C0\uC694."
  _nemoLine: "(\uC11C\uC7AC. \uC7A5\uBD80 \uD55C \uAD8C\uACFC \uC8FC\uD654, \uC601\uC218\uC99D
    \uBB36\uC74C\uC774 \uB193\uC5EC \uC788\uB2E4. \uBE44\uC11C\uB294 \uB3C8\uC758
    \uC591\uBCF4\uB2E4 \uD750\uB984\uC744 \uBA3C\uC800 \uBCF4\uB77C\uACE0 \uB9D0\uD55C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
