  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_house_talk_forest_rumor_direct__step_week_008_house_talk_forest_rumor_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBE44\uADF9\uC758 \uC232 \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "\uBE44\uADF9\uC758 \uC232 \uC18C\uBB38 - \uD5C8\uB77D \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: ea8bb1cd384c18f4c83d6f267d5433b5, type: 2}
    _text: "\uBE44\uADF9\uC758 \uC232 \uAC00\uC7A5\uC790\uB9AC\uC5D0\uC11C \uBC24\uB9C8\uB2E4
      \uB204\uAC00 \uB178\uB798\uD558\uB294 \uC18C\uB9AC\uAC00 \uB4E4\uB9B0\uB2E4\uB294
      \uB9D0\uC774 \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC0AC\uB78C\uC774\uC57C? \uC544\uB2C8\uBA74 \uC9C4\uC9DC \uC232\uC774
      \uC6B0\uB294 \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: 382a01f86413cfc439d75f63e427a411, type: 2}
    _text: "\uC783\uC5B4\uBC84\uB9B0 \uC0AC\uB78C\uB4E4\uC758 \uB9C8\uC74C\uC774
      \uB0A8\uC740 \uAC70\uB77C \uB9D0\uD558\uB294 \uC774\uB3C4 \uC788\uACE0, \uBC14\uB78C\uC774
      \uB098\uBB47\uC78E\uC744 \uC2A4\uCE58\uB294 \uC18C\uB9AC\uB77C\uACE0 \uD558\uB294
      \uC774\uB3C4 \uC788\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC2AC\uD504\uB124... \uADF8\uB798\uB3C4 \uC544\uBB34 \uC774\uC720 \uC5C6\uC774
      \uBB34\uC11C\uC6B4 \uAC74 \uC544\uB2C8\uAD6C\uB098."
  _nemoLine: "\uBE44\uADF9\uC758 \uC232 \uAC00\uC7A5\uC790\uB9AC\uC5D0\uC11C \uBC24\uB9C8\uB2E4
    \uB204\uAC00 \uB178\uB798\uD558\uB294 \uC18C\uB9AC\uAC00 \uB4E4\uB9B0\uB2E4\uB294
    \uB9D0\uC774 \uC788\uC5B4\uC694."
