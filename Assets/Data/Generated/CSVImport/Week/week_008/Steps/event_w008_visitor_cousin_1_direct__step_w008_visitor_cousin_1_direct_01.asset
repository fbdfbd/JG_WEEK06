  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_visitor_cousin_1_direct__step_w008_visitor_cousin_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 8\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uC0AC\uCD0C 1\uC774 \uC11C\uC7AC \uCC3D\uBB38\uC744 \uAC70\uCE60\uAC8C
    \uC5F4\uACE0 \uC800 \uBA40\uB9AC \uC5B4\uB450\uC6B4 \uC232\uC744 \uAC00\uB9AC\uD0A8\uB2E4.
    \uC720\uB144\uAE30\uC5D0\uB294 \uC591\uAF2C\uCE58\uB97C \uB9D0\uD558\uB358 \uADF8
    \uC785\uC5D0\uC11C \uC774\uC81C\uB294 \uC794\uC778\uD55C \uD3ED\uB85C\uAC00 \uD758\uB7EC\uB098\uC628\uB2E4.)\uC0AC\uCD0C
    1 : \uC800\uAE30 \uC232 \uBCF4\uC774\uC9C0? \uBC31\uC791\uB2D8\uC774 \"\uC704\uD5D8\uD558\uB2C8
    \uC808\uB300 \uAC00\uC9C0 \uB9C8\uB77C\"\uACE0 \uC2E0\uC2E0\uB2F9\uBD80\uD558\uB358
    \uACF3. \uAC70\uAE30\uAC00 \uB124 \uBD80\uBAA8\uB2D8\uC758 \uB9C8\uCC28\uAC00
    \uC804\uBCF5\uB41C \uACF3\uC774\uC57C. \uADFC\uB370 \uC6C3\uAE30\uC9C0 \uC54A\uC544?
    \uADF8\uB0A0 \uBC31\uC791\uB2D8\uC758 \uAE30\uC0AC\uB2E8\uC774 \uB531 \uADF8
    \uAE38\uBAA9\uC744 \uC9C0\uD0A4\uACE0 \uC788\uC5C8\uAC70\uB4E0. \uADFC\uB370
    \uC65C \uAD6C\uC870 \uC18C\uC2DD\uC740 \uC5C6\uC5C8\uC744\uAE4C?\r\n        \uB124\uBAA8
    : (\uCC3D\uD2C0\uC744 \uAF49 \uC6C0\uCF1C\uC950\uBA70) \uADF8\uB9CC\uD574\uC694.
    \uBC31\uC791\uB2D8\uC774 \uADF8\uB7F4 \uB9AC \uC5C6\uC5B4. \uADF8\uBD84\uC740
    \uB098\uB97C \uC704\uD574 \uD3C9\uC0DD\uC744 \uBC14\uCE58\uC168\uB2E8 \uB9D0\uC774\uC57C!\r\n       
    \r\n\r\n- (\uB124\uBAA8\uAC00 \uC0AC\uCD0C 1\uC758 \uBA71\uC0B4\uC774\uB77C\uB3C4
    \uC7A1\uC744 \uB4EF \uB2E4\uAC00\uAC00 \uCC28\uAC11\uAC8C \uBB3B\uB294\uB2E4.)\r\n       
    - \uB124\uBAA8 : \uC0BC\uCD0C\uC774 \uC6D0\uD558\uB294 \uAC8C \uC774\uAC70\uC608\uC694?
    \uB0B4\uAC00 \uBC31\uC791\uB2D8\uC744 \uC758\uC2EC\uD558\uAC8C \uB9CC\uB4DC\uB294
    \uAC70? \uADF8\uB798\uC11C \uAC00\uBB38\uC744 \uD1B5\uC9F8\uB85C \uC0BC\uD0A4\uB824\uACE0?\r\n       
    \uC0AC\uCD0C 1 : \uB09C \uADF8\uC800 \uB124\uAC00 \uBC14\uBCF4\uB85C \uC0AC\uB294
    \uAC8C \uC548\uD0C0\uAE4C\uC6B8 \uBFD0\uC774\uC57C. \uBC31\uC791\uC774 \uB110
    \uC774 \uC11C\uC7AC\uC5D0 \uAC00\uB46C\uB454 \uAC74 \uB110 \uC0AC\uB791\uD574\uC11C\uAC00
    \uC544\uB2C8\uB77C, \uB124\uAC00 \uC9C4\uC2E4\uC744 \uBCF4\uACE0 \uADF8\uBD84\uC744
    \uC6D0\uB9DD\uD560\uAE4C \uBD10 \uAC81\uC774 \uB098\uC11C\uB77C\uACE0.\r\n       
    \uB124\uBAA8 : (\uB208\uC744 \uAC00\uB298\uAC8C \uB728\uBA70) \uB9CC\uC57D \uBC31\uC791\uB2D8\uC774
    \uB098\uB97C \uC18D\uC778 \uAC70\uB77C\uBA74, \uB0B4\uAC00 \uADF8\uBD84\uC744
    \uBB34\uB108\uB728\uB9B4 \uAC70\uC608\uC694. \uC0BC\uCD0C \uAC19\uC740 \uC778\uAC04\uC5D0\uAC8C
    \uAE30\uD68C\uB97C \uC8FC\uC9C0\uB294 \uC54A\uC744 \uAC70\uB2C8\uAE4C \uAFC8
    \uAE68\uC138\uC694."
