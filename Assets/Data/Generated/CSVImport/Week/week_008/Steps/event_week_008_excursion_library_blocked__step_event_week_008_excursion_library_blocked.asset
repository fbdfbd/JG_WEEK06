  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_excursion_library_blocked__step_event_week_008_excursion_library_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 \uD1B5\uC81C"
  _bodyText: "excursion library Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uC11C\uB958\uB97C \uB09A\uC544\uCC44
      \uC11C\uB78D \uC548\uC5D0 \uB123\uACE0 \uC5F4\uC1E0\uB85C \uC7A0\uAC00\uBC84\uB9B0\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC601\uC9C0\uC758 \uD589\uC815 \uC808\uCC28\uB294 \uC544\uAC00\uC528\uAED8\uC11C
      \uAD00\uC5EC\uD558\uC2E4 \uB2E8\uACC4\uAC00 \uC544\uB2D9\uB2C8\uB2E4. \uC0AC\uCD0C
      1\uB2D8\uC740 \uBC31\uC791\uB2D8\uC744 \uB3D5\uACE0 \uACC4\uC2E0 \uAC83\uBFD0\uC774\uB2C8,
      \uC758\uC2EC\uC744 \uD0A4\uC6B0\uC9C0 \uB9C8\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB3D5\uB294 \uAC83\uCE58\uACE0\uB294 \uB108\uBB34 \uC740\uBC00\uD574
      \uBCF4\uC5EC\uC694. \uC65C \uC6B0\uB9AC \uAC00\uBB38\uC758 \uC624\uB798\uB41C
      \uAD8C\uB9AC \uC99D\uC11C\uB4E4\uC744 \uADF8\uBD84\uC774 \uC0B4\uD3B4\uBCF4\uACE0
      \uACC4\uC2E0 \uAC70\uC8E0?"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "(\uCC28\uAC11\uAC8C) \uB108\uBB34 \uB9CE\uC740 \uAC83\uC744 \uC544\uB294
      \uAC83\uC740 \uB3C5\uC774 \uB429\uB2C8\uB2E4. \uC544\uAC00\uC528\uB294 \uADF8\uC800
      \uC601\uC560\uB85C\uC11C\uC758 \uD488\uC704\uB9CC \uC9C0\uD0A4\uC2DC\uBA74
      \uB429\uB2C8\uB2E4."
  _nemoLine: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uC11C\uB958\uB97C \uB09A\uC544\uCC44
    \uC11C\uB78D \uC548\uC5D0 \uB123\uACE0 \uC5F4\uC1E0\uB85C \uC7A0\uAC00\uBC84\uB9B0\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
