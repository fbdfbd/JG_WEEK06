  m_Name: event_w008_excursion_lake_blocked__step_w008_excursion_lake_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 8\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uD638\uC218 \uAC74\uB108\uD3B8 \uC232\uAE38. \uD3C9\uC18C\uC5D4 \uBCF4\uC774\uC9C0
    \uC54A\uB358 \uAC80\uC740 \uC637\uC758 \uC0AC\uB0B4\uB4E4\uC774 \uC9C0\uB3C4\uB97C
    \uD3BC\uCCD0\uB193\uACE0 \uD638\uC218\uC758 \uC9C0\uD615\uC744 \uC0B4\uD53C\uACE0
    \uC788\uB2E4.)\n        \uD558\uB140 1 : \uC5B4\uBA38, \uC800 \uC0AC\uB78C\uB4E4\uC740
    \uB204\uAD6C\uC8E0? \uC6B0\uB9AC \uC800\uD0DD \uC0AC\uB78C\uC774 \uC544\uB2CC
    \uAC83 \uAC19\uC740\uB370...\n        \uD558\uB140 2 : \uC27F, \uC0AC\uCD0C 1\uB2D8\uC774
    \uBCF4\uB0B8 \uCE21\uB7C9\uC0AC\uB4E4\uC774\uB798\uC694. \uD638\uC218 \uADFC\uCC98\uC5D0
    \uBCC4\uC7A5\uC744 \uC9C0\uC744 \uACC4\uD68D\uC774\uB77C\uB358\uB370...\n       
    \n\n(\uACBD\uBE44\uB300\uC7A5\uC774 \uB124\uBAA8\uC758 \uC2DC\uC57C\uB97C \uAC00\uB85C\uB9C9\uC73C\uBA70
    \uBAB8\uC744 \uB3CC\uB9AC\uAC8C \uD55C\uB2E4.)\n        \uACBD\uBE44\uB300\uC7A5
    : \uC190\uB2D8\uB4E4\uC758 \uC0AC\uC18C\uD55C \uC5C5\uBB34\uC77C \uBFD0\uC785\uB2C8\uB2E4.
    \uC548\uC8FC\uC778\uC774 \uB418\uC2E4 \uBD84\uC774 \uC678\uBD80\uC778\uC5D0\uAC8C
    \uD568\uBD80\uB85C \uC2DC\uC120\uC744 \uC8FC\uB294 \uAC83\uC740 \uC88B\uC9C0
    \uC54A\uC2B5\uB2C8\uB2E4. \uCF54\uC2A4\uB97C \uBCC0\uACBD\uD558\uACA0\uC2B5\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uBCC4\uC7A5\uC774\uB77C\uB1E8? \uC544\uBC84\uC9C0\uB294 \uADF8\uB7F0
    \uB9D0\uC500 \uC5C6\uC73C\uC168\uC796\uC544\uC694. \uC5EC\uAE34 \uB0B4 \uC0B0\uCC45\uB85C\uC778\uB370!\n       
    \uACBD\uBE44\uB300\uC7A5 : (\uC5C4\uD558\uAC8C) \uACB0\uC815\uB41C \uAC83\uC740
    \uC544\uBB34\uAC83\uB3C4 \uC5C6\uC2B5\uB2C8\uB2E4. \uBD88\uD544\uC694\uD55C \uC18C\uBB38\uC5D0
    \uD754\uB4E4\uB9AC\uC9C0 \uB9C8\uC2ED\uC2DC\uC624."
