  _titleOverride: "\uBE44\uADF9\uC758 \uC232 \uC18C\uBB38 - \uD1B5\uC81C"
  _bodyText: "\uBE44\uADF9\uC758 \uC232 \uC18C\uBB38 - \uD1B5\uC81C \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBE44\uADF9\uC758 \uC232\uC5D0\uC11C \uB178\uB7AB\uC18C\uB9AC\uAC00
      \uB4E4\uB9B0\uB2E4\uB294 \uB9D0\uC740 \uB124\uBAA8 \uC55E\uC5D0\uC11C \uB354
      \uD0A4\uC6B0\uC9C0 \uC54A\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC232 \uC774\uC57C\uAE30 \uB610 \uC788\uC5C8\uC5B4\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBD88\uAE38\uD55C \uC5EC\uC6B4\uC774 \uB0A8\uC9C0 \uC54A\uAC8C, \uBC14\uB78C
      \uC18C\uB9AC\uAC00 \uC0AC\uB78C \uADC0\uC5D0 \uB2E4\uB974\uAC8C \uB4E4\uB9B4
      \uBFD0\uC774\uB77C\uACE0\uB9CC \uC815\uB9AC\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uAD1C\uD788 \uC0C1\uC0C1 \uC548 \uD574\uB3C4 \uB418\uACA0\uB2E4."
  _nemoLine: "(\uBE44\uADF9\uC758 \uC232\uC5D0\uC11C \uB178\uB7AB\uC18C\uB9AC\uAC00
    \uB4E4\uB9B0\uB2E4\uB294 \uB9D0\uC740 \uB124\uBAA8 \uC55E\uC5D0\uC11C \uB354
    \uD0A4\uC6B0\uC9C0 \uC54A\uB294\uB2E4.)"
