  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_visitor_friend_3_direct__step_w008_visitor_friend_3_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 8\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uB124\uBAA8\uC640 \uCE5C\uAD6C 3\uC774 \uC11C\uC7AC \uBCBD\uC5D0
    \uAC78\uB9B0 \uC601\uC9C0 \uC9C0\uB3C4\uB97C \uBCF4\uACE0 \uC788\uB2E4. \uCE5C\uAD6C
    3\uC740 \uBC31\uC791\uB2D8\uC774 \uCCA0\uC800\uD558\uAC8C \uAD00\uB9AC\uD558\uB294
    \uC601\uC9C0 \uACF3\uACF3\uC758 '\uC228\uC740 \uBA85\uC18C'\uB4E4\uC744 \uC190\uAC00\uB77D\uC73C\uB85C
    \uC9DA\uC5B4\uC900\uB2E4.)\r\n        \r\n        \uCE5C\uAD6C 3 : \uB124\uBAA8\uC57C,
    \uBC31\uC791\uB2D8\uC774 \uC5EC\uAE30 \uC232\uC774\uB791 \uACC4\uACE1\uC744 \uC65C
    \uC774\uB807\uAC8C \uC5C4\uACA9\uD558\uAC8C \uD1B5\uC81C\uD558\uC2DC\uB294\uC9C0
    \uC54C\uC544? \uC608\uC804\uC5D0 \uC0AC\uACE0\uAC00 \uC788\uC5C8\uB2E4\uACE0\uB294
    \uD558\uC9C0\uB9CC, \uC0AC\uC2E4\uC740 \uC774\uACF3\uC758 \uC0DD\uD0DC\uACC4\uB97C
    \uBCF4\uC874\uD574\uC11C \uB098\uC911\uC5D0 \uB124\uAC00 \uBB3C\uB824\uBC1B\uC558\uC744
    \uB54C \uAC00\uC7A5 \uC544\uB984\uB2E4\uC6B4 \uC0C1\uD0DC\uB85C \uC8FC\uB824\uACE0
    \uD558\uC2DC\uB294 \uAC70\uB798. \uC6B0\uB9AC \uC544\uBE60\uAC00 \uADF8\uB7EC\uC2DC\uB354\uB77C.\r\n       
    \r\n\r\n- (\uB124\uBAA8\uAC00 \uC9C0\uB3C4 \uC704\uC5D0 \uC791\uC740 \uBCC4\uD45C\uB97C
    \uD45C\uC2DC\uD55C\uB2E4.)\r\n        - \uB124\uBAA8 : \uADF8\uB7FC \uC815\uD588\uC5B4!
    \uC131\uC778\uC2DD \uC774\uD6C4 \uB0B4 \uCCAB \uBC88\uC9F8 \uD589\uBCF4\uB294
    \uC774\uACF3\uC744 \uC601\uC9C0\uBBFC\uB4E4\uC5D0\uAC8C \uAC1C\uBC29\uD558\uB294
    \uAC70\uC57C. \uBC31\uC791\uB2D8\uC774 \uC798 \uAC00\uAFB8\uC5B4\uB193\uC73C\uC2E0
    \uC774 \uC790\uC5F0\uC744 \uBAA8\uB450\uAC00 \uB204\uB9AC\uAC8C \uD558\uB294
    \uAC70\uC9C0. \uB124\uAC00 \uB0B4 \uAE38\uC548\uB0B4\uB97C \uB9E1\uC544\uC918!\r\n       
    \uCE5C\uAD6C 3 : \uC624! \uADF8\uAC70 \uC815\uB9D0 \uB05D\uB0B4\uC8FC\uB294 \uC0DD\uAC01\uC778\uB370?
    \uBC31\uC791\uB2D8\uB3C4 \uB124\uAC00 \uC601\uC9C0\uBBFC\uB4E4\uC744 \uC0DD\uAC01\uD558\uB294
    \uB9C8\uC74C\uC744 \uBCF4\uC2DC\uBA74 \uAE5C\uC9DD \uB180\uB77C\uBA70 \uCE6D\uCC2C\uD574
    \uC8FC\uC2E4 \uAC70\uC57C!"
