  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_visitor_friend_3_blocked__step_w008_visitor_friend_3_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 8\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uB124\uBAA8\uC640 \uCE5C\uAD6C 3\uC774 \uC11C\uC7AC \uBCBD\uC5D0
    \uAC78\uB9B0 \uC601\uC9C0 \uC9C0\uB3C4\uB97C \uBCF4\uACE0 \uC788\uB2E4. \uCE5C\uAD6C
    3\uC740 \uBC31\uC791\uB2D8\uC774 \uCCA0\uC800\uD558\uAC8C \uAD00\uB9AC\uD558\uB294
    \uC601\uC9C0 \uACF3\uACF3\uC758 '\uC228\uC740 \uBA85\uC18C'\uB4E4\uC744 \uC190\uAC00\uB77D\uC73C\uB85C
    \uC9DA\uC5B4\uC900\uB2E4.)\n        \n        \uCE5C\uAD6C 3 : \uB124\uBAA8\uC57C,
    \uBC31\uC791\uB2D8\uC774 \uC5EC\uAE30 \uC232\uC774\uB791 \uACC4\uACE1\uC744 \uC65C
    \uC774\uB807\uAC8C \uC5C4\uACA9\uD558\uAC8C \uD1B5\uC81C\uD558\uC2DC\uB294\uC9C0
    \uC54C\uC544? \uC608\uC804\uC5D0 \uC0AC\uACE0\uAC00 \uC788\uC5C8\uB2E4\uACE0\uB294
    \uD558\uC9C0\uB9CC, \uC0AC\uC2E4\uC740 \uC774\uACF3\uC758 \uC0DD\uD0DC\uACC4\uB97C
    \uBCF4\uC874\uD574\uC11C \uB098\uC911\uC5D0 \uB124\uAC00 \uBB3C\uB824\uBC1B\uC558\uC744
    \uB54C \uAC00\uC7A5 \uC544\uB984\uB2E4\uC6B4 \uC0C1\uD0DC\uB85C \uC8FC\uB824\uACE0
    \uD558\uC2DC\uB294 \uAC70\uB798. \uC6B0\uB9AC \uC544\uBE60\uAC00 \uADF8\uB7EC\uC2DC\uB354\uB77C.\n       
    \n\n- (\uB124\uBAA8\uAC00 \uC9C0\uB3C4\uC758 \uC232 \uBD80\uBD84\uC744 \uC815\uC911\uD558\uAC8C
    \uC190\uC73C\uB85C \uC4F8\uC5B4\uB0B4\uB9B0\uB2E4.)\n        - \uB124\uBAA8 :
    \uC0AC\uCD0C 1\uC740 \uC5EC\uAE30\uAC00 \uBE44\uADF9\uC758 \uC7A5\uC18C\uB77C\uACE0
    \uD588\uC9C0\uB9CC, \uBC31\uC791\uB2D8\uC740 \uC774\uACF3\uC744 \uBBF8\uB798\uC758
    \uC720\uC0B0\uC73C\uB85C \uC9C0\uD0A4\uACE0 \uACC4\uC168\uB358 \uAC70\uAD6C\uB098.
    \uB098\uB97C \uC704\uD574 \uADF8 \uC624\uB79C \uC2DC\uAC04 \uB3D9\uC548 \uBE44\uB09C\uC744
    \uAC10\uC218\uD558\uBA74\uC11C\uAE4C\uC9C0 \uB9D0\uC774\uC57C.\n        \uCE5C\uAD6C
    3 : \uB9DE\uC544! \uBC31\uC791\uB2D8\uC740 \uC815\uB9D0 \uC18D\uC774 \uAE4A\uC73C\uC2E0
    \uBD84\uC774\uB77C\uB2C8\uAE4C. \uB10C \uADF8\uB7F0 \uBC31\uC791\uB2D8\uC758
    \uC758\uC9C0\uB97C \uC774\uC5B4\uBC1B\uC744 \uC790\uACA9\uC774 \uCDA9\uBD84\uD574."
