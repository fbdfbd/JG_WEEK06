%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_law_modified__step_event_week_008_law_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB2E4\uD23C\uC758 \uC2DC\uC791\uC810\uC5D0\uC11C \uBC95\uC744
    \uBCF8\uB2E4"
  _bodyText: "\uC81C\uAD6D\uBC95\uACFC \uC601\uC9C0 \uD589\uC815 8\uC8FC\uCC28 Modified
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC11C\uC7AC. \uBE44\uC11C\uAC00 \uC587\uC740 \uD310\uB840 \uBB36\uC74C\uACFC
      \uC601\uC9C0 \uBBFC\uC6D0 \uAE30\uB85D \uBA87 \uC7A5\uC744 \uCC45\uC0C1 \uC704\uC5D0
      \uD3BC\uCCD0 \uB454\uB2E4. \uB0B4\uC6A9\uC740 \uBC2D \uACBD\uACC4 \uB2E4\uD23C,
      \uC6B0\uBB3C \uC0AC\uC6A9 \uC21C\uC11C, \uAC00\uCD95 \uD53C\uD574 \uAC19\uC740
      \uBE44\uAD50\uC801 \uC791\uC740 \uBD84\uC7C1\uB4E4\uC774\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uBC95 \uC870\uBB38 \uC790\uCCB4\uBCF4\uB2E4
      \uB204\uAC00 \uBB34\uC5C7 \uB54C\uBB38\uC5D0 \uB2E4\uD22C\uC5C8\uB294\uC9C0
      \uBA3C\uC800 \uBCF4\uB294 \uB0A0\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uACB0\uAD6D \uB2E4\uB4E4 \uC790\uAE30 \uB9D0\uC774 \uB9DE\uB2E4\uACE0
      \uD558\uACA0\uC9C0."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uB124. \uADF8\uB798\uC11C \uAE30\uB85D\uC774 \uD544\uC694\uD558\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBE44\uC11C\uAC00 \uC601\uC9C0 \uC9C0\uB3C4\uB97C \uD3BC\uCE58\uACE0
      \uCABD\uC9C0 \uBA87 \uC7A5\uC744 \uC62C\uB824 \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC870\uBB38\uBD80\uD130 \uC678\uC6B0\uAE30\uBCF4\uB2E4, \uC774 \uB2E4\uD23C\uC774
      \uC5B4\uB514\uC11C \uC2DC\uC791\uB410\uB294\uC9C0 \uBA3C\uC800 \uC9DA\uC5B4
      \uBCFC\uAE4C\uC694?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC704\uCE58\uB791 \uC774\uC720\uBD80\uD130?"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uB124. \uADF8\uB7EC\uBA74 \uADDC\uCE59\uC774 \uC65C \uD544\uC694\uD55C\uC9C0\uB3C4
      \uAC19\uC774 \uBCF4\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544. \uADF8\uB7FC \uBC95\uC774 \uC0AC\uB78C \uBC14\uAE65\uC5D0 \uB5A0
      \uC788\uB294 \uAC8C \uC544\uB2C8\uB124."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uB9DE\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uC0DD\uAC01\uBCF4\uB2E4 \uAD1C\uCC2E\uB2E4."
  _nemoLine: "(\uC11C\uC7AC. \uBE44\uC11C\uAC00 \uC587\uC740 \uD310\uB840 \uBB36\uC74C\uACFC
    \uC601\uC9C0 \uBBFC\uC6D0 \uAE30\uB85D \uBA87 \uC7A5\uC744 \uCC45\uC0C1 \uC704\uC5D0
    \uD3BC\uCCD0 \uB454\uB2E4. \uB0B4\uC6A9\uC740 \uBC2D \uACBD\uACC4 \uB2E4\uD23C,
    \uC6B0\uBB3C \uC0AC\uC6A9 \uC21C\uC11C, \uAC00\uCD95 \uD53C\uD574 \uAC19\uC740
    \uBE44\uAD50\uC801 \uC791\uC740 \uBD84\uC7C1\uB4E4\uC774\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
