  _titleOverride: "\uBC95\uB960 \uC218\uC5C5\uC744 \uC0AC\uB840 \uC911\uC2EC\uC73C\uB85C
    \uD47C\uB2E4"
  _bodyText: "\uBC95\uB960 \uC218\uC5C5\uC744 \uC0AC\uB840 \uC911\uC2EC\uC73C\uB85C
    \uD47C\uB2E4 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB531\uB531\uD55C \uC870\uBB38 \uB300\uC2E0 \uC26C\uC6B4 \uC0AC\uB840\uB97C
      \uB4E4\uC5B4 \uBC95\uC758 \uB73B\uC744 \uC774\uD574\uC2DC\uD0A4\uB824 \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB204\uAD6C \uB9D0\uC774 \uB354 \uB9DE\uB294\uC9C0 \uB530\uC838
      \uBCF4\uB294 \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uC2E4\uC81C\uCC98\uB7FC \uB290\uAEF4\uC9C0\uB294 \uC608\uC2DC\uB97C
      \uBD99\uC5EC \uBC95\uC758 \uD750\uB984\uC744 \uC7A1\uAC8C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uB807\uAC8C \uB4E4\uC73C\uB2C8\uAE4C \uD6E8\uC52C \uC54C\uC544\uB4E3\uACA0\uC5B4."
  _nemoLine: "(\uB531\uB531\uD55C \uC870\uBB38 \uB300\uC2E0 \uC26C\uC6B4 \uC0AC\uB840\uB97C
    \uB4E4\uC5B4 \uBC95\uC758 \uB73B\uC744 \uC774\uD574\uC2DC\uD0A4\uB824 \uD55C\uB2E4.)"
