  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_visitor_cousin_1_blocked__step_w008_visitor_cousin_1_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 8\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uC0AC\uCD0C 1\uC774 \uC11C\uC7AC \uCC3D\uBB38\uC744 \uAC70\uCE60\uAC8C
    \uC5F4\uACE0 \uC800 \uBA40\uB9AC \uC5B4\uB450\uC6B4 \uC232\uC744 \uAC00\uB9AC\uD0A8\uB2E4.
    \uC720\uB144\uAE30\uC5D0\uB294 \uC591\uAF2C\uCE58\uB97C \uB9D0\uD558\uB358 \uADF8
    \uC785\uC5D0\uC11C \uC774\uC81C\uB294 \uC794\uC778\uD55C \uD3ED\uB85C\uAC00 \uD758\uB7EC\uB098\uC628\uB2E4.)\uC0AC\uCD0C
    1 : \uC800\uAE30 \uC232 \uBCF4\uC774\uC9C0? \uBC31\uC791\uB2D8\uC774 \"\uC704\uD5D8\uD558\uB2C8
    \uC808\uB300 \uAC00\uC9C0 \uB9C8\uB77C\"\uACE0 \uC2E0\uC2E0\uB2F9\uBD80\uD558\uB358
    \uACF3. \uAC70\uAE30\uAC00 \uB124 \uBD80\uBAA8\uB2D8\uC758 \uB9C8\uCC28\uAC00
    \uC804\uBCF5\uB41C \uACF3\uC774\uC57C. \uADFC\uB370 \uC6C3\uAE30\uC9C0 \uC54A\uC544?
    \uADF8\uB0A0 \uBC31\uC791\uB2D8\uC758 \uAE30\uC0AC\uB2E8\uC774 \uB531 \uADF8
    \uAE38\uBAA9\uC744 \uC9C0\uD0A4\uACE0 \uC788\uC5C8\uAC70\uB4E0. \uADFC\uB370
    \uC65C \uAD6C\uC870 \uC18C\uC2DD\uC740 \uC5C6\uC5C8\uC744\uAE4C?\r\n        \uB124\uBAA8
    : (\uCC3D\uD2C0\uC744 \uAF49 \uC6C0\uCF1C\uC950\uBA70) \uADF8\uB9CC\uD574\uC694.
    \uBC31\uC791\uB2D8\uC774 \uADF8\uB7F4 \uB9AC \uC5C6\uC5B4. \uADF8\uBD84\uC740
    \uB098\uB97C \uC704\uD574 \uD3C9\uC0DD\uC744 \uBC14\uCE58\uC168\uB2E8 \uB9D0\uC774\uC57C!\r\n       
    \r\n\r\n- (\uACBD\uBE44\uB300\uC7A5\uC774 \uB2E4\uAC00\uC640 \uCC3D\uBB38\uC744
    \uAC70\uCE60\uAC8C \uB2EB\uC73C\uBA70 \uC0AC\uCD0C 1\uC758 \uC55E\uC744 \uAC00\uB85C\uB9C9\uB294\uB2E4.)\r\n       
    - \uACBD\uBE44\uB300\uC7A5 : \uC8FC\uC778\uB2D8\uC758 \uB9C8\uC74C\uC744 \uC5B4\uC9C0\uB7FD\uD788\uB294
    \uC790\uB294 \uB204\uAD6C\uB4E0 \uC6A9\uC11C\uCE58 \uC54A\uACA0\uC2B5\uB2C8\uB2E4.
    \uB2F9\uC7A5 \uBB3C\uB7EC\uB098\uC2ED\uC2DC\uC624!\r\n        \uB124\uBAA8 :
    (\uB2EB\uD788\uB294 \uCC3D\uBB38\uC744 \uBCF4\uBA70 \uC18C\uB9AC\uCE5C\uB2E4)
    \uC65C \uB2E4\uB4E4 \uC228\uAE30\uAE30\uB9CC \uD574! \uC544\uC800\uC528\uB3C4
    \uADF8\uB0A0 \uAC70\uAE30 \uC788\uC5C8\uC8E0? \uC0BC\uCD0C \uB9D0\uC774 \uC0AC\uC2E4\uC774\uC5D0\uC694?
    \uC65C \uBC31\uC791\uB2D8\uC740 \uB0B4 \uC9C8\uBB38\uC5D0\uB294 \uB2F5\uD574\uC8FC\uC9C0
    \uC54A\uACE0 \uADDC\uCE59\uB9CC \uAC15\uC694\uD558\uB294 \uAC70\uB0D0\uACE0!\r\n       
    \uC0AC\uCD0C 1 : \uCBE7\uCBE7, \uC9C4\uC2E4\uC744 \uB9C8\uC8FC\uD560 \uC6A9\uAE30\uB3C4
    \uC5C6\uB294 \uAC81\uC7C1\uC774\uB4E4\uC774\uAD70."
