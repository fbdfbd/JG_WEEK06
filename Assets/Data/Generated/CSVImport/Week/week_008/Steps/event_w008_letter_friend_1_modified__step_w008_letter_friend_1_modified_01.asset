  m_Name: event_w008_letter_friend_1_modified__step_w008_letter_friend_1_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 8\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uB450\uD23C\uD55C \uBD09\uD22C\uB97C \uB4E4\uACE0
    \uC628\uB2E4. \uBD09\uD22C \uAC89\uC5D0 '\uACBD\uBE44\uB300\uC7A5\uB2D8 \uB208
    \uAC10\uC544!'\uB77C\uACE0 \uC544\uC8FC \uD06C\uAC8C \uC801\uD600 \uC788\uB2E4.)\n       
    \n\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC8FC\uC778\uB2D8\uC758
    \uC131\uC778\uC2DD\uC744 \uB204\uAD6C\uBCF4\uB2E4 \uCD95\uD558\uD558\uBA70 \uAE30\uB2E4\uB9AC\uACE0
    \uC788\uC2B5\uB2C8\uB2E4.\n        \uB124\uBAA8 : \uAC54\uAC00 \uBB50\uB77C\uACE0
    \uD588\uB294\uB370?\n        \uD558\uB140 : \uC774\uC81C \uC8FC\uC778\uB2D8\uC774
    \uC815\uC2DD \uD6C4\uACC4\uC790\uAC00 \uB418\uBA74, \uACBD\uBE44\uB300\uC7A5\uB2D8\uB3C4
    \uC8FC\uC778\uB2D8\uC758 \uB4E0\uB4E0\uD55C \uC544\uAD70\uC774 \uB420 \uAC70\uB798\uC694.
    \uADF8\uB7EC\uB2C8 \uB354 \uC774\uC0C1 \uC544\uC800\uC528\uB97C \uBB34\uC11C\uC6CC\uD558\uC9C0
    \uC54A\uC544\uB3C4 \uB41C\uB2E4\uACE0 \uD569\uB2C8\uB2E4.\n        \uB124\uBAA8
    : \uC624, \uADF8\uB7FC \uC774\uC81C \uC544\uC800\uC528\uB791 \uAC19\uC774 \uC601\uC9C0\uB97C
    \uC21C\uCC30\uD560 \uC218\uB3C4 \uC788\uACA0\uB124!"
