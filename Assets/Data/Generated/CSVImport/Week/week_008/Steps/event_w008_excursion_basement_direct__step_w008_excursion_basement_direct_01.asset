  m_Name: event_w008_excursion_basement_direct__step_w008_excursion_basement_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 8\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uC640\uC778 \uC800\uC7A5\uACE0 \uB108\uBA38, \uD3C9\uC18C\uC5D4 \uBE44\uC5B4\uC788\uB358
    \uAD6C\uC5ED\uC5D0 \uC544\uBB34\uB7F0 \uBB38\uC7A5\uC774 \uCC0D\uD788\uC9C0 \uC54A\uC740
    \uD06C\uACE0 \uBB35\uC9C1\uD55C \uB098\uBB34 \uC0C1\uC790\uB4E4\uC774 \uC794\uB729
    \uC313\uC5EC \uC788\uB2E4.)\r\n        \uD558\uB140 1 : \uC5B4\uB77C? \uBABB
    \uBCF4\uB358 \uC0C1\uC790\uB4E4\uC774\uB124. \uC694\uB9AC\uC0AC\uB2D8\uC774 \uC0C8\uB85C
    \uC2DD\uC790\uC7AC\uB97C \uC8FC\uBB38\uD558\uC168\uB098?\r\n        \uD558\uB140
    2 : \uC27F, \uC544\uB2C8\uC57C. \uC5B4\uC82F\uBC24\uC5D0 \uC0AC\uCD0C 1\uB2D8\uC774
    \uBCF4\uB0B8 \uC0AC\uB78C\uB4E4\uC774 \uBAB0\uB798 \uC9D0\uC744 \uB0B4\uB824\uB193\uACE0
    \uAC00\uB294 \uAC78 \uBD24\uB2E4\uB294 \uD558\uC778\uC774 \uC788\uC5B4.\r\n       
    \r\n\r\n\uB124\uBAA8 : \uC6B0\uB9AC \uC544\uBC84\uC9C0\uB3C4 \uBAA8\uB974\uAC8C
    \uC9D0\uC744 \uB4E4\uC5EC\uB1A8\uB2E4\uACE0? \uC774 \uC548\uC5D0 \uBB50\uAC00
    \uB4E4\uC5C8\uAE38\uB798?\r\n        \uD558\uB140 2 : \uC1E0\uAC00 \uBD80\uB52A\uCE58\uB294
    \uC18C\uB9AC\uAC00 \uB0AC\uB2E4\uB294 \uB9D0\uB3C4 \uC788\uACE0... \uBB34\uAE30\uB77C\uB294
    \uC18C\uBB38\uB3C4 \uB3CC\uC544\uC694.\r\n        \uB124\uBAA8 : (\uC0C1\uC790\uB97C
    \uCC28\uAC11\uAC8C \uB178\uB824\uBCF4\uBA70) \uC6B0\uB9AC \uC800\uD0DD\uC758
    \uC2EC\uC7A5\uBD80\uB098 \uB2E4\uB984\uC5C6\uB294 \uC9C0\uD558\uC2E4\uC5D0 \uBB34\uAE30\uB97C
    \uC228\uACA8\uB46C? \uB2F9\uC7A5 \uC544\uBC84\uB2D8\uAED8 \uB9D0\uC500\uB4DC\uB824\uC57C\uACA0\uC5B4."
