  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_visitor_friend_1_blocked__step_w008_visitor_friend_1_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 8\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C (\uC804\uD1B5\uC758
    \uACC4\uC2B9)(\uACBD\uBE44\uB300\uC7A5\uC774 \uB2E4\uAC00\uC640 \uCC3D\uBB38\uC744
    \uC870\uC2EC\uC2A4\uB7FD\uAC8C \uB2EB\uC73C\uBA70, \uB124\uBAA8\uC5D0\uAC8C \uBC31\uC791\uB2D8\uC774
    \uBCF4\uB0B8 \uC791\uC740 \uD39C\uB358\uD2B8\uB97C \uAC74\uB128\uB2E4.)\uACBD\uBE44\uB300\uC7A5
    : \uC8FC\uC778\uB2D8, \uC774 \uD39C\uB358\uD2B8 \uC548\uC5D0\uB294 \uB3CC\uC544\uAC00\uC2E0
    \uB450 \uBD84\uC758 \uC0AC\uC9C4\uC774 \uB4E4\uC5B4\uC788\uC2B5\uB2C8\uB2E4.
    \uBC31\uC791\uB2D8\uC740 \uC8FC\uC778\uB2D8\uC774 \uCDA9\uBD84\uD788 \uAC15\uD574\uC9C8
    \uB54C\uAE4C\uC9C0 \uC2AC\uD514\uC744 \uB4A4\uB85C \uBBF8\uB904\uB450\uC168\uC744
    \uBFD0\uC785\uB2C8\uB2E4."
  _bodyText: "(\uC0AC\uCD0C 1\uC774 '\uBD80\uBAA8\uB2D8\uC758 \uBE44\uADF9'\uC774\uB77C\uBA70
    \uAC00\uB9AC\uCF30\uB358 \uADF8 \uC232\uC744 \uCE5C\uAD6C 1\uACFC \uD568\uAED8
    \uCC3D\uBC16\uC73C\uB85C \uBC14\uB77C\uBCF4\uACE0 \uC788\uC5B4. \uB124\uBAA8\uC758
    \uB208\uBE5B\uC774 \uD754\uB4E4\uB9AC\uC790, \uCE5C\uAD6C 1\uC740 \uB124\uBAA8\uC758
    \uC5B4\uAE68\uC5D0 \uC190\uC744 \uC5B9\uC5B4.)\n        \n        \uCE5C\uAD6C
    1 : \uB124\uBAA8\uC57C, \uC0AC\uCD0C 1\uC774 \uD558\uB294 \uC598\uAE30 \uB4E4\uC5C8\uC5B4.
    \uC800 \uC232\uC5D0\uC11C \uAE30\uC0AC\uB2E8\uC774 \uBC29\uAD00\uD588\uB2E4\uACE0?
    \uADF8\uAC74 \uB9D0\uB3C4 \uC548 \uB3FC. \uC6B0\uB9AC \uC544\uBC84\uC9C0\uAC00
    \uADF8\uB54C \uAE30\uC0AC\uB2E8 \uB9D0\uB2E8\uC774\uC5C8\uB294\uB370, \uBC31\uC791\uB2D8\uC740
    \uADF8\uB0A0 \uB124 \uBD80\uBAA8\uB2D8\uC744 \uAD6C\uD558\uB824\uACE0 \uC9C1\uC811
    \uB9D0\uAE4C\uC9C0 \uD0C0\uC168\uB2E4\uACE0 \uD558\uC168\uC5B4. \uBE44\uB85D
    \uACB0\uACFC\uB294 \uC2AC\uD390\uC9C0\uB9CC...\n        \uB124\uBAA8 : (\uCC3D\uD2C0\uC744
    \uAF49 \uC950\uBA70) \uC815\uB9D0... \uBC31\uC791\uB2D8\uC774 \uC9C1\uC811 \uAC00\uC168\uB2E4\uACE0?
    \uC0AC\uCD0C 1\uC740 \uBC31\uC791\uB2D8\uC774 \uC228\uAE30\uB294 \uAC8C \uB9CE\uB2E4\uACE0
    \uD588\uB2E8 \uB9D0\uC774\uC57C.\n        \n\n\uB124\uBAA8 : (\uD39C\uB358\uD2B8\uB97C
    \uC5F4\uC5B4\uBCF4\uACE0 \uB208\uC2DC\uC6B8\uC774 \uBD89\uC5B4\uC9C4\uB2E4) \uBC31\uC791\uB2D8\uC740
    \uC800\uB97C \uC9C0\uD0A4\uAE30 \uC704\uD574 \uC774 \uC544\uD514\uC744 \uD63C\uC790
    \uACAC\uB514\uACE0 \uACC4\uC168\uB358 \uAC70\uAD70\uC694. \uC0BC\uCD0C\uC758
    \uB9D0\uC5D0 \uD754\uB4E4\uB838\uB358 \uC81C\uAC00 \uBD80\uB044\uB7EC\uC6CC\uC694.\n       
    \uCE5C\uAD6C 1 : \uBD10, \uB124\uBAA8\uC57C. \uBC31\uC791\uB2D8\uC740 \uB110
    \uB204\uAD6C\uBCF4\uB2E4 \uC544\uB07C\uC154. \uC800 \uC232\uC740 \uC774\uC81C
    \uC2AC\uD514\uC758 \uC7A5\uC18C\uAC00 \uC544\uB2C8\uB77C \uB124\uAC00 \uC9C0\uCF1C\uC57C
    \uD560 \uC601\uC9C0\uC758 \uC77C\uBD80\uC77C \uBFD0\uC774\uC57C."
