  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_external_main_direct__step_w008_external_main_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "8\uCC28 - \uD5C8\uB77D"
  _bodyText: "\uC218\uB3C4\uC758 \uC815\uBCC0\uACFC \uC0AC\uB77C\uC9C4 \uC655\uB140\r\n   
    \r\n    (\uC751\uC811\uC2E4 \uBC16 \uBCF5\uB3C4, \uC218\uB3C4\uC5D0\uC11C \uC628
    \uC0AC\uC808\uC758 \uB9C8\uBD80\uAC00 \uC800\uD0DD \uD558\uC778\uB4E4\uACFC \uC2EC\uAC01\uD55C
    \uD45C\uC815\uC73C\uB85C \uB300\uD654\uD55C\uB2E4.)\r\n    \r\n    \uB9C8\uBD80
    1 : \uC218\uB3C4\uAC00 \uBC1C\uCE75 \uB4A4\uC9D1\uD614\uC5B4. \uC655\uC2E4\uC5D0
    \uD070 \uC2F8\uC6C0\uC774 \uB098\uC11C \uC5B4\uB9B0 \uC655\uB140\uB2D8\uC774
    \uBE44\uBC00\uB9AC\uC5D0 \uD53C\uC2E0\uD588\uB2E4\uB294\uB370, \uD589\uBC29\uC774
    \uBB18\uC5F0\uD558\uB300.\r\n    \uD558\uC778 : \uC124\uB9C8 \uC774 \uBA3C \uACF3\uAE4C\uC9C0
    \uC624\uACA0\uC5B4? \uC5EC\uAE30\uB294 \uC6CC\uB099 \uC870\uC6A9\uD574\uC11C
    \uC228\uAE30\uC5D4 \uB531\uC774\uAE34 \uD558\uC9C0\uB9CC...\r\n    \uB124\uBAA8
    : \uC655\uB140\uB2D8\uC774 \uB3C4\uB9DD\uAC14\uC5B4? \uC6B0\uB9AC \uC9D1\uC5D0
    \uC228\uC5B4 \uC788\uB294 \uAC70 \uC544\uB2C8\uC57C?\r\n    \r\n\r\n- \uB9C8\uBD80
    1 : \uC18C\uBB38\uC5D0 \uB530\uB974\uBA74 \uADF8 \uC655\uB140\uB2D8\uC774 \uC544\uC8FC
    \uC6A9\uAC10\uD574\uC11C, \uC9C1\uC811 \uAE30\uC0AC\uB85C \uBCC0\uC7A5\uD558\uACE0
    \uC138\uC0C1\uC744 \uAD6C\uD558\uB7EC \uB5A0\uB0AC\uB2E4\uB294 \uB9D0\uB3C4 \uC788\uC5B4\uC694.\r\n   
    \uB124\uBAA8 : \uC6B0\uC640, \uC655\uB140\uB2D8\uC774 \uAE30\uC0AC \uBCC0\uC7A5\uC744?
    \uADF8\uB7FC \uB098\uC911\uC5D0 \uC6B0\uB9AC \uC800\uD0DD\uC5D0\uB3C4 \uB4E4\uB7EC\uC904\uAE4C?\r\n   
    \uD558\uC778 : \uC8FC\uC778\uB2D8\uCC98\uB7FC \uC815\uC758\uB85C\uC6B4 \uBD84\uC774\uB77C\uBA74
    \uC655\uB140\uB2D8\uB3C4 \uAF2D \uB9CC\uB098\uACE0 \uC2F6\uC5B4 \uD560 \uAC70\uC608\uC694.
    \uC5B4\uCA4C\uBA74 \uC131\uC778\uC2DD \uB54C \uAE5C\uC9DD \uB4F1\uC7A5\uD560\uC9C0\uB3C4
    \uBAA8\uB974\uC8E0?\r\n    \uB124\uBAA8 : \uB098\uB3C4 \uAC80\uC220 \uC5F0\uC2B5
    \uB354 \uC5F4\uC2EC\uD788 \uD574\uC57C\uACA0\uB2E4! \uC655\uB140\uB2D8\uC744
    \uC9C0\uCF1C\uC904 \uC218 \uC788\uAC8C!"
