  m_Name: event_week_008_visitor_cousin_1_blocked__step_event_week_008_visitor_cousin_1_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE74\uC774\uC548 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor cousin_1 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uB2EB\uD788\uB294 \uCC3D\uBB38\uC744 \uBCF4\uBA70 \uC18C\uB9AC\uCE5C\uB2E4)
      \uC65C \uB2E4\uB4E4 \uC228\uAE30\uAE30\uB9CC \uD574! \uC544\uC800\uC528\uB3C4
      \uADF8\uB0A0 \uAC70\uAE30 \uC788\uC5C8\uC8E0? \uC0BC\uCD0C \uB9D0\uC774 \uC0AC\uC2E4\uC774\uC5D0\uC694?
      \uC65C \uBC31\uC791\uB2D8\uC740 \uB0B4 \uC9C8\uBB38\uC5D0\uB294 \uB2F5\uD574\uC8FC\uC9C0
      \uC54A\uACE0 \uADDC\uCE59\uB9CC \uAC15\uC694\uD558\uB294 \uAC70\uB0D0\uACE0!"
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uCBE7\uCBE7, \uC9C4\uC2E4\uC744 \uB9C8\uC8FC\uD560 \uC6A9\uAE30\uB3C4
      \uC5C6\uB294 \uAC81\uC7C1\uC774\uB4E4\uC774\uAD70."
  _nemoLine: "(\uB2EB\uD788\uB294 \uCC3D\uBB38\uC744 \uBCF4\uBA70 \uC18C\uB9AC\uCE5C\uB2E4)
    \uC65C \uB2E4\uB4E4 \uC228\uAE30\uAE30\uB9CC \uD574! \uC544\uC800\uC528\uB3C4
    \uADF8\uB0A0 \uAC70\uAE30 \uC788\uC5C8\uC8E0? \uC0BC\uCD0C \uB9D0\uC774 \uC0AC\uC2E4\uC774\uC5D0\uC694?
    \uC65C \uBC31\uC791\uB2D8\uC740 \uB0B4 \uC9C8\uBB38\uC5D0\uB294 \uB2F5\uD574\uC8FC\uC9C0
    \uC54A\uACE0 \uADDC\uCE59\uB9CC \uAC15\uC694\uD558\uB294 \uAC70\uB0D0\uACE0!"
