  _titleOverride: cousin_2 Blocked
  _bodyText: "visitor cousin_2 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "(\uBC14\uB2E5\uC5D0 \uB118\uC5B4\uC9C0\uBA70) \uC8C4\uC1A1\uD574\uC694!
      \uC804 \uADF8\uB0E5 \uC544\uBE60\uD55C\uD14C \uB4E4\uC740 \uB300\uB85C... \uB124\uBAA8\uC57C,
      \uB098 \uBB34\uC11C\uC6CC!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC5D0\uAC8C \uB300\uB4E4\uBA70) \uC560\uB97C
      \uBC00\uCE58\uBA74 \uC5B4\uB5A1\uD574\uC694! \uBC31\uC791\uB2D8\uC774 \uC2DC\uD0A4\uBA74
      \uC0AC\uB78C\uC744 \uB2E4\uCE58\uAC8C \uD574\uB3C4 \uB418\uB294 \uAC70\uC608\uC694?
      \uC0AC\uCD0C 2, \uC77C\uC5B4\uB098. \uB108\uD76C \uC9D1\uC73C\uB85C \uAC00.
      \uC5EC\uAE30 \uC788\uB2E4\uAC04 \uB108\uB3C4 \uB098\uCC98\uB7FC \uC228 \uB9C9\uD600
      \uC8FD\uC744 \uAC70\uC57C!"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "(\uB3C4\uB9DD\uCE58\uB4EF \uB098\uAC00\uBA70) \uB124\uBAA8\uC57C, \uC870\uC2EC\uD574!
      \uBC31\uC791\uB2D8\uC740 \uB2E4 \uBCF4\uACE0 \uACC4\uC154!"
  _nemoLine: "(\uBC14\uB2E5\uC5D0 \uB118\uC5B4\uC9C0\uBA70) \uC8C4\uC1A1\uD574\uC694!
    \uC804 \uADF8\uB0E5 \uC544\uBE60\uD55C\uD14C \uB4E4\uC740 \uB300\uB85C... \uB124\uBAA8\uC57C,
    \uB098 \uBB34\uC11C\uC6CC!"
