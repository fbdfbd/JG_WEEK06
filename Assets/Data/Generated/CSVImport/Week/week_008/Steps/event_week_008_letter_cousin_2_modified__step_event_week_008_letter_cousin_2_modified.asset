  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_letter_cousin_2_modified__step_event_week_008_letter_cousin_2_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9AC\uC548\uC758 \uD3B8\uC9C0 \uC218\uC815"
  _bodyText: "letter cousin_2 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uC774 \uC5B4\uB514\uC5D0
      \uC788\uB4E0 \uC8FC\uC778\uB2D8\uC744 \uC751\uC6D0\uD558\uACE0 \uC788\uB2E4\uACE0
      \uC804\uD574\uC654\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC14\uB2E4\uC5D0\uC11C\uB3C4 \uB0B4 \uC751\uC6D0\uC744 \uD55C \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC138\uC0C1\uC758 \uC5B4\uB5A4 \uC18C\uC74C\uBCF4\uB2E4 \uC8FC\uC778\uB2D8\uC758
      \uBAA9\uC18C\uB9AC\uAC00 \uB354 \uD06C\uAC8C \uB4E4\uB9B0\uB300\uC694. \uC131\uC778\uC2DD
      \uB0A0, \uB204\uAD6C\uBCF4\uB2E4 \uD658\uD558\uAC8C \uC6C3\uB294 \uC8FC\uC778\uB2D8\uC744
      \uBCF4\uACE0 \uC2F6\uC5B4 \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC54\uAC00 \uC624\uBA74 \uB0B4\uAC00 \uC81C\uC77C \uBA3C\uC800 \uBC18\uACA8\uC918\uC57C\uACA0\uB2E4."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC0AC\uCD0C \uC8FC\uC778\uB2D8\uC774 \uC5B4\uB514\uC5D0
    \uC788\uB4E0 \uC8FC\uC778\uB2D8\uC744 \uC751\uC6D0\uD558\uACE0 \uC788\uB2E4\uACE0
    \uC804\uD574\uC654\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
