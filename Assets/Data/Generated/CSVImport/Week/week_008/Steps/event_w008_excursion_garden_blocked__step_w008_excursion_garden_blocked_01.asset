  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_excursion_garden_blocked__step_w008_excursion_garden_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 8\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uBD84\uC218\uB300 \uADFC\uCC98 \uD654\uB2E8. \uD3C9\uC18C\uC640 \uB2EC\uB9AC
    \uD759\uC774 \uAC70\uCE60\uAC8C \uD30C\uC5EC \uC788\uACE0 \uB0AF\uC120 \uAC00\uC8FD
    \uC7A5\uD654 \uC790\uAD6D\uC774 \uC120\uBA85\uD558\uAC8C \uB0A8\uC544 \uC788\uB2E4.)\n       
    \uD558\uB140 1 : \uC774\uC0C1\uD558\uB124, \uC815\uC6D0\uC0AC\uB4E4\uC740 \uC774\uB7F0
    \uAC70\uCE5C \uC2E0\uBC1C\uC744 \uC548 \uC2E0\uB294\uB370...\n        \uD558\uB140
    2 : \uC544\uAE4C \uC0AC\uCD0C 1\uB2D8\uC774 \uBCF4\uB0B8 \uC2EC\uBD80\uB984\uAFBC\uB4E4\uC774
    \uC7A0\uC2DC \uB4E4\uB800\uB2E4\uB354\uB2C8, \uADF8 \uC0AC\uB78C\uB4E4\uC778\uAC00
    \uBD10\uC694.\n        \n\n(\uACBD\uBE44\uB300\uC7A5\uC774 \uBC1C\uC790\uAD6D\uC744
    \uBC1C\uB85C \uBB38\uC9C8\uB7EC \uC9C0\uC6CC\uBC84\uB9B0\uB2E4.)\n        \uACBD\uBE44\uB300\uC7A5
    : \uC678\uBD80\uC778\uC758 \uCD9C\uC785\uC774 \uC7A6\uC544\uC9C0\uBA74 \uCE58\uC548\uC774
    \uD750\uD2B8\uB7EC\uC9D1\uB2C8\uB2E4. \uB3C4\uB828\uB2D8\uC740 \uBABB \uBCF8
    \uAC83\uC73C\uB85C \uD558\uC2ED\uC2DC\uC624.\n        \uB124\uBAA8 : \uD558\uC9C0\uB9CC
    \uC544\uC800\uC528, \uAF43\uB4E4\uC774 \uBC1F\uD614\uC796\uC544\uC694. \uB204\uAC00
    \uC6B0\uB9AC \uC815\uC6D0\uC744 \uD568\uBD80\uB85C \uB2E4\uB2CC \uAC70\uC608\uC694?\n       
    \uACBD\uBE44\uB300\uC7A5 : \uC0AC\uC18C\uD55C \uC77C\uC785\uB2C8\uB2E4. \uACE7
    \uC815\uC6D0\uC0AC\uB4E4\uC774 \uB2E4\uC2DC \uC815\uB9AC\uD560 \uD14C\uB2C8,
    \uBCF8\uAD00\uC73C\uB85C \uB3CC\uC544\uAC00\uC2DC\uC8E0."
