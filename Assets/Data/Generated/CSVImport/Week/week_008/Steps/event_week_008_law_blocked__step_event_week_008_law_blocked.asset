  _titleOverride: "\uBC95\uB960 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4"
  _bodyText: "\uBC95\uB960 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBC95\uB960 \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
      \uC870\uBB38\uC744 \uAE4A\uAC8C \uC77D\uC9C0 \uC54A\uACE0 \uB36E\uC5B4 \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624\uB298\uC740 \uADDC\uCE59 \uC774\uC57C\uAE30 \uC548 \uD574?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uBB34\uB9AC\uD558\uAC8C \uC9C4\uB3C4\uB97C \uB098\uAC00\uAE30\uBCF4\uB2E4
      \uB2E4\uC74C \uAE30\uD68C\uC5D0 \uB2E4\uC2DC \uBCF4\uAE30\uB85C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB2E4\uC74C\uC5D4 \uC880 \uB354 \uC790\uC138\uD788 \uC54C\uB824
      \uC918."
  _nemoLine: "(\uBC95\uB960 \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
    \uC870\uBB38\uC744 \uAE4A\uAC8C \uC77D\uC9C0 \uC54A\uACE0 \uB36E\uC5B4 \uB454\uB2E4.)"
