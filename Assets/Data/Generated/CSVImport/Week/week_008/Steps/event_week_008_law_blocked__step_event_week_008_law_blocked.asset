%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_law_blocked__step_event_week_008_law_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBD84\uC7C1 \uAE30\uB85D\uC5D0\uC11C \uADDC\uCE59\uBD80\uD130
    \uBCF8\uB2E4"
  _bodyText: "\uC81C\uAD6D\uBC95\uACFC \uC601\uC9C0 \uD589\uC815 8\uC8FC\uCC28 Blocked
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC11C\uC7AC. \uBE44\uC11C\uAC00 \uC587\uC740 \uD310\uB840 \uBB36\uC74C\uACFC
      \uC601\uC9C0 \uBBFC\uC6D0 \uAE30\uB85D \uBA87 \uC7A5\uC744 \uCC45\uC0C1 \uC704\uC5D0
      \uD3BC\uCCD0 \uB454\uB2E4. \uB0B4\uC6A9\uC740 \uBC2D \uACBD\uACC4 \uB2E4\uD23C,
      \uC6B0\uBB3C \uC0AC\uC6A9 \uC21C\uC11C, \uAC00\uCD95 \uD53C\uD574 \uAC19\uC740
      \uBE44\uAD50\uC801 \uC791\uC740 \uBD84\uC7C1\uB4E4\uC774\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uBC95 \uC870\uBB38 \uC790\uCCB4\uBCF4\uB2E4
      \uB204\uAC00 \uBB34\uC5C7 \uB54C\uBB38\uC5D0 \uB2E4\uD22C\uC5C8\uB294\uC9C0
      \uBA3C\uC800 \uBCF4\uB294 \uB0A0\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uACB0\uAD6D \uB2E4\uB4E4 \uC790\uAE30 \uB9D0\uC774 \uB9DE\uB2E4\uACE0
      \uD558\uACA0\uC9C0."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uB124. \uADF8\uB798\uC11C \uAE30\uB85D\uC774 \uD544\uC694\uD558\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uD310\uB840\uC9D1 \uD55C \uAD8C\uC744
      \uB124\uBAA8 \uC55E\uC5D0 \uBC00\uC5B4 \uB454\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB3D9\uC815\uBD80\uD130 \uD558\uC9C0 \uB9C8\uC2ED\uC2DC\uC624. \uBA3C\uC800
      \uADDC\uCE59\uACFC \uC704\uBC18 \uC0AC\uC2E4\uC744 \uAD6C\uBD84\uD558\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC0AC\uC815\uC774 \uBCF4\uC5EC\uB3C4 \uC77C\uB2E8 \uC811\uC5B4\uB450\uB77C\uB294
      \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uADF8\uB807\uC2B5\uB2C8\uB2E4. \uAC10\uC815\uC73C\uB85C \uC2DC\uC791\uD558\uBA74
      \uD310\uB2E8\uC774 \uD754\uB4E4\uB9BD\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "...\uC54C\uACA0\uC5B4. \uADF8\uB7FC \uB204\uAC00 \uBA3C\uC800 \uC5B4\uAE34
      \uAC74\uC9C0\uBD80\uD130 \uBCFC\uAC8C."
  _nemoLine: "(\uC11C\uC7AC. \uBE44\uC11C\uAC00 \uC587\uC740 \uD310\uB840 \uBB36\uC74C\uACFC
    \uC601\uC9C0 \uBBFC\uC6D0 \uAE30\uB85D \uBA87 \uC7A5\uC744 \uCC45\uC0C1 \uC704\uC5D0
    \uD3BC\uCCD0 \uB454\uB2E4. \uB0B4\uC6A9\uC740 \uBC2D \uACBD\uACC4 \uB2E4\uD23C,
    \uC6B0\uBB3C \uC0AC\uC6A9 \uC21C\uC11C, \uAC00\uCD95 \uD53C\uD574 \uAC19\uC740
    \uBE44\uAD50\uC801 \uC791\uC740 \uBD84\uC7C1\uB4E4\uC774\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
