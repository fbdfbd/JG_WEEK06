  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_visitor_cousin_2_direct__step_w008_visitor_cousin_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 8\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uB124\uBAA8\uC640 \uC0AC\uCD0C 2\uAC00 \uBC31\uC791\uB2D8\uC758 \uC601\uC9C0
    \uC9C0\uB3C4\uB97C \uBCF4\uACE0 \uC788\uC5B4. \uC0AC\uCD0C 1\uC774 \uAC00\uB9AC\uCF30\uB358
    \uADF8 '\uBE44\uADF9\uC758 \uC232' \uADFC\uCC98\uC5D0\uC11C \uB124\uBAA8\uC758
    \uC190\uAE38\uC774 \uBA48\uCDB0. \uC0AC\uCD0C 2\uB294 \uAC81\uC5D0 \uC9C8\uB9B0
    \uB208\uC73C\uB85C \uC9C0\uB3C4\uB97C \uBC14\uB77C\uBD10.)\r\n        \r\n       
    \uC0AC\uCD0C 2 : \uB124\uBAA8\uC57C, \uC6B0\uB9AC \uC544\uBE60\uAC00 \uADF8\uB7EC\uB294\uB370
    \uC800 \uC232\uC740 \uC800\uC8FC\uBC1B\uC558\uB300. \uBC31\uC791\uB2D8\uC774
    \uC800\uAE30\uB97C \uD3D0\uC1C4\uD55C \uAC74 \uAD34\uBB3C\uC774 \uB098\uC640\uC11C\uAC00
    \uC544\uB2C8\uB77C... \uB204\uAD70\uAC00\uC758 \uBE44\uBA85 \uC18C\uB9AC\uAC00
    \uB4E4\uB824\uC11C\uB77C\uACE0...\r\n        \uB124\uBAA8 : (\uC9C0\uB3C4\uB97C
    \uC190\uD1B1\uC73C\uB85C \uAE01\uC73C\uBA70) \uBE44\uBA85 \uC18C\uB9AC? \uC0AC\uCD0C
    2, \uB108 \uB611\uBC14\uB85C \uB9D0\uD574. \uB108\uD76C \uC544\uBC84\uC9C0\uAC00
    \uC800 \uC232\uC5D0 \uB300\uD574 \uB610 \uBB50\uB77C\uACE0 \uD558\uC168\uC5B4?\r\n       
    \r\n\r\n- (\uB124\uBAA8\uAC00 \uC9C0\uB3C4 \uC704\uC5D0 \uC0AC\uCD0C 2\uAC00
    \uAC00\uC838\uC628 \uC791\uC740 \uC789\uD06C\uBCD1\uC744 \uC5CE\uC9C0\uB978\uB2E4.
    \uAC80\uC740 \uC789\uD06C\uAC00 '\uBE44\uADF9\uC758 \uC232'\uC744 \uAC00\uB824\uBC84\uB824.)\r\n       
    - \uB124\uBAA8 : \uBD10, \uC774\uC81C \uC544\uBB34\uAC83\uB3C4 \uC548 \uBCF4\uC5EC.
    \uBC31\uC791\uB2D8\uC774 \uAC00\uB9AC\uB824\uACE0 \uD588\uB358 \uC9C4\uC2E4\uB3C4,
    \uB108\uD76C \uC544\uBC84\uC9C0\uAC00 \uAC81\uC8FC\uB824\uB358 \uC232\uB3C4.\r\n       
    \uC0AC\uCD0C 2 : (\uACBD\uC545\uD558\uBA70) \uB124\uBAA8\uC57C! \uBC31\uC791\uB2D8\uC774
    \uC774 \uC9C0\uB3C4\uB97C \uC5BC\uB9C8\uB098 \uC544\uB07C\uC2DC\uB294\uB370...
    \uB108 \uAD1C\uCC2E\uACA0\uC5B4?\r\n        \uB124\uBAA8 : \uC0C1\uAD00\uC5C6\uC5B4.
    \uC774 \uC9C0\uB3C4\uAC00 \uC5C6\uC5B4\uB3C4 \uB09C \uB0B4 \uBC1C\uB85C \uC9C1\uC811
    \uC800 \uC232\uC5D0 \uAC08 \uAC70\uB2C8\uAE4C. \uC0AC\uCD0C 2, \uB108\uB3C4 \uAC19\uC774
    \uAC08 \uAC70\uC9C0? \uC6B0\uB9AC \uB458\uC774\uC11C \uBC31\uC791\uB2D8\uACFC
    \uB108\uD76C \uC544\uBC84\uC9C0\uAC00 \uC228\uAE30\uB294 \uAC78 \uCC3E\uC544\uB0B4\uB294
    \uAC70\uC57C.\r\n        \uC0AC\uCD0C 2 : (\uB5A8\uB9AC\uB294 \uBAA9\uC18C\uB9AC\uB85C)
    \uC751... \uB124\uAC00 \uAC00\uC790\uBA74 \uAC08\uAC8C. \uB10C \uB0B4 \uC720\uC77C\uD55C
    \uCE5C\uAD6C\uB2C8\uAE4C."
