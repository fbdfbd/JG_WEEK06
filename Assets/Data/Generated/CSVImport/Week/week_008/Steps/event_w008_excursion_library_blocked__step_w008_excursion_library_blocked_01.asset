  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_excursion_library_blocked__step_w008_excursion_library_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 8\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uAE08\uC11C \uAD6C\uC5ED \uADFC\uCC98, \uD3C9\uC18C\uC5D4 \uC798
    \uC5F4\uC9C0 \uC54A\uB294 \uAC00\uBB38 \uAE30\uB85D \uBCF4\uAD00\uC18C\uC758
    \uC11C\uB78D\uC774 \uC0B4\uC9DD \uC5F4\uB824 \uC788\uB2E4. \uADF8 \uC548\uC5D0\uB294
    \uC0AC\uCD0C 1\uC758 \uC778\uC7A5\uC774 \uCC0D\uD78C \uB0AF\uC120 \uACC4\uC57D\uC11C
    \uCD08\uC548\uB4E4\uC774 \uD769\uC5B4\uC838 \uC788\uB2E4.)\r\n        \uD558\uB140
    1 : \uC774\uC0C1\uD558\uB2E4. \uC774 \uC11C\uB958\uB4E4\uC740 \uBC31\uC791\uB2D8
    \uD5C8\uB77D \uC5C6\uC774\uB294 \uAEBC\uB0BC \uC218 \uC5C6\uB294 \uAC83\uB4E4\uC778\uB370...\r\n       
    \uD558\uB140 2 : \uC5B4\uC81C \uC0AC\uCD0C 1\uB2D8\uC774 \uB3C4\uC11C\uAD00\uC7A5\uB2D8\uACFC
    \uD55C\uCC38 \uB3D9\uC548 \uC5EC\uAE30\uC11C \uC774\uC57C\uAE30\uB97C \uB098\uB204\uC2DC\uB354\uB77C\uACE0\uC694.\r\n       
    \r\n\r\n(\uACBD\uBE44\uB300\uC7A5\uC774 \uC11C\uB958\uB97C \uB09A\uC544\uCC44
    \uC11C\uB78D \uC548\uC5D0 \uB123\uACE0 \uC5F4\uC1E0\uB85C \uC7A0\uAC00\uBC84\uB9B0\uB2E4.)\r\n       
    \uACBD\uBE44\uB300\uC7A5 : \uC601\uC9C0\uC758 \uD589\uC815 \uC808\uCC28\uB294
    \uC544\uAC00\uC528\uAED8\uC11C \uAD00\uC5EC\uD558\uC2E4 \uB2E8\uACC4\uAC00 \uC544\uB2D9\uB2C8\uB2E4.
    \uC0AC\uCD0C 1\uB2D8\uC740 \uBC31\uC791\uB2D8\uC744 \uB3D5\uACE0 \uACC4\uC2E0
    \uAC83\uBFD0\uC774\uB2C8, \uC758\uC2EC\uC744 \uD0A4\uC6B0\uC9C0 \uB9C8\uC2ED\uC2DC\uC624.\r\n       
    \uB124\uBAA8 : \uB3D5\uB294 \uAC83\uCE58\uACE0\uB294 \uB108\uBB34 \uC740\uBC00\uD574
    \uBCF4\uC5EC\uC694. \uC65C \uC6B0\uB9AC \uAC00\uBB38\uC758 \uC624\uB798\uB41C
    \uAD8C\uB9AC \uC99D\uC11C\uB4E4\uC744 \uADF8\uBD84\uC774 \uC0B4\uD3B4\uBCF4\uACE0
    \uACC4\uC2E0 \uAC70\uC8E0?\r\n        \uACBD\uBE44\uB300\uC7A5 : (\uCC28\uAC11\uAC8C)
    \uB108\uBB34 \uB9CE\uC740 \uAC83\uC744 \uC544\uB294 \uAC83\uC740 \uB3C5\uC774
    \uB429\uB2C8\uB2E4. \uC544\uAC00\uC528\uB294 \uADF8\uC800 \uC601\uC560\uB85C\uC11C\uC758
    \uD488\uC704\uB9CC \uC9C0\uD0A4\uC2DC\uBA74 \uB429\uB2C8\uB2E4."
