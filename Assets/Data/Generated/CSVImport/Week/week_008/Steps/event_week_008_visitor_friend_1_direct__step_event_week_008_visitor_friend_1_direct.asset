      \uCD94\uC5B5\uC744 \uCC44\uC6CC \uB123\uC790."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB798. \uC774\uC81C \uB354 \uC774\uC0C1 \uC0BC\uCD0C\uC758 \uB3C5\uC124\uC5D0
      \uD718\uB458\uB9AC\uC9C0 \uC54A\uC544. \uB098\uC5D0\uAC90 \uBC31\uC791\uB2D8\uACFC
      \uB124\uAC00 \uC788\uC73C\uB2C8\uAE4C."
  _nemoLine: "\uB2F9\uC5F0\uD558\uC9C0! \uBC31\uC791\uB2D8\uB3C4 \uB124\uAC00 \uB098\uC640
