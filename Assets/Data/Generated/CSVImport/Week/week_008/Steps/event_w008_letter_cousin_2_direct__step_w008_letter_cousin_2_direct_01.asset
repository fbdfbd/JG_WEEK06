  m_Name: event_w008_letter_cousin_2_direct__step_w008_letter_cousin_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 \uD3B8\uC9C0 8\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uBC14\uB2E4 \uB0C4\uC0C8\uAC00 \uBB3C\uC52C \uD48D\uAE30\uB294
    \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uC548\uC5D0\uB294 \uC870\uAC1C\uAECD\uB370\uAE30
    \uD558\uB098\uAC00 \uB4E4\uC5B4 \uC788\uB2E4.)\n        \n\n\uD558\uB140 : \uC0AC\uCD0C
    2 \uB3C4\uB828\uB2D8\uC774 \uC5EC\uD589\uC9C0\uC5D0\uC11C \uBCF4\uB0B4\uC2E0
    \uC120\uBB3C\uC774 \uB3C4\uCC29\uD588\uC2B5\uB2C8\uB2E4.\n        \uB124\uBAA8
    : \uC870\uAC1C\uAECD\uB370\uAE30\uB2E4! \uC9C4\uC9DC \uC608\uBED0.\n        (\uD558\uB140\uAC00
    \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)\n        \uB124\uBAA8\uC57C, \uC5EC\uAE34
    \uBC14\uB2E4\uC57C. \uC544\uBE60\uB294 \uC5EC\uAE30\uC11C\uB3C4 \uBB34\uC11C\uC6B4
    \uC0AC\uB78C\uB4E4\uB9CC \uB9CC\uB098\uC9C0\uB9CC, \uB09C \uBC14\uB2E4\uB9CC
    \uBCF4\uBA74 \uB124 \uC0DD\uAC01\uC774 \uB098. \uC774 \uC870\uAC1C\uAECD\uB370\uAE30\uC5D0
    \uADC0\uB97C \uB300\uBA74 \uD30C\uB3C4 \uC18C\uB9AC\uAC00 \uB098\uB294\uB370,
    \uB124\uAC00 \uD798\uB4E4 \uB54C \uB4E4\uC73C\uBA74 \uAE30\uBD84\uC774 \uC88B\uC544\uC9C8
    \uAC70\uC57C. \uC131\uC778\uC2DD \uB54C \uB0B4\uAC00 \uAF2D \uB108\uD55C\uD14C
    \uC9C1\uC811 \uC804\uD574\uC904\uAC8C!\n        \uB124\uBAA8 : \uD30C\uB3C4 \uC18C\uB9AC?
    \uC9C4\uC9DC \uB4E4\uB9AC\uB124!\n        \uD558\uB140 : \uBA40\uB9AC\uC11C\uB3C4
    \uC8FC\uC778\uB2D8\uC758 \uC548\uB155\uC744 \uBE4C\uACE0 \uC788\uB294 \uB530\uB73B\uD55C
    \uB9C8\uC74C\uC774\uB124\uC694.\n        \uB124\uBAA8 : \uC751. \uAC54\uAC00
    \uC624\uBA74 \uB098\uB3C4 \uB0B4\uAC00 \uC81C\uC77C \uC544\uB07C\uB294 \uB9CC\uB144\uD544
    \uC120\uBB3C\uD560\uB798."
