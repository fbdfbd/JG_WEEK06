  _titleOverride: "\uC655\uB140 \uD53C\uC2E0 \uC18C\uBB38 - \uD1B5\uC81C"
  _bodyText: "\uC655\uB140 \uD53C\uC2E0 \uC18C\uBB38 - \uD1B5\uC81C \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC0AC\uB77C\uC9C4 \uC655\uB140 \uC774\uC57C\uAE30\uB294 \uC815\uCE58
      \uC18C\uBB38\uC774 \uACFC\uD574\uC9C0\uC9C0 \uC54A\uAC8C \uC9E7\uAC8C \uB118\uAE34\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC655\uB140\uB2D8 \uC598\uAE30 \uC9C4\uC9DC\uC608\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD655\uC778\uB418\uC9C0 \uC54A\uC740 \uB9D0\uC740 \uB35C\uC5B4\uB0B4\uACE0,
      \uC218\uB3C4\uAC00 \uC5B4\uC218\uC120\uD558\uB2E4\uB294 \uC815\uB3C4\uB9CC
      \uC54C\uB824 \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uADF8\uB7FC \uD568\uBD80\uB85C \uBBFF\uC9C4 \uC54A\uC744\uB798."
  _nemoLine: "(\uC0AC\uB77C\uC9C4 \uC655\uB140 \uC774\uC57C\uAE30\uB294 \uC815\uCE58
    \uC18C\uBB38\uC774 \uACFC\uD574\uC9C0\uC9C0 \uC54A\uAC8C \uC9E7\uAC8C \uB118\uAE34\uB2E4.)"
