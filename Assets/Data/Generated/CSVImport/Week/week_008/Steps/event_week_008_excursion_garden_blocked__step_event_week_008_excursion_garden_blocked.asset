  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_excursion_garden_blocked__step_event_week_008_excursion_garden_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 \uD1B5\uC81C"
  _bodyText: "excursion garden Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uBC1C\uC790\uAD6D\uC744 \uBC1C\uB85C
      \uBB38\uC9C8\uB7EC \uC9C0\uC6CC\uBC84\uB9B0\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC678\uBD80\uC778\uC758 \uCD9C\uC785\uC774 \uC7A6\uC544\uC9C0\uBA74
      \uCE58\uC548\uC774 \uD750\uD2B8\uB7EC\uC9D1\uB2C8\uB2E4. \uB3C4\uB828\uB2D8\uC740
      \uBABB \uBCF8 \uAC83\uC73C\uB85C \uD558\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD558\uC9C0\uB9CC \uC544\uC800\uC528, \uAF43\uB4E4\uC774 \uBC1F\uD614\uC796\uC544\uC694.
      \uB204\uAC00 \uC6B0\uB9AC \uC815\uC6D0\uC744 \uD568\uBD80\uB85C \uB2E4\uB2CC
      \uAC70\uC608\uC694?"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC0AC\uC18C\uD55C \uC77C\uC785\uB2C8\uB2E4. \uACE7 \uC815\uC6D0\uC0AC\uB4E4\uC774
      \uB2E4\uC2DC \uC815\uB9AC\uD560 \uD14C\uB2C8, \uBCF8\uAD00\uC73C\uB85C \uB3CC\uC544\uAC00\uC2DC\uC8E0."
  _nemoLine: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uBC1C\uC790\uAD6D\uC744 \uBC1C\uB85C
    \uBB38\uC9C8\uB7EC \uC9C0\uC6CC\uBC84\uB9B0\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
