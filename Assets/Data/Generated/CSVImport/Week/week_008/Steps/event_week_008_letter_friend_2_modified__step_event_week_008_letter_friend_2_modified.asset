  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_letter_friend_2_modified__step_event_week_008_letter_friend_2_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC00\uB9AC\uC544 \uD3B8\uC9C0 \uC218\uC815"
  _bodyText: "letter friend_2 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC8FC\uC778\uB2D8\uC758
      \uD488\uACA9 \uC788\uB294 \uBAA8\uC2B5\uC774 \uC774\uBBF8 \uBC31\uC791\uB2D8\uC744
      \uB2EE\uC558\uB2E4\uACE0 \uCE6D\uCC2C\uD588\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC? \uB098 \uBC31\uC791\uB2D8 \uB2EE\uC558\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uCE74\uC774\uC628\uC758 \uC774\uAC04\uC9C8\uC5D0\uB3C4 \uD754\uB4E4\uB9AC\uC9C0
      \uC54A\uB294 \uC8FC\uC778\uB2D8\uC758 \uCC28\uBD84\uD568\uC774 \uC9C4\uC815\uD55C
      \uADC0\uC871\uC758 \uBAA8\uC2B5\uC774\uB77C\uACE0 \uD558\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD788\uD788, \uAC54\uD55C\uD14C \uCE6D\uCC2C\uBC1B\uC73C\uB2C8\uAE4C
      \uC9C4\uC9DC \uAE30\uBD84 \uC88B\uB2E4."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC8FC\uC778\uB2D8\uC758
    \uD488\uACA9 \uC788\uB294 \uBAA8\uC2B5\uC774 \uC774\uBBF8 \uBC31\uC791\uB2D8\uC744
    \uB2EE\uC558\uB2E4\uACE0 \uCE6D\uCC2C\uD588\uC2B5\uB2C8\uB2E4."
