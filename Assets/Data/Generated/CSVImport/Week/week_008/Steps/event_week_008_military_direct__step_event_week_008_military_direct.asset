--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_military_direct__step_event_week_008_military_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD615\uC5D0\uC11C \uC124 \uC790\uB9AC\uB97C \uC77D\uB294\uB2E4"
  _bodyText: "\uAD70\uC0AC \uC804\uB7B5\uACFC \uBC29\uC5B4 \uC9C4\uD615 8\uC8FC\uCC28
    Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC791\uC740 \uBAA8\uB798\uD310 \uC704\uC5D0 \uC5B8\uB355, \uC232, \uAE38\uBAA9\uC774
      \uD45C\uC2DC\uB418\uC5B4 \uC788\uB2E4. \uBCD1\uC815 \uB9D0 \uBA87 \uAC1C\uAC00
      \uB193\uC5EC \uC788\uACE0, \uC624\uB298\uC740 \uC9C0\uD615\uC744 \uBA3C\uC800
      \uC77D\uB294 \uC5F0\uC2B5\uC744 \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC624\uB298\uC740 \uBCD1\uC0AC\uB97C \uC6C0\uC9C1\uC774\uAE30 \uC804\uC5D0,
      \uC11C \uC788\uB294 \uB545\uBD80\uD130 \uBCF4\uB294 \uC218\uC5C5\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC0AC\uB78C\uBCF4\uB2E4 \uB545\uBD80\uD130?"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uB124. \uC0AC\uB78C\uC740 \uC6C0\uC9C1\uC5EC\uB3C4 \uC9C0\uD615\uC740
      \uBA3C\uC800 \uBC84\uD2F0\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC232\uC740 \uC228\uAE30 \uC88B\uC9C0\uB9CC, \uC5EC\uAE30 \uC5B8\uB355\uC774
      \uB354 \uBA3C\uC800 \uB208\uC5D0 \uB744\uB124."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC774\uC720\uB294\uC694?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC704\uC5D0\uC11C \uBCF4\uBA74 \uAE38\uC774 \uB2E4 \uBCF4\uC774\uB2C8\uAE4C."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC88B\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uC804\uD22C\uB3C4 \uACB0\uAD6D \uC5B4\uB514\uC5D0 \uC11C
      \uC788\uB290\uB0D0\uAC00 \uBA3C\uC800\uB124."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC815\uD655\uD569\uB2C8\uB2E4."
  _nemoLine: "(\uC791\uC740 \uBAA8\uB798\uD310 \uC704\uC5D0 \uC5B8\uB355, \uC232,
    \uAE38\uBAA9\uC774 \uD45C\uC2DC\uB418\uC5B4 \uC788\uB2E4. \uBCD1\uC815 \uB9D0
    \uBA87 \uAC1C\uAC00 \uB193\uC5EC \uC788\uACE0, \uC624\uB298\uC740 \uC9C0\uD615\uC744
    \uBA3C\uC800 \uC77D\uB294 \uC5F0\uC2B5\uC744 \uD55C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
