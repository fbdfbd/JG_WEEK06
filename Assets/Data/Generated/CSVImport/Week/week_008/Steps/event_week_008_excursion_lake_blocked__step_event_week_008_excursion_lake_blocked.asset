  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_excursion_lake_blocked__step_event_week_008_excursion_lake_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 \uD1B5\uC81C"
  _bodyText: "excursion lake Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uB124\uBAA8\uC758 \uC2DC\uC57C\uB97C
      \uAC00\uB85C\uB9C9\uC73C\uBA70 \uBAB8\uC744 \uB3CC\uB9AC\uAC8C \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC190\uB2D8\uB4E4\uC758 \uC0AC\uC18C\uD55C \uC5C5\uBB34\uC77C \uBFD0\uC785\uB2C8\uB2E4.
      \uC548\uC8FC\uC778\uC774 \uB418\uC2E4 \uBD84\uC774 \uC678\uBD80\uC778\uC5D0\uAC8C
      \uD568\uBD80\uB85C \uC2DC\uC120\uC744 \uC8FC\uB294 \uAC83\uC740 \uC88B\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4. \uCF54\uC2A4\uB97C \uBCC0\uACBD\uD558\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBCC4\uC7A5\uC774\uB77C\uB1E8? \uC544\uBC84\uC9C0\uB294 \uADF8\uB7F0
      \uB9D0\uC500 \uC5C6\uC73C\uC168\uC796\uC544\uC694. \uC5EC\uAE34 \uB0B4 \uC0B0\uCC45\uB85C\uC778\uB370!"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "(\uC5C4\uD558\uAC8C) \uACB0\uC815\uB41C \uAC83\uC740 \uC544\uBB34\uAC83\uB3C4
      \uC5C6\uC2B5\uB2C8\uB2E4. \uBD88\uD544\uC694\uD55C \uC18C\uBB38\uC5D0 \uD754\uB4E4\uB9AC\uC9C0
      \uB9C8\uC2ED\uC2DC\uC624."
  _nemoLine: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uB124\uBAA8\uC758 \uC2DC\uC57C\uB97C
    \uAC00\uB85C\uB9C9\uC73C\uBA70 \uBAB8\uC744 \uB3CC\uB9AC\uAC8C \uD55C\uB2E4.)"
