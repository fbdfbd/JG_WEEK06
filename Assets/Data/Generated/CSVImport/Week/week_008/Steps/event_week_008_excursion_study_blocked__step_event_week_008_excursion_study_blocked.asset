  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_excursion_study_blocked__step_event_week_008_excursion_study_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC11C\uC7AC \uD1B5\uC81C"
  _bodyText: "excursion study Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uC2DC\uACC4\uC758 \uC791\uB3D9\uC744
      \uBA48\uCD94\uACE0 \uCC9C\uC73C\uB85C \uB36E\uC5B4\uBC84\uB9B0\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC8FC\uC778\uC758 \uACF5\uAC04\uC5D0 \uCD9C\uCC98\uAC00 \uBD88\uBD84\uBA85\uD55C
      \uBB3C\uAC74\uC744 \uB4E4\uC774\uB294 \uAC83\uC740 \uC704\uD5D8\uD569\uB2C8\uB2E4.
      \uCE74\uC774\uC628\uB2D8\uC758 \uD638\uC758\uB294 \uAC10\uC0AC\uD788 \uBC1B\uB418,
      \uC774 \uC2DC\uACC4\uB294 \uCC3D\uACE0\uB85C \uC62E\uAE30\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD558\uC9C0\uB9CC \uC544\uC800\uC528, \uC120\uBB3C\uC778\uB370 \uB108\uBB34
      \uBB34\uB840\uD55C \uAC70 \uC544\uB2D0\uAE4C\uC694?"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uBB34\uB840\uD568\uBCF4\uB2E4\uB294 \uC548\uC804\uC774 \uC6B0\uC120\uC785\uB2C8\uB2E4.
      \uC81C \uB9D0\uC744 \uB530\uB974\uC2ED\uC2DC\uC624."
  _nemoLine: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uC2DC\uACC4\uC758 \uC791\uB3D9\uC744
    \uBA48\uCD94\uACE0 \uCC9C\uC73C\uB85C \uB36E\uC5B4\uBC84\uB9B0\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
