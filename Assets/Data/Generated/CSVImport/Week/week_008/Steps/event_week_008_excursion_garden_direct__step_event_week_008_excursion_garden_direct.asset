  _titleOverride: "\uC815\uC6D0 \uD5C8\uAC00"
  _bodyText: "excursion garden Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC0AC\uCD0C 1\uB2D8\uC774 \uC65C \uC0AC\uB78C\uB4E4\uC744 \uC5EC\uAE30\uAE4C\uC9C0
      \uBCF4\uB0B4\uC2E0 \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uC694\uC998 \uC800\uD0DD \uC8FC\uBCC0 \uC870\uC0AC\uB97C \uD558\uC2E0\uB2E4\uB098
      \uBD10\uC694. \uC8FC\uC778\uB2D8\uC740 \uAC71\uC815 \uB9C8\uC138\uC694, \uBC31\uC791\uB2D8\uC774
      \uC54C\uC544\uC11C \uD558\uC2DC\uACA0\uC8E0."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB798\uB3C4... \uC6B0\uB9AC \uC9D1\uC778\uB370 \uC65C \uC790\uAFB8
      \uB0AF\uC120 \uC0AC\uB78C\uB4E4\uC774 \uBCF4\uC774\uB294\uC9C0 \uAE30\uBD84\uC774
      \uC774\uC0C1\uD574."
  _nemoLine: "\uC0AC\uCD0C 1\uB2D8\uC774 \uC65C \uC0AC\uB78C\uB4E4\uC744 \uC5EC\uAE30\uAE4C\uC9C0
    \uBCF4\uB0B4\uC2E0 \uAC70\uC57C?"
