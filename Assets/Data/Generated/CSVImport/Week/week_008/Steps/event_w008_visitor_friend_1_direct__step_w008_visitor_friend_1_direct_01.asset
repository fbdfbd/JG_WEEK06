  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_visitor_friend_1_direct__step_w008_visitor_friend_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 8\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D (\uC6B0\uC815\uC758
    \uD655\uC7A5)(\uB124\uBAA8\uAC00 \uCE5C\uAD6C 1\uC758 \uC190\uC744 \uC7A1\uACE0
    \uC9C0\uB3C4 \uC704\uC5D0 \uC232\uC744 \uAC00\uB9AC\uD0A8\uB2E4.)\uB124\uBAA8
    : \uCE5C\uAD6C 1, \uADF8\uB7FC \uC131\uC778\uC2DD\uC774 \uB05D\uB098\uBA74 \uB098\uB791
    \uAC19\uC774 \uC800 \uC232\uC5D0 \uAC00\uBCF4\uC790. \uBC31\uC791\uB2D8\uC774
    \uB098\uB97C \uC704\uD574 \uC9C0\uCF1C\uB0B8 \uADF8\uACF3\uC774 \uC5B4\uB5A4
    \uACF3\uC778\uC9C0 \uB0B4 \uB208\uC73C\uB85C \uC9C1\uC811 \uD655\uC778\uD558\uACE0
    \uC2F6\uC5B4."
  _bodyText: "(\uC0AC\uCD0C 1\uC774 '\uBD80\uBAA8\uB2D8\uC758 \uBE44\uADF9'\uC774\uB77C\uBA70
    \uAC00\uB9AC\uCF30\uB358 \uADF8 \uC232\uC744 \uCE5C\uAD6C 1\uACFC \uD568\uAED8
    \uCC3D\uBC16\uC73C\uB85C \uBC14\uB77C\uBCF4\uACE0 \uC788\uC5B4. \uB124\uBAA8\uC758
    \uB208\uBE5B\uC774 \uD754\uB4E4\uB9AC\uC790, \uCE5C\uAD6C 1\uC740 \uB124\uBAA8\uC758
    \uC5B4\uAE68\uC5D0 \uC190\uC744 \uC5B9\uC5B4.)\r\n        \r\n        \uCE5C\uAD6C
    1 : \uB124\uBAA8\uC57C, \uC0AC\uCD0C 1\uC774 \uD558\uB294 \uC598\uAE30 \uB4E4\uC5C8\uC5B4.
    \uC800 \uC232\uC5D0\uC11C \uAE30\uC0AC\uB2E8\uC774 \uBC29\uAD00\uD588\uB2E4\uACE0?
    \uADF8\uAC74 \uB9D0\uB3C4 \uC548 \uB3FC. \uC6B0\uB9AC \uC544\uBC84\uC9C0\uAC00
    \uADF8\uB54C \uAE30\uC0AC\uB2E8 \uB9D0\uB2E8\uC774\uC5C8\uB294\uB370, \uBC31\uC791\uB2D8\uC740
    \uADF8\uB0A0 \uB124 \uBD80\uBAA8\uB2D8\uC744 \uAD6C\uD558\uB824\uACE0 \uC9C1\uC811
    \uB9D0\uAE4C\uC9C0 \uD0C0\uC168\uB2E4\uACE0 \uD558\uC168\uC5B4. \uBE44\uB85D
    \uACB0\uACFC\uB294 \uC2AC\uD390\uC9C0\uB9CC...\r\n        \uB124\uBAA8 : (\uCC3D\uD2C0\uC744
    \uAF49 \uC950\uBA70) \uC815\uB9D0... \uBC31\uC791\uB2D8\uC774 \uC9C1\uC811 \uAC00\uC168\uB2E4\uACE0?
    \uC0AC\uCD0C 1\uC740 \uBC31\uC791\uB2D8\uC774 \uC228\uAE30\uB294 \uAC8C \uB9CE\uB2E4\uACE0
    \uD588\uB2E8 \uB9D0\uC774\uC57C.\r\n        \r\n\r\n\uCE5C\uAD6C 1 : \uB2F9\uC5F0\uD558\uC9C0!
    \uBC31\uC791\uB2D8\uB3C4 \uB124\uAC00 \uB098\uC640 \uD568\uAED8\uB77C\uBA74 \uD5C8\uB77D\uD574
    \uC8FC\uC2E4 \uAC70\uC57C. \uC6B0\uB9AC\uAC00 \uAC00\uC11C \uADF8\uB0A0\uC758
    \uC2AC\uD508 \uAE30\uC5B5 \uB300\uC2E0 \uC0C8\uB85C\uC6B4 \uCD94\uC5B5\uC744
    \uCC44\uC6CC \uB123\uC790.\r\n        \uB124\uBAA8 : \uADF8\uB798. \uC774\uC81C
    \uB354 \uC774\uC0C1 \uC0BC\uCD0C\uC758 \uB3C5\uC124\uC5D0 \uD718\uB458\uB9AC\uC9C0
    \uC54A\uC544. \uB098\uC5D0\uAC90 \uBC31\uC791\uB2D8\uACFC \uB124\uAC00 \uC788\uC73C\uB2C8\uAE4C."
