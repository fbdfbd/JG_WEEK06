  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_excursion_study_direct__step_w008_excursion_study_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC 8\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uC11C\uC7AC \uD55C\uAC00\uC6B4\uB370, \uC0AC\uCD0C 1\uC774 \uC131\uC778\uC2DD
    \uCD95\uD558 \uC120\uBB3C\uC774\uB77C\uBA70 \uBBF8\uB9AC \uBCF4\uB0B4\uC628 \uD654\uB824\uD55C
    \uAD18\uC885\uC2DC\uACC4\uAC00 \uB193\uC5EC \uC788\uB2E4. \uC2DC\uACC4\uC758
    \uCD08\uCE68 \uC18C\uB9AC\uAC00 \uD3C9\uC18C\uBCF4\uB2E4 \uC720\uB3C5 \uD06C\uAC8C
    \uB4E4\uB824\uC628\uB2E4.)\r\n        \r\n        \uD558\uB140 1 : \uC0AC\uCD0C
    1\uB2D8\uC774 \uBCF4\uB0B4\uC2E0 \uC2DC\uACC4\uB77C\uB294\uB370, \uB108\uBB34
    \uD654\uB824\uD574\uC11C \uC6B0\uB9AC \uC11C\uC7AC \uBD84\uC704\uAE30\uB791\uC740
    \uC870\uAE08 \uC548 \uC5B4\uC6B8\uB9AC\uB294 \uAC83 \uAC19\uAE30\uB3C4 \uD574\uC694.\r\n       
    \uD558\uB140 2 : \uC27F, \uC870\uC6A9\uD788 \uD574. \uC2DC\uACC4 \uC548\uC5D0
    \uAC10\uC2DC \uC7A5\uCE58\uB77C\uB3C4 \uC788\uC73C\uBA74 \uC5B4\uB5A1\uD574?
    \uC694\uC998 \uC0AC\uCD0C 1\uB2D8 \uBD84\uC704\uAE30\uAC00 \uC774\uC0C1\uD558\uC796\uC544.\r\n       
    \r\n\r\n- \uB124\uBAA8 : (\uC2DC\uACC4\uC758 \uADDC\uCE59\uC801\uC778 \uC18C\uB9AC\uB97C
    \uB4E4\uC73C\uBA70) \uC18C\uB9AC\uAC00 \uC870\uAE08 \uD06C\uAE34 \uD558\uC9C0\uB9CC...
    \uC2DC\uAC04\uC774 \uC815\uD655\uD558\uAE34 \uD558\uB124. \uC0AC\uCD0C 1\uB2D8\uC740
    \uB0B4\uAC00 \uC2DC\uAC04\uC744 \uD5DB\uB418\uC774 \uC4F0\uC9C0 \uC54A\uAE38
    \uBC14\uB77C\uC2DC\uB294 \uAC78\uAE4C?\r\n        \uD558\uB140 : \uADF8\uB7F4
    \uC218\uB3C4 \uC788\uACA0\uC9C0\uB9CC, \uC660\uC9C0 \uC8FC\uC778\uB2D8\uC744
    \uC7AC\uCD09\uD558\uB294 \uAC83 \uAC19\uC544\uC11C \uAE30\uBD84\uC774 \uBB18\uD574\uC694.\r\n       
    \uB124\uBAA8 : \uB9DE\uC544. \uB0B4 \uACF5\uAC04\uC778\uB370 \uC0AC\uCD0C 1\uB2D8\uC774
    \uC606\uC5D0\uC11C \uC9C0\uCF1C\uBCF4\uACE0 \uC788\uB294 \uAC83 \uAC19\uC544.
    \uB2F9\uBD84\uAC04\uC740 \uC2E0\uACBD\uC774 \uC4F0\uC77C \uAC83 \uAC19\uB124."
