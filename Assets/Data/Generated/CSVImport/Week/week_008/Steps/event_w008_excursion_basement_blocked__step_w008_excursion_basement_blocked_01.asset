  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_excursion_basement_blocked__step_w008_excursion_basement_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 8\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uC640\uC778 \uC800\uC7A5\uACE0 \uB108\uBA38, \uD3C9\uC18C\uC5D4 \uBE44\uC5B4\uC788\uB358
    \uAD6C\uC5ED\uC5D0 \uC544\uBB34\uB7F0 \uBB38\uC7A5\uC774 \uCC0D\uD788\uC9C0 \uC54A\uC740
    \uD06C\uACE0 \uBB35\uC9C1\uD55C \uB098\uBB34 \uC0C1\uC790\uB4E4\uC774 \uC794\uB729
    \uC313\uC5EC \uC788\uB2E4.)\n        \uD558\uB140 1 : \uC5B4\uB77C? \uBABB \uBCF4\uB358
    \uC0C1\uC790\uB4E4\uC774\uB124. \uC694\uB9AC\uC0AC\uB2D8\uC774 \uC0C8\uB85C \uC2DD\uC790\uC7AC\uB97C
    \uC8FC\uBB38\uD558\uC168\uB098?\n        \uD558\uB140 2 : \uC27F, \uC544\uB2C8\uC57C.
    \uC5B4\uC82F\uBC24\uC5D0 \uC0AC\uCD0C 1\uB2D8\uC774 \uBCF4\uB0B8 \uC0AC\uB78C\uB4E4\uC774
    \uBAB0\uB798 \uC9D0\uC744 \uB0B4\uB824\uB193\uACE0 \uAC00\uB294 \uAC78 \uBD24\uB2E4\uB294
    \uD558\uC778\uC774 \uC788\uC5B4.\n        \n\n(\uACBD\uBE44\uB300\uC7A5\uC774
    \uC0C1\uC790 \uACC1\uC73C\uB85C \uB2E4\uAC00\uAC00\uB294 \uB124\uBAA8\uC758 \uC55E\uC744
    \uB9C9\uC544\uC120\uB2E4.)\n        \uACBD\uBE44\uB300\uC7A5 : \uC5B4\uB978\uB4E4
    \uAC04\uC758 \uBCF5\uC7A1\uD55C \uBB3C\uB958 \uC774\uB3D9\uC77C \uBFD0\uC785\uB2C8\uB2E4.
    \uC544\uAC00\uC528\uAED8\uC11C \uC2E0\uACBD \uC4F0\uC2E4 \uC77C\uC774 \uC544\uB2D9\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uD558\uC9C0\uB9CC \uC6B0\uB9AC \uC800\uD0DD \uC9C0\uD558\uC2E4\uC774\uC796\uC544\uC694.
    \uB0B4\uC6A9\uBB3C\uC774 \uBB54\uC9C0 \uD655\uC778\uC740 \uD574\uC57C\uC8E0!\n       
    \uACBD\uBE44\uB300\uC7A5 : \uD638\uAE30\uC2EC\uC774 \uB54C\uB85C\uB294 \uC548\uC804\uC744
    \uC704\uD611\uD558\uAE30\uB3C4 \uD569\uB2C8\uB2E4. \uC9C0\uAE08\uC740 \uBABB
    \uBCF8 \uCC99 \uACE0\uAC1C\uB97C \uB3CC\uB9AC\uB294 \uBC95\uC744 \uBC30\uC6B0\uC2ED\uC2DC\uC624."
