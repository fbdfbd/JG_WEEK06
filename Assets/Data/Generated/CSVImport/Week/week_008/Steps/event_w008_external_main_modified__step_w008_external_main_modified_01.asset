  m_Name: event_w008_external_main_modified__step_w008_external_main_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "8\uCC28 - \uC218\uC815"
  _bodyText: "\uC218\uB3C4\uC758 \uC815\uBCC0\uACFC \uC0AC\uB77C\uC9C4 \uC655\uB140\n   
    \n    (\uC751\uC811\uC2E4 \uBC16 \uBCF5\uB3C4, \uC218\uB3C4\uC5D0\uC11C \uC628
    \uC0AC\uC808\uC758 \uB9C8\uBD80\uAC00 \uC800\uD0DD \uD558\uC778\uB4E4\uACFC \uC2EC\uAC01\uD55C
    \uD45C\uC815\uC73C\uB85C \uB300\uD654\uD55C\uB2E4.)\n    \n    \uB9C8\uBD80 1
    : \uC218\uB3C4\uAC00 \uBC1C\uCE75 \uB4A4\uC9D1\uD614\uC5B4. \uC655\uC2E4\uC5D0
    \uD070 \uC2F8\uC6C0\uC774 \uB098\uC11C \uC5B4\uB9B0 \uC655\uB140\uB2D8\uC774
    \uBE44\uBC00\uB9AC\uC5D0 \uD53C\uC2E0\uD588\uB2E4\uB294\uB370, \uD589\uBC29\uC774
    \uBB18\uC5F0\uD558\uB300.\n    \uD558\uC778 : \uC124\uB9C8 \uC774 \uBA3C \uACF3\uAE4C\uC9C0
    \uC624\uACA0\uC5B4? \uC5EC\uAE30\uB294 \uC6CC\uB099 \uC870\uC6A9\uD574\uC11C
    \uC228\uAE30\uC5D4 \uB531\uC774\uAE34 \uD558\uC9C0\uB9CC...\n    \uB124\uBAA8
    : \uC655\uB140\uB2D8\uC774 \uB3C4\uB9DD\uAC14\uC5B4? \uC6B0\uB9AC \uC9D1\uC5D0
    \uC228\uC5B4 \uC788\uB294 \uAC70 \uC544\uB2C8\uC57C?\n    \n\n- \uB9C8\uBD80
    1 : \uC2E4\uC740 \uB3C4\uB9DD\uCE5C \uAC8C \uC544\uB2C8\uB77C, \uC131\uC778\uC774
    \uB418\uAE30 \uC804\uC5D0 \uB113\uC740 \uC138\uC0C1\uC744 \uBC30\uC6B0\uB824\uACE0
    \uBAB0\uB798 \uC5EC\uD589\uC744 \uB5A0\uB098\uC2E0 \uAC70\uB798\uC694.\n    \uB124\uBAA8
    : \uACF5\uBD80\uD558\uB7EC \uC5EC\uD589\uC744 \uAC04 \uAC70\uC57C? \uB098\uB791
    \uBE44\uC2B7\uD558\uB124!\n    \uD558\uC778 : \uB124. \uBC31\uC791\uB2D8\uB3C4
    \uC8FC\uC778\uB2D8\uC774 \uB098\uC911\uC5D0 \uADF8\uB7F0 \uBA4B\uC9C4 \uC5EC\uD589\uC744
    \uD558\uAE38 \uBC14\uB77C\uC2E4 \uAC70\uC608\uC694. \uC704\uD5D8\uD55C \uC77C\uC774
    \uC544\uB2C8\uB2C8 \uAC71\uC815 \uB9C8\uC138\uC694.\n    \uB124\uBAA8 : \uADF8\uB807\uAD6C\uB098.
    \uC655\uB140\uB2D8\uB3C4 \uB098\uCC98\uB7FC \uC88B\uC740 \uCE5C\uAD6C\uB4E4\uC744
    \uB9CE\uC774 \uB9CC\uB0AC\uC73C\uBA74 \uC88B\uACA0\uB2E4."
