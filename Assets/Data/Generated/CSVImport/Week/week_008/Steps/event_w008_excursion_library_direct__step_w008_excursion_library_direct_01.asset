  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_excursion_library_direct__step_w008_excursion_library_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 8\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uAE08\uC11C \uAD6C\uC5ED \uADFC\uCC98, \uD3C9\uC18C\uC5D4 \uC798
    \uC5F4\uC9C0 \uC54A\uB294 \uAC00\uBB38 \uAE30\uB85D \uBCF4\uAD00\uC18C\uC758
    \uC11C\uB78D\uC774 \uC0B4\uC9DD \uC5F4\uB824 \uC788\uB2E4. \uADF8 \uC548\uC5D0\uB294
    \uC0AC\uCD0C 1\uC758 \uC778\uC7A5\uC774 \uCC0D\uD78C \uB0AF\uC120 \uACC4\uC57D\uC11C
    \uCD08\uC548\uB4E4\uC774 \uD769\uC5B4\uC838 \uC788\uB2E4.)\r\n        \uD558\uB140
    1 : \uC774\uC0C1\uD558\uB2E4. \uC774 \uC11C\uB958\uB4E4\uC740 \uBC31\uC791\uB2D8
    \uD5C8\uB77D \uC5C6\uC774\uB294 \uAEBC\uB0BC \uC218 \uC5C6\uB294 \uAC83\uB4E4\uC778\uB370...\r\n       
    \uD558\uB140 2 : \uC5B4\uC81C \uC0AC\uCD0C 1\uB2D8\uC774 \uB3C4\uC11C\uAD00\uC7A5\uB2D8\uACFC
    \uD55C\uCC38 \uB3D9\uC548 \uC5EC\uAE30\uC11C \uC774\uC57C\uAE30\uB97C \uB098\uB204\uC2DC\uB354\uB77C\uACE0\uC694.\r\n       
    \r\n\r\n- \uD558\uB140 1 : \uC800 \uACC4\uC57D\uC11C... \uC6B0\uB9AC \uC800\uD0DD\uC758
    \uC77C\uBD80 \uBD80\uC9C0\uB97C \uB9E4\uAC01\uD558\uACA0\uB2E4\uB294 \uB0B4\uC6A9
    \uAC19\uC740\uB370, \uAD1C\uCC2E\uC740 \uAC78\uAE4C\uC694?\r\n        \uB124\uBAA8
    : (\uC2EC\uAC01\uD55C \uD45C\uC815\uC73C\uB85C \uC11C\uB958 \uB0B4\uC6A9\uC744
    \uD6D1\uC73C\uBA70) \uC0AC\uCD0C 1\uB2D8\uC774 \uC65C \uC774\uB7F0 \uACC4\uD68D\uC744
    \uC138\uC6B0\uC2DC\uB294 \uAC70\uC9C0? \uC544\uBC84\uC9C0\uAED8\uC120 \uC774\uB7F0
    \uB9D0\uC500\uC744 \uD558\uC2E0 \uC801\uC774 \uC5C6\uB294\uB370.\r\n        \uD558\uB140
    2 : \uC0AC\uCD0C 1\uB2D8\uC774 \uBBF8\uB9AC \uC900\uBE44\uD558\uC2DC\uB294 \uAC78\uC9C0\uB3C4
    \uBAB0\uB77C\uC694.\r\n        \uB124\uBAA8 : \uC900\uBE44\uB77C\uB2C8, \uC8FC\uC778
    \uD589\uC138\uB97C \uD558\uB824\uB294 \uAC74 \uC544\uB2C8\uACA0\uC9C0? \uB0B4\uAC00
    \uB354 \uC9C0\uCF1C\uBD10\uC57C\uACA0\uC5B4."
