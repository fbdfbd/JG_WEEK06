  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_letter_friend_3_modified__step_event_week_008_letter_friend_3_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC720\uD53C \uC218\uC815"
  _bodyText: "letter friend_3 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC11C\uC7AC \uC548\uC5D0\uC11C\uB3C4
      \uBC14\uAE65\uC138\uC0C1\uC758 \uBE5B\uC744 \uB290\uB084 \uC218 \uC788\uB294
      \uBC29\uBC95\uC744 \uC54C\uB824\uC92C\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4\uB5BB\uAC8C \uB290\uB07C\uB294\uB370?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uAC70\uC6B8\uC5D0 \uBE44\uCE5C \uD587\uBE5B \uD55C \uC870\uAC01\uB3C4
      \uC8FC\uC778\uB2D8\uC744 \uD5A5\uD55C \uC138\uC0C1\uC758 \uC778\uC0AC\uB77C\uACE0
      \uC0DD\uAC01\uD558\uB798\uC694. \uBC31\uC791\uB2D8\uB3C4 \uC8FC\uC778\uB2D8\uC774
      \uD56D\uC0C1 \uBC1D\uC740 \uACF3\uB9CC \uBCF4\uAE38 \uBC14\uB77C\uC2E0\uB2E4\uBA74\uC11C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC54\uB294 \uC9C4\uC9DC \uC2E0\uAE30\uD55C \uAC78 \uC798 \uCC3E\uC544\uB0B4.
      \uC11C\uC7AC\uAC00 \uAC11\uC790\uAE30 \uD658\uD574\uC9C4 \uAC83 \uAC19\uC544."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC11C\uC7AC \uC548\uC5D0\uC11C\uB3C4
    \uBC14\uAE65\uC138\uC0C1\uC758 \uBE5B\uC744 \uB290\uB084 \uC218 \uC788\uB294
    \uBC29\uBC95\uC744 \uC54C\uB824\uC92C\uC5B4\uC694."
  _useCustomVisualState: 0
  _visualState: 0
