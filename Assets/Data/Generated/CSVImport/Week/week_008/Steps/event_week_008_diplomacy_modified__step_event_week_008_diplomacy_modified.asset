  m_Name: event_week_008_diplomacy_modified__step_event_week_008_diplomacy_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC678\uAD50 \uC218\uC5C5\uC744 \uB300\uD654 \uC5F0\uC2B5\uCC98\uB7FC
    \uD47C\uB2E4"
  _bodyText: "\uC678\uAD50 \uC218\uC5C5\uC744 \uB300\uD654 \uC5F0\uC2B5\uCC98\uB7FC
    \uD47C\uB2E4 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC0C1\uD669\uADF9\uCC98\uB7FC \uC5ED\uD560\uC744 \uB098\uB220 \uC678\uAD50
      \uAD50\uC7AC \uB0B4\uC6A9\uC744 \uC790\uC5F0\uC2A4\uB7FD\uAC8C \uC775\uD788\uAC8C
      \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC81C\uAC00 \uC0AC\uC808\uC774\uBA74 \uBB50\uB77C\uACE0 \uBA3C\uC800
      \uB9D0\uD574\uC57C \uD574?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uB531\uB531\uD55C \uADDC\uCE59 \uB300\uC2E0 \uB300\uD654 \uD750\uB984\uC744
      \uBAB8\uC5D0 \uC775\uD788\uAC8C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uB9D0\uC2F8\uC6C0\uC774 \uC544\uB2C8\uB77C \uC904\uB2E4\uB9AC\uAE30
      \uAC19\uC544."
  _nemoLine: "(\uC0C1\uD669\uADF9\uCC98\uB7FC \uC5ED\uD560\uC744 \uB098\uB220 \uC678\uAD50
    \uAD50\uC7AC \uB0B4\uC6A9\uC744 \uC790\uC5F0\uC2A4\uB7FD\uAC8C \uC775\uD788\uAC8C
    \uD55C\uB2E4.)"
