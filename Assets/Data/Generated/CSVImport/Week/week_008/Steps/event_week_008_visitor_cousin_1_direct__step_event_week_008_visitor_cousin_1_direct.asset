  _titleOverride: "\uCE74\uC774\uC548 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor cousin_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 8359404ef52515f4888306bbceaf40c0, type: 2}
    _text: "\uB09C \uADF8\uC800 \uB124\uAC00 \uBC14\uBCF4\uB85C \uC0AC\uB294 \uAC8C
      \uC548\uD0C0\uAE4C\uC6B8 \uBFD0\uC774\uC57C. \uBC31\uC791\uC774 \uB110 \uC774
      \uC11C\uC7AC\uC5D0 \uAC00\uB46C\uB454 \uAC74 \uB110 \uC0AC\uB791\uD574\uC11C\uAC00
      \uC544\uB2C8\uB77C, \uB124\uAC00 \uC9C4\uC2E4\uC744 \uBCF4\uACE0 \uADF8\uBD84\uC744
      \uC6D0\uB9DD\uD560\uAE4C \uBD10 \uAC81\uC774 \uB098\uC11C\uB77C\uACE0."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uB208\uC744 \uAC00\uB298\uAC8C \uB728\uBA70) \uB9CC\uC57D \uBC31\uC791\uB2D8\uC774
      \uB098\uB97C \uC18D\uC778 \uAC70\uB77C\uBA74, \uB0B4\uAC00 \uADF8\uBD84\uC744
      \uBB34\uB108\uB728\uB9B4 \uAC70\uC608\uC694. \uC0BC\uCD0C \uAC19\uC740 \uC778\uAC04\uC5D0\uAC8C
      \uAE30\uD68C\uB97C \uC8FC\uC9C0\uB294 \uC54A\uC744 \uAC70\uB2C8\uAE4C \uAFC8
      \uAE68\uC138\uC694."
  _nemoLine: "\uB09C \uADF8\uC800 \uB124\uAC00 \uBC14\uBCF4\uB85C \uC0AC\uB294 \uAC8C
    \uC548\uD0C0\uAE4C\uC6B8 \uBFD0\uC774\uC57C. \uBC31\uC791\uC774 \uB110 \uC774
    \uC11C\uC7AC\uC5D0 \uAC00\uB46C\uB454 \uAC74 \uB110 \uC0AC\uB791\uD574\uC11C\uAC00
    \uC544\uB2C8\uB77C, \uB124\uAC00 \uC9C4\uC2E4\uC744 \uBCF4\uACE0 \uADF8\uBD84\uC744
    \uC6D0\uB9DD\uD560\uAE4C \uBD10 \uAC81\uC774 \uB098\uC11C\uB77C\uACE0."
