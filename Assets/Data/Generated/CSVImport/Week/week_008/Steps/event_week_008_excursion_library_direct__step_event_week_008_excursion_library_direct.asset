  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_excursion_library_direct__step_event_week_008_excursion_library_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 \uD5C8\uAC00"
  _bodyText: "excursion library Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uC2EC\uAC01\uD55C \uD45C\uC815\uC73C\uB85C \uC11C\uB958 \uB0B4\uC6A9\uC744
      \uD6D1\uC73C\uBA70) \uCE74\uC774\uC628\uB2D8\uC774 \uC65C \uC774\uB7F0 \uACC4\uD68D\uC744
      \uC138\uC6B0\uC2DC\uB294 \uAC70\uC9C0? \uC544\uBC84\uC9C0\uAED8\uC120 \uC774\uB7F0
      \uB9D0\uC500\uC744 \uD558\uC2E0 \uC801\uC774 \uC5C6\uB294\uB370."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uCE74\uC774\uC628\uB2D8\uC774 \uBBF8\uB9AC \uC900\uBE44\uD558\uC2DC\uB294
      \uAC78\uC9C0\uB3C4 \uBAB0\uB77C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC900\uBE44\uB77C\uB2C8, \uC8FC\uC778 \uD589\uC138\uB97C \uD558\uB824\uB294
      \uAC74 \uC544\uB2C8\uACA0\uC9C0? \uB0B4\uAC00 \uB354 \uC9C0\uCF1C\uBD10\uC57C\uACA0\uC5B4."
  _nemoLine: "(\uC2EC\uAC01\uD55C \uD45C\uC815\uC73C\uB85C \uC11C\uB958 \uB0B4\uC6A9\uC744
    \uD6D1\uC73C\uBA70) \uCE74\uC774\uC628\uB2D8\uC774 \uC65C \uC774\uB7F0 \uACC4\uD68D\uC744
    \uC138\uC6B0\uC2DC\uB294 \uAC70\uC9C0? \uC544\uBC84\uC9C0\uAED8\uC120 \uC774\uB7F0
    \uB9D0\uC500\uC744 \uD558\uC2E0 \uC801\uC774 \uC5C6\uB294\uB370."
