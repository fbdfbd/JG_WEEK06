  m_Name: event_w008_letter_friend_3_modified__step_w008_letter_friend_3_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 8\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C
    \uADC0\uD241\uC774\uC5D0 \uB178\uB780 \uC789\uD06C \uC790\uAD6D\uC774 \uBC88\uC838
    \uC788\uACE0, '\uBE44\uBC00 \uC2E0\uD638 2\uD0C4'\uC774\uB77C\uACE0 \uC801\uD600
    \uC788\uB2E4.)\n        \uD558\uB140 : \uC8FC\uC778\uB2D8 \uC55E\uC73C\uB85C
    \uC628 \uD3B8\uC9C0\uC785\uB2C8\uB2E4. \uC774\uBC88\uC5D4 \uC789\uD06C \uC694\uC815\uC774
    \uC544\uB2C8\uB77C \uD587\uBE5B \uC694\uC815 \uC774\uC57C\uAE30\uB77C\uB294\uB370\uC694?\n       
    \n\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC11C\uC7AC
    \uC548\uC5D0\uC11C\uB3C4 \uBC14\uAE65\uC138\uC0C1\uC758 \uBE5B\uC744 \uB290\uB084
    \uC218 \uC788\uB294 \uBC29\uBC95\uC744 \uC54C\uB824\uC92C\uC5B4\uC694.\n       
    \uB124\uBAA8 : \uC5B4\uB5BB\uAC8C \uB290\uB07C\uB294\uB370?\n        \uD558\uB140
    : \uAC70\uC6B8\uC5D0 \uBE44\uCE5C \uD587\uBE5B \uD55C \uC870\uAC01\uB3C4 \uC8FC\uC778\uB2D8\uC744
    \uD5A5\uD55C \uC138\uC0C1\uC758 \uC778\uC0AC\uB77C\uACE0 \uC0DD\uAC01\uD558\uB798\uC694.
    \uBC31\uC791\uB2D8\uB3C4 \uC8FC\uC778\uB2D8\uC774 \uD56D\uC0C1 \uBC1D\uC740 \uACF3\uB9CC
    \uBCF4\uAE38 \uBC14\uB77C\uC2E0\uB2E4\uBA74\uC11C\uC694.\n        \uB124\uBAA8
    : \uAC54\uB294 \uC9C4\uC9DC \uC2E0\uAE30\uD55C \uAC78 \uC798 \uCC3E\uC544\uB0B4.
    \uC11C\uC7AC\uAC00 \uAC11\uC790\uAE30 \uD658\uD574\uC9C4 \uAC83 \uAC19\uC544."
