  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_visitor_friend_2_direct__step_w008_visitor_friend_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 8\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uB124\uBAA8\uC640 \uCE5C\uAD6C 2\uAC00 \uC11C\uC7AC \uCC3D\uAC00\uC5D0\uC11C
    \uC815\uC6D0\uC744 \uB0B4\uB824\uB2E4\uBCF8\uB2E4. \uC0AC\uCD0C 1\uC774 '\uAC10\uC625'\uC774\uB77C
    \uBD88\uB800\uB358 \uB192\uC740 \uB2F4\uBCBC\uB77D\uC744 \uBCF4\uBA70 \uCE5C\uAD6C
    2\uAC00 \uC785\uC744 \uC5F0\uB2E4.)\n        \n        \uCE5C\uAD6C  : \uC800
    \uB2F4\uC7A5\uC774 \uB2F5\uB2F5\uD574 \uBCF4\uC77C \uC218\uB3C4 \uC788\uACA0\uC9C0\uB9CC,
    \uC800\uAC74 \uB110 \uAC00\uB450\uB294 \uAC8C \uC544\uB2C8\uB77C \uC678\uBD80\uC758
    \uC2DC\uAE30\uC2EC\uC73C\uB85C\uBD80\uD130 \uB110 \uBCF4\uD638\uD558\uB294 \uBC29\uD328\uC57C.
    \uBC31\uC791\uB2D8\uC740 \uB124\uAC00 \uCDA9\uBD84\uD788 \uC790\uB77C\uAE30 \uC804\uAE4C\uC9C0
    \uC138\uC0C1\uC758 \uD48D\uD30C\uB97C \uB300\uC2E0 \uB9DE\uACE0 \uACC4\uC2E0
    \uAC70\uC9C0.\n        \n\n- (\uB124\uBAA8\uAC00 \uCC3D\uD2C0\uC5D0 \uC190\uC744
    \uC5B9\uACE0 \uCE5C\uAD6C 2\uB97C \uBC14\uB77C\uBCF8\uB2E4.)\n        - \uB124\uBAA8
    : \uCE5C\uAD6C 2, \uC131\uC778\uC2DD \uB0A0 \uB0B4\uAC00 \uBC31\uC791\uB2D8\uAED8
    \uAC74\uC758\uD574 \uBCFC\uAC8C. \uC774\uC81C \uC774 \uB2F4\uC7A5\uC744 \uC870\uAE08
    \uB0AE\uCD94\uACE0, \uB108\uD76C \uAC19\uC740 \uCE5C\uAD6C\uB4E4\uC774 \uB354
    \uC790\uC8FC \uB180\uB7EC \uC62C \uC218 \uC788\uAC8C \uD574\uB2EC\uB77C\uACE0.
    \uBC31\uC791\uB2D8\uB3C4 \uC774\uC81C \uB0B4 \uC548\uBAA9\uC744 \uBBFF\uC5B4\uC8FC\uC2E4
    \uAC70\uC57C.\n        \uCE5C\uAD6C 2 : (\uD658\uD558\uAC8C \uC6C3\uC73C\uBA70)
    \uADF8\uAC70 \uC815\uB9D0 \uC88B\uC740 \uC0DD\uAC01\uC774\uB2E4! \uBC31\uC791\uB2D8\uC774
    \uC313\uC544 \uC62C\uB9B0 \uACAC\uACE0\uD55C \uC131\uC5D0 \uB124\uAC00 \uC0DD\uB3D9\uAC10\uC744
    \uBD88\uC5B4\uB123\uB294 \uAC70\uC9C0. \uBC8C\uC368\uBD80\uD130 \uB0B4\uC77C\uC774
    \uAE30\uB2E4\uB824\uC838."
