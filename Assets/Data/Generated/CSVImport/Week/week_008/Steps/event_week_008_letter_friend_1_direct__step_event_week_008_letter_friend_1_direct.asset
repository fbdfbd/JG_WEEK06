  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_letter_friend_1_direct__step_event_week_008_letter_friend_1_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: friend_1 Direct
  _bodyText: "letter friend_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC544\uC8FC \uBC1C\uCE59\uD55C
      \uACC4\uD68D\uC744 \uC138\uC6B4 \uBAA8\uC591\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB54\uB370? \uB610 \uD0C8\uCD9C\uC774\uC57C?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uD3BC\uCE5C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB0B4\uAC00 \uC544\uC800\uC528\uC758 \uB300\uC7A5\uC774 \uB41C\uB2E4\uACE0?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124, \uC8FC\uC778\uB2D8. \uC774\uC81C \uB2F9\uC2E0\uC774 \uC774 \uC800\uD0DD\uC758
      \uC0C8\uB85C\uC6B4 \uADDC\uCE59\uC774 \uB420 \uB0A0\uC774 \uBA38\uC9C0\uC54A\uC558\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544\uC800\uC528\uAC00 \uB098\uD55C\uD14C \uACBD\uB840\uD558\uB294
      \uBAA8\uC2B5... \uC0DD\uAC01\uB9CC \uD574\uB3C4 \uC2E0\uAE30\uD574!"
  _nemoLine: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC544\uC8FC \uBC1C\uCE59\uD55C
    \uACC4\uD68D\uC744 \uC138\uC6B4 \uBAA8\uC591\uC785\uB2C8\uB2E4."
