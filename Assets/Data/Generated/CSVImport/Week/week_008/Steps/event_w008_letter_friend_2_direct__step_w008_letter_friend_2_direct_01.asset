  m_Name: event_w008_letter_friend_2_direct__step_w008_letter_friend_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 \uD3B8\uC9C0 8\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uC870\uAE08 \uB450\uAEBC\uC6B4 \uD3B8\uC9C0\uB97C
    \uB4E4\uACE0 \uC628\uB2E4. \uC548\uC5D0\uB294 \uBE73\uBE73\uD558\uAC8C \uB9D0\uB9B0
    \uAF43\uC78E \uCC45\uAC08\uD53C\uAC00 \uB4E4\uC5B4 \uC788\uB2E4.)\n        \n\n\uD558\uB140
    : \uCE5C\uAD6C\uBD84\uC774 \uC8FC\uC778\uB2D8\uC744 \uC704\uD574 \uC9C1\uC811
    \uB9CC\uB4E0 \uCC45\uAC08\uD53C\uC640 \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\n       
    \uB124\uBAA8 : \uCC45\uAC08\uD53C? \uC608\uC058\uB2E4!\n        (\uD558\uB140\uAC00
    \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)\n        \uB124\uBAA8, \uC694\uC998 \uC0AC\uCD0C
    1 \uB54C\uBB38\uC5D0 \uB9C8\uC74C\uC774 \uC5B4\uC218\uC120\uD558\uC9C0? \uADF8\uB7F4
    \uB550 \uC774 \uAF43\uAC08\uD53C\uB97C \uB07C\uC6CC\uB450\uACE0 \uC7A0\uC2DC
    \uB208\uC744 \uAC10\uC544\uBD10. \uBC31\uC791\uB2D8\uC774 \uB110 \uC704\uD574
    \uC2EC\uC73C\uC2E0 \uAF43\uC758 \uD5A5\uAE30\uC57C. \uB10C \uC774\uBBF8 \uB204\uAD6C\uBCF4\uB2E4
    \uD6CC\uB96D\uD55C \uD6C4\uACC4\uC790\uB2C8\uAE4C \uC2A4\uC2A4\uB85C\uB97C \uBBFF\uC5B4\uB3C4
    \uB3FC.\n        \uB124\uBAA8 : \uBC31\uC791\uB2D8\uC774 \uC2EC\uC73C\uC2E0 \uAF43...
    \uAC54\uB294 \uB0B4 \uB9C8\uC74C\uC744 \uB2E4 \uC544\uB294 \uAC83 \uAC19\uC544.\n       
    \uD558\uB140 : \uC8FC\uC778\uB2D8\uC744 \uB204\uAD6C\uBCF4\uB2E4 \uAC00\uAE4C\uC774\uC11C
    \uC9C0\uCF1C\uBCF4\uACE0 \uC751\uC6D0\uD558\uB294 \uCE5C\uAD6C\uB124\uC694.\n       
    \uB124\uBAA8 : \uC751. \uC774 \uAF43 \uD5A5\uAE30 \uB9E1\uC73C\uB2C8\uAE4C \uBC31\uC791\uB2D8\uC774
    \uBCF4\uACE0 \uC2F6\uC5B4."
