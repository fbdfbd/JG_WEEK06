  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_008_letter_friend_1_modified__step_event_week_008_letter_friend_1_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: friend_1 Modified
  _bodyText: "letter friend_1 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC8FC\uC778\uB2D8\uC758
      \uC131\uC778\uC2DD\uC744 \uB204\uAD6C\uBCF4\uB2E4 \uCD95\uD558\uD558\uBA70
      \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC54\uAC00 \uBB50\uB77C\uACE0 \uD588\uB294\uB370?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC774\uC81C \uC8FC\uC778\uB2D8\uC774 \uC815\uC2DD \uD6C4\uACC4\uC790\uAC00
      \uB418\uBA74, \uACBD\uBE44\uB300\uC7A5\uB2D8\uB3C4 \uC8FC\uC778\uB2D8\uC758
      \uB4E0\uB4E0\uD55C \uC544\uAD70\uC774 \uB420 \uAC70\uB798\uC694. \uADF8\uB7EC\uB2C8
      \uB354 \uC774\uC0C1 \uC544\uC800\uC528\uB97C \uBB34\uC11C\uC6CC\uD558\uC9C0
      \uC54A\uC544\uB3C4 \uB41C\uB2E4\uACE0 \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624, \uADF8\uB7FC \uC774\uC81C \uC544\uC800\uC528\uB791 \uAC19\uC774
      \uC601\uC9C0\uB97C \uC21C\uCC30\uD560 \uC218\uB3C4 \uC788\uACA0\uB124!"
  _nemoLine: "\uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC8FC\uC778\uB2D8\uC758
    \uC131\uC778\uC2DD\uC744 \uB204\uAD6C\uBCF4\uB2E4 \uCD95\uD558\uD558\uBA70 \uAE30\uB2E4\uB9AC\uACE0
    \uC788\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
