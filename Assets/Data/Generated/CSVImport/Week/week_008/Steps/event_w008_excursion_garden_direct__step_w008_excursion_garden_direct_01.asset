  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_excursion_garden_direct__step_w008_excursion_garden_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 8\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uBD84\uC218\uB300 \uADFC\uCC98 \uD654\uB2E8. \uD3C9\uC18C\uC640 \uB2EC\uB9AC
    \uD759\uC774 \uAC70\uCE60\uAC8C \uD30C\uC5EC \uC788\uACE0 \uB0AF\uC120 \uAC00\uC8FD
    \uC7A5\uD654 \uC790\uAD6D\uC774 \uC120\uBA85\uD558\uAC8C \uB0A8\uC544 \uC788\uB2E4.)\r\n       
    \uD558\uB140 1 : \uC774\uC0C1\uD558\uB124, \uC815\uC6D0\uC0AC\uB4E4\uC740 \uC774\uB7F0
    \uAC70\uCE5C \uC2E0\uBC1C\uC744 \uC548 \uC2E0\uB294\uB370...\r\n        \uD558\uB140
    2 : \uC544\uAE4C \uC0AC\uCD0C 1\uB2D8\uC774 \uBCF4\uB0B8 \uC2EC\uBD80\uB984\uAFBC\uB4E4\uC774
    \uC7A0\uC2DC \uB4E4\uB800\uB2E4\uB354\uB2C8, \uADF8 \uC0AC\uB78C\uB4E4\uC778\uAC00
    \uBD10\uC694.\r\n        \r\n\r\n- \uD558\uB140 1 : \uC0AC\uCD0C 1\uB2D8 \uC0AC\uB78C\uB4E4\uC778\uAC00
    \uBCF8\uB370, \uC608\uC758\uAC00 \uB108\uBB34 \uC5C6\uB124\uC694. \uC8FC\uC778\uB2D8
    \uC18C\uC911\uD55C \uAF43\uBC2D\uC778\uB370.\r\n        \uB124\uBAA8 : \uC0AC\uCD0C
    1\uB2D8\uC774 \uC65C \uC0AC\uB78C\uB4E4\uC744 \uC5EC\uAE30\uAE4C\uC9C0 \uBCF4\uB0B4\uC2E0
    \uAC70\uC57C?\r\n        \uD558\uB140 2 : \uC694\uC998 \uC800\uD0DD \uC8FC\uBCC0
    \uC870\uC0AC\uB97C \uD558\uC2E0\uB2E4\uB098 \uBD10\uC694. \uC8FC\uC778\uB2D8\uC740
    \uAC71\uC815 \uB9C8\uC138\uC694, \uBC31\uC791\uB2D8\uC774 \uC54C\uC544\uC11C
    \uD558\uC2DC\uACA0\uC8E0.\r\n        \uB124\uBAA8 : \uADF8\uB798\uB3C4... \uC6B0\uB9AC
    \uC9D1\uC778\uB370 \uC65C \uC790\uAFB8 \uB0AF\uC120 \uC0AC\uB78C\uB4E4\uC774
    \uBCF4\uC774\uB294\uC9C0 \uAE30\uBD84\uC774 \uC774\uC0C1\uD574."
