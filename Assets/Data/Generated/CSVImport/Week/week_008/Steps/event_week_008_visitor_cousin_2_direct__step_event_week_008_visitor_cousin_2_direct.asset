  _titleOverride: "\uB9AC\uC548 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor cousin_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "(\uACBD\uC545\uD558\uBA70) \uB124\uBAA8\uC57C! \uBC31\uC791\uB2D8\uC774
      \uC774 \uC9C0\uB3C4\uB97C \uC5BC\uB9C8\uB098 \uC544\uB07C\uC2DC\uB294\uB370...
      \uB108 \uAD1C\uCC2E\uACA0\uC5B4?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC0C1\uAD00\uC5C6\uC5B4. \uC774 \uC9C0\uB3C4\uAC00 \uC5C6\uC5B4\uB3C4
      \uB09C \uB0B4 \uBC1C\uB85C \uC9C1\uC811 \uC800 \uC232\uC5D0 \uAC08 \uAC70\uB2C8\uAE4C.
      \uB9AC\uC548, \uB108\uB3C4 \uAC19\uC774 \uAC08 \uAC70\uC9C0? \uC6B0\uB9AC \uB458\uC774\uC11C
      \uBC31\uC791\uB2D8\uACFC \uB108\uD76C \uC544\uBC84\uC9C0\uAC00 \uC228\uAE30\uB294
      \uAC78 \uCC3E\uC544\uB0B4\uB294 \uAC70\uC57C."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "(\uB5A8\uB9AC\uB294 \uBAA9\uC18C\uB9AC\uB85C) \uC751... \uB124\uAC00
      \uAC00\uC790\uBA74 \uAC08\uAC8C. \uB10C \uB0B4 \uC720\uC77C\uD55C \uCE5C\uAD6C\uB2C8\uAE4C."
  _nemoLine: "(\uACBD\uC545\uD558\uBA70) \uB124\uBAA8\uC57C! \uBC31\uC791\uB2D8\uC774
    \uC774 \uC9C0\uB3C4\uB97C \uC5BC\uB9C8\uB098 \uC544\uB07C\uC2DC\uB294\uB370...
    \uB108 \uAD1C\uCC2E\uACA0\uC5B4?"
