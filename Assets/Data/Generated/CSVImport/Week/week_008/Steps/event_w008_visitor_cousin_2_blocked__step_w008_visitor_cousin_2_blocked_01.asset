  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_visitor_cousin_2_blocked__step_w008_visitor_cousin_2_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 8\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uB124\uBAA8\uC640 \uC0AC\uCD0C 2\uAC00 \uBC31\uC791\uB2D8\uC758 \uC601\uC9C0
    \uC9C0\uB3C4\uB97C \uBCF4\uACE0 \uC788\uC5B4. \uC0AC\uCD0C 1\uC774 \uAC00\uB9AC\uCF30\uB358
    \uADF8 '\uBE44\uADF9\uC758 \uC232' \uADFC\uCC98\uC5D0\uC11C \uB124\uBAA8\uC758
    \uC190\uAE38\uC774 \uBA48\uCDB0. \uC0AC\uCD0C 2\uB294 \uAC81\uC5D0 \uC9C8\uB9B0
    \uB208\uC73C\uB85C \uC9C0\uB3C4\uB97C \uBC14\uB77C\uBD10.)\n        \n       
    \uC0AC\uCD0C 2 : \uB124\uBAA8\uC57C, \uC6B0\uB9AC \uC544\uBE60\uAC00 \uADF8\uB7EC\uB294\uB370
    \uC800 \uC232\uC740 \uC800\uC8FC\uBC1B\uC558\uB300. \uBC31\uC791\uB2D8\uC774
    \uC800\uAE30\uB97C \uD3D0\uC1C4\uD55C \uAC74 \uAD34\uBB3C\uC774 \uB098\uC640\uC11C\uAC00
    \uC544\uB2C8\uB77C... \uB204\uAD70\uAC00\uC758 \uBE44\uBA85 \uC18C\uB9AC\uAC00
    \uB4E4\uB824\uC11C\uB77C\uACE0...\n        \uB124\uBAA8 : (\uC9C0\uB3C4\uB97C
    \uC190\uD1B1\uC73C\uB85C \uAE01\uC73C\uBA70) \uBE44\uBA85 \uC18C\uB9AC? \uC0AC\uCD0C
    2, \uB108 \uB611\uBC14\uB85C \uB9D0\uD574. \uB108\uD76C \uC544\uBC84\uC9C0\uAC00
    \uC800 \uC232\uC5D0 \uB300\uD574 \uB610 \uBB50\uB77C\uACE0 \uD558\uC168\uC5B4?\n       
    \n\n- (\uACBD\uBE44\uB300\uC7A5\uC774 \uB2E4\uAC00\uC640 \uC9C0\uB3C4\uB97C \uAC70\uCE60\uAC8C
    \uB9D0\uC544 \uC62C\uB9AC\uBA70 \uC0AC\uCD0C 2\uB97C \uBC00\uC5B4\uB0B8\uB2E4.)\n       
    - \uACBD\uBE44\uB300\uC7A5 : \uC678\uBD80\uC778\uC740 \uC9C0\uD615 \uC815\uBCF4\uC5D0
    \uC811\uADFC\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. \uD2B9\uD788 \uC720\uC5B8\uBE44\uC5B4\uB97C
    \uD37C\uB728\uB9AC\uB294 \uC790\uB294 \uC989\uC2DC \uD1F4\uC7A5 \uC870\uCE58\uD558\uACA0\uC2B5\uB2C8\uB2E4.\n       
    \uC0AC\uCD0C 2 : (\uBC14\uB2E5\uC5D0 \uB118\uC5B4\uC9C0\uBA70) \uC8C4\uC1A1\uD574\uC694!
    \uC804 \uADF8\uB0E5 \uC544\uBE60\uD55C\uD14C \uB4E4\uC740 \uB300\uB85C... \uB124\uBAA8\uC57C,
    \uB098 \uBB34\uC11C\uC6CC!\n        \uB124\uBAA8 : (\uACBD\uBE44\uB300\uC7A5\uC5D0\uAC8C
    \uB300\uB4E4\uBA70) \uC560\uB97C \uBC00\uCE58\uBA74 \uC5B4\uB5A1\uD574\uC694!
    \uBC31\uC791\uB2D8\uC774 \uC2DC\uD0A4\uBA74 \uC0AC\uB78C\uC744 \uB2E4\uCE58\uAC8C
    \uD574\uB3C4 \uB418\uB294 \uAC70\uC608\uC694? \uC0AC\uCD0C 2, \uC77C\uC5B4\uB098.
    \uB108\uD76C \uC9D1\uC73C\uB85C \uAC00. \uC5EC\uAE30 \uC788\uB2E4\uAC04 \uB108\uB3C4
    \uB098\uCC98\uB7FC \uC228 \uB9C9\uD600 \uC8FD\uC744 \uAC70\uC57C!\n        \uC0AC\uCD0C
    2 : (\uB3C4\uB9DD\uCE58\uB4EF \uB098\uAC00\uBA70) \uB124\uBAA8\uC57C, \uC870\uC2EC\uD574!
    \uBC31\uC791\uB2D8\uC740 \uB2E4 \uBCF4\uACE0 \uACC4\uC154!"
