  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_letter_friend_1_direct__step_w008_letter_friend_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 8\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uB450\uD23C\uD55C \uBD09\uD22C\uB97C \uB4E4\uACE0
    \uC628\uB2E4. \uBD09\uD22C \uAC89\uC5D0 '\uACBD\uBE44\uB300\uC7A5\uB2D8 \uB208
    \uAC10\uC544!'\uB77C\uACE0 \uC544\uC8FC \uD06C\uAC8C \uC801\uD600 \uC788\uB2E4.)\r\n       
    \r\n\r\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uCE5C\uAD6C\uBD84\uC774 \uC544\uC8FC
    \uBC1C\uCE59\uD55C \uACC4\uD68D\uC744 \uC138\uC6B4 \uBAA8\uC591\uC785\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : \uBB54\uB370? \uB610 \uD0C8\uCD9C\uC774\uC57C?\r\n        (\uD558\uB140\uAC00
    \uBD09\uD22C\uB97C \uD3BC\uCE5C\uB2E4.)\r\n        \uB124\uBAA8! \uB0B4\uC77C
    \uC131\uC778\uC2DD \uB54C \uBC31\uC791\uB2D8\uC774 \uB110 \uD6C4\uACC4\uC790\uB85C
    \uC120\uD3EC\uD558\uBA74, \uB10C \uC774\uC81C \uC6B0\uB9AC \uB300\uC7A5\uC774\uC57C!
    \uADF8\uB7FC \uACBD\uBE44\uB300\uC7A5 \uC544\uC800\uC528\uB3C4 \uB108\uD55C\uD14C
    \uACBD\uB840\uD558\uACA0\uC9C0? \uADF8\uB54C \uC544\uC800\uC528 \uBAB0\uB798
    \uB098\uD55C\uD14C \uC719\uD06C\uD574 \uC918. \uC6B0\uB9AC\uAC00 \uC774\uACBC\uB2E4\uB294
    \uC2E0\uD638\uB85C \uB9D0\uC774\uC57C!\r\n        \uB124\uBAA8 : \uB0B4\uAC00
    \uC544\uC800\uC528\uC758 \uB300\uC7A5\uC774 \uB41C\uB2E4\uACE0?\r\n        \uD558\uB140
    : \uB124, \uC8FC\uC778\uB2D8. \uC774\uC81C \uB2F9\uC2E0\uC774 \uC774 \uC800\uD0DD\uC758
    \uC0C8\uB85C\uC6B4 \uADDC\uCE59\uC774 \uB420 \uB0A0\uC774 \uBA38\uC9C0\uC54A\uC558\uC2B5\uB2C8\uB2E4.\r\n       
    \uB124\uBAA8 : \uC544\uC800\uC528\uAC00 \uB098\uD55C\uD14C \uACBD\uB840\uD558\uB294
    \uBAA8\uC2B5... \uC0DD\uAC01\uB9CC \uD574\uB3C4 \uC2E0\uAE30\uD574!"
