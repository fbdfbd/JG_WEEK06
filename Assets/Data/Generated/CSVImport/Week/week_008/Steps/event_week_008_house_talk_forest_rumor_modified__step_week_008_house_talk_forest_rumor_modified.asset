  _titleOverride: "\uBE44\uADF9\uC758 \uC232 \uC18C\uBB38 - \uC218\uC815"
  _bodyText: "\uBE44\uADF9\uC758 \uC232 \uC18C\uBB38 - \uC218\uC815 \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: ea8bb1cd384c18f4c83d6f267d5433b5, type: 2}
    _text: "\uC232\uC5D0\uC11C \uB178\uB7AB\uC18C\uB9AC\uCC98\uB7FC \uB4E4\uB9AC\uB294
      \uBC14\uB78C \uC774\uC57C\uAE30\uAC00 \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC78 \uB2E4\uB4E4 \uBB34\uC11C\uC6CC\uD574?"
  - _speaker: {fileID: 11400000, guid: 382a01f86413cfc439d75f63e427a411, type: 2}
    _text: "\uC2AC\uD508 \uC774\uC57C\uAE30\uB97C \uBD99\uC774\uB294 \uC0AC\uB78C\uB3C4
      \uC788\uC9C0\uB9CC, \uADF8\uB0E5 \uBC14\uB78C\uACFC \uB098\uBB34\uAC00 \uACB9\uCCD0
      \uADF8\uB807\uAC8C \uB4E4\uB9B4 \uB54C\uB3C4 \uB9CE\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB108\uBB34 \uAC81\uB0BC \uD544\uC694\uB294 \uC5C6\uACA0\uB124."
  _nemoLine: "\uC232\uC5D0\uC11C \uB178\uB7AB\uC18C\uB9AC\uCC98\uB7FC \uB4E4\uB9AC\uB294
    \uBC14\uB78C \uC774\uC57C\uAE30\uAC00 \uC788\uC5B4\uC694."
