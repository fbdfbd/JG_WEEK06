  _titleOverride: "\uC720\uD53C\uC758 \uD3B8\uC9C0 \uD1B5\uC81C"
  _bodyText: "letter friend_3 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uB294 \uB178\uB780 \uC789\uD06C \uC790\uAD6D\uC744 \uBCF4\uACE0
      \uD600\uB97C \uCC28\uBA70 \uC138\uD0C1\uC2E4 \uBC14\uAD6C\uB2C8 \uC544\uB798\uC5D0
      \uD3B8\uC9C0\uB97C \uC228\uAE34\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uCC45\uC0C1 \uC704\uC5D0 \uB193\uC778 \uB3CB\uBCF4\uAE30\uB97C
      \uB4E4\uC5EC\uB2E4\uBCF4\uBA70 \uC2EC\uC2EC\uD574\uD558\uACE0 \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\u2026\u2026\uB9C8\uC9C0\uB9C9 \uC2DC\uD5D8\uC744 \uC55E\uB450\uACE0
      \uC774\uB7F0 \uC7A5\uB09C\uC740 \uACE4\uB780\uD569\uB2C8\uB2E4."
  _nemoLine: "(\uD558\uB140\uB294 \uB178\uB780 \uC789\uD06C \uC790\uAD6D\uC744 \uBCF4\uACE0
    \uD600\uB97C \uCC28\uBA70 \uC138\uD0C1\uC2E4 \uBC14\uAD6C\uB2C8 \uC544\uB798\uC5D0
