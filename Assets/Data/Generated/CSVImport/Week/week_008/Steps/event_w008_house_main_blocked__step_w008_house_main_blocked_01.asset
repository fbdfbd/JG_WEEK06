  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w008_house_main_blocked__step_w008_house_main_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "8\uC8FC\uCC28 \uC18C\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uC548\uAC1C \uB080 \uC0C8\uBCBD\uC758 \uCC3D\uAC00. \uD558\uB140
    \uB458\uC774 \uC815\uC6D0 \uCABD '\uBE44\uADF9\uC758 \uC232' \uBC29\uD5A5\uC744
    \uBCF4\uBA70 \uBAB8\uC744 \uB5A8\uACE0 \uC788\uB2E4.)\n    \n    \uD558\uB140
    1 : \uB4E4\uC5C8\uC5B4? \uBC14\uB78C \uC18C\uB9AC\uB77C\uAE30\uC5D4 \uB108\uBB34
    \uCC98\uB7C9\uD55C \uB178\uB7AB\uC18C\uB9AC \uAC19\uC558\uC5B4.\n    \uD558\uB140
    2 : \uD639\uC2DC \uC608\uC804\uC5D0 \uADF8 \uC232\uC5D0\uC11C \uC0AC\uB77C\uC84C\uB2E4\uB294...
    \uC544\uB2C8\uC57C, \uB9D0\uD558\uBA74 \uC548 \uB3FC.\n    \uB124\uBAA8 : \uC232\uC5D0\uC11C
    \uB204\uAC00 \uB178\uB798\uB97C \uD574? \uB098\uB3C4 \uB4E4\uB824\uC918!\n   
    \n\n- \uD558\uB140 1 : \uC544\uB2D9\uB2C8\uB2E4! \uB0A1\uC740 \uD48D\uD5A5\uACC4\uAC00
    \uB3CC\uC544\uAC00\uBA70 \uB098\uB294 \uB9C8\uCC30\uC74C\uC774\uC5C8\uC5B4\uC694.\n   
    \uB124\uBAA8 : \uB178\uB7AB\uC18C\uB9AC \uAC19\uC558\uB2E4\uBA70! \uC0AC\uCD0C
    1 \uC0BC\uCD0C\uB3C4 \uAC70\uAE30\uC11C \uBE44\uBA85\uC774 \uB4E4\uB9B0\uB2E4\uACE0
    \uD588\uB2E8 \uB9D0\uC774\uC57C.\n    \uD558\uB140 2 : \uC0BC\uCD0C\uBD84\uAED8\uC11C
    \uC8FC\uC778\uB2D8\uC744 \uB180\uB77C\uAC8C \uD558\uB824\uACE0 \uC7A5\uB09C\uCE58\uC2E0
    \uAC81\uB2C8\uB2E4. \uC544\uBB34 \uC77C\uB3C4 \uC5C6\uC73C\uB2C8 \uC548\uC2EC\uD558\uC138\uC694.\n   
    \uB124\uBAA8 : \uCE58... \uB2E4\uB4E4 \uBC31\uC791\uB2D8 \uB208\uCE58\uB9CC \uBCF4\uACE0
    \uB098\uD55C\uD150 \uC544\uBB34 \uB9D0\uB3C4 \uC548 \uD574\uC918."
