  m_Name: event_w008_house_main_modified__step_w008_house_main_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "8\uC8FC\uCC28 \uC18C\uBB38 - \uC218\uC815"
  _bodyText: "(\uC548\uAC1C \uB080 \uC0C8\uBCBD\uC758 \uCC3D\uAC00. \uD558\uB140
    \uB458\uC774 \uC815\uC6D0 \uCABD '\uBE44\uADF9\uC758 \uC232' \uBC29\uD5A5\uC744
    \uBCF4\uBA70 \uBAB8\uC744 \uB5A8\uACE0 \uC788\uB2E4.)\n    \n    \uD558\uB140
    1 : \uB4E4\uC5C8\uC5B4? \uBC14\uB78C \uC18C\uB9AC\uB77C\uAE30\uC5D4 \uB108\uBB34
    \uCC98\uB7C9\uD55C \uB178\uB7AB\uC18C\uB9AC \uAC19\uC558\uC5B4.\n    \uD558\uB140
    2 : \uD639\uC2DC \uC608\uC804\uC5D0 \uADF8 \uC232\uC5D0\uC11C \uC0AC\uB77C\uC84C\uB2E4\uB294...
    \uC544\uB2C8\uC57C, \uB9D0\uD558\uBA74 \uC548 \uB3FC.\n    \uB124\uBAA8 : \uC232\uC5D0\uC11C
    \uB204\uAC00 \uB178\uB798\uB97C \uD574? \uB098\uB3C4 \uB4E4\uB824\uC918!\n   
    \n\n- \uD558\uB140 1 : \uC0AC\uC2E4 \uADF8\uAC74 \uBC31\uC791\uB2D8\uC774 \uC232\uC18D\uC5D0
    \uC124\uCE58\uD574\uB450\uC2E0 '\uBC14\uB78C\uC758 \uD558\uD504' \uC18C\uB9AC\uC608\uC694.
    \uC232\uC744 \uC9C0\uB098\uB294 \uBC14\uB78C\uC744 \uC544\uB984\uB2E4\uC6B4 \uC120\uC728\uB85C
    \uBC14\uAFD4\uC8FC\uC8E0.\n    \uB124\uBAA8 : \uBC14\uB78C\uC758 \uD558\uD504?
    \uADF8\uB7F0 \uAC8C \uC788\uC5B4?\n    \uD558\uB140 2 : \uB124. \uC8FC\uC778\uB2D8\uC774
    \uACF5\uBD80\uD558\uB2E4 \uC9C0\uCCE4\uC744 \uB54C \uC790\uC5F0\uC758 \uC18C\uB9AC\uB97C
    \uB4E4\uC73C\uBA70 \uD790\uB9C1\uD558\uC2DC\uB77C\uACE0 \uBC31\uC791\uB2D8\uC774
    \uBAB0\uB798 \uC900\uBE44\uD558\uC2E0 \uC120\uBB3C\uC774\uC5D0\uC694.\n    \uB124\uBAA8
    : \uC6B0\uC640, \uBC31\uC791\uB2D8 \uC815\uB9D0 \uC12C\uC138\uD558\uC2DC\uB2E4!
    \uC774\uC81C \uADF8 \uC18C\uB9AC\uAC00 \uB4E4\uB9AC\uBA74 \uB098\uB3C4 \uAC19\uC774
    \uCF67\uB178\uB798\uB97C \uBD80\uB97C\uB798."
