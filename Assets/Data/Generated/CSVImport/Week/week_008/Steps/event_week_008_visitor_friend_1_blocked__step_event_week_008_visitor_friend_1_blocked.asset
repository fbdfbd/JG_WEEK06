  _titleOverride: "\uB9C9\uC2A4 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "visitor friend_1 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "(\uD39C\uB358\uD2B8\uB97C \uC5F4\uC5B4\uBCF4\uACE0 \uB208\uC2DC\uC6B8\uC774
      \uBD89\uC5B4\uC9C4\uB2E4) \uBC31\uC791\uB2D8\uC740 \uC800\uB97C \uC9C0\uD0A4\uAE30
      \uC704\uD574 \uC774 \uC544\uD514\uC744 \uD63C\uC790 \uACAC\uB514\uACE0 \uACC4\uC168\uB358
      \uAC70\uAD70\uC694. \uC0BC\uCD0C\uC758 \uB9D0\uC5D0 \uD754\uB4E4\uB838\uB358
      \uC81C\uAC00 \uBD80\uB044\uB7EC\uC6CC\uC694."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uBD10, \uB124\uBAA8\uC57C. \uBC31\uC791\uB2D8\uC740 \uB110 \uB204\uAD6C\uBCF4\uB2E4
      \uC544\uB07C\uC154. \uC800 \uC232\uC740 \uC774\uC81C \uC2AC\uD514\uC758 \uC7A5\uC18C\uAC00
      \uC544\uB2C8\uB77C \uB124\uAC00 \uC9C0\uCF1C\uC57C \uD560 \uC601\uC9C0\uC758
      \uC77C\uBD80\uC77C \uBFD0\uC774\uC57C."
  _nemoLine: "(\uD39C\uB358\uD2B8\uB97C \uC5F4\uC5B4\uBCF4\uACE0 \uB208\uC2DC\uC6B8\uC774
    \uBD89\uC5B4\uC9C4\uB2E4) \uBC31\uC791\uB2D8\uC740 \uC800\uB97C \uC9C0\uD0A4\uAE30
    \uC704\uD574 \uC774 \uC544\uD514\uC744 \uD63C\uC790 \uACAC\uB514\uACE0 \uACC4\uC168\uB358
    \uAC70\uAD70\uC694. \uC0BC\uCD0C\uC758 \uB9D0\uC5D0 \uD754\uB4E4\uB838\uB358
    \uC81C\uAC00 \uBD80\uB044\uB7EC\uC6CC\uC694."
