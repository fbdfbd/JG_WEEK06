  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_206_child_visitor_friend_1_02_blocked__step_206_child_visitor_friend_1_02_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uB450 \uBC88\uC9F8 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "\uB2E4\uC2DC \uB9CC\uB09C \uCE5C\uAD6C1\uACFC \uB9CE\uC774 \uB6F0\uC9C0
    \uBABB\uD558\uAC8C \uD558\uC790 \uC7A5\uB09C\uC2A4\uB7EC\uC6B4 \uD22C\uC815\uB9CC
    \uB0A8\uB294\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uB124\uBAA8! \uB610 \uC654\uB2E4!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC \uBE60\uB974\uB124."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uB9CE\uC774 \uB6F0\uBA74 \uC548
      \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uC65C\uC5D0?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uB6F0\uACE0 \uC2F6\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC624\uB298\uC740 \uC9E7\uAC8C\uB9CC\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uADF8\uB7FC \uC81C\uC790\uB9AC \uB2EC\uB9AC\uAE30 \uD560\uB798?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uC774\uC0C1\uD55C\uB370."
  _nemoLine: "\uB124\uBAA8! \uB610 \uC654\uB2E4!"
  _useCustomVisualState: 0
  _visualState: 0
