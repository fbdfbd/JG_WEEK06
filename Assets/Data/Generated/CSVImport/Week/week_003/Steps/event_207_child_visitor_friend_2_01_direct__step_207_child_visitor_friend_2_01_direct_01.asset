  _titleOverride: "\uCE5C\uAD6C2 \uCCAB \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "\uCE5C\uAD6C2\uB294 \uD241\uBA85\uC2A4\uB7FD\uC9C0\uB9CC \uB124\uBAA8\uC758
    \uC637\uC5D0 \uBB3B\uC740 \uBA3C\uC9C0\uB97C \uD138\uC5B4 \uC8FC\uBA70 \uCCAB
    \uC778\uC0C1\uC744 \uB0A8\uAE34\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB108\uB294 \uC65C \uC548 \uB180\uC544?"
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uC637 \uB354\uB7EC\uC6CC\uC9C0\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5E5? \uB09C \uAD1C\uCC2E\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uB108\uB294 \uADF8\uB798 \uBCF4\uC5EC."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: '?'
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uB108 \uC774\uC0C1\uD574."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: ..?
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uC5EC\uAE30 \uBA3C\uC9C0 \uBB3B\uC5C8\uC5B4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uACE0\uB9C8\uC6CC."
  _nemoLine: "\uC548\uB155."
