  m_Name: event_w003_letter_friend_1_direct__step_w003_letter_friend_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 3\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uC190\uB54C\uAC00 \uC880 \uBB3B\uC740 \uBD09\uD22C\uB97C
    \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C \uBAA8\uC11C\uB9AC\uC5D4 \uC5C9\uC131\uD55C
    \uBCC4\uD45C\uAC00 \uBA87 \uAC1C \uADF8\uB824\uC838 \uC788\uB2E4.)\r\n       
    \r\n\r\n\uD558\uB140 : \uB124. \uC9C0\uB09C\uBC88\uC5D0 \uAC19\uC774 \uB180\uB358
    \uB610\uB798 \uC190\uB2D8\uC774 \uBCF4\uB0B8 \uD3B8\uC9C0\uC785\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uC77D\uC5B4 \uC918. \uBE68\uB9AC.\r\n        \r\n       
    (\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uD3BC\uCE5C\uB2E4.)\r\n        \r\n       
    \uB124\uBAA8 \uC548\uB155. \uC9C0\uB09C\uBC88\uC5D0 \uB108\uB791 \uB6F0\uC5B4\uB2E4\uB2CC
    \uAC70 \uC544\uC9C1\uB3C4 \uAE30\uC5B5\uB098. \uBCF5\uB3C4 \uB05D\uC5D0\uC11C
    \uB108 \uC6C3\uB358 \uAC83\uB3C4 \uC0DD\uAC01\uB098. \uC694\uC998\uC740 \uBE44\uBC00
    \uC790\uB9AC \uD558\uB098\uB97C \uCC3E\uC558\uB294\uB370, \uB108\uB3C4 \uBCF4\uBA74
    \uC88B\uC544\uD560 \uAC83 \uAC19\uC544. \uB2E4\uC74C\uC5D0 \uC624\uBA74 \uAC19\uC774
    \uAC00\uC790.\r\n        \r\n        \uB124\uBAA8 : \uC5B4?\r\n        \r\n       
    \uB124\uBAA8 : \uB0B4\uAC00 \uC6C3\uB358 \uAC83\uB3C4 \uAE30\uC5B5\uD574?\r\n       
    \r\n        \uD558\uB140 : \uB124. \uC8FC\uC778\uB2D8 \uC0DD\uAC01\uC744 \uAF64
    \uB9CE\uC774 \uD558\uB098 \uBD05\uB2C8\uB2E4.\r\n        \r\n        \uB124\uBAA8
    : \uBE44\uBC00 \uC790\uB9AC\uB3C4 \uCC3E\uC558\uB300.\r\n        \r\n       
    \uD558\uB140 : \uC774\uBC88\uC5D4 \uADF8\uB0E5 \uB6F0\uB294 \uAC83\uBCF4\uB2E4
    \uB354 \uD2B9\uBCC4\uD55C \uAC78 \uBCF4\uC5EC \uC8FC\uACE0 \uC2F6\uC5C8\uB098
    \uBCF4\uC9C0\uC694.\r\n        \r\n        \uB124\uBAA8 : \uADF8\uAC70 \uAD81\uAE08\uD55C\uB370.
    \uB2E4\uC74C\uC5D0 \uAC00\uBA74 \uBC14\uB85C \uBCF4\uC5EC \uB2EC\uB77C \uD574\uC57C\uC9C0."
