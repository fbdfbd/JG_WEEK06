MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_excursion_garden_direct__step_event_week_003_excursion_garden_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: garden Direct
  _bodyText: "excursion garden Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC815\uC6D0\uC0AC\uAC00 \uB124\uBAA8\uB97C \uBD84\uC218\uB300 \uAC00\uC7A5\uC790\uB9AC\uC5D0\uC11C
      \uC870\uAE08 \uB5A8\uC5B4\uC9C4 \uC548\uC804\uD55C \uC790\uB9AC\uC5D0 \uC138\uC6B4\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC5EC\uAE30\uC11C \uBCF4\uC2DC\uBA74 \uB429\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5EC\uAE30\uC11C\uB3C4 \uBCF4\uC5EC?"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC608~ \uD574\uAC00 \uC800\uB807\uAC8C \uBE44\uCE60 \uB54C\uB9CC \uC7A0\uAE50
      \uC0DD\uAE34\uB2F5\uB2C8\uB2E4~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC\uB124."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBE68\uAC15\uB3C4 \uC788\uACE0 \uD30C\uB791\uB3C4 \uC788\uB2E4."
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uAE08\uBC29 \uC0AC\uB77C\uC9C8 \uC218\uB3C4 \uC788\uC73C\uB2C8 \uB9CE\uC774
      \uBCF4\uC154\uC57C\uC9C0\uC694~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC815\uC6D0 \uAC00\uACE0 \uC2F6\uC740\uB370"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uCC3D\uBC16\uC744 \uBC14\uB77C\uBCF8\uB2E4. \uCC3D\uBB38
      \uB108\uBA38\uB85C \uBE44\uAC00 \uC8FC\uB975\uC8FC\uB975 \uB0B4\uB9AC\uACE0
      \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC7AC\uBC0C\uACA0\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC815\uC6D0\uC73C\uB85C \uB098\uAC00\uB824 \uD55C\uB2E4.
      )"
  _nemoLine: "(\uC815\uC6D0\uC0AC\uAC00 \uB124\uBAA8\uB97C \uBD84\uC218\uB300 \uAC00\uC7A5\uC790\uB9AC\uC5D0\uC11C
    \uC870\uAE08 \uB5A8\uC5B4\uC9C4 \uC548\uC804\uD55C \uC790\uB9AC\uC5D0 \uC138\uC6B4\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
