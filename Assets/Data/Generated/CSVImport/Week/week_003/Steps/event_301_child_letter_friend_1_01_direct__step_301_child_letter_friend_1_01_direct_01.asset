  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 - \uADF8\uB300\uB85C \uC77D\uAE30"
  _bodyText: "\uCE5C\uAD6C1\uC758 \uD3B8\uC9C0\uB97C \uAC70\uC758 \uADF8\uB300\uB85C
    \uC77D\uC5B4 \uC8FC\uC790 \uB124\uBAA8\uB3C4 \uAE08\uC138 \uB4E4\uB72C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124\uBAA8 \uC548\uB155. \uC800\uBC88\uC5D0 \uB6F0\uC5B4\uC11C \uC7AC\uBC0C\uC5C8\uC5B4.
      \uB2E4\uC74C\uC5D4 \uB0B4\uAC00 \uB354 \uBE68\uB9AC \uB6F8 \uAC70\uC57C."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB108\uB3C4 \uAF2D \uB2E4\uC2DC \uC640. \uC774\uBC88\uC5D4 \uB0B4\uAC00
      \uC88B\uC740 \uC228\uB294 \uACF3\uB3C4 \uBCF4\uC5EC \uC904\uAC8C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uC9C4\uC9DC \uC2E0\uB098 \uBCF4\uC774\uB124."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uB610 \uAC19\uC774 \uB6F0\uACE0 \uC2F6\uC5B4."
  _nemoLine: "\uB124\uBAA8 \uC548\uB155. \uC800\uBC88\uC5D0 \uB6F0\uC5B4\uC11C \uC7AC\uBC0C\uC5C8\uC5B4.
    \uB2E4\uC74C\uC5D4 \uB0B4\uAC00 \uB354 \uBE68\uB9AC \uB6F8 \uAC70\uC57C."
