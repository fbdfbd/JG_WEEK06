  m_Name: event_w003_visitor_friend_3_blocked__step_w003_visitor_friend_3_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 3\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uBCF5\uB3C4 \uBCBD\uC5D0 \uC624\uD6C4 \uD587\uBE5B\uC774 \uAE38\uAC8C
    \uB4E4\uC5B4\uC628\uB2E4. \uCE5C\uAD6C3\uC774 \uB450 \uC190\uC744 \uBCBD\uC5D0
    \uBE44\uCDB0 \uC774\uC0C1\uD55C \uADF8\uB9BC\uC790\uB97C \uB9CC\uB4E4\uACE0 \uC788\uB2E4.)\n       
    \n        \uCE5C\uAD6C3 : \uB124\uBAA8, \uBE68\uB9AC \uC640.\n        \n       
    \uB124\uBAA8 : \uC65C?\n        \n        \uCE5C\uAD6C3 : \uC5EC\uAE30 \uAC1C\uAD6C\uB9AC
    \uC0DD\uACBC\uC5B4.\n        \n        \uB124\uBAA8 : \uC5B4\uB514?\n       
    \n        \uCE5C\uAD6C3 : \uBCBD\uC5D0.\n        \n\n(\uD558\uB140\uAC00 \uB124\uBAA8\uB97C
    \uBD80\uB978\uB2E4.)\n        \n        \uD558\uB140 : \uC8FC\uC778\uB2D8, \uC624\uB298\uC740
    \uC9E7\uAC8C\uB9CC \uC778\uC0AC\uD558\uC154\uC57C \uD569\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uC7A0\uAE50\uB9CC. \uAC1C\uAD6C\uB9AC \uC788\uB300.\n       
    \n        \uCE5C\uAD6C3 : \uC190\uC73C\uB85C \uB9CC\uB4E0 \uAC74\uB370.\n       
    \n        \uB124\uBAA8 : \uBB50\uC57C.\n        \n        \uCE5C\uAD6C3 : \uADF8\uB798\uB3C4
    \uAC1C\uAD6C\uB9AC \uAC19\uC558\uC796\uC544.\n        \n        \uB124\uBAA8
    : \uC870\uAE08.\n        \n        \uCE5C\uAD6C3 : \uB2E4\uC74C\uC5D4 \uD1A0\uB07C\uB3C4
    \uB9CC\uB4E4\uAC8C.\n        \n        \uB124\uBAA8 : \uADF8\uB7FC \uB2E4\uC74C\uC5D0
    \uBCFC\uB798."
