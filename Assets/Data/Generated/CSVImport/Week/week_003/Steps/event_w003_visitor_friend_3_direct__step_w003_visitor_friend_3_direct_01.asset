  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_visitor_friend_3_direct__step_w003_visitor_friend_3_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 3\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uBCF5\uB3C4 \uBCBD\uC5D0 \uC624\uD6C4 \uD587\uBE5B\uC774 \uAE38\uAC8C
    \uB4E4\uC5B4\uC628\uB2E4. \uCE5C\uAD6C3\uC774 \uB450 \uC190\uC744 \uBCBD\uC5D0
    \uBE44\uCDB0 \uC774\uC0C1\uD55C \uADF8\uB9BC\uC790\uB97C \uB9CC\uB4E4\uACE0 \uC788\uB2E4.)\n       
    \n        \uCE5C\uAD6C3 : \uB124\uBAA8, \uBE68\uB9AC \uC640.\n        \n       
    \uB124\uBAA8 : \uC65C?\n        \n        \uCE5C\uAD6C3 : \uC5EC\uAE30 \uAC1C\uAD6C\uB9AC
    \uC0DD\uACBC\uC5B4.\n        \n        \uB124\uBAA8 : \uC5B4\uB514?\n       
    \n        \uCE5C\uAD6C3 : \uBCBD\uC5D0.\n        \n\n(\uB124\uBAA8\uAC00 \uCE5C\uAD6C3
    \uC606\uC73C\uB85C \uCABC\uB974\uB974 \uAC04\uB2E4.)\n        \n        \uCE5C\uAD6C3
    : \uBD10. \uC190\uAC00\uB77D \uC774\uB807\uAC8C \uD558\uBA74 \uC785\uC774\uC57C.\n       
    \n        \uB124\uBAA8 : \uC6B0\uC640. \uC9C4\uC9DC \uAC1C\uAD6C\uB9AC \uAC19\uC544.\n       
    \n        \uCE5C\uAD6C3 : \uB108\uB3C4 \uD574 \uBD10.\n        \n        \uB124\uBAA8
    : \uB09C \uC548 \uB420\uAC78.\n        \n        \uCE5C\uAD6C3 : \uB3FC. \uC190\uB9CC
    \uC788\uC73C\uBA74 \uB3FC.\n        \n        (\uB124\uBAA8\uAC00 \uC190\uC744
    \uBE44\uCDC4\uB2E4\uAC00 \uC774\uC0C1\uD55C \uB369\uC5B4\uB9AC\uB97C \uB9CC\uB4E0\uB2E4.)\n       
    \n        \uCE5C\uAD6C3 : \uADF8\uAC74 \uAC1C\uAD6C\uB9AC \uC544\uB2C8\uACE0
    \uAC10\uC790\uC57C.\n        \n        \uB124\uBAA8 : \uBB50\uC57C!\n       
    \n        \uCE5C\uAD6C3 : \uAC10\uC790\uB3C4 \uADC0\uC5EC\uC6CC.\n        \n       
    \uB124\uBAA8 : \uC2EB\uC5B4. \uB098\uB3C4 \uAC1C\uAD6C\uB9AC \uD560\uB798.\n       
    \n        (\uB458\uC774 \uBCBD \uC55E\uC5D0\uC11C \uC190\uAC00\uB77D\uC744 \uAF3C\uC9C0\uB77D\uAC70\uB9AC\uBA70
    \uD55C\uCC38 \uC6C3\uB294\uB2E4.)\n        \n        \uCE5C\uAD6C3 : \uC774\uBC88\uC5D4
    \uD1A0\uB07C!\n        \n        \uB124\uBAA8 : \uADF8\uAC74 \uC9C4\uC9DC \uD1A0\uB07C
    \uAC19\uB2E4."
  _dialogueLines: []
