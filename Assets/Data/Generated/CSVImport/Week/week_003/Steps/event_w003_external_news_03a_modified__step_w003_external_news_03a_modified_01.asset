  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_external_news_03a_modified__step_w003_external_news_03a_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC18C\uC2DD 3\uCC28-1 - \uC218\uC815"
  _bodyText: "\uBCC4\uBE5B \uBE44\uB217\uBC29\uC6B8 \uC545\uC0AC\n        \n       
    (\uD604\uAD00 \uADFC\uCC98. \uD558\uB140 \uB458\uC774 \uC7A5\uBC14\uAD6C\uB2C8\uB97C
    \uC815\uB9AC\uD558\uB2E4\uAC00, \uBC18\uC9DD\uC774\uB294 \uC587\uC740 \uC885\uC774
    \uC804\uB2E8 \uD55C \uC7A5\uC744 \uD3BC\uCE5C\uB2E4. \uC885\uC774\uC5D4 \uCEE4\uB2E4\uB780
    \uBE44\uB217\uBC29\uC6B8 \uC548\uC5D0 \uBCC4\uC774 \uB5A0 \uC788\uB294 \uADF8\uB9BC\uC774
    \uADF8\uB824\uC838 \uC788\uB2E4.)\n        \n        \uB124\uBAA8 : \uC5B4?\n       
    \n        \uB124\uBAA8 : \uC800 \uC548\uC5D0 \uBCC4 \uB4E4\uC5B4 \uC788\uC5B4.\n       
    \n        \uD558\uB1401 : \uC544, \uC774\uAC70 \uC7AC\uBBF8\uC788\uB124\uC694.\n       
    \n        \uD558\uB1402 : \uC218\uB3C4\uC5D0\uC11C \uC694\uC998 \uC720\uBA85\uD55C
    \uAC70\uB9AC \uC545\uC0AC \uC774\uC57C\uAE30\uB798\uC694.\n        \n       
    \uB124\uBAA8 : \uC545\uC0AC?\n        \n\n\uD558\uB1401 : \uC218\uB3C4\uC5D0\uC11C
    \uBE44\uB217\uBC29\uC6B8 \uACF5\uC5F0\uC774 \uC720\uD589\uC774\uB77C\uB124\uC694,
    \uC8FC\uC778\uB2D8.\n        \n        \uB124\uBAA8 : \uADF8\uB0E5 \uBE44\uB217\uBC29\uC6B8?\n       
    \n        \uD558\uB1402 : \uB124. \uD587\uBE5B\uC774\uB098 \uC791\uC740 \uBD88\uBE5B\uC744
    \uBE44\uCDB0\uC11C \uC608\uC058\uAC8C \uBCF4\uC774\uAC8C \uD55C\uB300\uC694.\n       
    \n        \uB124\uBAA8 : \uD130\uC9C0\uBA74?\n        \n        \uD558\uB1401
    : \uBC18\uC9DD \uD558\uACE0 \uC0AC\uB77C\uC9C0\uACA0\uC9C0\uC694. \uC7A0\uAE50
    \uC608\uC05C \uAD6C\uACBD \uAC19\uC740 \uAC70\uC608\uC694.\n        \n       
    \uB124\uBAA8 : \uADF8\uAC74 \uC880 \uC88B\uB2E4.\n        \n        \uD558\uB1402
    : \uC2DC\uB044\uB7EC\uC6B4 \uC7A5\uD130\uBCF4\uB2E4, \uC7A0\uAE50 \uD558\uB298
    \uBCF4\uB294 \uB290\uB08C\uC77C\uC9C0\uB3C4 \uBAA8\uB974\uACA0\uB124\uC694.\n       
    \n        \uB124\uBAA8 : \uB098 \uADF8\uAC70\uBA74 \uAD1C\uCC2E\uC544."
