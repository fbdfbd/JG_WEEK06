  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_visitor_friend_2_direct__step_w003_visitor_friend_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 3\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uC751\uC811\uC2E4 \uCC3D\uAC00. \uCE5C\uAD6C2\uAC00 \uC190\uC218\uAC74\uC744
    \uB124\uBAA8 \uBC18\uB4EF\uD558\uAC8C \uC811\uACE0 \uC788\uB2E4. \uC606\uC5D4
    \uC791\uC740 \uB9AC\uBCF8 \uD558\uB098\uAC00 \uB193\uC5EC \uC788\uB2E4.)\n       
    \n        \uB124\uBAA8 : \uBB50 \uD574?\n        \n        \uCE5C\uAD6C2 : \uC190\uC218\uAC74
    \uC811\uACE0 \uC788\uC5B4.\n        \n        \uB124\uBAA8 : \uC190\uC218\uAC74?\n       
    \n\n(\uB124\uBAA8\uAC00 \uCE5C\uAD6C2 \uC606\uC5D0 \uC549\uB294\uB2E4.)\n       
    \n        \uCE5C\uAD6C2 : \uBD10. \uC774\uB807\uAC8C \uBC18 \uC811\uACE0, \uB610
    \uC811\uACE0, \uBAA8\uC11C\uB9AC \uB9DE\uCD94\uBA74 \uB3FC.\n        \n       
    \uB124\uBAA8 : \uADF8\uAC8C \uC65C \uC7AC\uBC0C\uC5B4?\n        \n        \uCE5C\uAD6C2
    : \uB2E4 \uB9DE\uC73C\uBA74 \uAE30\uBD84 \uC88B\uC544.\n        \n        \uB124\uBAA8
    : \uC774\uC0C1\uD55C\uB370.\n        \n        \uCE5C\uAD6C2 : \uB124\uAC00 \uD574
    \uBD10.\n        \n        (\uB124\uBAA8\uAC00 \uC190\uC218\uAC74\uC744 \uC811\uC9C0\uB9CC
    \uBAA8\uC11C\uB9AC\uAC00 \uC090\uB6A4\uB2E4.)\n        \n        \uCE5C\uAD6C2
    : \uAC70\uAE30 \uC544\uB2C8\uC9C0.\n        \n        \uB124\uBAA8 : \uC54C\uC544.\n       
    \n        \uCE5C\uAD6C2 : \uBAB0\uB790\uC796\uC544.\n        \n        \uB124\uBAA8
    : \uC9C0\uAE08 \uC54C\uC558\uC5B4.\n        \n        (\uCE5C\uAD6C2\uAC00 \uB124\uBAA8
    \uC190\uB05D\uC744 \uD1A1 \uAC74\uB4DC\uB824 \uB2E4\uC2DC \uB9DE\uCDB0 \uC900\uB2E4.)\n       
    \n        \uCE5C\uAD6C2 : \uC790, \uC774\uB807\uAC8C.\n        \n        \uB124\uBAA8
    : \u2026\uC624.\n        \n        \uB124\uBAA8 : \uC774\uAC74 \uC880 \uC7AC\uBC0C\uB124.\n       
    \n        \uCE5C\uAD6C2 : \uADF8\uCE58?"
