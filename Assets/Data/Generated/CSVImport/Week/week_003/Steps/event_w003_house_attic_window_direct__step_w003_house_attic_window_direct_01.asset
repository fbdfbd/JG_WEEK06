  m_Name: event_w003_house_attic_window_direct__step_w003_house_attic_window_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB2E4\uB77D \uCC3D\uBB38 \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uB2E4\uB77D \uACC4\uB2E8 \uC544\uB798. \uD558\uB140 \uB458\uC774
    \uBA3C\uC9C0\uB97C \uD138\uBA70 \uC774\uC57C\uAE30\uD55C\uB2E4.)\r\n        \r\n       
    \uD558\uB1401 : \uC624\uB298\uB3C4 \uB2E4\uB77D \uCC3D\uBB38\uC774 \uC5F4\uB824
    \uC788\uC5C8\uB300.\r\n        \r\n        \uD558\uB1402 : \uB204\uAC00 \uB610
    \uB2EB\uACE0\uB3C4 \uAE5C\uBE61\uD588\uB098 \uBD10.\r\n        \r\n        \uB124\uBAA8
    : \uB2E4\uB77D\uC740 \uB204\uAC00 \uAC00?\r\n        \r\n\r\n\uD558\uB1401 :
    \uB2E4\uB77D\uC740 \uC624\uB798\uB41C \uBB3C\uAC74 \uB450\uB294 \uACF3\uC774\uB77C
    \uAC00\uB054 \uD558\uC778\uB4E4\uC774 \uC62C\uB77C\uAC04\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.\r\n       
    \r\n        \uB124\uBAA8 : \uADF8\uB7FC \uB204\uAC00 \uC5F4\uC5C8\uC5B4?\r\n       
    \r\n        \uD558\uB1402 : \uC544\uB9C8 \uC815\uB9AC\uD558\uB2E4\uAC00 \uAE5C\uBE61\uD55C
    \uAC70\uACA0\uC9C0\uC694.\r\n        \r\n        \uB124\uBAA8 : \uB2E4\uB77D\uC5D4
    \uBB50 \uC788\uC5B4?\r\n        \r\n        \uD558\uB1401 : \uC624\uB798\uB41C
    \uC0C1\uC790\uB791, \uCC9C\uC774\uB791, \uB0A1\uC740 \uC561\uC790 \uAC19\uC740
    \uAC83\uB4E4\uC774\uC694.\r\n        \r\n        \uB124\uBAA8 : \uC6B0\uC640.
    \uAC00\uBCF4\uACE0 \uC2F6\uB2E4.\r\n        \r\n        \uD558\uB1402 : \uBA3C\uC9C0\uAC00
    \uB9CE\uC544\uC11C \uD558\uB140\uB4E4\uC740 \uBCC4\uB85C \uC548 \uAC00\uACE0
    \uC2F6\uB2F5\uB2C8\uB2E4.\r\n        \r\n        \uB124\uBAA8 : \uAC70\uC9D3\uB9D0"
