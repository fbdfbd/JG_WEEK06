  _titleOverride: "\uC628\uC2E4 \uC720\uB9AC \uC18C\uBB38 \uD1B5\uC81C"
  _bodyText: "house_talk \uC628\uC2E4_\uC720\uB9AC_\uC18C\uBB38 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 3f7713609b39db74c98a5b754e5eaf5e, type: 2}
    _text: "\uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAE08 \uAC14\uB2E4\uBA70."
  - _speaker: {fileID: 11400000, guid: 31350c3de27bb9c43a5cd19e30d43ba8, type: 2}
    _text: "\uC544\uC8FC \uC791\uC740 \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uAD1C\uCC2E\uC544?"
  - _speaker: {fileID: 11400000, guid: 3f7713609b39db74c98a5b754e5eaf5e, type: 2}
    _text: "\uB124. \uADF8\uB0E5 \uC800\uD76C\uAC00 \uACE0\uCE58\uBA74 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uB4E4 \uB9E8\uB0A0 \uC544\uBB34\uAC83\uB3C4 \uC544\uB2C8\uB798."
  _nemoLine: "\uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
