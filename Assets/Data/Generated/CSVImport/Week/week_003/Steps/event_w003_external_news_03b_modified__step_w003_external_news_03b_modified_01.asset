  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_external_news_03b_modified__step_w003_external_news_03b_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC18C\uC2DD 3\uCC28-2 - \uC218\uC815"
  _bodyText: "\uC124\uD0D5 \uC131 \uBB34\uB108\uC9C4 \uC774\uC57C\uAE30\r\n       
    \r\n        (\uBD80\uC5CC \uC606 \uBCF5\uB3C4. \uD558\uB140 \uB458\uC774 \uC6C3\uC74C\uC744
    \uCC38\uB2E4\uAC00 \uACB0\uAD6D \uC785\uC744 \uB9C9\uB294\uB2E4. \uC7C1\uBC18
    \uC704\uC5D4 \uC124\uD0D5\uAC00\uB8E8\uAC00 \uC870\uAE08 \uB0A8\uC740 \uACFC\uC790
    \uC870\uAC01\uC774 \uC788\uB2E4.)\r\n        \r\n        \uB124\uBAA8 : \uC65C
    \uC6C3\uC5B4?\r\n        \r\n        \uD558\uB1401 : \uC27F, \uC8FC\uC778\uB2D8.\r\n       
    \r\n        \uD558\uB1402 : \uBC16\uC5D0\uC11C \uB4E4\uC740 \uC598\uAE34\uB370,
    \uB108\uBB34 \uC6C3\uACA8\uC11C\uC694.\r\n        \r\n\r\n\uD558\uB1401 : \uC5B4\uB5A4
    \uC794\uCE6B\uC0C1\uC5D0\uC11C \uC124\uD0D5 \uC7A5\uC2DD\uC774 \uC870\uAE08 \uB179\uC544\uB0B4\uB838\uB300\uC694,
    \uC8FC\uC778\uB2D8.\r\n        \r\n        \uB124\uBAA8 : \uB9CE\uC774?\r\n       
    \r\n        \uD558\uB1402 : \uC544\uC8FC \uC5C9\uB9DD\uC774 \uB41C \uAC74 \uC544\uB2C8\uACE0,
    \uC717\uBD80\uBD84\uC774 \uC870\uAE08 \uBB34\uB108\uC84C\uB2E4\uB354\uAD70\uC694.\r\n       
    \r\n        \uB124\uBAA8 : \uC65C?\r\n        \r\n        \uD558\uB1401 : \uBD88\uC774
    \uAC00\uAE4C\uC6E0\uB098 \uBD10\uC694. \uB2EC\uCF64\uD55C \uAC74 \uC5F4\uC5D0
    \uC57D\uD558\uC796\uC544\uC694.\r\n        \r\n        \uB124\uBAA8 : \uADF8\uB7FC
    \uBA39\uC744 \uC218\uB294 \uC788\uC5B4?\r\n        \r\n        \uD558\uB1402
    : \uB124. \uC624\uD788\uB824 \uB354 \uBE68\uB9AC \uB098\uB220 \uBA39\uAC8C \uB410\uACA0\uC9C0\uC694.\r\n       
    \r\n        \uB124\uBAA8 : \uADF8\uB7FC \uB098\uC058\uAE30\uB9CC \uD55C \uAC74
    \uC544\uB2C8\uB124.\r\n        \r\n        \uD558\uB1401 : \uADF8\uB807\uC9C0\uC694.
    \uBCF4\uAE30 \uC88B\uB358 \uAC8C \uC870\uAE08 \uC6C3\uACA8\uC84C\uC744 \uBFD0\uC785\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uC124\uD0D5 \uC131\uC740 \uC880 \uC544\uAE5D\uB2E4."
