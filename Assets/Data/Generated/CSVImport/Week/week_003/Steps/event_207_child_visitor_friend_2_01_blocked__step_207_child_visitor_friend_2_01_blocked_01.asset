  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_207_child_visitor_friend_2_01_blocked__step_207_child_visitor_friend_2_01_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 \uCCAB \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "\uC58C\uC804\uD55C \uCE5C\uAD6C2\uC5D0\uAC8C \uB2E4\uAC00\uAC00\uB824\uB294
    \uB124\uBAA8\uB97C \uD558\uB140\uAC00 \uB9C9\uACE0 \uC778\uC0AC\uB9CC \uD558\uAC8C
    \uD55C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4? \uC7E4\uB294 \uC65C \uC800\uB807\uAC8C \uAC00\uB9CC\uD788 \uC788\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uBC31\uC791\uB2D8\uC758 \uC190\uB2D8\uACFC \uAC19\uC774 \uC624\uC2E0
      \uC190\uB2D8\uC774\uC2ED\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uBCF4\uB2E4 \uC58C\uC804\uD55C\uB370."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC778\uC0AC\uB9CC \uD558\uC154\uC57C
      \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uBC31\uC791\uB2D8\uAED8\uC11C \uC190\uB2D8\uAED8 \uC608\uB97C \uAC16\uCD94\uB77C
      \uD558\uC168\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB124\u2026 \uC548\uB155."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\u2026\u2026\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB05D\uC774\uC57C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124, \uC624\uB298\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uC785\uB2C8\uB2E4."
  _nemoLine: "\uC5B4? \uC7E4\uB294 \uC65C \uC800\uB807\uAC8C \uAC00\uB9CC\uD788 \uC788\uC5B4?"
  _useCustomVisualState: 0
  _visualState: 0
