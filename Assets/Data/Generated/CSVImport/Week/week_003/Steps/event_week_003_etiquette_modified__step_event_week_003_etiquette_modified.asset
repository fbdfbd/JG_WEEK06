  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_etiquette_modified__step_event_week_003_etiquette_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD568\uAED8 \uC2DC\uC791\uD558\uACE0 \uB05D\uB0B4\uB294 \uAC10\uAC01\uC744
    \uC775\uD78C\uB2E4"
  _bodyText: "\uC778\uC0AC\uC640 \uC2DD\uC0AC \uC608\uC808 3\uC8FC\uCC28 Modified
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC2DD\uD0C1. \uB2E4\uB978 \uD558\uC778 \uD558\uB098\uAC00 \uD568\uAED8
      \uC11C \uC788\uACE0, \uC5EC\uB7EC \uC811\uC2DC\uAC00 \uBC88\uAC08\uC544 \uB098\uC628\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC624\uB298\uC740 \uD63C\uC790\uB9CC\uC774 \uC544\uB2C8\uB77C, \uB2E4\uB978
      \uC0AC\uB78C\uACFC \uD568\uAED8\uD558\uB294 \uC2DD\uC0AC\uB97C \uC5F0\uC2B5\uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544\u2026 \uB354 \uADC0\uCC2E\uC544\uC84C\uB124."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uBA3C\uC800 \uBA39\uB294 \uAC8C \uC544\uB2C8\uB77C, \uD750\uB984\uC744
      \uB9DE\uCD98\uB2E4\uACE0 \uC0DD\uAC01\uD574 \uBCF4\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD750\uB984?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uAC19\uC774 \uC2DC\uC791\uD558\uACE0, \uAC19\uC774 \uB05D\uB098\uB294
      \uC2DD\uC73C\uB85C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\uADF8\uAC74 \uC880 \uAD1C\uCC2E\uB124."
  _nemoLine: "(\uC2DD\uD0C1. \uB2E4\uB978 \uD558\uC778 \uD558\uB098\uAC00 \uD568\uAED8
    \uC11C \uC788\uACE0, \uC5EC\uB7EC \uC811\uC2DC\uAC00 \uBC88\uAC08\uC544 \uB098\uC628\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
