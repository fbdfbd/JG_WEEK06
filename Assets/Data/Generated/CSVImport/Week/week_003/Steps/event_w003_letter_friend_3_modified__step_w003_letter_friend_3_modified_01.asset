  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_letter_friend_3_modified__step_w003_letter_friend_3_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 3\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uAD6C\uACA8\uC9C4 \uB4EF\uD558\uBA74\uC11C\uB3C4
    \uC54C\uB85D\uB2EC\uB85D\uD55C \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4.
    \uBD09\uD22C\uC5D4 \uC774\uBC88\uC5D4 \uBCC4\uC774 \uC544\uB2C8\uB77C \uBB3C\uACB0
    \uAC19\uC740 \uC120\uC774 \uC794\uB729 \uADF8\uB824\uC838 \uC788\uB2E4.)\n       
    \n        \uD558\uB140 : \uC8FC\uC778\uB2D8 \uC55E\uC73C\uB85C \uC628 \uD3B8\uC9C0\uC785\uB2C8\uB2E4.\n       
    \n\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C
    \uB610\uB798 \uC190\uB2D8\uC774 \uB610 \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uBB50\uB77C\uACE0 \uD588\uC5B4?\n        \n       
    \uD558\uB140 : \uC624\uB298 \uBCF8 \uBC18\uC9DD\uC774\uB294 \uD48D\uACBD\uC744
    \uC8FC\uC778\uB2D8\uC774\uB791 \uAC19\uC774 \uBD24\uC73C\uBA74 \uC88B\uC558\uACA0\uB2E4\uACE0
    \uD588\uC5B4\uC694.\n        \n        \uB124\uBAA8 : \uB098\uB791?\n       
    \n        \uD558\uB140 : \uB124. \uADF8\uB9AC\uACE0 \uC9C0\uB09C\uBC88\uC5D0
    \uC8FC\uC778\uB2D8\uC774 \uAC19\uC774 \uC774\uC57C\uAE30\uD574 \uC900 \uAC78
    \uC544\uC9C1 \uAE30\uC5B5\uD55C\uB2E4\uACE0 \uD588\uC2B5\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uADF8\uAC83\uB3C4 \uC37C\uC5B4?\n        \n       
    \uD558\uB140 : \uB124. \uB2E4\uC74C\uC5D4 \uC8FC\uC778\uB2D8\uC774 \uBA3C\uC800
    \uC7AC\uBC0C\uB294 \uAC78 \uCC3E\uC544 \uB2EC\uB77C\uACE0\uB3C4 \uD588\uACE0\uC694.\n       
    \n        \uB124\uBAA8 : \uC624.\n        \n        \uB124\uBAA8 : \uADF8\uAC74
    \uD560 \uC218 \uC788\uC5B4.\n        \n        \uD558\uB140 : \uB9CE\uC774 \uAE30\uB300\uD558\uC2DC\uB294
    \uAC83 \uAC19\uB124\uC694, \uC8FC\uC778\uB2D8.\n        \n        \uB124\uBAA8
    : \uC751. \uC774\uBC88\uC5D4 \uB0B4\uAC00 \uB354 \uC774\uC0C1\uD55C \uAC70 \uCC3E\uC744\uB798."
