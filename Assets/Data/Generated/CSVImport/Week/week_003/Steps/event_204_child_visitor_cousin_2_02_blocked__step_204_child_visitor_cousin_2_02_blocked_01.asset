  _titleOverride: "\uC0AC\uCD0C2 \uB450 \uBC88\uC9F8 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "\uB2E4\uC2DC \uB9CC\uB09C \uC0AC\uCD0C2\uC640 \uC624\uB798 \uB180\uC9C0
    \uBABB\uD558\uAC8C \uD558\uC790 \uB458\uC740 \uC9E7\uC740 \uC57D\uC18D\uB9CC
    \uB0A8\uAE34\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\u2026\u2026\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC624\uB298\uC740 \uAE38\uAC8C \uB180 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\u2026\u2026\uAD1C\uCC2E\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548 \uAD1C\uCC2E\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uB2E4\uC74C\uC5D0\u2026 \uB610 \uBCF4\uBA74 \uB418\uB2C8\uAE4C."
  _nemoLine: "\uC548\uB155."
