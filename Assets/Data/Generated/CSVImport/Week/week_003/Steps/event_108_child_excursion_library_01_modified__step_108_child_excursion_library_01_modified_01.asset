  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_108_child_excursion_library_01_modified__step_108_child_excursion_library_01_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 1\uCC28 - \uB300\uCCB4"
  _bodyText: "\uC6D0\uD558\uB358 \uCC45 \uB300\uC2E0 \uBC18\uC9DD\uC774\uB294 \uB3D9\uBB3C
    \uADF8\uB9BC\uCC45\uC73C\uB85C \uAD00\uC2EC\uC744 \uC62E\uACA8 \uC900\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uC800 \uCC45\uC740 \uC548 \uB429\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC5D0\u2026"
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uB300\uC2E0 \uC8FC\uC778\uB2D8\uC774 \uBCF4\uC2E4 \uB9CC\uD55C \uBC18\uC9DD\uC774\uB294
      \uCC45\uC774 \uD558\uB098 \uB354 \uC788\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC\uC694?"
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uC608. \uB3D9\uBB3C \uADF8\uB9BC\uC774 \uB9CE\uC740 \uCC45\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB3D9\uBB3C?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC70 \uBCFC\uB798\uC694!"
  _nemoLine: "\uC800 \uCC45\uC740 \uC548 \uB429\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
