  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_letter_friend_3_direct__step_w003_letter_friend_3_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 3\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uAD6C\uACA8\uC9C4 \uB4EF\uD558\uBA74\uC11C\uB3C4
    \uC54C\uB85D\uB2EC\uB85D\uD55C \uBD09\uD22C\uB97C \uB4E4\uACE0 \uC628\uB2E4.
    \uBD09\uD22C\uC5D4 \uC774\uBC88\uC5D4 \uBCC4\uC774 \uC544\uB2C8\uB77C \uBB3C\uACB0
    \uAC19\uC740 \uC120\uC774 \uC794\uB729 \uADF8\uB824\uC838 \uC788\uB2E4.)\r\n       
    \r\n        \uD558\uB140 : \uC8FC\uC778\uB2D8 \uC55E\uC73C\uB85C \uC628 \uD3B8\uC9C0\uC785\uB2C8\uB2E4.\r\n       
    \r\n\r\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uC800\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798
    \uC190\uB2D8\uC774 \uB2E4\uC2DC \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uB610 \uBB50 \uB2EE\uC558\uB300?\r\n        \r\n       
    \uD558\uB140 : \uADF8\uAC83\uB3C4 \uC788\uC744 \uAC83 \uAC19\uAD70\uC694.\r\n       
    \r\n        \uB124\uBAA8 : \uBE68\uB9AC \uC77D\uC5B4\uC918.\r\n        \r\n       
    (\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)\r\n        \r\n       
    \uB124\uBAA8 \uC548\uB155. \uC624\uB298 \uC5F0\uBABB \uC704 \uD587\uBE5B\uC740
    \uC740 \uAD6D\uC218 \uAC19\uC558\uC5B4. \uBC14\uB78C \uBD88\uBA74 \uB2E4 \uB04A\uC5B4\uC9C8
    \uAC83\uCC98\uB7FC \uD754\uB4E4\uB838\uC5B4. \uB108\uB791 \uBCF4\uBA74 \uB354
    \uC7AC\uBC0C\uC5C8\uC744 \uD150\uB370. \uADF8\uB9AC\uACE0 \uC800\uBC88\uC5D0
    \uB124\uAC00 \"\uC548 \uB2EE\uC558\uC5B4\" \uD558\uB358 \uBAA9\uC18C\uB9AC\uAC00
    \uC544\uC9C1\uB3C4 \uAE30\uC5B5\uB098. \uB2E4\uC74C\uC5D4 \uB124\uAC00 \uBA3C\uC800
    \uB2EE\uC740 \uAC78 \uCC3E\uC544 \uC918.\r\n        \r\n        \uB124\uBAA8
    : \uC740 \uAD6D\uC218\uB294 \uB610 \uBB50\uC57C.\r\n        \r\n        \uD558\uB140
    : \uC0C1\uC0C1\uB825\uC774 \uC544\uC8FC \uBC14\uC058\uB124\uC694.\r\n       
    \r\n        \uB124\uBAA8 : \uADFC\uB370 \uB0B4 \uBAA9\uC18C\uB9AC \uAE30\uC5B5\uD55C\uB300.\r\n       
    \r\n        \uD558\uB140 : \uB124. \uC8FC\uC778\uB2D8\uC774\uB791 \uAC19\uC774
    \uBCF8 \uAC8C \uC624\uB798 \uB0A8\uC558\uB098 \uBD05\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uB2E4\uC74C\uC5D4 \uB0B4\uAC00 \uBA3C\uC800 \uCC3E\uC73C\uB798.\r\n       
    \r\n        \uD558\uB140 : \uC790\uC2E0 \uC788\uC73C\uC2ED\uB2C8\uAE4C?\r\n       
    \r\n        \uB124\uBAA8 : \uC751. \uC774\uBC88\uC5D4 \uB0B4\uAC00 \uC774\uAE38
    \uAC70\uC57C."
