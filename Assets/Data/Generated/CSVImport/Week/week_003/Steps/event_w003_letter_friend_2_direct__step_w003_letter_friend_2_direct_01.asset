  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_letter_friend_2_direct__step_w003_letter_friend_2_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C2 \uD3B8\uC9C0 3\uC8FC\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140\uAC00 \uB2E8\uC815\uD55C \uBD09\uD22C \uD558\uB098\uB97C
    \uBC1B\uC544 \uB4E0\uB2E4. \uBD09\uD22C\uB294 \uBC18\uB4EF\uD558\uAC8C \uC811\uD600
    \uC788\uACE0, \uAE00\uC528\uB3C4 \uC791\uACE0 \uACE0\uB974\uAC8C \uC4F0\uC5EC
    \uC788\uB2E4.)\r\n        \r\n        \uD558\uB140 : \uC800\uBC88 \uC190\uB2D8
    \uCABD\uC5D0\uC11C \uD3B8\uC9C0\uAC00 \uC654\uB124.\r\n        \r\n\r\n\uD558\uB140
    : \uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798 \uC190\uB2D8\uC774
    \uB2E4\uC2DC \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\r\n        \r\n       
    \uB124\uBAA8 : \uB610 \uC794\uC18C\uB9AC\uD588\uC5B4?\r\n        \r\n       
    \uD558\uB140 : \uADF8\uAC74 \uC77D\uC5B4 \uBD10\uC57C \uC54C\uACA0\uC9C0\uC694.\r\n       
    \r\n        \uB124\uBAA8 : \uC77D\uC5B4 \uC918.\r\n        \r\n        (\uD558\uB140\uAC00
    \uD3B8\uC9C0\uB97C \uD3BC\uCE5C\uB2E4.)\r\n        \r\n        \uB124\uBAA8\uC5D0\uAC8C.
    \uC9C0\uB09C\uBC88\uC5D4 \uC190\uC218\uAC74\uC744 \uCC59\uAE34 \uAC8C \uB098\uC558\uB2E4.
    \uD558\uC9C0\uB9CC \uB124 \uBA38\uB9AC\uCE74\uB77D\uC740 \uB610 \uD750\uD2B8\uB7EC\uC838
    \uC788\uC5C8\uB2E4. \uB2E4\uC74C\uC5D4 \uB9AC\uBCF8\uB3C4 \uC81C\uB300\uB85C
    \uBB36\uB294 \uAC8C \uC88B\uACA0\uB2E4. \uADF8\uB9AC\uACE0\u2026 \uC9C0\uB09C\uBC88\uC5D0
    \uB124\uAC00 \uC6C3\uC740 \uAC74 \uC880 \uC2DC\uB044\uB7EC\uC6E0\uC9C0\uB9CC,
    \uB098\uC058\uC9C4 \uC54A\uC558\uB2E4.\r\n        \r\n        \uB124\uBAA8 :
    \uBB50\uC57C.\r\n        \r\n        \uB124\uBAA8 : \uBA38\uB9AC\uCE74\uB77D\uC774
    \uB610 \uC5B4\uCA0C\uB300.\r\n        \r\n        \uD558\uB140 : \uC544\uC8FC
    \uAF3C\uAF3C\uD55C \uBD84\uC774\uB124\uC694.\r\n        \r\n        \uB124\uBAA8
    : \uADFC\uB370 \uB9C8\uC9C0\uB9C9\uC740 \uC774\uC0C1\uD574.\r\n        \r\n       
    \uD558\uB140 : \uCE6D\uCC2C\uD558\uB824\uB2E4 \uC5B4\uC0C9\uD574\uC9C4 \uAC83
    \uAC19\uAE30\uB3C4 \uD569\uB2C8\uB2E4.\r\n        \r\n        \uB124\uBAA8 :
    \u2026\u2026\uC6C3\uC740 \uAC74 \uB098\uC058\uC9C0 \uC54A\uC558\uB300.\r\n       
    \r\n        \uD558\uB140 : \uB124.\r\n        \r\n        \uB124\uBAA8 : \uAC54
    \uC9C4\uC9DC \uB9D0 \uC774\uC0C1\uD558\uAC8C \uD574."
