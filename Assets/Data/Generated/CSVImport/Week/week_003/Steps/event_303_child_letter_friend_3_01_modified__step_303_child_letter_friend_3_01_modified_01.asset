  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 - \uC815\uB9AC"
  _bodyText: "\uC5C9\uB6B1\uD55C \uBE44\uC720\uB294 \uC904\uC774\uACE0 \uB2E4\uC74C\uC5D0
    \uAC19\uC774 \uBCF4\uACE0 \uC2F6\uB2E4\uB294 \uB73B \uC704\uC8FC\uB85C \uC77D\uC5B4
