  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_external_headline_03_direct__step_w003_external_headline_03_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB274\uC2A4 3\uCC28 - \uD5C8\uB77D"
  _bodyText: "(\uD558\uB140 \uB458\uC774 \uBCF5\uB3C4\uC5D0\uC11C \uC804\uB2E8 \uD558\uB098\uB97C
    \uBD99\uC7A1\uACE0 \uC6C3\uC74C\uC744 \uCC38\uB294\uB2E4. \uC804\uB2E8 \uC704\uC5D4
    \uCEE4\uB2E4\uB797\uAC8C \uADF8\uB824\uC9C4 \uBBF8\uC2A4\uD130 \uC784 \uC5BC\uAD74\uC774
    \uBC18\uCBE4 \uC606\uC73C\uB85C \uB3CC\uC544\uAC00 \uC788\uB2E4. \uAD1C\uD788
    \uC798\uC0DD\uAE34 \uCC99\uD558\uB294 \uAC01\uB3C4\uB2E4.)\r\n        \r\n       
    \uB124\uBAA8 : \uBB50\uC57C?\r\n        \r\n        \uB124\uBAA8 : \uC5BC\uAD74\uC774
    \uC65C \uC800\uB798.\r\n        \r\n        \uD558\uB1401 : \uC27F.\r\n       
    \r\n        \uD558\uB1402 : \uC8FC\uC778\uB2D8, \uB610 \uBBF8\uC2A4\uD130 \uC784
    \uC774\uC57C\uAE30\uC608\uC694.\r\n        \r\n\r\n\uB124\uBAA8 : \uBB58 \uD588\uB294\uB370?\r\n       
    \r\n        \uD558\uB1401 : \uC5F0\uD68C\uC7A5 \uC55E\uC5D0\uC11C \uCD08\uB300\uC7A5
    \uAC80\uC0AC\uBC1B\uB2E4\uAC00,\r\n        \r\n        \"\uBBF8\uC2A4\uD130 \uC784
    \uAC19\uC740 \uC0AC\uB78C\uC5D0\uAC8C \uC885\uC774\uAC00 \uAF2D \uD544\uC694\uD558\uC9C4
    \uC54A\uC9C0\" \uD588\uB300\uC694.\r\n        \r\n        \uB124\uBAA8 : \uD5C9.
    \uC9C4\uC9DC \uADF8\uB807\uAC8C \uB9D0\uD588\uC5B4?\r\n        \r\n        \uD558\uB1402
    : \uB124. \uADF8\uB798\uC11C \uB2E4\uB4E4 \uAE30\uAC00 \uB9C9\uD600\uD588\uB294\uB370\u2026\r\n       
    \r\n        \uD558\uB1401 : \uC7A0\uAE50 \uB4A4\uC5D0 \uC790\uAE30\uAC00 \uD574\uCE58\uC6B4
    \uB9C8\uC218 \uC598\uAE30\uB97C \uC2DC\uC791\uD558\uB354\uB2C8,\r\n        \r\n       
    \uC0AC\uB78C\uB4E4\uC774 \uB610 \uBC15\uC218 \uCCE4\uB2F5\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uBB50\uC57C.\r\n        \r\n        \uB124\uBAA8
    : \uC9C4\uC9DC \uC774\uC0C1\uD55C\uB370 \uBA4B\uC788\uB124.\r\n        \r\n       
    \uD558\uB1402 : \uB531 \uADF8 \uB9D0\uC774 \uB9DE\uC9C0\uC694, \uC8FC\uC778\uB2D8.\r\n       
    \r\n        \uB124\uBAA8 : \uB098\uB3C4 \uC800\uB807\uAC8C \uB9D0\uD558\uBA74
    \uD63C\uB0A0\uAE4C?\r\n        \r\n        \uD558\uB1401 : \uC8FC\uC778\uB2D8\uC740
    \uB9CE\uC774 \uD63C\uB098\uC2E4 \uAC81\uB2C8\uB2E4.\r\n        \r\n        \uB124\uBAA8
    : \uC5D0\uC774."
