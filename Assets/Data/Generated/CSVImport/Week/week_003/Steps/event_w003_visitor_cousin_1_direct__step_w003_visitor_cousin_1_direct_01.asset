  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_visitor_cousin_1_direct__step_w003_visitor_cousin_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 3\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uC751\uC811\uC2E4. \uC0AC\uCD0C1\uC774 \uCC28\uB97C \uB9C8\uC2DC\uBA70
    \uB124\uBAA8\uB97C \uBCF4\uC790 \uBA3C\uC800 \uC190\uC9D3\uD55C\uB2E4. \uD14C\uC774\uBE14
    \uC704\uC5D4 \uC791\uC740 \uB098\uBB34 \uC0C1\uC790\uAC00 \uD558\uB098 \uB193\uC5EC
    \uC788\uB2E4.)\n        \n        \uC0AC\uCD0C1 : \uB610 \uB9CC\uB098\uB294\uAD6C\uB098.\n       
    \n        \uB124\uBAA8 : \uC548\uB155\uD558\uC138\uC694.\n        \n        \uB124\uBAA8
    : \uC800 \uC0C1\uC790 \uBB50\uC57C?\n        \n\n(\uC0AC\uCD0C1\uC774 \uC0C1\uC790\uB97C
    \uB124\uBAA8 \uCABD\uC73C\uB85C \uBC00\uC5B4 \uC900\uB2E4.)\n        \n       
    \uC0AC\uCD0C1 : \uC5F4\uC5B4 \uBCF4\uACA0\uB2C8?\n        \n        \uB124\uBAA8
    : \uC751.\n        \n        (\uB124\uBAA8\uAC00 \uC0C1\uC790\uB97C \uC5F4\uC790,
    \uC548\uC5D0\uC11C \uC791\uC740 \uB098\uBB34 \uC778\uD615\uC774 \uD280\uC5B4\uB098\uC640
    \uACE0\uAC1C\uB97C \uAE4C\uB531\uAC70\uB9B0\uB2E4.)\n        \n        \uB124\uBAA8
    : \uD5C9. \uB180\uB790\uB2E4.\n        \n        \uC0AC\uCD0C1 : \uD558\uD558.
    \uB9C8\uC74C\uC5D0 \uB4DC\uB2C8?\n        \n        \uB124\uBAA8 : \uC751. \uC774\uAC70
    \uC6C3\uACA8.\n        \n        \uC0AC\uCD0C1 : \uB204\uB974\uBA74 \uB2E4\uC2DC
    \uB4E4\uC5B4\uAC04\uB2E8\uB2E4.\n        \n        \uB124\uBAA8 : \uB610 \uD574\uB3C4
    \uB3FC?\n        \n        \uC0AC\uCD0C1 : \uBB3C\uB860\uC774\uC9C0.\n       
    \n        (\uC9D1\uC0AC\uC7A5\uC740 \uBA40\uCC0D\uC774 \uC11C\uC11C \uC870\uC6A9\uD788
    \uC9C0\uCF1C\uBCF8\uB2E4.)\n        \n        \uB124\uBAA8 : \uC774 \uC0AC\uB78C\uC740
    \uC790\uAFB8 \uC774\uC0C1\uD55C \uAC78 \uAC00\uC838\uC640."
