  _titleOverride: "\uD6C4\uBB38 \uBC14\uB78C \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "\uD6C4\uBB38 \uBC14\uB78C\uC774 \uC2EC\uD574 \uC6B0\uC0B0\uB3C4 \uB4A4\uC9D1\uD78C\uB2E4\uACE0
    \uC54C\uB824 \uC900\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uD6C4\uBB38 \uCABD \uBC14\uB78C\uC740 \uC6B0\uC0B0\uC774\uB791 \uC6D0\uC218\uC57C."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC5B4\uC81C\uB3C4 \uD558\uB098 \uB4A4\uC9D1\uD614\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC0B0\uC774 \uB4A4\uC9D1\uD600?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124, \uC8FC\uC778\uB2D8. \uAC70\uAE34 \uBC14\uB78C\uC774 \uC2EC\uC220\uC774
      \uC0AC\uB0A9\uAC70\uB4E0\uC694."
  _nemoLine: "\uD6C4\uBB38 \uCABD \uBC14\uB78C\uC740 \uC6B0\uC0B0\uC774\uB791 \uC6D0\uC218\uC57C."
