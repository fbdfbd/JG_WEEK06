  _titleOverride: "\uB9AC\uC548 \uBC29\uBB38 \uD1B5\uC81C"
  _bodyText: "letter cousin_2 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uB294 \uBD09\uD22C\uB97C \uBCF4\uACE0 \uC7A0\uAE50 \uBA48\uCD98
      \uB4A4, \uB2E4\uB978 \uC11C\uB958\uC640 \uD568\uAED8 \uC815\uB9AC\uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uB294 \uCE74\uD3AB \uBB34\uB2AC\uB97C \uB530\uB77C \uBC1C\uB05D\uC73C\uB85C
      \uC120\uC744 \uBC1F\uACE0 \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\u2026\u2026\uC774\uAC74 \uC870\uC6A9\uD788 \uBCF4\uAD00\uD574 \uB450\uB294
      \uAC8C \uC88B\uACA0\uB124."
  _nemoLine: "(\uD558\uB140\uB294 \uBD09\uD22C\uB97C \uBCF4\uACE0 \uC7A0\uAE50 \uBA48\uCD98
    \uB4A4, \uB2E4\uB978 \uC11C\uB958\uC640 \uD568\uAED8 \uC815\uB9AC\uD55C\uB2E4.)"
