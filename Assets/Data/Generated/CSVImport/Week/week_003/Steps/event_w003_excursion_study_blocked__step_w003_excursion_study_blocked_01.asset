  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_excursion_study_blocked__step_w003_excursion_study_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC 3\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uC11C\uC7AC \uBB38\uC774 \uC870\uAE08 \uC5F4\uB824 \uC788\uB2E4.
    \uC548\uCABD\uC5D0\uC11C \uBE44\uC11C\uAC00 \uC791\uC740 \uB18B\uADF8\uB987 \uC704\uC5D0
    \uBD89\uC740 \uBC00\uB78D\uC744 \uB179\uC774\uACE0 \uC788\uB2E4. \uADF8\uB987
    \uBC11\uC758 \uC5F4\uC11D\uC774 \uC740\uC740\uD558\uAC8C \uB2EC\uC544\uC62C\uB77C
    \uC788\uB2E4.)\n        \n        \uB124\uBAA8 : \uC5B4?\n        \n        \uB124\uBAA8
    : \uC800\uAC70 \uC7BC\uC774\uC57C?\n        \n        \uB124\uBAA8 : \uB0C4\uC0C8\uB294
    \uC544\uB2CC\uB370 \uC0C9\uC740 \uC7BC \uAC19\uC544.\n        \n        (\uBE44\uC11C\uAC00
    \uC6C3\uC74C\uC744 \uCC38\uC73C\uBA70 \uBC00\uB78D\uC744 \uBD09\uD22C \uC704\uC5D0
    \uB611 \uB5A8\uC5B4\uB728\uB9B0\uB2E4. \uACE7\uC774\uC5B4 \uC778\uC7A5\uC744
    \uAFB9 \uB204\uB974\uC790 \uBB38\uC591\uC774 \uB0A8\uB294\uB2E4.)\n        \n\n(\uBE44\uC11C\uAC00
    \uBC00\uB78D \uADF8\uB987\uC744 \uBC14\uB85C \uC548\uCABD\uC73C\uB85C \uC62E\uAE34\uB2E4.)\n       
    \n        \uBE44\uC11C : \uC8FC\uC778\uB2D8, \uC774\uCABD\uC740 \uC548 \uB429\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uC7BC \uC544\uB2CC \uAC74 \uC54C\uACA0\uC5B4.\n       
    \n        \uBE44\uC11C : \uADF8\uAC78 \uC544\uC2E0 \uAC83\uB9CC\uC73C\uB85C \uCDA9\uBD84\uD569\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uD55C \uBC88 \uB20C\uB7EC \uBCF4\uACE0 \uC2F6\uC740\uB370.\n       
    \n        \uBE44\uC11C : \uC774\uAC74 \uBC31\uC791\uB2D8 \uBB38\uC11C\uC6A9\uC785\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uB9E8\uB0A0 \uC911\uC694\uD55C \uAC70\uC57C.\n       
    \n        \uBE44\uC11C : \uC608. \uD2B9\uD788 \uC774\uAC74\uC694.\n        \n       
    \uB124\uBAA8 : \uC11C\uC7AC\uB294 \uBA39\uB294 \uAC74 \uC5C6\uACE0 \uB204\uB974\uB294
    \uAC83\uB9CC \uB9CE\uB124."
