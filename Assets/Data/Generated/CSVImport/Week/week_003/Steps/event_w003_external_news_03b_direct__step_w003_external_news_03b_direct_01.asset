  m_Name: event_w003_external_news_03b_direct__step_w003_external_news_03b_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC18C\uC2DD 3\uCC28-2 - \uD5C8\uB77D"
  _bodyText: "\uC124\uD0D5 \uC131 \uBB34\uB108\uC9C4 \uC774\uC57C\uAE30\n       
    \n        (\uBD80\uC5CC \uC606 \uBCF5\uB3C4. \uD558\uB140 \uB458\uC774 \uC6C3\uC74C\uC744
    \uCC38\uB2E4\uAC00 \uACB0\uAD6D \uC785\uC744 \uB9C9\uB294\uB2E4. \uC7C1\uBC18
    \uC704\uC5D4 \uC124\uD0D5\uAC00\uB8E8\uAC00 \uC870\uAE08 \uB0A8\uC740 \uACFC\uC790
    \uC870\uAC01\uC774 \uC788\uB2E4.)\n        \n        \uB124\uBAA8 : \uC65C \uC6C3\uC5B4?\n       
    \n        \uD558\uB1401 : \uC27F, \uC8FC\uC778\uB2D8.\n        \n        \uD558\uB1402
    : \uBC16\uC5D0\uC11C \uB4E4\uC740 \uC598\uAE34\uB370, \uB108\uBB34 \uC6C3\uACA8\uC11C\uC694.\n       
    \n\n\uD558\uB1401 : \uC5B4\uB5A4 \uADC0\uC871\uAC00 \uC0DD\uC77C\uC794\uCE58\uC5D0\uC11C
    \uC124\uD0D5\uC73C\uB85C \uB9CC\uB4E0 \uC131\uC744 \uC62C\uB838\uB300\uC694,
    \uC8FC\uC778\uB2D8.\n        \n        \uB124\uBAA8 : \uC131\uC744? \uBA39\uB294
    \uAC78\uB85C?\n        \n        \uD558\uB1402 : \uB124. \uC544\uC8FC \uD06C\uAC8C\uC694.
    \uADF8\uB7F0\uB370 \uB204\uAC00 \uCD1B\uBD88\uC744 \uB108\uBB34 \uAC00\uAE4C\uC774
    \uB450\uB294 \uBC14\uB78C\uC5D0, \uC0DD\uD65C \uC628\uC5F4\uC11D\uAE4C\uC9C0
    \uAC19\uC774 \uB2EC\uC544\uC62C\uB77C\uC11C\u2026\n        \n        \uB124\uBAA8
    : \uC5B4?\n        \n        \uD558\uB1401 : \uD0D1\uC774 \uD55C\uCABD\uC73C\uB85C
    \uD479 \uAEBC\uC9C0\uB354\uB2C8, \uC0AC\uD0D5 \uCC3D\uBB38\uC774 \uC6B0\uC218\uC218
    \uC3DF\uC544\uC84C\uB300\uC694.\n        \n        \uB124\uBAA8 : \uD5C9. \uADF8\uB7FC
    \uB2E4 \uB9DD\uD588\uC796\uC544.\n        \n        \uD558\uB1402 : \uB124. \uADF8\uB7F0\uB370
    \uC544\uC774\uB4E4\uC774 \uBC11\uC5D0\uC11C \uB5A8\uC5B4\uC9C4 \uC0AC\uD0D5 \uC8FC\uC6CC
    \uBA39\uB290\uB77C \uB354 \uB09C\uB9AC\uC600\uB300\uC694.\n        \n       
    \uB124\uBAA8 : \uBB50\uC57C. \uADF8\uAC74 \uC880 \uC7AC\uBC0C\uB2E4.\n       
    \n        \uD558\uB1401 : \uC8FC\uC778\uB2D8\uB3C4 \uAC70\uAE30 \uC788\uC5C8\uC73C\uBA74
    \uC81C\uC77C \uBA3C\uC800 \uB6F0\uC5B4\uAC00\uC168\uC744 \uAC83 \uAC19\uB124\uC694.\n       
    \n        \uB124\uBAA8 : \uB2F9\uC5F0\uD558\uC9C0."
