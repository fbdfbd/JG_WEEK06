  _titleOverride: "\uCE5C\uAD6C2 \uD3B8\uC9C0 - \uADF8\uB300\uB85C \uC77D\uAE30"
  _bodyText: "\uC870\uAE08 \uBFB0\uC871\uD558\uC9C0\uB9CC \uC194\uC9C1\uD55C \uCE5C\uAD6C2\uC758
    \uBB38\uC7A5\uC744 \uADF8\uB300\uB85C \uC77D\uC5B4 \uC900\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124\uBAA8\uC5D0\uAC8C. \uC9C0\uB09C\uBC88 \uC637\uC5D0 \uBA3C\uC9C0\uAC00
      \uB9CE\uC774 \uBB3B\uC5B4 \uC788\uC5C8\uB2E4. \uB2E4\uC74C\uC5D4 \uC190\uC218\uAC74\uC744
      \uCC59\uACA8."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8\uB9AC\uACE0 \uB108\uBB34 \uBE68\uB9AC \uB6F0\uC9C0 \uB9C8. \uADF8\uB798\uB3C4\u2026
      \uB2E4\uC2DC \uBCF4\uBA74 \uC778\uC0AC\uB294 \uD574\uB3C4 \uB41C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC815\uB9D0 \uAC54\uB2F5\uB2E4."
  _nemoLine: "\uB124\uBAA8\uC5D0\uAC8C. \uC9C0\uB09C\uBC88 \uC637\uC5D0 \uBA3C\uC9C0\uAC00
