  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: "event_week_003_house_talk_\uBD84\uC218\uB300_\uBB3C\uACE0\uAE30_\uC18C\uBB38_direct__step_event_week_003_house_talk_\uBD84\uC218\uB300_\uBB3C\uACE0\uAE30_\uC18C\uBB38_direct"
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBD84\uC218\uB300_\uBB3C\uACE0\uAE30_\uC18C\uBB38 Direct"
  _bodyText: "house_talk \uBD84\uC218\uB300_\uBB3C\uACE0\uAE30_\uC18C\uBB38 Direct
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uBD84\uC218\uB300 \uBB3C\uACE0\uAE30 \uD55C \uB9C8\uB9AC\uAC00 \uC790\uAFB8
      \uC548 \uBCF4\uC778\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4\uB514 \uAC14\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB204\uAD70\uAC00 \uAC00\uC838\uAC04\uAC8C \uC544\uB2D0\uAE4C \uC2F6\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB204\uAC00? \uC65C?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uADF8\uAC74 \uBAA8\uB974\uACA0\uC5B4\uC694 \uC8FC\uC778\uB2D8 \uC544\uB9C8
      \uB3C4\uB451\uC774\uC9C0 \uC54A\uC744\uAE4C\uC694? \uB3C4\uB451\uACE0\uC591\uC774\uC77C\uC218\uB3C4
      \uC788\uACE0\uC694"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u31613\u3161"
  _nemoLine: "\uBD84\uC218\uB300 \uBB3C\uACE0\uAE30 \uD55C \uB9C8\uB9AC\uAC00 \uC790\uAFB8
    \uC548 \uBCF4\uC778\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
