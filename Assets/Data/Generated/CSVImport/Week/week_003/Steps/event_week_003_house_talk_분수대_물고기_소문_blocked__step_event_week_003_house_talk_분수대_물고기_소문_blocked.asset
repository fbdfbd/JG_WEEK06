  _titleOverride: "\uBD84\uC218\uB300 \uBB3C\uACE0\uAE30 \uC18C\uBB38 \uD1B5\uC81C"
  _bodyText: "house_talk \uBD84\uC218\uB300_\uBB3C\uACE0\uAE30_\uC18C\uBB38 Blocked
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610 \uC544\uBB34\uAC83\uB3C4 \uC544\uB2C8\uB798."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uADF8\uB0E5 \uBB3C\uACE0\uAE30 \uC22B\uC790 \uC138\uB294 \uC911\uC774\uC5C8\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C \uC138?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC800\uD76C\uAC00 \uC2EC\uC2EC\uD574\uC11C\uC694."
  _nemoLine: "\uC544\uBB34\uAC83\uB3C4 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
