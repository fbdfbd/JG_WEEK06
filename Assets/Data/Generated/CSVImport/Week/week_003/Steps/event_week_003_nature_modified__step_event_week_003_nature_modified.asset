  _titleOverride: "\uAE30\uC5B5\uC5D0 \uB0A8\uC740 \uAC83\uB9CC \uC801\uAC8C \uD55C\uB2E4"
  _bodyText: "\uAF43\uACFC \uBC8C\uB808 \uAD00\uCC30 3\uC8FC\uCC28 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uAC04\uB2E8\uD55C \uAE30\uB85D\uC9C0. \uBCF8 \uAC83\uC744 \uD45C\uC2DC\uD558\uB294
      \uCE78\uC774 \uC788\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC624\uB298\uC740 \uBCF8 \uAC83\uC744 \uB0A8\uACA8\uBCF4\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAE30\uB85D\uAE4C\uC9C0?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC804\uBD80 \uC801\uC9C0 \uC54A\uC544\uB3C4, \uAE30\uC5B5\uC5D0 \uB0A8\uC740
      \uAC83\uB9CC \uC801\uC5B4\uB3C4 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uC880 \uD560 \uB9CC\uD558\uB2E4."
  _nemoLine: "(\uAC04\uB2E8\uD55C \uAE30\uB85D\uC9C0. \uBCF8 \uAC83\uC744 \uD45C\uC2DC\uD558\uB294
    \uCE78\uC774 \uC788\uB2E4.)"
