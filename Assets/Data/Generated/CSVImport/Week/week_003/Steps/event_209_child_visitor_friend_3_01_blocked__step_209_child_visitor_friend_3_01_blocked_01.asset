  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_209_child_visitor_friend_3_01_blocked__step_209_child_visitor_friend_3_01_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uCCAB \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "\uCE5C\uAD6C3\uC5D0\uAC8C \uB2E4\uAC00\uAC00\uB824\uB294 \uB124\uBAA8\uB97C
    \uD558\uB140\uAC00 \uBD80\uB4DC\uB7FD\uAC8C \uB9C9\uACE0 \uC9E7\uC740 \uC778\uC0AC\uB9CC
    \uB0A8\uAE34\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4? \uC548\uB155? \uB10C \uB204\uAD6C\uC57C?"
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uC800 \uAD6C\uB984 \uBD10. \uBE75 \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBE75?"
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uC751. \uB72F\uC5B4 \uBA39\uACE0 \uC2F6\uC5B4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB108\uB3C4? \uB098\uB3C4 \uADF8\uB7F0 \uC0DD\uAC01 \uB4E0 \uC801 \uC788\uC5B4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC9E7\uAC8C \uC778\uC0AC\uB9CC
      \uD558\uC154\uC57C \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774\u2026 \uC548\uB155."
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uC548\uB155! \uB2E4\uC74C\uC5D4 \uAC19\uC774 \uBCF4\uC790!"
  _nemoLine: "\uC5B4? \uC548\uB155? \uB10C \uB204\uAD6C\uC57C?"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
