  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_letter_friend_1_direct__step_event_week_003_letter_friend_1_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9C9\uC2A4 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "letter friend_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC9C0\uB09C\uBC88\uC5D0 \uAC19\uC774 \uB180\uB358 \uB610\uB798
      \uC190\uB2D8\uC774 \uBCF4\uB0B8 \uD3B8\uC9C0\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC77D\uC5B4 \uC918. \uBE68\uB9AC."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uD3BC\uCE5C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB0B4\uAC00 \uC6C3\uB358 \uAC83\uB3C4 \uAE30\uC5B5\uD574?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC8FC\uC778\uB2D8 \uC0DD\uAC01\uC744 \uAF64 \uB9CE\uC774 \uD558\uB098
      \uBD05\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBE44\uBC00 \uC790\uB9AC\uB3C4 \uCC3E\uC558\uB300."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC774\uBC88\uC5D4 \uADF8\uB0E5 \uB6F0\uB294 \uAC83\uBCF4\uB2E4 \uB354
      \uD2B9\uBCC4\uD55C \uAC78 \uBCF4\uC5EC \uC8FC\uACE0 \uC2F6\uC5C8\uB098 \uBCF4\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC70 \uAD81\uAE08\uD55C\uB370. \uB2E4\uC74C\uC5D0 \uAC00\uBA74
      \uBC14\uB85C \uBCF4\uC5EC \uB2EC\uB77C \uD574\uC57C\uC9C0."
  _nemoLine: "\uB124. \uC9C0\uB09C\uBC88\uC5D0 \uAC19\uC774 \uB180\uB358 \uB610\uB798
    \uC190\uB2D8\uC774 \uBCF4\uB0B8 \uD3B8\uC9C0\uC785\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
