  _titleOverride: "\uB3C4\uC11C\uAD00 2\uCC28 - \uD5C8\uB77D"
  _bodyText: "\uC11C\uACE0\uAD00\uB9AC\uC778\uC774 \uC9C0\uCF1C\uBCF4\uB294 \uAC00\uC6B4\uB370
    \uC624\uB798\uB41C \uCC45\uC744 \uC870\uC2EC\uC870\uC2EC \uB118\uACA8 \uBCF4\uAC8C
    \uD55C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uADF8 \uCC45\uC740 \uC5B4\uB824\uC6B0\uC2E4 \uAC81\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC\uC694?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uBAA8\uB974\uB294 \uAE00\uC790 \uC5C4\uCCAD \uB9CE\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB9BC\uB3C4 \uC5C6\uB124. \uC7AC\uBBF8\uC5C6\uC5B4."
  _nemoLine: "\uADF8 \uCC45\uC740 \uC5B4\uB824\uC6B0\uC2E4 \uAC81\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
