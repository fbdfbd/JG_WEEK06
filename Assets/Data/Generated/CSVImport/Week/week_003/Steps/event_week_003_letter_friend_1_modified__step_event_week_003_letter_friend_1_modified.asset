  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_letter_friend_1_modified__step_event_week_003_letter_friend_1_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9C9\uC2A4 \uD3B8\uC9C0 \uC218\uC815"
  _bodyText: "letter friend_1 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798
      \uC190\uB2D8\uC774 \uB2E4\uC2DC \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uB77C\uACE0 \uD588\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC9C0\uB09C\uBC88\uC5D0 \uC8FC\uC778\uB2D8\uC774\uB791 \uB180\uC558\uB358
      \uAC78 \uC544\uC9C1\uB3C4 \uAE30\uC5B5\uD558\uACE0 \uC788\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uADF8\uB9AC\uACE0 \uB2E4\uC74C\uC5D0 \uB9CC\uB098\uBA74 \uBCF4\uC5EC
      \uC8FC\uACE0 \uC2F6\uC740 \uC7AC\uBC0C\uB294 \uACF3\uC774 \uD558\uB098 \uC0DD\uACBC\uB2E4\uACE0
      \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC228\uB294 \uACF3\uC774\uC57C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC544\uB9C8 \uADF8\uB7F4\uC9C0\uB3C4\uC694. \uC544\uB2C8\uBA74 \uB458\uC774
      \uAC19\uC774 \uAD6C\uACBD\uD558\uAE30 \uC88B\uC740 \uACF3\uC77C \uC218\uB3C4
      \uC788\uACE0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624. \uADF8\uB7FC \uB098\uB3C4 \uB2E4\uC74C\uC5D0 \uBB50 \uBCF4\uC5EC
      \uC904 \uAC70 \uCC3E\uC544\uC57C\uACA0\uB2E4."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798
    \uC190\uB2D8\uC774 \uB2E4\uC2DC \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
