--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_external_w003_direct__step_event_week_003_external_w003_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC678\uBD80 \uC815\uBCF4 \uD5C8\uAC00"
  _bodyText: "external w003 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC218\uB3C4 \uD070\uAE38\uC5D0 \uBCC4\uBE5B \uBE44\uB217\uBC29\uC6B8
      \uC545\uC0AC\uB77C\uB294 \uC0AC\uB78C\uC774 \uB098\uD0C0\uB0AC\uB300\uC694,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uB984\uC774 \uC774\uC0C1\uD574."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uD53C\uB9AC\uB97C \uBD88\uBA74 \uD070 \uBE44\uB217\uBC29\uC6B8\uC774
      \uB5A0\uC624\uB974\uACE0, \uADF8 \uC548\uC5D0 \uC791\uC740 \uBD88\uBE5B\uC774
      \uBC18\uC9DD\uC778\uB2E4\uB354\uAD70\uC694. \uC0DD\uD65C \uB9C8\uBC95\uC744
      \uC5B9\uC740 \uAC70\uB798\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC \uBCC4\uCC98\uB7FC?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uB124. \uC5B4\uB5A4 \uAC74 \uD30C\uB797\uACE0, \uC5B4\uB5A4 \uAC74 \uAE08\uBE5B\uC774\uACE0,
      \uC5B4\uB5A4 \uAC74 \uD130\uC9C8 \uB54C \uBC18\uC9DD\uC774\uAE4C\uC9C0 \uD769\uC5B4\uC9C4\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5C9."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098 \uADF8\uAC70 \uBCF4\uACE0 \uC2F6\uC5B4."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uC544\uC774\uB4E4\uC774 \uCAD3\uC544\uB2E4\uB2C8\uB290\uB77C \uAE38\uC774
      \uB9C9\uD790 \uC815\uB3C4\uC600\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uCAD3\uC544\uB2E4\uB2D0 \uAC74\uB370."
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uADF8\uAC74 \uBBFF\uC2B5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  _nemoLine: "\uC218\uB3C4 \uD070\uAE38\uC5D0 \uBCC4\uBE5B \uBE44\uB217\uBC29\uC6B8
    \uC545\uC0AC\uB77C\uB294 \uC0AC\uB78C\uC774 \uB098\uD0C0\uB0AC\uB300\uC694, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
