  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_107_child_excursion_basement_02_blocked__step_107_child_excursion_basement_02_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 2\uCC28 - \uD1B5\uC81C"
  _bodyText: "\uACF5\uC744 \uB530\uB77C \uB2E4\uC2DC \uC9C0\uD558\uC2E4 \uC55E\uC5D0
    \uC11C\uC790 \uCC3D\uACE0\uC9C0\uAE30\uAC00 \uC624\uB298\uC740 \uC548\uCABD \uC815\uB9AC\uAC00
    \uB35C \uB05D\uB0AC\uB2E4\uACE0 \uB9D0\uD55C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4? \uC7A1\uC558\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548\uC5D0 \uBB50\uAC00 \uC788\uB098? \uC800\uBC88\uBCF4\uB2E4 \uB354
      \uAD81\uAE08\uD55C\uB370."
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC548\uCABD\uC740 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610\uC694?"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC624\uB298\uC740 \uC548\uCABD \uC815\uB9AC\uAC00 \uB35C \uB05D\uB0AC\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9E8\uB0A0 \uC548 \uB41C\uB300."
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uADF8\uB798\uB3C4 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uC54C\uACA0\uC5B4\uC694."
  _nemoLine: "\uC5B4? \uC7A1\uC558\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
