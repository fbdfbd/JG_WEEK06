  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_external_news_03a_blocked__step_w003_external_news_03a_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC18C\uC2DD 3\uCC28-1 - \uD1B5\uC81C"
  _bodyText: "\uBCC4\uBE5B \uBE44\uB217\uBC29\uC6B8 \uC545\uC0AC\r\n        \r\n       
    (\uD604\uAD00 \uADFC\uCC98. \uD558\uB140 \uB458\uC774 \uC7A5\uBC14\uAD6C\uB2C8\uB97C
    \uC815\uB9AC\uD558\uB2E4\uAC00, \uBC18\uC9DD\uC774\uB294 \uC587\uC740 \uC885\uC774
    \uC804\uB2E8 \uD55C \uC7A5\uC744 \uD3BC\uCE5C\uB2E4. \uC885\uC774\uC5D4 \uCEE4\uB2E4\uB780
    \uBE44\uB217\uBC29\uC6B8 \uC548\uC5D0 \uBCC4\uC774 \uB5A0 \uC788\uB294 \uADF8\uB9BC\uC774
    \uADF8\uB824\uC838 \uC788\uB2E4.)\r\n        \r\n        \uB124\uBAA8 : \uC5B4?\r\n       
    \r\n        \uB124\uBAA8 : \uC800 \uC548\uC5D0 \uBCC4 \uB4E4\uC5B4 \uC788\uC5B4.\r\n       
    \r\n        \uD558\uB1401 : \uC544, \uC774\uAC70 \uC7AC\uBBF8\uC788\uB124\uC694.\r\n       
    \r\n        \uD558\uB1402 : \uC218\uB3C4\uC5D0\uC11C \uC694\uC998 \uC720\uBA85\uD55C
    \uAC70\uB9AC \uC545\uC0AC \uC774\uC57C\uAE30\uB798\uC694.\r\n        \r\n       
    \uB124\uBAA8 : \uC545\uC0AC?\r\n        \r\n\r\n\uD558\uB1401 : \uBCC4\uAC70
    \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.\r\n        \r\n        \uB124\uBAA8
    : \uBC29\uAE08 \uC7AC\uBBF8\uC788\uB2E4\uBA70.\r\n        \r\n        \uD558\uB1402
    : \uADF8\uB0E5 \uAE38\uAC70\uB9AC\uC5D0\uC11C \uC2DC\uB044\uB7FD\uAC8C \uB5A0\uB4DC\uB294
    \uC0AC\uB78C\uB4E4 \uC598\uAE30\uC608\uC694.\r\n        \r\n        \uB124\uBAA8
    : \uADFC\uB370 \uC65C \uBCC4\uC774 \uC788\uC5B4?\r\n        \r\n        \uD558\uB1401
    : \uBCF4\uAE30 \uC88B\uAC8C \uADF8\uB824 \uB193\uC740 \uAC70\uACA0\uC9C0\uC694.\r\n       
    \r\n        \uB124\uBAA8 : \uC9C4\uC9DC \uBCC4\uC740 \uC544\uB2C8\uC57C?\r\n       
    \r\n        \uD558\uB1402 : \uB124. \uADF8\uB7F0 \uAC74 \uC544\uB2D9\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uC5D0\uC774.\r\n        \r\n        \uB124\uBAA8
    : \uADF8\uB9BC\uB9CC \uBC18\uC9DD\uC600\uB124."
