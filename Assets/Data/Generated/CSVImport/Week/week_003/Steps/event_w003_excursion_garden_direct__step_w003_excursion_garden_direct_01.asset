  m_Name: event_w003_excursion_garden_direct__step_w003_excursion_garden_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC815\uC6D0 3\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uD574\uAC00 \uAE30\uC6B8 \uBB34\uB835. \uC815\uC6D0 \uBD84\uC218\uB300
    \uBB3C\uC904\uAE30 \uB05D\uC5D0 \uC791\uACE0 \uC605\uC740 \uBB34\uC9C0\uAC1C\uAC00
    \uAC78\uB824 \uC788\uB2E4.)\n        \n        \uB124\uBAA8 : \uC5B4?\n       
    \n        \uB124\uBAA8 : \uC800\uAE30 \uC0C9\uAE54 \uC788\uB2E4.\n        \n       
    \uB124\uBAA8 : \uC6B0\uC640. \uBB3C\uC774 \uBC18\uC9DD\uBC18\uC9DD\uD558\uB294\uB370
    \uBB34\uC9C0\uAC1C\uB3C4 \uC788\uC5B4.\n        \n        (\uB124\uBAA8\uAC00
    \uBD84\uC218\uB300 \uAC00\uAE4C\uC774\uB85C \uB2E4\uAC00\uAC04\uB2E4.)\n       
    \n\n(\uC815\uC6D0\uC0AC\uAC00 \uB124\uBAA8\uB97C \uBD84\uC218\uB300 \uAC00\uC7A5\uC790\uB9AC\uC5D0\uC11C
    \uC870\uAE08 \uB5A8\uC5B4\uC9C4 \uC548\uC804\uD55C \uC790\uB9AC\uC5D0 \uC138\uC6B4\uB2E4.)\n           
    \n            \uC815\uC6D0\uC0AC : \uC5EC\uAE30\uC11C \uBCF4\uC2DC\uBA74 \uB429\uB2C8\uB2E4,
    \uC8FC\uC778\uB2D8.\n            \n            \uB124\uBAA8 : \uC5EC\uAE30\uC11C\uB3C4
    \uBCF4\uC5EC?\n            \n            \uC815\uC6D0\uC0AC : \uC608~ \uD574\uAC00
    \uC800\uB807\uAC8C \uBE44\uCE60 \uB54C\uB9CC \uC7A0\uAE50 \uC0DD\uAE34\uB2F5\uB2C8\uB2E4~\n           
    \n            \uB124\uBAA8 : \uC9C4\uC9DC\uB124.\n            \n            \uB124\uBAA8
    : \uBE68\uAC15\uB3C4 \uC788\uACE0 \uD30C\uB791\uB3C4 \uC788\uB2E4.\n           
    \n            \uC815\uC6D0\uC0AC : \uAE08\uBC29 \uC0AC\uB77C\uC9C8 \uC218\uB3C4
    \uC788\uC73C\uB2C8 \uB9CE\uC774 \uBCF4\uC154\uC57C\uC9C0\uC694~\n           
    \n            \uB124\uBAA8 : \uC751."
