  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_excursion_basement_direct__step_event_week_003_excursion_basement_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: basement Direct
  _bodyText: "excursion basement Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uB124\uBAA8\uB97C \uBB38 \uC55E\uC5D0
      \uC138\uC6B4 \uCC44, \uD478\uB978 \uB3CC \uC606\uC5D0 \uB193\uC778 \uC0AC\uACFC
      \uD558\uB098\uB97C \uB4E4\uC5B4 \uBCF4\uC778\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uAC00\uAE4C\uC774\uB294 \uC548 \uB418\uACE0, \uC5EC\uAE30\uC11C\uB9CC
      \uBCF4\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751."
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC774 \uB0C9\uAC01\uC11D \uB355\uC5D0 \uC0AC\uACFC\uAC00 \uC624\uB798
      \uBC84\uD301\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB798\uC11C \uC9C0\uD558\uC2E4\uC774 \uCC28\uAC00\uC6B4 \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC608. \uC5EC\uB984\uC5D0\uB3C4 \uC870\uAE08 \uC11C\uB298\uD558\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uC774 \uB3CC\uC740 \uC0AC\uACFC \uC9C0\uCF1C\uC8FC\uB294
      \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uADF8\uB807\uAC8C \uBCFC \uC218\uB3C4 \uC788\uACA0\uAD70\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098 \uC800 \uB3CC \uC88B\uC544. \uB9D0\uC740 \uC548 \uD558\uB294\uB370
      \uC5F4\uC2EC\uD788 \uC77C\uD558\uC796\uC544."
  _nemoLine: "(\uCC3D\uACE0\uC9C0\uAE30\uAC00 \uB124\uBAA8\uB97C \uBB38 \uC55E\uC5D0
    \uC138\uC6B4 \uCC44, \uD478\uB978 \uB3CC \uC606\uC5D0 \uB193\uC778 \uC0AC\uACFC
    \uD558\uB098\uB97C \uB4E4\uC5B4 \uBCF4\uC778\uB2E4.)"
