  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_house_talk_attic_window_rumor_direct__step_event_week_003_house_talk_attic_window_rumor_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB2E4\uB77D \uCC3D\uBB38 \uC18C\uBB38 \uD5C8\uAC00"
  _bodyText: "house_talk \uB2E4\uB77D_\uCC3D\uBB38_\uC18C\uBB38 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uB2E4\uB77D\uC740 \uC624\uB798\uB41C \uBB3C\uAC74 \uB450\uB294 \uACF3\uC774\uB77C
      \uAC00\uB054 \uD558\uC778\uB4E4\uC774 \uC62C\uB77C\uAC04\uB2F5\uB2C8\uB2E4,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB204\uAC00 \uC5F4\uC5C8\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uC544\uB9C8 \uC815\uB9AC\uD558\uB2E4\uAC00 \uAE5C\uBE61\uD55C \uAC70\uACA0\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2E4\uB77D\uC5D4 \uBB50 \uC788\uC5B4?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC624\uB798\uB41C \uC0C1\uC790\uB791, \uCC9C\uC774\uB791, \uB0A1\uC740
      \uC561\uC790 \uAC19\uC740 \uAC83\uB4E4\uC774\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uAC00\uBCF4\uACE0 \uC2F6\uB2E4."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uBA3C\uC9C0\uAC00 \uB9CE\uC544\uC11C \uD558\uB140\uB4E4\uC740 \uBCC4\uB85C
      \uC548 \uAC00\uACE0 \uC2F6\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC70\uC9D3\uB9D0"
  _nemoLine: "\uB2E4\uB77D\uC740 \uC624\uB798\uB41C \uBB3C\uAC74 \uB450\uB294 \uACF3\uC774\uB77C
    \uAC00\uB054 \uD558\uC778\uB4E4\uC774 \uC62C\uB77C\uAC04\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
