  _titleOverride: "\uCE5C\uAD6C2 \uD3B8\uC9C0 - \uC815\uB9AC"
  _bodyText: "\uC190\uC218\uAC74\uC744 \uCC59\uAE30\uACE0 \uB108\uBB34 \uBE68\uB9AC
    \uB6F0\uC9C0 \uB9D0\uB77C\uB294 \uC870\uC5B8\uB9CC \uCD94\uB824 \uB4E4\uB824\uC900\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB2E4\uC74C\uC5D4 \uC190\uC218\uAC74\uC744 \uCC59\uAE30\uACE0, \uB108\uBB34
      \uBE68\uB9AC \uB6F0\uC9C0 \uB9D0\uB77C\uACE0 \uC801\uD600 \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAC54\uB2F5\uB2E4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8\uB798\uB3C4 \uB2E4\uC2DC \uBCF4\uBA74 \uC778\uC0AC\uB294 \uD574\uB3C4
      \uB41C\uB2E4\uACE0 \uD588\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\uADF8\uAC74 \uC88B\uB124."
  _nemoLine: "\uB2E4\uC74C\uC5D4 \uC190\uC218\uAC74\uC744 \uCC59\uAE30\uACE0, \uB108\uBB34
    \uBE68\uB9AC \uB6F0\uC9C0 \uB9D0\uB77C\uACE0 \uC801\uD600 \uC788\uC5B4\uC694."
