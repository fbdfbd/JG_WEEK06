  _titleOverride: "\uC628\uC2E4 \uC720\uB9AC \uC18C\uBB38 \uC218\uC815"
  _bodyText: "house_talk \uC628\uC2E4_\uC720\uB9AC_\uC18C\uBB38 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 3f7713609b39db74c98a5b754e5eaf5e, type: 2}
    _text: "\uC628\uC2E4 \uC720\uB9AC\uAC00 \uC870\uAE08 \uC090\uAC71\uD55C\uB2F5\uB2C8\uB2E4,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC090\uAC71\uD574?"
  - _speaker: {fileID: 11400000, guid: 31350c3de27bb9c43a5cd19e30d43ba8, type: 2}
    _text: "\uB124. \uB0A0\uC528\uAC00 \uBC14\uB00C\uBA74 \uC720\uB9AC\uB3C4 \uAE30\uBD84\uC774
      \uBC14\uB00C\uB098 \uBD10\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC720\uB9AC\uAC00 \uAE30\uBD84 \uC788\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 3f7713609b39db74c98a5b754e5eaf5e, type: 2}
    _text: "\uC544\uC8FC \uC870\uAE08\uC740\uC694. \uADF8\uB798\uC11C \uAC00\uB054
      \uC190\uC744 \uBD10 \uC918\uC57C \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD788\uD788 \uAF43 \uD0A4\uC6B0\uB294 \uAC83\uB3C4 \uD798\uB4DC\uB124."
  _nemoLine: "\uC628\uC2E4 \uC720\uB9AC\uAC00 \uC870\uAE08 \uC090\uAC71\uD55C\uB2F5\uB2C8\uB2E4,
    \uC8FC\uC778\uB2D8."
