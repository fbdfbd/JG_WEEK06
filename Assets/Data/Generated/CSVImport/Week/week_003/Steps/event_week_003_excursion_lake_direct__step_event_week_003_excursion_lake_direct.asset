  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_excursion_lake_direct__step_event_week_003_excursion_lake_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 \uD5C8\uAC00"
  _bodyText: "excursion lake Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uB3CC\uAE38 \uB05D\uAE4C\uC9C0\uB9CC
      \uB530\uB77C\uAC00\uAC8C \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC624\uB298\uB3C4 \uC774 \uC120\uAE4C\uC9C0\uB9CC\uC785\uB2C8\uB2E4,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uC548 \uB118\uC744\uAC8C."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uD5C8\uB9AC\uB97C \uC219\uC5EC \uBB3C\uAC00\uB97C
      \uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uC9C4\uC9DC \uC791\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB4A4\uB6B1\uB4A4\uB6B1\uD574."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC0C8\uB07C\uB4E4\uC774\uB77C \uADF8\uB807\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5C4\uB9C8 \uB530\uB77C\uAC00\uB294 \uAC70 \uBD10."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uC800\uB807\uAC8C \uC904 \uC11C\uC11C \uAC00\uACE0 \uC2F6\uB2E4."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\u2026\u2026\uADF8\uAC74 \uC880 \uC5B4\uB835\uACA0\uC2B5\uB2C8\uB2E4,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u31613\u3161."
  _nemoLine: "(\uACBD\uBE44\uB300\uC7A5\uC774 \uB3CC\uAE38 \uB05D\uAE4C\uC9C0\uB9CC
    \uB530\uB77C\uAC00\uAC8C \uD55C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
