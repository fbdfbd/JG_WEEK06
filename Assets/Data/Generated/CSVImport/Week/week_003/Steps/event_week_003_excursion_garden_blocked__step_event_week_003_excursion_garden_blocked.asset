  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_excursion_garden_blocked__step_event_week_003_excursion_garden_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: garden Blocked
  _bodyText: "excursion garden Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC815\uC6D0\uC0AC\uAC00 \uAC00\uC704\uB97C \uB4E0 \uCC44 \uB2E4\uAC00\uC640
      \uB124\uBAA8\uB97C \uBD80\uB4DC\uB7FD\uAC8C \uB9C9\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC8FC\uC778\uB2D8~ \uB108\uBB34 \uAC00\uAE4C\uC774 \uAC00\uC2DC\uBA74
      \uC548 \uB429\uB2C8\uB2E4~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uB3CC \uBC14\uB2E5\uC774 \uC816\uC5B4 \uC788\uC5B4\uC11C \uBBF8\uB044\uB7FD\uC9C0\uC694~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098 \uC548 \uB118\uC5B4\uC9C8 \uAC74\uB370."
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uADF8\uB798\uB3C4 \uC624\uB298\uC740 \uBA40\uB9AC\uC11C\uB9CC \uBCF4\uC2DC\uB294
      \uAC8C \uC88B\uC2B5\uB2C8\uB2E4~"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB34\uC9C0\uAC1C \uB9CC\uC838 \uBCF4\uACE0 \uC2F6\uC5C8\uB294\uB370."
  _nemoLine: "(\uC815\uC6D0\uC0AC\uAC00 \uAC00\uC704\uB97C \uB4E0 \uCC44 \uB2E4\uAC00\uC640
    \uB124\uBAA8\uB97C \uBD80\uB4DC\uB7FD\uAC8C \uB9C9\uB294\uB2E4.)"
