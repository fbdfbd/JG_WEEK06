  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 2\uCC28 - \uD5C8\uB77D"
  _bodyText: "\uBB38\uC744 \uC870\uAE08 \uB354 \uC5F4\uC5B4 \uB450\uACE0, \uC800\uC7A5\uACE0
    \uC548\uCABD\uC5D0 \uC788\uB294 \uC0C1\uC790\uC640 \uBCD1\uB4E4\uC744 \uBCF4\uC5EC
    \uC900\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uBCF4\uC154\uB3C4 \uB429\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC\uC694?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uB0C4\uC0C8\uAC00 \uB2E4\uB974\uB2E4."
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC548\uCABD\uC740 \uC800\uC7A5\uACE0\uB77C \uADF8\uB807\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774 \uC0C1\uC790\uB294 \uBB50 \uB4E4\uC5B4 \uC788\uC5B4?"
  - _speaker: {fileID: 11400000, guid: fecbee78e68de874dbc9bec96e9344c0, type: 2}
    _text: "\uC624\uB298 \uC800\uB141 \uC7AC\uB8CC\uC785\uB2C8\uB2E4."
  _nemoLine: "\uBCF4\uC154\uB3C4 \uB429\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
