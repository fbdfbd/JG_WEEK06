  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_204_child_visitor_cousin_2_02_direct__step_204_child_visitor_cousin_2_02_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C2 \uB450 \uBC88\uC9F8 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "\uC9C0\uB09C\uBC88\uBCF4\uB2E4 \uC870\uAE08 \uD3B8\uD574\uC9C4 \uC0AC\uCD0C2\uC640
    \uC228\uBC14\uAF2D\uC9C8 \uC774\uC57C\uAE30\uB97C \uB098\uB208\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC800\uBC88\uC5D0 \uC0AC\uD0D5 \uC88B\uC544\uD55C\uB2E4\uBA70."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uC751."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uC88B\uC544\uD574."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uC54C\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC54C\uC544?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uC800\uBC88\uC5D0 \uB9D0\uD588\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uB108\u2026 \uC228\uBC14\uAF2D\uC9C8 \uC88B\uC544\uD574?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC88B\uC544\uD574!"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\u2026\u2026\uADF8\uB7FC \uB2E4\uC74C\uC5D4 \uAC19\uC774 \uD558\uC790."
  _nemoLine: "\uC800\uBC88\uC5D0 \uC0AC\uD0D5 \uC88B\uC544\uD55C\uB2E4\uBA70."
