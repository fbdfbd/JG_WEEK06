--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_excursion_study_direct__step_event_week_003_excursion_study_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC11C\uC7AC \uD5C8\uAC00"
  _bodyText: "excursion study Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBE44\uC11C\uAC00 \uB2E4 \uC2DD\uC740 \uBC00\uB78D \uC790\uAD6D \uD558\uB098\uB97C
      \uC885\uC774 \uC870\uAC01\uC9F8 \uB4E4\uC5B4 \uBCF4\uC5EC \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uB9CC\uC9C0\uB294 \uAC74 \uC548 \uB418\uC9C0\uB9CC, \uAC00\uAE4C\uC774\uC11C
      \uBCF4\uB294 \uAC74 \uAD1C\uCC2E\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uAF43\uCC98\uB7FC \uCC0D\uD614\uC5B4."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC2A4\uD018\uC5B4 \uAC00\uBB38 \uC778\uC7A5\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC70 \uBC31\uC791\uB2D8 \uD45C\uC2DC\uC57C?"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC608. \uC774 \uBB38\uC11C\uAC00 \uBC31\uC791\uB2D8 \uB73B\uB300\uB85C
      \uBD09\uD574\uC84C\uB2E4\uB294 \uD45C\uC2DC\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uC5F4\uBA74 \uC548 \uB418\uB294 \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uB9DE\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBA4B\uC788\uB2E4. \uB098\uB3C4 \uC5B8\uC820\uAC00 \uAFB9 \uD574 \uBCF4\uACE0
      \uC2F6\uC5B4."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC5B8\uC820\uAC00 \uC5F0\uC2B5\uC6A9\uC73C\uB85C \uBCF4\uC5EC \uB4DC\uB9B4
      \uB0A0\uB3C4 \uC788\uACA0\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC?"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC544\uC8FC \uC5B8\uC820\uAC00\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uAE30\uB2E4\uB9B4\uB798."
  _nemoLine: "(\uBE44\uC11C\uAC00 \uB2E4 \uC2DD\uC740 \uBC00\uB78D \uC790\uAD6D \uD558\uB098\uB97C
    \uC885\uC774 \uC870\uAC01\uC9F8 \uB4E4\uC5B4 \uBCF4\uC5EC \uC900\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
