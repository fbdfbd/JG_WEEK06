  _titleOverride: w003 Blocked
  _bodyText: "external w003 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB34\uC2A8 \uC598\uAE34\uB370?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uBCC4\uAC70 \uC544\uB2D9\uB2C8\uB2E4. \uC5B4\uB5A4 \uC9D1 \uC794\uCE6B\uC0C1\uC5D0\uC11C
      \uD6C4\uC2DD\uC774 \uC870\uAE08 \uB9DD\uAC00\uC84C\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD6C4\uC2DD\uC774 \uB9DD\uAC00\uC838?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uAC00\uB054 \uADF8\uB7F4 \uB54C\uB3C4 \uC788\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C \uC6C3\uC5B4?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uADF8\uB0E5 \uBAA8\uC591\uC774 \uC880 \uC6B0\uC2A4\uC6E0\uB098 \uBD05\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uB4E3\uACE0 \uC2F6\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uC548 \uB4E4\uC73C\uC154\uB3C4 \uB429\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uCE58\uC0AC\uD574."
  _nemoLine: "\uBB34\uC2A8 \uC598\uAE34\uB370?"
