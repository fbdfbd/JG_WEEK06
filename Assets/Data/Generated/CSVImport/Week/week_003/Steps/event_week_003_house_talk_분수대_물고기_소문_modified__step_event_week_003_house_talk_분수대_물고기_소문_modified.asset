  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: "event_week_003_house_talk_\uBD84\uC218\uB300_\uBB3C\uACE0\uAE30_\uC18C\uBB38_modified__step_event_week_003_house_talk_\uBD84\uC218\uB300_\uBB3C\uACE0\uAE30_\uC18C\uBB38_modified"
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBD84\uC218\uB300 \uBB3C\uACE0\uAE30 \uC18C\uBB38 \uC218\uC815"
  _bodyText: "house_talk \uBD84\uC218\uB300_\uBB3C\uACE0\uAE30_\uC18C\uBB38 Modified
    \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uBD84\uC218\uB300 \uBB3C\uACE0\uAE30 \uD55C \uB9C8\uB9AC\uAC00 \uC790\uAFB8
      \uC548 \uBCF4\uC778\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4\uB514 \uAC14\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB3CC \uBC11\uC5D0 \uC228\uB294 \uAC78 \uC88B\uC544\uD55C\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB3C\uACE0\uAE30\uB3C4 \uC228\uBC14\uAF2D\uC9C8\uD574?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uB124. \uD558\uB140\uB4E4\uC740 \uADF8\uB807\uAC8C \uC0DD\uAC01\uD558\uACE0
      \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uCC3E\uACE0 \uC2F6\uB2E4."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uCC3E\uC73C\uC154\uB3C4 \uC190 \uB123\uC73C\uC2DC\uBA74 \uC548 \uB429\uB2C8\uB2E4,
      \uC8FC\uC778\uB2D8."
  _nemoLine: "\uBD84\uC218\uB300 \uBB3C\uACE0\uAE30 \uD55C \uB9C8\uB9AC\uAC00 \uC790\uAFB8
    \uC548 \uBCF4\uC778\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
