  _titleOverride: "\uCE5C\uAD6C2 \uB450 \uBC88\uC9F8 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "\uC9E7\uAC8C\uB9CC \uC778\uC0AC\uD558\uB77C\uB294 \uB9D0\uB05D\uC5D0
    \uB458\uC740 \uC5B4\uB9B0 \uD2F0\uB97C \uB0B4\uBA70 \uD22C\uB2E5\uAC70\uB9B0\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uC548\uB155."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC9E7\uAC8C\uB9CC \uC778\uC0AC\uD558\uC154\uC57C
      \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uAD1C\uCC2E\uC544. \uB09C \uC624\uB798 \uC11C \uC788\uB294 \uAC70 \uC2EB\uC5B4\uD574."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098 \uB108 \uC2EB\uC5B4."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uB098\uB3C4 \uB108 \uC2EB\uC5B4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uC57C."
