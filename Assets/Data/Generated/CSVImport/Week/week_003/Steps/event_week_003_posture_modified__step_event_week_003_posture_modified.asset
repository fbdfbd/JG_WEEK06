  _titleOverride: "\uBAB8\uAC00\uC9D0 \uC218\uC5C5\uC744 \uB180\uC774\uCC98\uB7FC
    \uD55C\uB2E4"
  _bodyText: "\uBAB8\uAC00\uC9D0\uACFC \uBC1C\uB180\uB9BC \uAD50\uC7AC Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC120 \uC704\uB97C \uB530\uB77C \uAC77\uAC8C \uD558\uBA70 \uC790\uC138\uC640
      \uADE0\uD615\uC744 \uB180\uC774\uCC98\uB7FC \uC775\uD788\uAC8C \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548 \uBC1F\uACE0 \uB05D\uAE4C\uC9C0 \uAC08 \uC218 \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uCE6D\uCC2C\uC744 \uC11E\uC5B4 \uAE34\uC7A5\uC744 \uB35C\uACE0 \uC6C0\uC9C1\uC784\uC744
      \uC775\uD788\uAC8C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD55C \uBC88 \uB354 \uD558\uBA74 \uB354 \uC798\uD560 \uC218 \uC788\uC5B4."
  _nemoLine: "(\uC120 \uC704\uB97C \uB530\uB77C \uAC77\uAC8C \uD558\uBA70 \uC790\uC138\uC640
    \uADE0\uD615\uC744 \uB180\uC774\uCC98\uB7FC \uC775\uD788\uAC8C \uD55C\uB2E4.)"
