%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_letter_friend_2_modified__step_event_week_003_letter_friend_2_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC00\uB9AC\uC544 \uC218\uC815"
  _bodyText: "letter friend_2 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uC77D\uACE0, \uB124\uBAA8 \uC55E\uC5D0
      \uC549\uC544 \uB0B4\uC6A9\uC744 \uCC9C\uCC9C\uD788 \uC804\uD574 \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC800\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798 \uC190\uB2D8\uC774
      \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uB77C\uACE0 \uD588\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB2E4\uC74C\uC5D4 \uC190\uC218\uAC74\uC744 \uCC59\uAE30\uACE0, \uB108\uBB34
      \uAE09\uD558\uAC8C \uB6F0\uC9C0 \uB9D0\uB77C\uACE0 \uD588\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8 \uC637\uC5D0 \uBA3C\uC9C0\uAC00 \uB9CE\uC774 \uBB3B\uC5B4
      \uC788\uC5C8\uB358 \uAC8C \uAE30\uC5B5\uC5D0 \uB0A8\uC558\uB098 \uBD05\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610 \uADF8 \uC598\uAE30\uC57C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8\uB798\uB3C4 \uB2E4\uC2DC \uB9CC\uB098\uBA74 \uC778\uC0AC\uB294
      \uD558\uACE0 \uC2F6\uB2E4\uACE0 \uD588\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uC9C4\uC9DC?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uC870\uAE08 \uBB34\uB69D\uB69D\uD560 \uBFD0, \uC2EB\uC5B4\uD558\uB294
      \uAC74 \uC544\uB2CC \uBAA8\uC591\uC774\uC5D0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB2E4\uC74C\uC5D4 \uB0B4\uAC00 \uBA3C\uC800 \uC548\uB155
      \uD574\uC57C\uACA0\uB2E4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uBD09\uD22C\uB97C \uBC1B\uC544 \uB4E0\uB2E4. \uC774\uBC88
      \uBD09\uD22C\uB294 \uC9C0\uB09C\uBC88\uBCF4\uB2E4 \uB354 \uBC18\uB4EF\uD558\uAC8C
      \uC811\uD600 \uC788\uACE0, \uC548\uCABD \uC885\uC774\uB3C4 \uB450 \uC7A5\uC774\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8 \uC55E\uC73C\uB85C \uC628 \uD3B8\uC9C0\uC785\uB2C8\uB2E4."
  _nemoLine: "(\uD558\uB140\uAC00 \uD3B8\uC9C0\uB97C \uC77D\uACE0, \uB124\uBAA8 \uC55E\uC5D0
    \uC549\uC544 \uB0B4\uC6A9\uC744 \uCC9C\uCC9C\uD788 \uC804\uD574 \uC900\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
