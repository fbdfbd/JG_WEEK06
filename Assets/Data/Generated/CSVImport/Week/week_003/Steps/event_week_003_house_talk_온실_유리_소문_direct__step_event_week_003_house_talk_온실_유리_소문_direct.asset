  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: "event_week_003_house_talk_\uC628\uC2E4_\uC720\uB9AC_\uC18C\uBB38_direct__step_event_week_003_house_talk_\uC628\uC2E4_\uC720\uB9AC_\uC18C\uBB38_direct"
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC628\uC2E4 \uC720\uB9AC \uC18C\uBB38 \uD5C8\uAC00"
  _bodyText: "house_talk \uC628\uC2E4_\uC720\uB9AC_\uC18C\uBB38 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 3f7713609b39db74c98a5b754e5eaf5e, type: 2}
    _text: "\uC628\uC2E4 \uC720\uB9AC\uC5D0 \uC791\uC740 \uAE08\uC774 \uAC14\uB2F5\uB2C8\uB2E4,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  - _speaker: {fileID: 11400000, guid: 31350c3de27bb9c43a5cd19e30d43ba8, type: 2}
    _text: "\uD587\uBE5B\uC774 \uC138\uAC8C \uB4E4\uAC70\uB098, \uB0A0\uC774 \uAC11\uC790\uAE30
      \uCC28\uAC00\uC6CC\uC9C0\uBA74 \uADF8\uB7F4 \uB54C\uAC00 \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC720\uB9AC\uB3C4 \uC544\uD30C?"
  - _speaker: {fileID: 11400000, guid: 3f7713609b39db74c98a5b754e5eaf5e, type: 2}
    _text: "\uADF8\uB7F4\uC9C0\uB3C4 \uBAA8\uB974\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5C9. \uADF8\uB7FC \uAF43\uB4E4\uB3C4 \uB180\uB790\uACA0\uB2E4."
  - _speaker: {fileID: 11400000, guid: 31350c3de27bb9c43a5cd19e30d43ba8, type: 2}
    _text: "\uADF8\uB798\uC11C \uC800\uD76C\uAC00 \uBC14\uB85C \uC190\uBCF4\uB294
      \uAC81\uB2C8\uB2E4."
  _nemoLine: "\uC628\uC2E4 \uC720\uB9AC\uC5D0 \uC791\uC740 \uAE08\uC774 \uAC14\uB2F5\uB2C8\uB2E4,
    \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
