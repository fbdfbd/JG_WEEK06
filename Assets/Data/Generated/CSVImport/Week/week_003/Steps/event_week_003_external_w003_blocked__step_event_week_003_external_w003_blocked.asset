  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_external_w003_blocked__step_event_week_003_external_w003_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: w003 Blocked
  _bodyText: "external w003 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uBCC4\uAC70 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC29\uAE08 \uC7AC\uBBF8\uC788\uB2E4\uBA70."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uADF8\uB0E5 \uAE38\uAC70\uB9AC\uC5D0\uC11C \uC2DC\uB044\uB7FD\uAC8C
      \uB5A0\uB4DC\uB294 \uC0AC\uB78C\uB4E4 \uC598\uAE30\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADFC\uB370 \uC65C \uBCC4\uC774 \uC788\uC5B4?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uBCF4\uAE30 \uC88B\uAC8C \uADF8\uB824 \uB193\uC740 \uAC70\uACA0\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC \uBCC4\uC740 \uC544\uB2C8\uC57C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uADF8\uB7F0 \uAC74 \uC544\uB2D9\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB9BC\uB9CC \uBC18\uC9DD\uC600\uB124."
  _nemoLine: "\uBCC4\uAC70 \uC544\uB2D9\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
