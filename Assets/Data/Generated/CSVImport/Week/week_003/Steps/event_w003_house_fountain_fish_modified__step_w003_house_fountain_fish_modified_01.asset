  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBD84\uC218\uB300 \uBB3C\uACE0\uAE30 \uC18C\uBB38 - \uC218\uC815"
  _bodyText: "(\uC815\uC6D0 \uC548\uCABD. \uD558\uB140 \uB458\uC774 \uBD84\uC218\uB300\uB97C
    \uB4E4\uC5EC\uB2E4\uBCF4\uBA70 \uC465\uB355\uC778\uB2E4.)\r\n        \r\n       
    \uD558\uB1401 : \uC624\uB298\uB3C4 \uD55C \uB9C8\uB9AC \uC548 \uBCF4\uC774\uC9C0?\r\n       
    \r\n        \uD558\uB1402 : \uC751. \uC5B4\uB514 \uAC14\uC9C0?\r\n        \r\n       
    \uB124\uBAA8 : \uBB50\uAC00?\r\n        \r\n\r\n\uD558\uB1401 : \uBD84\uC218\uB300
    \uBB3C\uACE0\uAE30 \uD55C \uB9C8\uB9AC\uAC00 \uC790\uAFB8 \uC548 \uBCF4\uC778\uB2F5\uB2C8\uB2E4,
    \uC8FC\uC778\uB2D8.\r\n        \r\n        \uB124\uBAA8 : \uC5B4\uB514 \uAC14\uC5B4?\r\n       
    \r\n        \uD558\uB1402 : \uB3CC \uBC11\uC5D0 \uC228\uB294 \uAC78 \uC88B\uC544\uD55C\uB300\uC694.\r\n       
    \r\n        \uB124\uBAA8 : \uBB3C\uACE0\uAE30\uB3C4 \uC228\uBC14\uAF2D\uC9C8\uD574?\r\n       
    \r\n        \uD558\uB1401 : \uB124. \uD558\uB140\uB4E4\uC740 \uADF8\uB807\uAC8C
    \uC0DD\uAC01\uD558\uACE0 \uC788\uC5B4\uC694.\r\n        \r\n        \uB124\uBAA8
    : \uC6B0\uC640.\r\n        \r\n        \uB124\uBAA8 : \uB098\uB3C4 \uCC3E\uACE0
    \uC2F6\uB2E4.\r\n        \r\n        \uD558\uB1402 : \uCC3E\uC73C\uC154\uB3C4
    \uC190 \uB123\uC73C\uC2DC\uBA74 \uC548 \uB429\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
