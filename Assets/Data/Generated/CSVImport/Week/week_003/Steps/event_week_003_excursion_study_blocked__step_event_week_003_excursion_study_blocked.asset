  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_excursion_study_blocked__step_event_week_003_excursion_study_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC11C\uC7AC \uD1B5\uC81C"
  _bodyText: "excursion study Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBE44\uC11C\uAC00 \uBC00\uB78D \uADF8\uB987\uC744 \uBC14\uB85C \uC548\uCABD\uC73C\uB85C
      \uC62E\uAE34\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC774\uCABD\uC740 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC7BC \uC544\uB2CC \uAC74 \uC54C\uACA0\uC5B4."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uADF8\uAC78 \uC544\uC2E0 \uAC83\uB9CC\uC73C\uB85C \uCDA9\uBD84\uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD55C \uBC88 \uB20C\uB7EC \uBCF4\uACE0 \uC2F6\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC774\uAC74 \uBC31\uC791\uB2D8 \uBB38\uC11C\uC6A9\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9E8\uB0A0 \uC911\uC694\uD55C \uAC70\uC57C."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC608. \uD2B9\uD788 \uC774\uAC74\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC11C\uC7AC\uB294 \uBA39\uB294 \uAC74 \uC5C6\uACE0 \uB204\uB974\uB294
      \uAC83\uB9CC \uB9CE\uB124."
  _nemoLine: "(\uBE44\uC11C\uAC00 \uBC00\uB78D \uADF8\uB987\uC744 \uBC14\uB85C \uC548\uCABD\uC73C\uB85C
    \uC62E\uAE34\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
