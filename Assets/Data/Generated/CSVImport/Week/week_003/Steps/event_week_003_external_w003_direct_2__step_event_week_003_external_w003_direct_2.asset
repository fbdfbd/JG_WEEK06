--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_external_w003_direct_2__step_event_week_003_external_w003_direct_2
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: w003 Direct
  _bodyText: "external w003 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC5B4\uB5A4 \uADC0\uC871\uAC00 \uC0DD\uC77C\uC794\uCE58\uC5D0\uC11C
      \uC124\uD0D5\uC73C\uB85C \uB9CC\uB4E0 \uC131\uC744 \uC62C\uB838\uB300\uC694,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC131\uC744? \uBA39\uB294 \uAC78\uB85C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uC544\uC8FC \uD06C\uAC8C\uC694. \uADF8\uB7F0\uB370 \uB204\uAC00
      \uCD1B\uBD88\uC744 \uB108\uBB34 \uAC00\uAE4C\uC774 \uB450\uB294 \uBC14\uB78C\uC5D0,
      \uC0DD\uD65C \uC628\uC5F4\uC11D\uAE4C\uC9C0 \uAC19\uC774 \uB2EC\uC544\uC62C\uB77C\uC11C\u2026"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uD0D1\uC774 \uD55C\uCABD\uC73C\uB85C \uD479 \uAEBC\uC9C0\uB354\uB2C8,
      \uC0AC\uD0D5 \uCC3D\uBB38\uC774 \uC6B0\uC218\uC218 \uC3DF\uC544\uC84C\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5C9. \uADF8\uB7FC \uB2E4 \uB9DD\uD588\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uADF8\uB7F0\uB370 \uC544\uC774\uB4E4\uC774 \uBC11\uC5D0\uC11C
      \uB5A8\uC5B4\uC9C4 \uC0AC\uD0D5 \uC8FC\uC6CC \uBA39\uB290\uB77C \uB354 \uB09C\uB9AC\uC600\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uC57C. \uADF8\uAC74 \uC880 \uC7AC\uBC0C\uB2E4."
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uB3C4 \uAC70\uAE30 \uC788\uC5C8\uC73C\uBA74 \uC81C\uC77C
      \uBA3C\uC800 \uB6F0\uC5B4\uAC00\uC168\uC744 \uAC83 \uAC19\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2F9\uC5F0\uD558\uC9C0."
  _nemoLine: "\uC5B4\uB5A4 \uADC0\uC871\uAC00 \uC0DD\uC77C\uC794\uCE58\uC5D0\uC11C
    \uC124\uD0D5\uC73C\uB85C \uB9CC\uB4E0 \uC131\uC744 \uC62C\uB838\uB300\uC694,
    \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
