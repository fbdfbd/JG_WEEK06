  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_excursion_lake_blocked__step_w003_excursion_lake_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 3\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uBC14\uB78C\uC774 \uC794\uC794\uD55C \uC624\uD6C4. \uAC08\uB300 \uC0AC\uC774\uB85C
    \uC624\uB9AC \uD55C \uC30D\uACFC \uC791\uC740 \uC0C8\uB07C\uB4E4\uC774 \uBB3C
    \uC704\uB97C \uCC9C\uCC9C\uD788 \uC9C0\uB098\uAC04\uB2E4.)\r\n        \r\n       
    \uB124\uBAA8 : \uC5B4? \uC800\uAE30 \uBD10.\r\n        \r\n        \uB124\uBAA8
    : \uCABC\uADF8\uB9CC \uAC70 \uB530\uB77C\uAC04\uB2E4.\r\n        \r\n       
    (\uB124\uBAA8\uAC00 \uBC1C\uB05D\uC744 \uC138\uC6B0\uBA70 \uBB3C\uAC00 \uCABD\uC744
    \uB354 \uBCF4\uB824 \uD55C\uB2E4.)\r\n        \r\n\r\n(\uACBD\uBE44\uB300\uC7A5\uC774
    \uBA3C\uC800 \uC55E\uC744 \uB9C9\uACE0 \uC120\uB2E4.)\r\n            \r\n           
    \uACBD\uBE44\uB300\uC7A5 : \uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC5EC\uAE30\uAE4C\uC9C0\uB9CC\uC785\uB2C8\uB2E4.\r\n           
    \r\n            \uB124\uBAA8 : \uC65C\uC694?\r\n            \r\n            \uACBD\uBE44\uB300\uC7A5
    : \uBB3C\uAC00 \uAC00\uAE4C\uC774\uB294 \uC544\uC9C1 \uC704\uD5D8\uD569\uB2C8\uB2E4.\r\n           
    \r\n            \uB124\uBAA8 : \uC800\uAE30 \uC0C8\uB07C\uB4E4 \uBCF4\uC774\uB294\uB370.\r\n           
    \r\n            \uACBD\uBE44\uB300\uC7A5 : \uC800 \uC790\uB9AC\uC5D0\uC11C\uB3C4
    \uCDA9\uBD84\uD788 \uBCF4\uC785\uB2C8\uB2E4.\r\n            \r\n            \uB124\uBAA8
    : \uAC00\uAE4C\uC774\uC11C \uBD10\uC57C \uB354 \uADC0\uC5FD\uC796\uC544.\r\n           
    \r\n            \uACBD\uBE44\uB300\uC7A5 : \uADF8\uB798\uB3C4 \uC548 \uB429\uB2C8\uB2E4.\r\n           
    \r\n            \uB124\uBAA8 : \uCE6B.\r\n            \r\n            \uB124\uBAA8
    : \uC624\uB9AC\uB4E4\uC740 \uC790\uC720\uB85C\uC6CC\uC11C \uC88B\uACA0\uB2E4."
