  m_Name: event_w003_house_attic_window_modified__step_w003_house_attic_window_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB2E4\uB77D \uCC3D\uBB38 \uC18C\uBB38 - \uC218\uC815"
  _bodyText: "(\uB2E4\uB77D \uACC4\uB2E8 \uC544\uB798. \uD558\uB140 \uB458\uC774
    \uBA3C\uC9C0\uB97C \uD138\uBA70 \uC774\uC57C\uAE30\uD55C\uB2E4.)\n        \n       
    \uD558\uB1401 : \uC624\uB298\uB3C4 \uB2E4\uB77D \uCC3D\uBB38\uC774 \uC5F4\uB824
    \uC788\uC5C8\uB300.\n        \n        \uD558\uB1402 : \uB204\uAC00 \uB610 \uB2EB\uACE0\uB3C4
    \uAE5C\uBE61\uD588\uB098 \uBD10.\n        \n        \uB124\uBAA8 : \uB2E4\uB77D\uC740
    \uB204\uAC00 \uAC00?\n        \n\n\uD558\uB1401 : \uB2E4\uB77D \uCC3D\uBB38\uC774
    \uC790\uC8FC \uC5F4\uB9AC\uB294 \uAC74, \uAC70\uAE30 \uACF5\uAE30\uAC00 \uB2F5\uB2F5\uD574\uC11C
    \uADF8\uB798\uC694, \uC8FC\uC778\uB2D8.\n        \n        \uB124\uBAA8 : \uB2F5\uB2F5\uD574?\n       
    \n        \uD558\uB1402 : \uB124. \uC624\uB798\uB41C \uCC9C\uC774 \uB9CE\uC544\uC11C
    \uD658\uAE30\uB97C \uC2DC\uCF1C \uC918\uC57C \uD55C\uB2F5\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uC544.\n        \n        \uD558\uB1401 : \uADF8\uB798\uC11C
    \uAC00\uB054 \uC5F4\uC5B4 \uB450\uB294 \uAC70\uC608\uC694.\n        \n       
    \uB124\uBAA8 : \uADF8\uB7FC \uB2E4\uB77D\uB3C4 \uC228 \uC26C\uB294 \uAC70\uB124.\n       
    \n        \uD558\uB1402 : \uB124. \uADF8\uB807\uAC8C \uBCF4\uC154\uB3C4 \uB429\uB2C8\uB2E4,
    \uC8FC\uC778\uB2D8."
