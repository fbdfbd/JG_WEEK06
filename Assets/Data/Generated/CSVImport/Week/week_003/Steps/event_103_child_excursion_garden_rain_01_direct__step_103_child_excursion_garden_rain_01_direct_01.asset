  _titleOverride: "\uC815\uC6D0 \uBE44 \uC624\uB294 \uB0A0 - \uD5C8\uB77D"
  _bodyText: "\uACBD\uBE44\uB300\uC7A5\uC774 \uC6B0\uC0B0\uC744 \uC900\uBE44\uD574
    \uC8FC\uACE0 \uBE44 \uC624\uB294 \uC815\uC6D0\uC73C\uB85C \uC7A0\uAE50 \uB098\uAC00\uAC8C
    \uD55C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC815\uC6D0 \uAC00\uACE0 \uC2F6\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4? \uC6B0\uC0B0\uC774\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC800 \uB098\uAC00\uB3C4 \uB3FC\uC694?"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC608. \uC900\uBE44\uD574 \uB450\uC5C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC\uC694?"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC608."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC640\uC544!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC800 \uAC1C\uAD6C\uB9AC\uB3C4 \uCC3E\uC744\uB798\uC694!"
  _nemoLine: "\uC815\uC6D0 \uAC00\uACE0 \uC2F6\uC740\uB370."
