  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 - \uC694\uC57D"
  _bodyText: "\uCE5C\uAD6C1\uC774 \uB2E4\uC74C\uC5D0 \uB354 \uBE68\uB9AC \uB6F0\uACE0
    \uC2F6\uC5B4 \uD55C\uB2E4\uB294 \uB73B\uB9CC \uACE8\uB77C \uBD80\uB4DC\uB7FD\uAC8C
    \uC804\uD55C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124\uBAA8 \uC548\uB155. \uC800\uBC88\uC5D0 \uB6F0\uC5B4\uC11C \uC7AC\uBC0C\uC5C8\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB2E4\uC74C\uC5D0\uB3C4 \uB2E4\uC2DC \uAC19\uC774 \uB180\uACE0 \uC2F6\uB2E4\uACE0
      \uC801\uD600 \uC788\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB098\uB3C4 \uB2E4\uC2DC \uBCF4\uACE0 \uC2F6\uC5B4."
  _nemoLine: "\uB124\uBAA8 \uC548\uB155. \uC800\uBC88\uC5D0 \uB6F0\uC5B4\uC11C \uC7AC\uBC0C\uC5C8\uB300\uC694."
