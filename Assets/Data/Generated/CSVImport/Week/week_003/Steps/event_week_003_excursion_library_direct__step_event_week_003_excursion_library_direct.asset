  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_excursion_library_direct__step_event_week_003_excursion_library_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: library Direct
  _bodyText: "excursion library Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC11C\uACE0\uAD00\uB9AC\uC778\uC774 \uAC00\uB290\uB2E4\uB780 \uB9C9\uB300\uB97C
      \uD558\uB098 \uAC74\uB128\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uC190 \uB300\uC2E0 \uC774\uAC78\uB85C \uAC00\uB9AC\uCF1C \uBCF4\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC?"
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uC608. \uBCC4\uC810\uC740 \uAC74\uB4DC\uB9AC\uC9C0 \uB9C8\uC2DC\uACE0,
      \uBAA8\uC591\uB9CC \uB530\uB77C\uAC00\uC2DC\uBA74 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uC774\uAC74 \uD1A0\uB07C!"
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uBCF8\uB798\uB294 \uC0AC\uB0E5\uAC1C\uC790\uB9AC\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0? \uAC1C\uC600\uC5B4?"
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uC8FC\uC778\uB2D8 \uB208\uC5D4 \uD1A0\uB07C\uCC98\uB7FC \uBCF4\uC774\uB098
      \uBD05\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB0B4 \uD1A0\uB07C\uAC00 \uB354 \uADC0\uC5EC\uC6CC."
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uADF8\uAC74 \uC778\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5E4. \uADF8\uB7FC \uC774\uAC74 \uB0B4\uAC00 \uB9CC\uB4E0 \uD1A0\uB07C\uC790\uB9AC
      \uD560\uB798."
  _nemoLine: "(\uC11C\uACE0\uAD00\uB9AC\uC778\uC774 \uAC00\uB290\uB2E4\uB780 \uB9C9\uB300\uB97C
    \uD558\uB098 \uAC74\uB128\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
