  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_visitor_cousin_2_direct__step_event_week_003_visitor_cousin_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9AC\uC548 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor cousin_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC0AC\uCD0C2 \uC55E\uC73C\uB85C \uAC00\uAE4C\uC774
      \uAC04\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50 \uC8FC\uB294\uB370?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uC774\uAC70."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC0AC\uCD0C2\uAC00 \uC811\uC740 \uC885\uC774\uB97C \uD3B4 \uBCF4\uC774\uC790,
      \uC090\uB6A4\uC9C0\uB9CC \uC815\uC131 \uB4E4\uC778 \uC885\uC774\uBCC4 \uD558\uB098\uAC00
      \uB098\uC628\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uB124\uAC00 \uB9CC\uB4E4\uC5C8\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uC751."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uADF8\uB0E5\u2026 \uB124 \uC0DD\uAC01\uB098\uC11C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uD3B8\uC9C0 \uBCF4\uB0C8\uC73C\uB2C8\uAE4C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098 \uC774\uB7F0 \uAC70 \uCC98\uC74C \uBC1B\uC544."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uADF8\uB7FC \uAC00\uC838."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098 \uC774\uAC70 \uC548 \uBC84\uB9B4\uB798."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uC0AC\uCD0C2 \uC55E\uC73C\uB85C \uAC00\uAE4C\uC774
    \uAC04\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
