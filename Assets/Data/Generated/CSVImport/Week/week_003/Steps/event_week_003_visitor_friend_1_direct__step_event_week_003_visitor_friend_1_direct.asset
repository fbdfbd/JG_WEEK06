  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_visitor_friend_1_direct__step_event_week_003_visitor_friend_1_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9C9\uC2A4 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor friend_1 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uD55C\uC228 \uC26C\uB4EF \uBB3C\uB7EC\uB09C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uBA40\uB9AC\uB9CC \uAC00\uC9C0 \uB9C8\uC138\uC694."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uC2DC\uC791!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4\uC5B4? \uC7A0\uAE50!"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uCE5C\uAD6C1\uC774 \uBA3C\uC800 \uC120\uC744 \uD53C\uD574 \uB6F0\uAE30
      \uC2DC\uC791\uD558\uACE0, \uB124\uBAA8\uB3C4 \uB4A4\uB2A6\uAC8C \uB530\uB77C
      \uB6F4\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uBC1F\uC558\uB2E4!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC548 \uBC1F\uC558\uC5B4!"
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uBC1C\uB05D \uB2FF\uC558\uC5B4!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uBC1C\uB05D\uC774\uB77C \uAD1C\uCC2E\uC544!"
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uADF8\uB7F0 \uAC8C \uC5B4\uB528\uC5B4!"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB458\uC774 \uAE54\uAE54 \uC6C3\uC73C\uBA70 \uC120\uC744 \uD53C\uD574
      \uD3F4\uC9DD\uC778\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uBC88\uC5D4 \uB0B4\uAC00 \uBA3C\uC800 \uD560\uB798."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uC88B\uC544. \uC9C0\uBA74 \uC18C\uB9AC \uC9C0\uB974\uAE30\uB2E4!"
  _nemoLine: "(\uD558\uB140\uAC00 \uD55C\uC228 \uC26C\uB4EF \uBB3C\uB7EC\uB09C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
