MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_visitor_friend_3_direct__step_event_week_003_visitor_friend_3_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC720\uD53C \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor friend_3 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uCE5C\uAD6C3 \uC606\uC73C\uB85C \uCABC\uB974\uB974
      \uAC04\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uBD10. \uC190\uAC00\uB77D \uC774\uB807\uAC8C \uD558\uBA74 \uC785\uC774\uC57C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uC9C4\uC9DC \uAC1C\uAD6C\uB9AC \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uB108\uB3C4 \uD574 \uBD10."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB09C \uC548 \uB420\uAC78."
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uB3FC. \uC190\uB9CC \uC788\uC73C\uBA74 \uB3FC."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC190\uC744 \uBE44\uCDC4\uB2E4\uAC00 \uC774\uC0C1\uD55C
      \uB369\uC5B4\uB9AC\uB97C \uB9CC\uB4E0\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uADF8\uAC74 \uAC1C\uAD6C\uB9AC \uC544\uB2C8\uACE0 \uAC10\uC790\uC57C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uC57C!"
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uAC10\uC790\uB3C4 \uADC0\uC5EC\uC6CC."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC2EB\uC5B4. \uB098\uB3C4 \uAC1C\uAD6C\uB9AC \uD560\uB798."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB458\uC774 \uBCBD \uC55E\uC5D0\uC11C \uC190\uAC00\uB77D\uC744 \uAF3C\uC9C0\uB77D\uAC70\uB9AC\uBA70
      \uD55C\uCC38 \uC6C3\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uC774\uBC88\uC5D4 \uD1A0\uB07C!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uC9C4\uC9DC \uD1A0\uB07C \uAC19\uB2E4."
  _nemoLine: "(\uB124\uBAA8\uAC00 \uCE5C\uAD6C3 \uC606\uC73C\uB85C \uCABC\uB974\uB974
    \uAC04\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
