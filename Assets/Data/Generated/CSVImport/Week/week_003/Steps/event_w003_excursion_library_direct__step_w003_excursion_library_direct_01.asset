  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_excursion_library_direct__step_w003_excursion_library_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 3\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uB3C4\uC11C\uAD00 \uAE4A\uC219\uD55C \uC790\uB9AC. \uC11C\uACE0\uAD00\uB9AC\uC778\uC774
    \uB450\uAEBC\uC6B4 \uCC45 \uD55C \uAD8C\uC744 \uD3BC\uCE58\uC790, \uAC80\uC740
    \uC885\uC774 \uC704\uC5D0 \uC791\uC740 \uBCC4\uC810\uB4E4\uC774 \uD558\uB098\uC529
    \uB5A0\uC624\uB978\uB2E4. \uBE5B\uC218\uC815 \uB7A8\uD504\uAC00 \uD398\uC774\uC9C0
    \uC704\uB97C \uBE44\uCD94\uACE0 \uC788\uB2E4.)\n        \n        \uB124\uBAA8
    : \uC6B0\uC640. \uCC45 \uC548\uC5D0 \uBC24\uC774 \uB4E4\uC5B4 \uC788\uB124.\n       
    \n        (\uB124\uBAA8\uAC00 \uC758\uC790\uB97C \uB04C\uACE0 \uC640 \uD131\uC744
    \uAD34\uACE0 \uB4E4\uC5EC\uB2E4\uBCF8\uB2E4. \uBCC4\uC810\uB4E4\uC740 \uC774\uC5B4\uC838
    \uC774\uC0C1\uD55C \uB3D9\uBB3C \uBAA8\uC591\uCC98\uB7FC \uBCF4\uC778\uB2E4.)\n       
    \n        \uB124\uBAA8 : \uC800\uAC74 \uD1A0\uB07C \uAC19\uC544.\n        \n       
    \uB124\uBAA8 : \uC544\uB2C8, \uC5FC\uC18C\uC778\uAC00?\n        \n\n(\uC11C\uACE0\uAD00\uB9AC\uC778\uC774
    \uAC00\uB290\uB2E4\uB780 \uB9C9\uB300\uB97C \uD558\uB098 \uAC74\uB128\uB2E4.)\n       
    \n        \uC11C\uACE0\uAD00\uB9AC\uC778 : \uC190 \uB300\uC2E0 \uC774\uAC78\uB85C
    \uAC00\uB9AC\uCF1C \uBCF4\uC2ED\uC2DC\uC624.\n        \n        \uB124\uBAA8
    : \uC9C4\uC9DC?\n        \n        \uC11C\uACE0\uAD00\uB9AC\uC778 : \uC608. \uBCC4\uC810\uC740
    \uAC74\uB4DC\uB9AC\uC9C0 \uB9C8\uC2DC\uACE0, \uBAA8\uC591\uB9CC \uB530\uB77C\uAC00\uC2DC\uBA74
    \uB429\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : \uADF8\uB7FC \uC774\uAC74
    \uD1A0\uB07C!\n        \n        \uC11C\uACE0\uAD00\uB9AC\uC778 : \uBCF8\uB798\uB294
    \uC0AC\uB0E5\uAC1C\uC790\uB9AC\uC785\uB2C8\uB2E4.\n        \n        \uB124\uBAA8
    : \uC5D0? \uAC1C\uC600\uC5B4?\n        \n        \uC11C\uACE0\uAD00\uB9AC\uC778
    : \uC8FC\uC778\uB2D8 \uB208\uC5D4 \uD1A0\uB07C\uCC98\uB7FC \uBCF4\uC774\uB098
    \uBD05\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : \uB0B4 \uD1A0\uB07C\uAC00
    \uB354 \uADC0\uC5EC\uC6CC.\n        \n        \uC11C\uACE0\uAD00\uB9AC\uC778
    : \uADF8\uAC74 \uC778\uC815\uD558\uACA0\uC2B5\uB2C8\uB2E4.\n        \n       
    \uB124\uBAA8 : \uD5E4. \uADF8\uB7FC \uC774\uAC74 \uB0B4\uAC00 \uB9CC\uB4E0 \uD1A0\uB07C\uC790\uB9AC
    \uD560\uB798."
