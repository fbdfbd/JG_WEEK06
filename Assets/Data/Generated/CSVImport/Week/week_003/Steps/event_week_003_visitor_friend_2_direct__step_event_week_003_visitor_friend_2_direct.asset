MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_visitor_friend_2_direct__step_event_week_003_visitor_friend_2_direct
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC00\uB9AC\uC544 \uBC29\uBB38 \uD5C8\uAC00"
  _bodyText: "visitor friend_2 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uBC00\uB9AC\uC544 \uC606\uC5D0 \uC549\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uBD10. \uC774\uB807\uAC8C \uBC18 \uC811\uACE0, \uB610 \uC811\uACE0,
      \uBAA8\uC11C\uB9AC \uB9DE\uCD94\uBA74 \uB3FC."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC8C \uC65C \uC7AC\uBC0C\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uB2E4 \uB9DE\uC73C\uBA74 \uAE30\uBD84 \uC88B\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uC0C1\uD55C\uB370."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uB124\uAC00 \uD574 \uBD10."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uB124\uBAA8\uAC00 \uC190\uC218\uAC74\uC744 \uC811\uC9C0\uB9CC \uBAA8\uC11C\uB9AC\uAC00
      \uC090\uB6A4\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uAC70\uAE30 \uC544\uB2C8\uC9C0."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC54C\uC544."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uBAB0\uB790\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C0\uAE08 \uC54C\uC558\uC5B4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uBC00\uB9AC\uC544\uAC00 \uB124\uBAA8 \uC190\uB05D\uC744 \uD1A1 \uAC74\uB4DC\uB824
      \uB2E4\uC2DC \uB9DE\uCDB0 \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uC790, \uC774\uB807\uAC8C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC74 \uC880 \uC7AC\uBC0C\uB124."
  - _speaker: {fileID: 11400000, guid: 368e68c539160c54e9a0ad64ce528c0d, type: 2}
    _text: "\uADF8\uCE58?"
  _nemoLine: "(\uB124\uBAA8\uAC00 \uBC00\uB9AC\uC544 \uC606\uC5D0 \uC549\uB294\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
