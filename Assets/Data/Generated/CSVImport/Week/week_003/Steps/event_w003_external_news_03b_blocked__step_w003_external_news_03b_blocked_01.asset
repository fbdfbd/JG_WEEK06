  m_Name: event_w003_external_news_03b_blocked__step_w003_external_news_03b_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC18C\uC2DD 3\uCC28-2 - \uD1B5\uC81C"
  _bodyText: "\uC124\uD0D5 \uC131 \uBB34\uB108\uC9C4 \uC774\uC57C\uAE30\n       
    \n        (\uBD80\uC5CC \uC606 \uBCF5\uB3C4. \uD558\uB140 \uB458\uC774 \uC6C3\uC74C\uC744
    \uCC38\uB2E4\uAC00 \uACB0\uAD6D \uC785\uC744 \uB9C9\uB294\uB2E4. \uC7C1\uBC18
    \uC704\uC5D4 \uC124\uD0D5\uAC00\uB8E8\uAC00 \uC870\uAE08 \uB0A8\uC740 \uACFC\uC790
    \uC870\uAC01\uC774 \uC788\uB2E4.)\n        \n        \uB124\uBAA8 : \uC65C \uC6C3\uC5B4?\n       
    \n        \uD558\uB1401 : \uC27F, \uC8FC\uC778\uB2D8.\n        \n        \uD558\uB1402
    : \uBC16\uC5D0\uC11C \uB4E4\uC740 \uC598\uAE34\uB370, \uB108\uBB34 \uC6C3\uACA8\uC11C\uC694.\n       
    \n\n\uB124\uBAA8 : \uBB34\uC2A8 \uC598\uAE34\uB370?\n        \n        \uD558\uB1401
    : \uBCC4\uAC70 \uC544\uB2D9\uB2C8\uB2E4. \uC5B4\uB5A4 \uC9D1 \uC794\uCE6B\uC0C1\uC5D0\uC11C
    \uD6C4\uC2DD\uC774 \uC870\uAE08 \uB9DD\uAC00\uC84C\uB300\uC694.\n        \n       
    \uB124\uBAA8 : \uD6C4\uC2DD\uC774 \uB9DD\uAC00\uC838?\n        \n        \uD558\uB1402
    : \uB124. \uAC00\uB054 \uADF8\uB7F4 \uB54C\uB3C4 \uC788\uC9C0\uC694.\n       
    \n        \uB124\uBAA8 : \uC65C \uC6C3\uC5B4?\n        \n        \uD558\uB1401
    : \uADF8\uB0E5 \uBAA8\uC591\uC774 \uC880 \uC6B0\uC2A4\uC6E0\uB098 \uBD05\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uB098\uB3C4 \uB4E3\uACE0 \uC2F6\uC740\uB370.\n       
    \n        \uD558\uB1402 : \uC548 \uB4E4\uC73C\uC154\uB3C4 \uB429\uB2C8\uB2E4,
    \uC8FC\uC778\uB2D8.\n        \n        \uB124\uBAA8 : \uCE58\uC0AC\uD574."
