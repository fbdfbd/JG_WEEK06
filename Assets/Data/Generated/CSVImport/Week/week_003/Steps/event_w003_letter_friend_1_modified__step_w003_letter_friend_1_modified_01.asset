  m_Name: event_w003_letter_friend_1_modified__step_w003_letter_friend_1_modified_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 \uD3B8\uC9C0 3\uC8FC\uCC28 - \uC218\uC815"
  _bodyText: "(\uD558\uB140\uAC00 \uC190\uB54C\uAC00 \uC880 \uBB3B\uC740 \uBD09\uD22C\uB97C
    \uB4E4\uACE0 \uC628\uB2E4. \uBD09\uD22C \uBAA8\uC11C\uB9AC\uC5D4 \uC5C9\uC131\uD55C
    \uBCC4\uD45C\uAC00 \uBA87 \uAC1C \uADF8\uB824\uC838 \uC788\uB2E4.)\r\n       
    \r\n\r\n\uD558\uB140 : \uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C
    \uB610\uB798 \uC190\uB2D8\uC774 \uB2E4\uC2DC \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uBB50\uB77C\uACE0 \uD588\uC5B4?\r\n        \r\n       
    \uD558\uB140 : \uC9C0\uB09C\uBC88\uC5D0 \uC8FC\uC778\uB2D8\uC774\uB791 \uB180\uC558\uB358
    \uAC78 \uC544\uC9C1\uB3C4 \uAE30\uC5B5\uD558\uACE0 \uC788\uB300\uC694.\r\n       
    \r\n        \uB124\uBAA8 : \uC9C4\uC9DC?\r\n        \r\n        \uD558\uB140
    : \uB124. \uADF8\uB9AC\uACE0 \uB2E4\uC74C\uC5D0 \uB9CC\uB098\uBA74 \uBCF4\uC5EC
    \uC8FC\uACE0 \uC2F6\uC740 \uC7AC\uBC0C\uB294 \uACF3\uC774 \uD558\uB098 \uC0DD\uACBC\uB2E4\uACE0
    \uD569\uB2C8\uB2E4.\r\n        \r\n        \uB124\uBAA8 : \uC228\uB294 \uACF3\uC774\uC57C?\r\n       
    \r\n        \uD558\uB140 : \uC544\uB9C8 \uADF8\uB7F4\uC9C0\uB3C4\uC694. \uC544\uB2C8\uBA74
    \uB458\uC774 \uAC19\uC774 \uAD6C\uACBD\uD558\uAE30 \uC88B\uC740 \uACF3\uC77C
    \uC218\uB3C4 \uC788\uACE0\uC694.\r\n        \r\n        \uB124\uBAA8 : \uC624. 
    \uADF8\uB7FC \uB098\uB3C4 \uB2E4\uC74C\uC5D0 \uBB50 \uBCF4\uC5EC \uC904 \uAC70
    \uCC3E\uC544\uC57C\uACA0\uB2E4."
