  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_108_child_excursion_library_01_blocked__step_108_child_excursion_library_01_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 1\uCC28 - \uD1B5\uC81C"
  _bodyText: "\uB192\uC740 \uCC45\uC7A5\uC758 \uBC18\uC9DD\uC774\uB294 \uCC45\uC744
    \uC9D1\uC73C\uB824 \uD558\uC790 \uC11C\uACE0\uAD00\uB9AC\uC778\uC774 \uC704\uD5D8\uD558\uB2E4\uACE0
    \uC81C\uC9C0\uD55C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640\u2026 \uCC45 \uC9C4\uC9DC \uB9CE\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC800\uAC70 \uBC18\uC9DD\uBC18\uC9DD\uD55C\uB2E4. \uC800\uAC70 \uBCF4\uACE0
      \uC2F6\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uADF8 \uCC45\uC740 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uB192\uC740 \uACF3\uC5D0 \uC788\uC5B4\uC11C \uC704\uD5D8\uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC800 \uC870\uAE08\uB9CC \uBCFC \uAC74\uB370."
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uC548 \uB429\uB2C8\uB2E4. \uC544\uC9C1 \uC8FC\uC778\uB2D8\uAED8\uB294
      \uC5B4\uB824\uC6B4 \uCC45\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB9BC\uB3C4 \uC548 \uB3FC\uC694?"
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uC774\uCABD \uCC45\uC740 \uBCF4\uC154\uB3C4 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uC54C\uACA0\uC5B4\uC694."
  _nemoLine: "\uC6B0\uC640\u2026 \uCC45 \uC9C4\uC9DC \uB9CE\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
