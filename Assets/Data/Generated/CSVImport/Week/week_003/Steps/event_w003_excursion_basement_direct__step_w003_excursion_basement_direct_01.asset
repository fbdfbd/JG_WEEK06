  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_excursion_basement_direct__step_w003_excursion_basement_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 3\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uC800\uB141 \uBB34\uB835. \uC9C0\uD558\uC2E4 \uBB38\uD2C8\uC5D0\uC11C
    \uC11C\uB298\uD55C \uBC14\uB78C\uC774 \uC0C8\uC5B4 \uB098\uC628\uB2E4. \uC548\uCABD
    \uC5B4\uB460 \uC18D\uC5D0\uC120 \uD478\uB978 \uBE5B\uC774 \uC544\uC8FC \uC57D\uD558\uAC8C
    \uAE5C\uBE61\uC778\uB2E4.)\n        \n        \uB124\uBAA8 : \uC5B4? \uC800 \uC548\uC5D0
    \uBB50 \uC0B4\uC544? \u3147\u3141\u3147\n        \n        (\uB124\uBAA8\uAC00
    \uBB38\uC744 \uC870\uAE08 \uB354 \uBC00\uC5B4 \uBCF4\uB2C8, \uACFC\uC77C \uC0C1\uC790\uB4E4
    \uC0AC\uC774\uC5D0 \uC190\uBC14\uB2E5\uB9CC \uD55C \uD478\uB978 \uB3CC\uC774
    \uB193\uC5EC \uC788\uB2E4. \uADF8 \uC8FC\uC704 \uACF5\uAE30\uAC00 \uC720\uB09C\uD788
    \uCC28\uAC11\uB2E4.)\n        \n        \uB124\uBAA8 : \uC6B0\uC640. \uB3CC\uC778\uB370
    \uCC28\uAC00\uC6B4 \uBE5B \uB098.\n        \n\n(\uCC3D\uACE0\uC9C0\uAE30\uAC00
    \uB124\uBAA8\uB97C \uBB38 \uC55E\uC5D0 \uC138\uC6B4 \uCC44, \uD478\uB978 \uB3CC
    \uC606\uC5D0 \uB193\uC778 \uC0AC\uACFC \uD558\uB098\uB97C \uB4E4\uC5B4 \uBCF4\uC778\uB2E4.)\n       
    \n        \uCC3D\uACE0\uC9C0\uAE30 : \uAC00\uAE4C\uC774\uB294 \uC548 \uB418\uACE0,
    \uC5EC\uAE30\uC11C\uB9CC \uBCF4\uC2ED\uC2DC\uC624.\n        \n        \uB124\uBAA8
    : \uC751.\n        \n        \uCC3D\uACE0\uC9C0\uAE30 : \uC774 \uB0C9\uAC01\uC11D
    \uB355\uC5D0 \uC0AC\uACFC\uAC00 \uC624\uB798 \uBC84\uD301\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uADF8\uB798\uC11C \uC9C0\uD558\uC2E4\uC774 \uCC28\uAC00\uC6B4
    \uAC70\uC57C?\n        \n        \uCC3D\uACE0\uC9C0\uAE30 : \uC608. \uC5EC\uB984\uC5D0\uB3C4
    \uC870\uAE08 \uC11C\uB298\uD558\uC9C0\uC694.\n        \n        \uB124\uBAA8
    : \uC6B0\uC640.\n        \n        \uB124\uBAA8 : \uADF8\uB7FC \uC774 \uB3CC\uC740
    \uC0AC\uACFC \uC9C0\uCF1C\uC8FC\uB294 \uAC70\uB124.\n        \n        \uCC3D\uACE0\uC9C0\uAE30
    : \uADF8\uB807\uAC8C \uBCFC \uC218\uB3C4 \uC788\uACA0\uAD70\uC694.\n        \n       
    \uB124\uBAA8 : \uB098 \uC800 \uB3CC \uC88B\uC544. \uB9D0\uC740 \uC548 \uD558\uB294\uB370
    \uC5F4\uC2EC\uD788 \uC77C\uD558\uC796\uC544."
