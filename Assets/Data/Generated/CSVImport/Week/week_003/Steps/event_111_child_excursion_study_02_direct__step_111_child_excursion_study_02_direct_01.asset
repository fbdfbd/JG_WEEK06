  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_111_child_excursion_study_02_direct__step_111_child_excursion_study_02_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC 2\uCC28 - \uD5C8\uB77D"
  _bodyText: "\uBB38 \uC55E\uAE4C\uC9C0\uB294 \uC790\uB9AC\uB97C \uD130 \uC8FC\uACE0
    \uBC00\uB78D \uBD09\uC778\uC758 \uC758\uBBF8\uB97C \uC124\uBA85\uD574 \uC900\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uAC00\uAE4C\uC774 \uC624\uC2DC\uBA74 \uC548 \uB418\uC9C0\uB9CC, \uC5EC\uAE30\uC11C
      \uBCF4\uB294 \uAC74 \uAD1C\uCC2E\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uC800 \uBE68\uAC04 \uAC74 \uBB50\uC57C?"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uBC00\uB78D\uC785\uB2C8\uB2E4. \uBC31\uC791\uB2D8\uAED8\uC11C \uBB38\uC11C\uB97C
      \uBD09\uD560 \uB54C \uC4F0\uC2ED\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBD09\uD574?"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC5F4\uC9C0 \uBABB\uD558\uAC8C \uB531 \uBD99\uC774\uB294 \uAC81\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uBC1B\uB294 \uC0AC\uB78C \uC678\uC758 \uC774\uAC00 \uBCF4\uBA74 \uC548
      \uB418\uB2C8\uAE4C\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  _nemoLine: "\uAC00\uAE4C\uC774 \uC624\uC2DC\uBA74 \uC548 \uB418\uC9C0\uB9CC, \uC5EC\uAE30\uC11C
    \uBCF4\uB294 \uAC74 \uAD1C\uCC2E\uC2B5\uB2C8\uB2E4."
