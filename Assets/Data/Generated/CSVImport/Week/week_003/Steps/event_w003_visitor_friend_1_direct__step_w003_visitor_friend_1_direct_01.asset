  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_visitor_friend_1_direct__step_w003_visitor_friend_1_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C1 3\uCC28 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "(\uBCF5\uB3C4 \uC911\uAC04. \uCE5C\uAD6C1\uC774 \uBC14\uB2E5 \uD0C0\uC77C
    \uC0AC\uC774 \uC120 \uC704\uB97C \uD55C \uBC1C\uB85C \uD3F4\uC9DD\uD3F4\uC9DD
    \uB6F0\uACE0 \uC788\uB2E4.)\n        \n        \uCE5C\uAD6C1 : \uB124\uBAA8!
    \uBE68\uB9AC \uC640!\n        \n        \uB124\uBAA8 : \uBB50 \uD574?\n       
    \n        \uCE5C\uAD6C1 : \uBC14\uB2E5 \uC120 \uBC1F\uC73C\uBA74 \uC9C0\uB294
    \uAC8C\uC784!\n        \n\n(\uD558\uB140\uAC00 \uD55C\uC228 \uC26C\uB4EF \uBB3C\uB7EC\uB09C\uB2E4.)\n       
    \n        \uD558\uB140 : \uBA40\uB9AC\uB9CC \uAC00\uC9C0 \uB9C8\uC138\uC694.\n       
    \n        \uCE5C\uAD6C1 : \uC2DC\uC791!\n        \n        \uB124\uBAA8 : \uC5B4\uC5B4?
    \uC7A0\uAE50!\n        \n        (\uCE5C\uAD6C1\uC774 \uBA3C\uC800 \uC120\uC744
    \uD53C\uD574 \uB6F0\uAE30 \uC2DC\uC791\uD558\uACE0, \uB124\uBAA8\uB3C4 \uB4A4\uB2A6\uAC8C
    \uB530\uB77C \uB6F4\uB2E4.)\n        \n        \uCE5C\uAD6C1 : \uBC1F\uC558\uB2E4!\n       
    \n        \uB124\uBAA8 : \uC548 \uBC1F\uC558\uC5B4!\n        \n        \uCE5C\uAD6C1
    : \uBC1C\uB05D \uB2FF\uC558\uC5B4!\n        \n        \uB124\uBAA8 : \uADF8\uAC74
    \uBC1C\uB05D\uC774\uB77C \uAD1C\uCC2E\uC544!\n        \n        \uCE5C\uAD6C1
    : \uADF8\uB7F0 \uAC8C \uC5B4\uB528\uC5B4!\n        \n        (\uB458\uC774 \uAE54\uAE54
    \uC6C3\uC73C\uBA70 \uC120\uC744 \uD53C\uD574 \uD3F4\uC9DD\uC778\uB2E4.)\n       
    \n        \uB124\uBAA8 : \uC774\uBC88\uC5D4 \uB0B4\uAC00 \uBA3C\uC800 \uD560\uB798.\n       
    \n        \uCE5C\uAD6C1 : \uC88B\uC544. \uC9C0\uBA74 \uC18C\uB9AC \uC9C0\uB974\uAE30\uB2E4!"
