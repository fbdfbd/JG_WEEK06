MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_letter_friend_2_modified_2__step_event_week_003_letter_friend_2_modified_2
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uBC00\uB9AC\uC544 \uC218\uC815"
  _bodyText: "letter friend_2 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798
      \uC190\uB2D8\uC774 \uB610 \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uB77C\uACE0 \uD588\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC9C0\uB09C\uBC88\uBCF4\uB2E4 \uD6E8\uC52C \uB2E8\uC815\uD574 \uBCF4\uC5EC\uC11C
      \uAD1C\uCC2E\uC558\uB2E4\uACE0 \uD588\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uB2E4\uC74C\uC5D4 \uB9AC\uBCF8\uB3C4 \uB354 \uC608\uC058\uAC8C
      \uBB36\uC73C\uBA74 \uC88B\uACA0\uB2E4\uACE0 \uD588\uACE0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610 \uADF8\uB7F0 \uC598\uAE30 \uD588\uB124."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uADF8\uB798\uB3C4 \uC8FC\uC778\uB2D8 \uC6C3\uB294 \uBAA8\uC2B5\uC774
      \uAE30\uC5B5\uC5D0 \uB0A8\uC558\uB2E4\uACE0 \uD588\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\u2026\u2026\uADF8\uAC74 \uC880 \uAD1C\uCC2E\uB124."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uD45C\uD604\uC774 \uC11C\uD230 \uBAA8\uC591\uC774\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9DE\uC544. \uAC54\uB294 \uB9E8\uB0A0 \uC774\uC0C1\uD558\uAC8C \uB9D0\uD574."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798
    \uC190\uB2D8\uC774 \uB610 \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
