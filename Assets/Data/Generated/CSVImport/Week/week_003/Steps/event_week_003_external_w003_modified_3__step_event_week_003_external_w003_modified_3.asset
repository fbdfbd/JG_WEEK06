  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_external_w003_modified_3__step_event_week_003_external_w003_modified_3
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: w003 Modified
  _bodyText: "external w003 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB58 \uD588\uB294\uB370?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC5F0\uD68C\uC7A5 \uC55E\uC5D0\uC11C \uC880 \uB208\uC5D0 \uB744\uAC8C
      \uAD74\uC5C8\uB2E4\uB354\uAD70\uC694, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB9D0\uC774 \uD06C\uACE0, \uC790\uB791\uB3C4 \uB9CE\uACE0, \uC0AC\uB78C\uB4E4
      \uC2DC\uC120 \uB044\uB294 \uB370\uB294 \uC544\uC8FC \uB2A5\uD558\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610 \uC790\uB791\uD588\uC5B4?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uB124. \uADF8\uB798\uB3C4 \uC0AC\uB78C\uB4E4\uC774 \uC6C3\uC5C8\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uBBF8\uC6B4 \uB9D0\uB9CC \uD558\uB294 \uAC8C \uC544\uB2C8\uB77C, \uAF2D
      \uB05D\uC5D4 \uC7AC\uBC0C\uAC8C \uB9CC\uB4E4\uC5B4 \uBC84\uB9AC\uAC70\uB4E0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC74C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uC2DC\uB044\uB7EC\uC6B4 \uAD11\uB300 \uAC19\uC740 \uC601\uC6C5\uC774\uB124."
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\u2026\uBE44\uC2B7\uD560\uC9C0\uB3C4 \uBAA8\uB974\uACA0\uB124\uC694."
  _nemoLine: "\uBB58 \uD588\uB294\uB370?"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
