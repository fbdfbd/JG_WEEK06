  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC0AC\uCD0C1 3\uCC28 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "(\uC751\uC811\uC2E4. \uC0AC\uCD0C1\uC774 \uCC28\uB97C \uB9C8\uC2DC\uBA70
    \uB124\uBAA8\uB97C \uBCF4\uC790 \uBA3C\uC800 \uC190\uC9D3\uD55C\uB2E4. \uD14C\uC774\uBE14
    \uC704\uC5D4 \uC791\uC740 \uB098\uBB34 \uC0C1\uC790\uAC00 \uD558\uB098 \uB193\uC5EC
    \uC788\uB2E4.)\r\n        \r\n        \uC0AC\uCD0C1 : \uB610 \uB9CC\uB098\uB294\uAD6C\uB098.\r\n       
    \r\n        \uB124\uBAA8 : \uC548\uB155\uD558\uC138\uC694.\r\n        \r\n       
    \uB124\uBAA8 : \uC800 \uC0C1\uC790 \uBB50\uC57C?\r\n        \r\n\r\n(\uC9D1\uC0AC\uC7A5\uC774
    \uB124\uBAA8\uB97C \uC0B4\uC9DD \uB4A4\uB85C \uBB3C\uB9B0\uB2E4.)\r\n       
    \r\n        \uC9D1\uC0AC\uC7A5 : \uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC9E7\uAC8C
    \uC778\uC0AC\uB9CC \uD558\uC154\uC57C \uD569\uB2C8\uB2E4.\r\n        \r\n       
    \uB124\uBAA8 : \uC65C\uC694? \uC800\uAC70 \uAD81\uAE08\uD55C\uB370.\r\n       
    \r\n        \uC0AC\uCD0C1 : \uC544\uC27D\uAD6C\uB098. \uC8FC\uC778\uB2D8\uAED8
    \uBCF4\uC5EC \uB4DC\uB9B4 \uC791\uC740 \uC7A5\uB09C\uAC10\uC774\uC5C8\uB294\uB370.\r\n       
    \r\n        \uB124\uBAA8 : \uC7A5\uB09C\uAC10?\r\n        \r\n        \uC9D1\uC0AC\uC7A5
    : \uB2E4\uC74C \uAE30\uD68C\uAC00 \uC788\uC2B5\uB2C8\uB2E4.\r\n        \r\n       
    \uC0AC\uCD0C1 : \uADF8\uB798. \uB2E4\uC74C\uC5D4 \uB354 \uC7AC\uBBF8\uC788\uB294
    \uAC78 \uAC00\uC838\uC624\uB9C8.\r\n        \r\n        \uB124\uBAA8 : \uC9C4\uC9DC\uC694?\r\n       
    \r\n        \uC9D1\uC0AC\uC7A5 : \uC8FC\uC778\uB2D8.\r\n        \r\n        \uB124\uBAA8
    : \u2026\u2026\uC751."
