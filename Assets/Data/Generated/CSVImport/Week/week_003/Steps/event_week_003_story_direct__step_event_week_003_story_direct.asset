  _titleOverride: "\uB3D9\uD654\uC640 \uAE00\uC790\uB97C \uCC28\uADFC\uCC28\uADFC
    \uC77D\uD78C\uB2E4"
  _bodyText: "\uB3D9\uD654\uC640 \uAE00\uC790 \uAD50\uC7AC Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC9E7\uC740 \uB3D9\uD654\uB97C \uD55C \uC904\uC529 \uC9DA\uC73C\uBA70
      \uAE00\uC790\uC640 \uB73B\uC744 \uCC28\uBD84\uD788 \uC77D\uD600 \uC900\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774 \uAE00\uC790\uB294 \uC544\uAE4C \uBCF8 \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uBC18\uBCF5\uB418\uB294 \uAE00\uC790\uB97C \uB2E4\uC2DC \uC77D\uAC8C
      \uD558\uBA70 \uBB38\uC7A5\uC744 \uC775\uD788\uAC8C \uD55C\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uBC88\uC5D4 \uC81C\uAC00 \uBA3C\uC800 \uC77D\uC5B4 \uBCFC\uB798\uC694."
  _nemoLine: "(\uC9E7\uC740 \uB3D9\uD654\uB97C \uD55C \uC904\uC529 \uC9DA\uC73C\uBA70
    \uAE00\uC790\uC640 \uB73B\uC744 \uCC28\uBD84\uD788 \uC77D\uD600 \uC900\uB2E4.)"
