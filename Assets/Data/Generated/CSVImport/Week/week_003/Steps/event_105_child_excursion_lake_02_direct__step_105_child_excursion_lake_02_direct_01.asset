  _titleOverride: "\uD638\uC218 2\uCC28 - \uD5C8\uB77D"
  _bodyText: "\uB3CC\uAE38 \uB05D\uAE4C\uC9C0\uB9CC \uB2E4\uAC00\uAC00 \uC218\uBA74\uC744
    \uBC14\uB77C\uBCF4\uAC8C \uD558\uBA70 \uD638\uC218\uC640\uC758 \uAC70\uB9AC\uB97C
    \uC870\uC808\uD55C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC544\uC8FC \uAC00\uAE4C\uC774\uAE4C\uC9C4 \uC548 \uB429\uB2C8\uB2E4,
      \uC8FC\uC778\uB2D8. \uC774 \uC120\uAE4C\uC9C0\uB9CC\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640\u2026 \uC9C4\uC9DC \uAC70\uC6B8 \uAC19\uC544."
  _nemoLine: "\uC544\uC8FC \uAC00\uAE4C\uC774\uAE4C\uC9C4 \uC548 \uB429\uB2C8\uB2E4,
    \uC8FC\uC778\uB2D8. \uC774 \uC120\uAE4C\uC9C0\uB9CC\uC785\uB2C8\uB2E4."
