  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_111_child_excursion_study_02_blocked__step_111_child_excursion_study_02_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC 2\uCC28 - \uD1B5\uC81C"
  _bodyText: "\uCC45\uC0C1 \uC704 \uD3B8\uC9C0 \uBD09\uD22C\uB97C \uBCF4\uB358 \uB124\uBAA8\uC5D0\uAC8C
    \uBE44\uC11C\uAC00 \uC624\uB298\uB3C4 \uC5C5\uBB34\uC6A9 \uBB38\uC11C\uB77C\uACE0
    \uB9D0\uD558\uBA70 \uB9C9\uB294\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5B4? \uC774\uBC88\uC5D4 \uC885\uC774\uAC00 \uB9CE\uB124. \uC800 \uBE68\uAC04
      \uAC74 \uB610 \uBB50\uC9C0?"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC774\uCABD\uC740 \uBCF4\uC2DC\uBA74 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uBC31\uC791\uB2D8 \uC5C5\uBB34\uC6A9 \uBB38\uC11C\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9E8\uB0A0 \uC911\uC694\uD55C \uAC70\uC57C."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC608. \uC624\uB298\uB3C4 \uADF8\uB807\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC54C\uACA0\uC5B4\uC694."
  _nemoLine: "\uC5B4? \uC774\uBC88\uC5D4 \uC885\uC774\uAC00 \uB9CE\uB124. \uC800
    \uBE68\uAC04 \uAC74 \uB610 \uBB50\uC9C0?"
