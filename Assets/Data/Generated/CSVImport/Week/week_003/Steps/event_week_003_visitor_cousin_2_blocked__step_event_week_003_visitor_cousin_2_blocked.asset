  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_visitor_cousin_2_blocked__step_event_week_003_visitor_cousin_2_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: cousin_2 Blocked
  _bodyText: "visitor cousin_2 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC9D1\uC0AC\uC7A5\uC774 \uB458 \uC0AC\uC774\uB85C \uD55C \uAC78\uC74C
      \uB4E4\uC5B4\uC628\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uAE38\uAC8C \uACC4\uC2DC\uBA74
      \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC7A0\uAE50\uB9CC. \uBB50 \uC900\uB2E4\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\u2026\u2026\uAD1C\uCC2E\uC544. \uB2E4\uC74C\uC5D0 \uC904\uAC8C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uC600\uB294\uB370?"
  - _speaker: {fileID: 11400000, guid: 7ba078414ab25104a821c91cc498d418, type: 2}
    _text: "\uADF8\uB0E5\u2026 \uBCC4\uAC70 \uC544\uB0D0."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBCC4\uAC70 \uC544\uB2C8\uBA74 \uB354 \uAD81\uAE08\uD55C\uB370."
  - _speaker: {fileID: 11400000, guid: 84ffa10995c48764388074048cfd595e, type: 2}
    _text: "\uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC54C\uACA0\uC5B4."
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC0AC\uCD0C2\uB294 \uC811\uD78C \uC885\uC774\uB97C \uB2E4\uC2DC \uC8FC\uBA38\uB2C8\uC5D0
      \uB123\uB294\uB2E4.)"
  _nemoLine: "(\uC9D1\uC0AC\uC7A5\uC774 \uB458 \uC0AC\uC774\uB85C \uD55C \uAC78\uC74C
    \uB4E4\uC5B4\uC628\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
