  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_excursion_library_blocked__step_w003_excursion_library_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 3\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uB3C4\uC11C\uAD00 \uAE4A\uC219\uD55C \uC790\uB9AC. \uC11C\uACE0\uAD00\uB9AC\uC778\uC774
    \uB450\uAEBC\uC6B4 \uCC45 \uD55C \uAD8C\uC744 \uD3BC\uCE58\uC790, \uAC80\uC740
    \uC885\uC774 \uC704\uC5D0 \uC791\uC740 \uBCC4\uC810\uB4E4\uC774 \uD558\uB098\uC529
    \uB5A0\uC624\uB978\uB2E4. \uBE5B\uC218\uC815 \uB7A8\uD504\uAC00 \uD398\uC774\uC9C0
    \uC704\uB97C \uBE44\uCD94\uACE0 \uC788\uB2E4.)\r\n        \r\n        \uB124\uBAA8
    : \uC6B0\uC640. \uCC45 \uC548\uC5D0 \uBC24\uC774 \uB4E4\uC5B4 \uC788\uB124.\r\n       
    \r\n        (\uB124\uBAA8\uAC00 \uC758\uC790\uB97C \uB04C\uACE0 \uC640 \uD131\uC744
    \uAD34\uACE0 \uB4E4\uC5EC\uB2E4\uBCF8\uB2E4. \uBCC4\uC810\uB4E4\uC740 \uC774\uC5B4\uC838
    \uC774\uC0C1\uD55C \uB3D9\uBB3C \uBAA8\uC591\uCC98\uB7FC \uBCF4\uC778\uB2E4.)\r\n       
    \r\n        \uB124\uBAA8 : \uC800\uAC74 \uD1A0\uB07C \uAC19\uC544.\r\n       
    \r\n        \uB124\uBAA8 : \uC544\uB2C8, \uC5FC\uC18C\uC778\uAC00?\r\n       
    \r\n\r\n(\uC11C\uACE0\uAD00\uB9AC\uC778\uC774 \uCC45\uC744 \uC0B4\uC9DD \uC790\uAE30
    \uCABD\uC73C\uB85C \uB3CC\uB9B0\uB2E4.)\r\n        \r\n        \uC11C\uACE0\uAD00\uB9AC\uC778
    : \uC8FC\uC778\uB2D8, \uC774 \uCC45\uC740 \uAC00\uAE4C\uC774 \uB9CC\uC9C0\uC2DC\uBA74
    \uC548 \uB429\uB2C8\uB2E4.\r\n        \r\n        \uB124\uBAA8 : \uC65C\uC694?\r\n       
    \r\n        \uC11C\uACE0\uAD00\uB9AC\uC778 : \uBCC4\uBB34\uB2AC \uAC00\uB8E8\uAC00
    \uB0A0\uC544\uAC11\uB2C8\uB2E4. \uADF8\uB7EC\uBA74 \uB2E4\uC2DC \uB9DE\uCD94\uAE30
    \uC5B4\uB835\uC2B5\uB2C8\uB2E4.\r\n        \r\n        \uB124\uBAA8 : \uD55C
    \uBC88\uB9CC \uC9DA\uC5B4 \uBCFC \uAC74\uB370.\r\n        \r\n        \uC11C\uACE0\uAD00\uB9AC\uC778
    : \uC548 \uB429\uB2C8\uB2E4. \uB300\uC2E0 \uC81C\uAC00 \uB118\uACA8 \uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uCE58\uC0AC\uD574. \uBCC4\uC740 \uD558\uB298\uC5D0
    \uC788\uC744 \uB550 \uC548 \uB3C4\uB9DD\uAC00\uBA74\uC11C.\r\n        \r\n       
    \uC11C\uACE0\uAD00\uB9AC\uC778 : \uC885\uC774 \uC704 \uBCC4\uC740 \uC870\uAE08
    \uB354 \uC608\uBBFC\uD569\uB2C8\uB2E4.\r\n        \r\n        \uB124\uBAA8 :
    \uC74C\u2026 \uADF8\uAC74 \uC880 \uC57D\uD558\uB124."
