  m_Name: event_w003_house_candlestick_direct__step_w003_house_candlestick_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCD1B\uB300 \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uC800\uB141 \uBB34\uB835 \uBCF5\uB3C4. \uD558\uB140 \uB458\uC774
    \uCD1B\uB300\uB97C \uC62E\uAE30\uBA70 \uC18D\uC0AD\uC778\uB2E4.)\r\n        \r\n       
    \uD558\uB1401 : \uC5B4\uC81C \uC5EC\uAE30 \uCD1B\uB18D\uC774 \uB354 \uB9CE\uC558\uB358
    \uAC83 \uAC19\uC740\uB370.\r\n        \r\n        \uD558\uB1402 : \uB204\uAC00
    \uBAB0\uB798 \uBD88 \uCF30\uB2E4 \uAED0\uB098?\r\n        \r\n        \uB124\uBAA8
    : \uB610 \uBB50\uC57C \uBB50\uC57C \uBB50\uC57C?\r\n        \r\n\r\n\uD558\uB1401
    : \uB204\uAC00 \uBCF5\uB3C4 \uCD1B\uB300\uB97C \uBA3C\uC800 \uCF30\uB2E4 \uAED0\uB294\uC9C0,
    \uCD1B\uB18D\uC774 \uC870\uAE08 \uB354 \uB0A8\uC544 \uC788\uB354\uAD70\uC694,
    \uC8FC\uC778\uB2D8.\r\n        \r\n        \uB124\uBAA8 : \uB204\uAC00?\r\n       
    \r\n        \uD558\uB1402 : \uC798 \uBAA8\uB974\uACA0\uC5B4\uC694. \uB2A6\uAC8C
    \uC9C0\uB098\uAC04 \uD558\uC778\uC774 \uC788\uC5C8\uB098 \uBD10\uC694.\r\n       
    \r\n        \uB124\uBAA8 : \uBC24\uC5D0?\r\n        \r\n        \uD558\uB1401
    : \uB124. \uC800\uD0DD\uC774 \uD06C\uB2E4 \uBCF4\uB2C8 \uADF8\uB7F0 \uC77C\uB3C4
    \uC788\uC9C0\uC694.\r\n        \r\n        \uB124\uBAA8 : \uBC24\uC5D0 \uBCF5\uB3C4
    \uAC78\uC73C\uBA74 \uC880 \uBB34\uC11C\uC6B8 \uAC83 \uAC19\uC740\uB370.\r\n       
    \r\n        \uD558\uB1402 : \uADF8\uB798\uC11C \uCD1B\uBD88\uC774 \uB354 \uD544\uC694\uD55C
    \uAC70\uB78D\uB2C8\uB2E4."
