  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_external_w003_modified__step_event_week_003_external_w003_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC678\uBD80 \uC815\uBCF4 \uC218\uC815"
  _bodyText: "external w003 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC218\uB3C4\uC5D0\uC11C \uBE44\uB217\uBC29\uC6B8 \uACF5\uC5F0\uC774
      \uC720\uD589\uC774\uB77C\uB124\uC694, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB0E5 \uBE44\uB217\uBC29\uC6B8?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uD587\uBE5B\uC774\uB098 \uC791\uC740 \uBD88\uBE5B\uC744 \uBE44\uCDB0\uC11C
      \uC608\uC058\uAC8C \uBCF4\uC774\uAC8C \uD55C\uB300\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD130\uC9C0\uBA74?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uBC18\uC9DD \uD558\uACE0 \uC0AC\uB77C\uC9C0\uACA0\uC9C0\uC694. \uC7A0\uAE50
      \uC608\uC05C \uAD6C\uACBD \uAC19\uC740 \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uC880 \uC88B\uB2E4."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uC2DC\uB044\uB7EC\uC6B4 \uC7A5\uD130\uBCF4\uB2E4, \uC7A0\uAE50 \uD558\uB298
      \uBCF4\uB294 \uB290\uB08C\uC77C\uC9C0\uB3C4 \uBAA8\uB974\uACA0\uB124\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098 \uADF8\uAC70\uBA74 \uAD1C\uCC2E\uC544."
  _nemoLine: "\uC218\uB3C4\uC5D0\uC11C \uBE44\uB217\uBC29\uC6B8 \uACF5\uC5F0\uC774
    \uC720\uD589\uC774\uB77C\uB124\uC694, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
