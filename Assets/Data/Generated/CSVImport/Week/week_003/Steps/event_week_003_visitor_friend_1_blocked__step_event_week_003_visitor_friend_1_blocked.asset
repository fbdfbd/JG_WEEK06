  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_visitor_friend_1_blocked__step_event_week_003_visitor_friend_1_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: friend_1 Blocked
  _bodyText: "visitor friend_1 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uB124\uBAA8 \uC5B4\uAE68\uB97C \uC0B4\uC9DD \uBD99\uC7A1\uB294\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uB6F0\uC2DC\uBA74 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uC5D0\uC774. \uB531 \uD55C \uBC88\uB9CC!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uD558\uACE0 \uC2F6\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC624\uB298\uC740 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uADF8\uB7FC \uB9D0\uB85C\uB9CC \uD558\uC790."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9D0\uB85C \uC5B4\uB5BB\uAC8C \uD574."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uB0B4\uAC00 \uB6F0\uB294 \uAC70 \uBCF4\uACE0 \uC751\uC6D0\uD574!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uC880 \uCE58\uC0AC\uD55C\uB370."
  - _speaker: {fileID: 11400000, guid: 6fe25525451893048a0f5f4a4e6c6eeb, type: 2}
    _text: "\uADF8\uB798\uB3C4 \uBD10 \uC918!"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uCE5C\uAD6C1\uC774 \uD63C\uC790 \uC120\uC744 \uD53C\uD574 \uB6F0\uACE0,
      \uB124\uBAA8\uB294 \uD314\uC9F1 \uB07C\uACE0 \uBCF8\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uD558\uBA74 \uB354 \uC798\uD558\uB294\uB370."
  _nemoLine: "(\uD558\uB140\uAC00 \uB124\uBAA8 \uC5B4\uAE68\uB97C \uC0B4\uC9DD \uBD99\uC7A1\uB294\uB2E4.)"
