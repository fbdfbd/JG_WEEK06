  _titleOverride: w003 Blocked
  _bodyText: "external w003 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610 \uADF8 \uC774\uC0C1\uD55C \uC0AC\uB78C?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uB124. \uC774\uBC88\uC5D0\uB3C4 \uC2DC\uB044\uB7FD\uAC8C \uAD74\uC5C8\uB2E4\uB294
      \uC598\uAE30\uB78D\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB58 \uD588\uB294\uB370?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uC544\uC2E4 \uAC83\uAE4C\uC9C4 \uC5C6\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADFC\uB370 \uC5BC\uAD74\uC740 \uC65C \uC800\uB807\uAC8C \uADF8\uB838\uC5B4?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC790\uAE30\uAC00 \uC81C\uC77C \uB9C8\uC74C\uC5D0 \uB4DC\uB294 \uCABD
      \uC5BC\uAD74\uC774 \uC788\uB098 \uBCF4\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6C3\uAE30\uB2E4."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uC6C3\uACE0 \uC9C0\uB098\uAC00\uC2DC\uBA74 \uB429\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  _nemoLine: "\uB610 \uADF8 \uC774\uC0C1\uD55C \uC0AC\uB78C?"
