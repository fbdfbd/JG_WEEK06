  m_Name: event_w003_excursion_lake_direct__step_w003_excursion_lake_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 3\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uBC14\uB78C\uC774 \uC794\uC794\uD55C \uC624\uD6C4. \uAC08\uB300 \uC0AC\uC774\uB85C
    \uC624\uB9AC \uD55C \uC30D\uACFC \uC791\uC740 \uC0C8\uB07C\uB4E4\uC774 \uBB3C
    \uC704\uB97C \uCC9C\uCC9C\uD788 \uC9C0\uB098\uAC04\uB2E4.)\n        \n       
    \uB124\uBAA8 : \uC5B4? \uC800\uAE30 \uBD10.\n        \n        \uB124\uBAA8 :
    \uCABC\uADF8\uB9CC \uAC70 \uB530\uB77C\uAC04\uB2E4.\n        \n        (\uB124\uBAA8\uAC00
    \uBC1C\uB05D\uC744 \uC138\uC6B0\uBA70 \uBB3C\uAC00 \uCABD\uC744 \uB354 \uBCF4\uB824
    \uD55C\uB2E4.)\n        \n\n(\uACBD\uBE44\uB300\uC7A5\uC774 \uB3CC\uAE38 \uB05D\uAE4C\uC9C0\uB9CC
    \uB530\uB77C\uAC00\uAC8C \uD55C\uB2E4.)\n            \n            \uACBD\uBE44\uB300\uC7A5
    : \uC624\uB298\uB3C4 \uC774 \uC120\uAE4C\uC9C0\uB9CC\uC785\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.\n           
    \n            \uB124\uBAA8 : \uC751. \uC548 \uB118\uC744\uAC8C.\n           
    \n            (\uB124\uBAA8\uAC00 \uD5C8\uB9AC\uB97C \uC219\uC5EC \uBB3C\uAC00\uB97C
    \uBCF8\uB2E4.)\n            \n            \uB124\uBAA8 : \uC6B0\uC640. \uC9C4\uC9DC
    \uC791\uB2E4.\n            \n            \uB124\uBAA8 : \uB4A4\uB6B1\uB4A4\uB6B1\uD574.\n           
    \n            \uACBD\uBE44\uB300\uC7A5 : \uC0C8\uB07C\uB4E4\uC774\uB77C \uADF8\uB807\uC2B5\uB2C8\uB2E4.\n           
    \n            \uB124\uBAA8 : \uC5C4\uB9C8 \uB530\uB77C\uAC00\uB294 \uAC70 \uBD10.\n           
    \n            \uB124\uBAA8 : \uB098\uB3C4 \uC800\uB807\uAC8C \uC904 \uC11C\uC11C
    \uAC00\uACE0 \uC2F6\uB2E4.\n            \n            \uACBD\uBE44\uB300\uC7A5
    : \u2026\u2026\uADF8\uAC74 \uC880 \uC5B4\uB835\uACA0\uC2B5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.\n           
    \n            \uB124\uBAA8 : \u31613\u3161."
