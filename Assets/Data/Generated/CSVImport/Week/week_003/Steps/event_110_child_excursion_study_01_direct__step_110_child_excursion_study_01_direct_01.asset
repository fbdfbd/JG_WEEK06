  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_110_child_excursion_study_01_direct__step_110_child_excursion_study_01_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC 1\uCC28 - \uD5C8\uB77D"
  _bodyText: "\uBE44\uC11C\uAC00 \uBB38\uC744 \uC870\uAE08 \uB354 \uC5F4\uC5B4 \uBB38\uC55E\uC5D0\uC11C
    \uC548\uCABD\uC744 \uAD6C\uACBD\uD558\uAC8C \uD574 \uC900\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC548\uC774 \uAD81\uAE08\uD558\uC2ED\uB2C8\uAE4C?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uC800 \uBC18\uC9DD\uC774\uB294 \uAC70 \uBCF4\uACE0 \uC2F6\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC548\uCABD\uAE4C\uC9C4 \uC548 \uB418\uC9C0\uB9CC, \uBB38 \uC55E\uC5D0\uC11C
      \uC7A0\uAE50 \uBCF4\uB294 \uAC74 \uAD1C\uCC2E\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC\uC694?"
  - _speaker: {fileID: 11400000, guid: 22a4c5e895307e74fae01c9ccdc97b8f, type: 2}
    _text: "\uC608. \uB300\uC2E0 \uC190\uB300\uC2DC\uBA74 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751! \uC548 \uB9CC\uC9C8\uB798\uC694!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640\u2026 \uBA4B\uC788\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBC31\uC791\uB2D8\uC740 \uB9E8\uB0A0 \uC774\uB7F0 \uAC70 \uC4F0\uB098?"
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC548\uC774 \uAD81\uAE08\uD558\uC2ED\uB2C8\uAE4C?"
  _useCustomVisualState: 0
  _visualState: 0
