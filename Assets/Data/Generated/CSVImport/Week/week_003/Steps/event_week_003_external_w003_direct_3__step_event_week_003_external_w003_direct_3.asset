  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_external_w003_direct_3__step_event_week_003_external_w003_direct_3
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: w003 Direct
  _bodyText: "external w003 Direct \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB58 \uD588\uB294\uB370?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC5F0\uD68C\uC7A5 \uC55E\uC5D0\uC11C \uCD08\uB300\uC7A5 \uAC80\uC0AC\uBC1B\uB2E4\uAC00,"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uD5C9. \uC9C4\uC9DC \uADF8\uB807\uAC8C \uB9D0\uD588\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uADF8\uB798\uC11C \uB2E4\uB4E4 \uAE30\uAC00 \uB9C9\uD600\uD588\uB294\uB370\u2026"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC7A0\uAE50 \uB4A4\uC5D0 \uC790\uAE30\uAC00 \uD574\uCE58\uC6B4 \uB9C8\uC218
      \uC598\uAE30\uB97C \uC2DC\uC791\uD558\uB354\uB2C8,"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uC57C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC \uC774\uC0C1\uD55C\uB370 \uBA4B\uC788\uB124."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB531 \uADF8 \uB9D0\uC774 \uB9DE\uC9C0\uC694, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB3C4 \uC800\uB807\uAC8C \uB9D0\uD558\uBA74 \uD63C\uB0A0\uAE4C?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC8FC\uC778\uB2D8\uC740 \uB9CE\uC774 \uD63C\uB098\uC2E4 \uAC81\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774."
  _nemoLine: "\uBB58 \uD588\uB294\uB370?"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
