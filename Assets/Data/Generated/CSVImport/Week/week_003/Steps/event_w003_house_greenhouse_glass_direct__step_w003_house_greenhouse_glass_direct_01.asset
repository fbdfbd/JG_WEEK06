  m_Name: event_w003_house_greenhouse_glass_direct__step_w003_house_greenhouse_glass_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC628\uC2E4 \uC720\uB9AC \uC18C\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uC815\uC6D0 \uC606 \uD1B5\uB85C. \uC815\uC6D0\uC0AC \uB458\uC774
    \uC720\uB9AC\uCC3D\uC744 \uB2E6\uC73C\uBA70 \uC911\uC5BC\uAC70\uB9B0\uB2E4.)\n       
    \n        \uC815\uC6D0\uC0AC1 : \uB610 \uAE08 \uAC14\uB124.\n        \n       
    \uC815\uC6D0\uC0AC2 : \uC5B4\uC81C \uD574\uAC00 \uB108\uBB34 \uC138\uC11C \uADF8\uB7F0\uAC00
    \uBD10.\n        \n        \uB124\uBAA8 : \uBB50\uAC00 \uAE68\uC84C\uC5B4?\n       
    \n\n\uC815\uC6D0\uC0AC1 : \uC628\uC2E4 \uC720\uB9AC\uC5D0 \uC791\uC740 \uAE08\uC774
    \uAC14\uB2F5\uB2C8\uB2E4, \uC8FC\uC778\uB2D8.\n        \n        \uB124\uBAA8
    : \uC65C?\n        \n        \uC815\uC6D0\uC0AC2 : \uD587\uBE5B\uC774 \uC138\uAC8C
    \uB4E4\uAC70\uB098, \uB0A0\uC774 \uAC11\uC790\uAE30 \uCC28\uAC00\uC6CC\uC9C0\uBA74
    \uADF8\uB7F4 \uB54C\uAC00 \uC788\uC5B4\uC694.\n        \n        \uB124\uBAA8
    : \uC720\uB9AC\uB3C4 \uC544\uD30C?\n        \n        \uC815\uC6D0\uC0AC1 : \uADF8\uB7F4\uC9C0\uB3C4
    \uBAA8\uB974\uC9C0\uC694.\n        \n        \uB124\uBAA8 : \uD5C9. \uADF8\uB7FC
    \uAF43\uB4E4\uB3C4 \uB180\uB790\uACA0\uB2E4.\n        \n        \uC815\uC6D0\uC0AC2
    : \uADF8\uB798\uC11C \uC800\uD76C\uAC00 \uBC14\uB85C \uC190\uBCF4\uB294 \uAC81\uB2C8\uB2E4."
