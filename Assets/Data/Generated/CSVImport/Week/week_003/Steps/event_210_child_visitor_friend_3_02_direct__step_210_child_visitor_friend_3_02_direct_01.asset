  _titleOverride: "\uCE5C\uAD6C3 \uB450 \uBC88\uC9F8 \uB9CC\uB0A8 - \uD5C8\uB77D"
  _bodyText: "\uAF43\uBCD1\uB3C4 \uD30C\uB974\uD398\uCC98\uB7FC \uBCF4\uC778\uB2E4\uB294
    \uB9D0\uC744 \uC8FC\uACE0\uBC1B\uC73C\uBA70 \uB458\uC758 \uC7A5\uB09C\uC774 \uC774\uC5B4\uC9C4\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uC800 \uAF43\uBCD1\uC740 \uD30C\uB974\uD398 \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB610 \uBA39\uB294 \uAC70\uC57C?"
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uC751. \uADF8\uB807\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB10C \uB9E8\uB0A0 \uBA39\uB294 \uAC70 \uAC19\uB300."
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uADF8\uB7FC \uB108\uB294 \uBB50 \uAC19\uC544?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB09C\u2026 \uC798 \uBAA8\uB974\uACA0\uC5B4."
  _nemoLine: "\uC800 \uAF43\uBCD1\uC740 \uD30C\uB974\uD398 \uAC19\uC544."
