  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_excursion_study_direct__step_w003_excursion_study_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB0B4\uC11C\uC7AC 3\uCC28 \uBC29\uBB38 - \uD5C8\uB77D"
  _bodyText: "(\uC11C\uC7AC \uBB38\uC774 \uC870\uAE08 \uC5F4\uB824 \uC788\uB2E4.
    \uC548\uCABD\uC5D0\uC11C \uBE44\uC11C\uAC00 \uC791\uC740 \uB18B\uADF8\uB987 \uC704\uC5D0
    \uBD89\uC740 \uBC00\uB78D\uC744 \uB179\uC774\uACE0 \uC788\uB2E4. \uADF8\uB987
    \uBC11\uC758 \uC5F4\uC11D\uC774 \uC740\uC740\uD558\uAC8C \uB2EC\uC544\uC62C\uB77C
    \uC788\uB2E4.)\r\n        \r\n        \uB124\uBAA8 : \uC5B4?\r\n        \r\n       
    \uB124\uBAA8 : \uC800\uAC70 \uC7BC\uC774\uC57C?\r\n        \r\n        \uB124\uBAA8
    : \uB0C4\uC0C8\uB294 \uC544\uB2CC\uB370 \uC0C9\uC740 \uC7BC \uAC19\uC544.\r\n       
    \r\n        (\uBE44\uC11C\uAC00 \uC6C3\uC74C\uC744 \uCC38\uC73C\uBA70 \uBC00\uB78D\uC744
    \uBD09\uD22C \uC704\uC5D0 \uB611 \uB5A8\uC5B4\uB728\uB9B0\uB2E4. \uACE7\uC774\uC5B4
    \uC778\uC7A5\uC744 \uAFB9 \uB204\uB974\uC790 \uBB38\uC591\uC774 \uB0A8\uB294\uB2E4.)\r\n       
    \r\n\r\n(\uBE44\uC11C\uAC00 \uB2E4 \uC2DD\uC740 \uBC00\uB78D \uC790\uAD6D \uD558\uB098\uB97C
    \uC885\uC774 \uC870\uAC01\uC9F8 \uB4E4\uC5B4 \uBCF4\uC5EC \uC900\uB2E4.)\r\n       
    \r\n        \uBE44\uC11C : \uB9CC\uC9C0\uB294 \uAC74 \uC548 \uB418\uC9C0\uB9CC,
    \uAC00\uAE4C\uC774\uC11C \uBCF4\uB294 \uAC74 \uAD1C\uCC2E\uC2B5\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uC6B0\uC640.\r\n        \r\n        \uB124\uBAA8
    : \uAF43\uCC98\uB7FC \uCC0D\uD614\uC5B4.\r\n        \r\n        \uBE44\uC11C
    : \uC2A4\uD018\uC5B4 \uAC00\uBB38 \uC778\uC7A5\uC785\uB2C8\uB2E4.\r\n       
    \r\n        \uB124\uBAA8 : \uC774\uAC70 \uBC31\uC791\uB2D8 \uD45C\uC2DC\uC57C?\r\n       
    \r\n        \uBE44\uC11C : \uC608. \uC774 \uBB38\uC11C\uAC00 \uBC31\uC791\uB2D8
    \uB73B\uB300\uB85C \uBD09\uD574\uC84C\uB2E4\uB294 \uD45C\uC2DC\uC9C0\uC694.\r\n       
    \r\n        \uB124\uBAA8 : \uADF8\uB7FC \uC5F4\uBA74 \uC548 \uB418\uB294 \uAC70\uB124.\r\n       
    \r\n        \uBE44\uC11C : \uB9DE\uC2B5\uB2C8\uB2E4.\r\n        \r\n        \uB124\uBAA8
    : \uBA4B\uC788\uB2E4. \uB098\uB3C4 \uC5B8\uC820\uAC00 \uAFB9 \uD574 \uBCF4\uACE0
    \uC2F6\uC5B4.\r\n        \r\n        \uBE44\uC11C : \uC5B8\uC820\uAC00 \uC5F0\uC2B5\uC6A9\uC73C\uB85C
    \uBCF4\uC5EC \uB4DC\uB9B4 \uB0A0\uB3C4 \uC788\uACA0\uC9C0\uC694.\r\n        \r\n       
    \uB124\uBAA8 : \uC9C4\uC9DC?\r\n        \r\n        \uBE44\uC11C : \uC544\uC8FC
    \uC5B8\uC820\uAC00\uC694.\r\n        \r\n        \uB124\uBAA8 : \uADF8\uB7FC
    \uAE30\uB2E4\uB9B4\uB798."
