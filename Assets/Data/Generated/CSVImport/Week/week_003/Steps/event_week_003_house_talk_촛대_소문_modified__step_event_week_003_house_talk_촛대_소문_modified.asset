  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: "event_week_003_house_talk_\uCD1B\uB300_\uC18C\uBB38_modified__step_event_week_003_house_talk_\uCD1B\uB300_\uC18C\uBB38_modified"
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCD1B\uB300_\uC18C\uBB38 Modified"
  _bodyText: "house_talk \uCD1B\uB300_\uC18C\uBB38 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uBCF5\uB3C4 \uCD1B\uB300\uB97C \uC870\uAE08 \uC77C\uCC0D \uCF20 \uC0AC\uB78C\uC774
      \uC788\uC5C8\uB098 \uBD05\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB0A0\uC774 \uBE68\uB9AC \uC5B4\uB450\uC6CC\uC838\uC11C \uADF8\uB7AC\uACA0\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544."
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uAF2D \uC774\uC0C1\uD55C \uC77C\uC740 \uC544\uB2C8\uC5D0\uC694. \uADF8\uB0E5
      \uC11C\uB458\uB7EC \uC900\uBE44\uD55C \uAC70\uB78D\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uAD1C\uCC2E\uB124."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uCD1B\uBD88\uC740 \uC6D0\uB798 \uBA3C\uC800 \uCF1C \uB450\uBA74
      \uB9C8\uC74C\uC774 \uB193\uC774\uB2C8\uAE4C\uC694."
  _nemoLine: "\uBCF5\uB3C4 \uCD1B\uB300\uB97C \uC870\uAE08 \uC77C\uCC0D \uCF20 \uC0AC\uB78C\uC774
    \uC788\uC5C8\uB098 \uBD05\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
