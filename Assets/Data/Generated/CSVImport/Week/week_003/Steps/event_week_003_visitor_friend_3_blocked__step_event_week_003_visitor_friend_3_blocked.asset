  _titleOverride: friend_3 Blocked
  _bodyText: "visitor friend_3 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uD558\uB140\uAC00 \uB124\uBAA8\uB97C \uBD80\uB978\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC9E7\uAC8C\uB9CC \uC778\uC0AC\uD558\uC154\uC57C
      \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC7A0\uAE50\uB9CC. \uAC1C\uAD6C\uB9AC \uC788\uB300."
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uC190\uC73C\uB85C \uB9CC\uB4E0 \uAC74\uB370."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uC57C."
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uADF8\uB798\uB3C4 \uAC1C\uAD6C\uB9AC \uAC19\uC558\uC796\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC870\uAE08."
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uB2E4\uC74C\uC5D4 \uD1A0\uB07C\uB3C4 \uB9CC\uB4E4\uAC8C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB2E4\uC74C\uC5D0 \uBCFC\uB798."
  _nemoLine: "(\uD558\uB140\uAC00 \uB124\uBAA8\uB97C \uBD80\uB978\uB2E4.)"
