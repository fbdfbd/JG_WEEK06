  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_210_child_visitor_friend_3_02_blocked__step_210_child_visitor_friend_3_02_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uCE5C\uAD6C3 \uB450 \uBC88\uC9F8 \uB9CC\uB0A8 - \uD1B5\uC81C"
  _bodyText: "\uC624\uB298\uB3C4 \uC5C9\uB6B1\uD55C \uCE5C\uAD6C3\uB97C \uB450\uACE0
    \uC9E7\uC740 \uC778\uC0AC\uB9CC \uB098\uB204\uACE0 \uD5E4\uC5B4\uC9C4\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uC624\uB298 \uAD6C\uB984\uC740 \uB9CC\uB450 \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC800\uBC88\uC5D4 \uBE75 \uC544\uB2C8\uC5C8\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uC624\uB298\uC740 \uB9CC\uB450\uC57C."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uC9E7\uAC8C \uC778\uC0AC\uB9CC
      \uD558\uC154\uC57C \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC7E4 \uB610 \uC774\uC0C1\uD55C \uB9D0 \uD574."
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uC9C4\uC9DC \uB9CC\uB450 \uAC19\uC740\uB370."
  - _speaker: {fileID: 11400000, guid: 746862c98c186d24d80b54442fdd7344, type: 2}
    _text: "\uB2E4\uC74C\uC5D4 \uB354 \uB9DB\uC788\uB294 \uAC70 \uBCF4\uC5EC \uC904\uAC8C."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751."
  _nemoLine: "\uC624\uB298 \uAD6C\uB984\uC740 \uB9CC\uB450 \uAC19\uC544."
