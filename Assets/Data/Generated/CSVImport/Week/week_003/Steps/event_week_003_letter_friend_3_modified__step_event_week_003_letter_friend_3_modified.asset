--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_letter_friend_3_modified__step_event_week_003_letter_friend_3_modified
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: friend_3 Modified
  _bodyText: "letter friend_3 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798
      \uC190\uB2D8\uC774 \uB610 \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uB77C\uACE0 \uD588\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC624\uB298 \uBCF8 \uBC18\uC9DD\uC774\uB294 \uD48D\uACBD\uC744 \uC8FC\uC778\uB2D8\uC774\uB791
      \uAC19\uC774 \uBD24\uC73C\uBA74 \uC88B\uC558\uACA0\uB2E4\uACE0 \uD588\uC5B4\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB098\uB791?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uADF8\uB9AC\uACE0 \uC9C0\uB09C\uBC88\uC5D0 \uC8FC\uC778\uB2D8\uC774
      \uAC19\uC774 \uC774\uC57C\uAE30\uD574 \uC900 \uAC78 \uC544\uC9C1 \uAE30\uC5B5\uD55C\uB2E4\uACE0
      \uD588\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC83\uB3C4 \uC37C\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124. \uB2E4\uC74C\uC5D4 \uC8FC\uC778\uB2D8\uC774 \uBA3C\uC800 \uC7AC\uBC0C\uB294
      \uAC78 \uCC3E\uC544 \uB2EC\uB77C\uACE0\uB3C4 \uD588\uACE0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uD560 \uC218 \uC788\uC5B4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB9CE\uC774 \uAE30\uB300\uD558\uC2DC\uB294 \uAC83 \uAC19\uB124\uC694,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uC774\uBC88\uC5D4 \uB0B4\uAC00 \uB354 \uC774\uC0C1\uD55C \uAC70
      \uCC3E\uC744\uB798."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC9C0\uB09C\uBC88\uC5D0 \uB9CC\uB09C \uB610\uB798
    \uC190\uB2D8\uC774 \uB610 \uD3B8\uC9C0\uB97C \uBCF4\uB0C8\uC2B5\uB2C8\uB2E4."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
