  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: "event_week_003_house_talk_\uB2E4\uB77D_\uCC3D\uBB38_\uC18C\uBB38_modified__step_event_week_003_house_talk_\uB2E4\uB77D_\uCC3D\uBB38_\uC18C\uBB38_modified"
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB2E4\uB77D_\uCC3D\uBB38_\uC18C\uBB38 Modified"
  _bodyText: "house_talk \uB2E4\uB77D_\uCC3D\uBB38_\uC18C\uBB38 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uB2E4\uB77D \uCC3D\uBB38\uC774 \uC790\uC8FC \uC5F4\uB9AC\uB294 \uAC74,
      \uAC70\uAE30 \uACF5\uAE30\uAC00 \uB2F5\uB2F5\uD574\uC11C \uADF8\uB798\uC694,
      \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB2F5\uB2F5\uD574?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uC624\uB798\uB41C \uCC9C\uC774 \uB9CE\uC544\uC11C \uD658\uAE30\uB97C
      \uC2DC\uCF1C \uC918\uC57C \uD55C\uB2F5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC544."
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uADF8\uB798\uC11C \uAC00\uB054 \uC5F4\uC5B4 \uB450\uB294 \uAC70\uC608\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB2E4\uB77D\uB3C4 \uC228 \uC26C\uB294 \uAC70\uB124."
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uADF8\uB807\uAC8C \uBCF4\uC154\uB3C4 \uB429\uB2C8\uB2E4, \uC8FC\uC778\uB2D8."
  _nemoLine: "\uB2E4\uB77D \uCC3D\uBB38\uC774 \uC790\uC8FC \uC5F4\uB9AC\uB294 \uAC74,
    \uAC70\uAE30 \uACF5\uAE30\uAC00 \uB2F5\uB2F5\uD574\uC11C \uADF8\uB798\uC694,
    \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
