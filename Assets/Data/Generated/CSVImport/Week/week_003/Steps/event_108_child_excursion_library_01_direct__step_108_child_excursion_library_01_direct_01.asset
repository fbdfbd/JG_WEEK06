  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_108_child_excursion_library_01_direct__step_108_child_excursion_library_01_direct_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB3C4\uC11C\uAD00 1\uCC28 - \uD5C8\uB77D"
  _bodyText: "\uC11C\uACE0\uAD00\uB9AC\uC778\uC774 \uC0AC\uB2E4\uB9AC\uB97C \uC368\uC11C
    \uCC45\uC744 \uB0B4\uB824 \uC8FC\uACE0 \uC870\uC2EC\uD788 \uC0B4\uD3B4\uBCF4\uAC8C
    \uD55C\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC800 \uCC45\uC774 \uAD81\uAE08\uD558\uC168\uC2B5\uB2C8\uAE4C?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751. \uC800 \uBC18\uC9DD\uC774\uB294 \uAC70."
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uD63C\uC790 \uAEBC\uB0B4\uC2DC\uBA74 \uC704\uD5D8\uD558\uB2C8 \uC81C\uAC00
      \uB0B4\uB824\uB4DC\uB9AC\uACA0\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC\uC694?"
  - _speaker: {fileID: 11400000, guid: f8e7ba4054caf9048a0b07e84278c8e6, type: 2}
    _text: "\uC608. \uB300\uC2E0 \uC870\uC2EC\uD574\uC11C \uBCF4\uC154\uC57C \uD569\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC751! \uC870\uC2EC\uD560\uB798\uC694!"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640\u2026 \uADF8\uB9BC\uC774\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC774\uAC70 \uC608\uC058\uB2E4. \uB2E4\uB978 \uAC83\uB3C4 \uBCF4\uACE0
      \uC2F6\uC5B4."
  _nemoLine: "\uC8FC\uC778\uB2D8, \uC800 \uCC45\uC774 \uAD81\uAE08\uD558\uC168\uC2B5\uB2C8\uAE4C?"
  _useCustomVisualState: 0
  _visualState: 0
