  _titleOverride: "\uCE5C\uAD6C3 \uD3B8\uC9C0 - \uADF8\uB300\uB85C \uC77D\uAE30"
  _bodyText: "\uCE5C\uAD6C3\uC758 \uAE30\uBB18\uD55C \uBE44\uC720\uB97C \uADF8\uB300\uB85C
    \uC77D\uC5B4 \uC8FC\uC790 \uB124\uBAA8\uAC00 \uC6C3\uC74C\uC744 \uD130\uB728\uB9B0\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uB124\uBAA8 \uC548\uB155. \uC624\uB298 \uBCF8 \uAD6C\uB984\uC740 \uAD6D\uC218
      \uAC19\uC558\uC5B4. \uB2E4\uC74C\uC5D4 \uB108\uB3C4 \uAC19\uC774 \uBCF4\uBA74
      \uC88B\uACA0\uC5B4."
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC9C0\uB09C\uBC88 \uAF43\uBCD1\uC740 \uC544\uC9C1\uB3C4 \uD30C\uB974\uD398
      \uAC19\uC544."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC598\uB294 \uC9C4\uC9DC \uADF8\uB300\uB85C\uB124."
  _nemoLine: "\uB124\uBAA8 \uC548\uB155. \uC624\uB298 \uBCF8 \uAD6C\uB984\uC740 \uAD6D\uC218
