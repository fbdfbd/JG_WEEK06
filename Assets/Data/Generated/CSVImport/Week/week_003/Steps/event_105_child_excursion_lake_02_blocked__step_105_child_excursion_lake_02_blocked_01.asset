  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_105_child_excursion_lake_02_blocked__step_105_child_excursion_lake_02_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uD638\uC218 2\uCC28 - \uD1B5\uC81C"
  _bodyText: "\uB2E4\uC2DC \uD638\uC22B\uAC00\uB85C \uD5A5\uD558\uB294 \uB124\uBAA8\uB97C
    \uACBD\uBE44\uB300\uC7A5\uC774 \uBB3C\uAC00\uAC00 \uC704\uD5D8\uD558\uB2E4\uBA70
    \uB9C9\uB294\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uBB3C\uC774 \uBC18\uC9DD\uBC18\uC9DD\uD574."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uC8FC\uC778\uB2D8, \uC624\uB298\uC740 \uD638\uC22B\uAC00\uAE4C\uC9C0
      \uAC00\uC2E4 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C\uC694?"
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uBB3C\uAC00 \uCABD\uC740 \uBC1C\uC744 \uD5DB\uB514\uB514\uAE30 \uC27D\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC800 \uC548 \uBE60\uC9C8 \uAC74\uB370\uC694."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uADF8\uB798\uB3C4 \uC548 \uB429\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC5D0\uC774\u2026"
  _nemoLine: "\uC6B0\uC640. \uBB3C\uC774 \uBC18\uC9DD\uBC18\uC9DD\uD574."
