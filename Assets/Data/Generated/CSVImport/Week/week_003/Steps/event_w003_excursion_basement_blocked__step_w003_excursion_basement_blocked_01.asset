  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_w003_excursion_basement_blocked__step_w003_excursion_basement_blocked_01
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC9C0\uD558\uC2E4 3\uCC28 \uBC29\uBB38 - \uD1B5\uC81C"
  _bodyText: "(\uC800\uB141 \uBB34\uB835. \uC9C0\uD558\uC2E4 \uBB38\uD2C8\uC5D0\uC11C
    \uC11C\uB298\uD55C \uBC14\uB78C\uC774 \uC0C8\uC5B4 \uB098\uC628\uB2E4. \uC548\uCABD
    \uC5B4\uB460 \uC18D\uC5D0\uC120 \uD478\uB978 \uBE5B\uC774 \uC544\uC8FC \uC57D\uD558\uAC8C
    \uAE5C\uBE61\uC778\uB2E4.)\n        \n        \uB124\uBAA8 : \uC5B4? \uC800 \uC548\uC5D0
    \uBB50 \uC0B4\uC544? \u3147\u3141\u3147\n        \n        (\uB124\uBAA8\uAC00
    \uBB38\uC744 \uC870\uAE08 \uB354 \uBC00\uC5B4 \uBCF4\uB2C8, \uACFC\uC77C \uC0C1\uC790\uB4E4
    \uC0AC\uC774\uC5D0 \uC190\uBC14\uB2E5\uB9CC \uD55C \uD478\uB978 \uB3CC\uC774
    \uB193\uC5EC \uC788\uB2E4. \uADF8 \uC8FC\uC704 \uACF5\uAE30\uAC00 \uC720\uB09C\uD788
    \uCC28\uAC11\uB2E4.)\n        \n        \uB124\uBAA8 : \uC6B0\uC640. \uB3CC\uC778\uB370
    \uCC28\uAC00\uC6B4 \uBE5B \uB098.\n        \n\n(\uCC3D\uACE0\uC9C0\uAE30\uAC00
    \uC0C1\uC790 \uD558\uB098\uB97C \uB4E4\uACE0 \uB098\uC624\uB2E4 \uB124\uBAA8\uB97C
    \uBC1C\uACAC\uD55C\uB2E4.)\n        \n        \uCC3D\uACE0\uC9C0\uAE30 : \uC8FC\uC778\uB2D8,
    \uAC70\uAE34 \uC548 \uB429\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : \uC800
    \uB3CC\uB9CC \uBCFC\uB798.\n        \n        \uCC3D\uACE0\uC9C0\uAE30 : \uC800\uC7A5\uC6A9
    \uB0C9\uAC01\uC11D\uC785\uB2C8\uB2E4. \uAC00\uAE4C\uC774 \uAC00\uC2DC\uBA74 \uC190
    \uC2DC\uB9BD\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : \uC190 \uC2DC\uB9B0
    \uAC74 \uAD1C\uCC2E\uC740\uB370.\n        \n        \uCC3D\uACE0\uC9C0\uAE30
    : \uB3CC \uC606 \uBC14\uB2E5\uC774 \uCC28\uACE0 \uC816\uC5B4 \uC788\uC5B4 \uBBF8\uB044\uB7FD\uC2B5\uB2C8\uB2E4.\n       
    \n        \uB124\uBAA8 : \uC9C0\uD558\uC2E4\uC740 \uB9E8\uB0A0 \uB9DB\uC788\uB294
    \uAC83\uB3C4 \uC788\uACE0, \uC704\uD5D8\uD55C \uAC83\uB3C4 \uC788\uACE0 \uADF8\uB798.\n       
    \n        \uCC3D\uACE0\uC9C0\uAE30 : \uADF8\uB798\uC11C \uC5B4\uB978\uC774 \uAC19\uC774
    \uC788\uC5B4\uC57C \uD569\uB2C8\uB2E4.\n        \n        \uB124\uBAA8 : \uC54C\uACA0\uC5B4.
    \uADFC\uB370 \uC800 \uB3CC\uC740 \uC880 \uBA4B\uC788\uB2E4."
