  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uD638\uC218\uAE4C\uC9C4 \uC548 \uB418\uC9C0\uB9CC, \uBB3C\uC744 \uC870\uAE08
