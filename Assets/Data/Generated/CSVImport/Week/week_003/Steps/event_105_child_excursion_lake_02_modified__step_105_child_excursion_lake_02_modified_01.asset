  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC?"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC6B0\uC640. \uC791\uC740 \uD638\uC218\uB124."
  - _speaker: {fileID: 11400000, guid: 6df200cf2bc61f541b9a6e6cd6484c7b, type: 2}
    _text: "\uC624\uB298\uC740 \uC774\uAC78\uB85C \uAD6C\uACBD\uD558\uC2DC\uC9C0\uC694~"
  _nemoLine: "\uD638\uC218\uAE4C\uC9C4 \uC548 \uB418\uC9C0\uB9CC, \uBB3C\uC744 \uC870\uAE08
