  _titleOverride: "\uD638\uC218 2\uCC28 - \uB300\uCCB4"
  _bodyText: "\uD638\uC218\uAE4C\uC9C0\uB294 \uBABB \uAC00\uC9C0\uB9CC, \uB5A0\uC628
    \uBB3C\uC744 \uC791\uC740 \uB300\uC57C\uC5D0 \uB2F4\uC544 \uC791\uC740 \uD638\uC218\uCC98\uB7FC
