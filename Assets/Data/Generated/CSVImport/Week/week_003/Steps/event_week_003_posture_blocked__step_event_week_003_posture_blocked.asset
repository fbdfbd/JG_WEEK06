  _titleOverride: "\uBAB8\uAC00\uC9D0 \uC218\uC5C5\uC744 \uBBF8\uB8EC\uB2E4"
  _bodyText: "\uBAB8\uAC00\uC9D0\uACFC \uBC1C\uB180\uB9BC \uAD50\uC7AC Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC790\uC138 \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
      \uBB34\uB9AC\uC2DC\uD0A4\uC9C0 \uC54A\uACE0 \uC9E7\uAC8C \uC26C\uAC8C \uD55C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC624\uB298\uC740 \uC548 \uC11C\uB3C4 \uB3FC\uC694?"
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "\uAC00\uBCBC\uC6B4 \uC815\uB9AC\uB9CC \uD558\uACE0 \uBCF8\uACA9\uC801\uC778
      \uC5F0\uC2B5\uC740 \uB2E4\uC74C\uC73C\uB85C \uBBF8\uB8EC\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB2E4\uC74C\uC5D4 \uB35C \uD754\uB4E4\uB9B4\uB798."
  _nemoLine: "(\uC790\uC138 \uAD50\uC7AC\uB97C \uD3BC\uCCE4\uB2E4\uAC00, \uC624\uB298\uC740
    \uBB34\uB9AC\uC2DC\uD0A4\uC9C0 \uC54A\uACE0 \uC9E7\uAC8C \uC26C\uAC8C \uD55C\uB2E4.)"
