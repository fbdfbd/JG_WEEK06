  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_posture_blocked__step_event_week_003_posture_blocked
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uB9C8\uC8FC \uAC77\uB294 \uB3D9\uC120\uC744 \uC5C4\uD558\uAC8C
    \uC775\uD78C\uB2E4"
  _bodyText: "\uBAB8\uAC00\uC9D0\uACFC \uBC1C\uB180\uB9BC 3\uC8FC\uCC28 Blocked \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: 847f079bcbea6a646a71c4510ac11245, type: 2}
    _text: "(\uC774\uBC88\uC5D4 \uB2E4\uB978 \uC0AC\uB78C\uACFC \uB9C8\uC8FC \uBCF4\uACE0,
      \uC2A4\uCCD0 \uC9C0\uB098\uAC00\uB294 \uB3D9\uC120\uAE4C\uC9C0 \uCD94\uAC00\uB41C\uB2E4.)"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC624\uB298\uC740 \uD63C\uC790\uAC00 \uC544\uB2C8\uB77C, \uB9C8\uC8FC
      \uBCF4\uACE0 \uAC77\uC2B5\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC9C4\uC9DC \uADC0\uCC2E\uC740 \uAC70 \uB2E4 \uBD99\uC774\uB124."
  - _speaker: {fileID: 11400000, guid: 0c996a4b6053a604a8453b8d2e8e4626, type: 2}
    _text: "\uBD80\uB52A\uD788\uC9C0 \uB9C8\uC2ED\uC2DC\uC624. \uAC70\uB9AC \uC720\uC9C0\uD558\uC2ED\uC2DC\uC624."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC77C\uBD80\uB7EC \uC548 \uBD80\uB52A\uD788\uB294 \uAC8C \uB354 \uC5B4\uB835\uB2E4\u2026"
  _nemoLine: "(\uC774\uBC88\uC5D4 \uB2E4\uB978 \uC0AC\uB78C\uACFC \uB9C8\uC8FC \uBCF4\uACE0,
    \uC2A4\uCCD0 \uC9C0\uB098\uAC00\uB294 \uB3D9\uC120\uAE4C\uC9C0 \uCD94\uAC00\uB41C\uB2E4.)"
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
