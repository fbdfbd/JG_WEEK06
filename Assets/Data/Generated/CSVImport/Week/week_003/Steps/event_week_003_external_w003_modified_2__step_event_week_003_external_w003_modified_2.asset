  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4ae0b7e66326e1946bca6ce9fa70ec4c, type: 3}
  m_Name: event_week_003_external_w003_modified_2__step_event_week_003_external_w003_modified_2
  m_EditorClassIdentifier: Assembly-CSharp::SO_InteractiveEventStepDefinition
  _titleOverride: "\uC678\uBD80 \uC815\uBCF4 \uC218\uC815"
  _bodyText: "external w003 Modified \uB8E8\uD2B8"
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uC5B4\uB5A4 \uC794\uCE6B\uC0C1\uC5D0\uC11C \uC124\uD0D5 \uC7A5\uC2DD\uC774
      \uC870\uAE08 \uB179\uC544\uB0B4\uB838\uB300\uC694, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uB9CE\uC774?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uC544\uC8FC \uC5C9\uB9DD\uC774 \uB41C \uAC74 \uC544\uB2C8\uACE0, \uC717\uBD80\uBD84\uC774
      \uC870\uAE08 \uBB34\uB108\uC84C\uB2E4\uB354\uAD70\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC65C?"
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uBD88\uC774 \uAC00\uAE4C\uC6E0\uB098 \uBD10\uC694. \uB2EC\uCF64\uD55C
      \uAC74 \uC5F4\uC5D0 \uC57D\uD558\uC796\uC544\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uBA39\uC744 \uC218\uB294 \uC788\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 139777b36d46b234ca8c06c758cad573, type: 2}
    _text: "\uB124. \uC624\uD788\uB824 \uB354 \uBE68\uB9AC \uB098\uB220 \uBA39\uAC8C
      \uB410\uACA0\uC9C0\uC694."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uB7FC \uB098\uC058\uAE30\uB9CC \uD55C \uAC74 \uC544\uB2C8\uB124."
  - _speaker: {fileID: 11400000, guid: fa0a52ca28fa9e14780e4a40b6bca1a5, type: 2}
    _text: "\uADF8\uB807\uC9C0\uC694. \uBCF4\uAE30 \uC88B\uB358 \uAC8C \uC870\uAE08
      \uC6C3\uACA8\uC84C\uC744 \uBFD0\uC785\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uC124\uD0D5 \uC131\uC740 \uC880 \uC544\uAE5D\uB2E4."
  _nemoLine: "\uC5B4\uB5A4 \uC794\uCE6B\uC0C1\uC5D0\uC11C \uC124\uD0D5 \uC7A5\uC2DD\uC774
    \uC870\uAE08 \uB179\uC544\uB0B4\uB838\uB300\uC694, \uC8FC\uC778\uB2D8."
  _useCustomVisualState: 0
  _visualState: 0
  _onEnterInteractions: []
  _choices: []
  _nextStep: {fileID: 0}
  _cinematicCues:
    _enterCue: {fileID: 0}
    _exitCue: {fileID: 0}
