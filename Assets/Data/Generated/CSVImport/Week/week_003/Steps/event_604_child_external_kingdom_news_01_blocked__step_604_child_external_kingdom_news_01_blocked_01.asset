  _titleOverride: "\uC655\uAD6D \uB274\uC2A4 1\uCC28 - \uCC28\uB2E8"
  _bodyText: "\uC720\uBA85\uD55C \uC0AC\uB78C\uC758 \uBA3C \uBAA8\uD5D8\uB2F4\uC774\uB77C\uACE0
    \uC9E7\uAC8C\uB9CC \uC804\uD558\uACE0 \uB05D\uB0B8\uB2E4."
  _dialogueLines:
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uADF8\uAC74 \uBB50\uC57C?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uBC14\uAE65 \uC18C\uC2DD\uC774\uC5D0\uC694, \uC8FC\uC778\uB2D8."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBB50\uB77C\uACE0 \uC801\uD600 \uC788\uC5B4?"
  - _speaker: {fileID: 11400000, guid: 5bb39217ef6e2284f84306acd528c0b3, type: 2}
    _text: "\uC5B4\uB5A4 \uC0AC\uB78C\uC774 \uBA3C \uB370 \uB2E4\uB140\uC654\uB2E4\uB294
      \uC774\uC57C\uAE30\uB78D\uB2C8\uB2E4."
  - _speaker: {fileID: 11400000, guid: f0ccb6cf85e90dd45a93470958b81247, type: 2}
    _text: "\uBCC4\uB85C \uC548 \uC7AC\uBC0C\uB124."
  _nemoLine: "\uADF8\uAC74 \uBB50\uC57C?"
